---
import BaseLayout from '../layouts/BaseLayout.astro';
import TrafficAnalytics from '../components/TrafficAnalytics.astro';

// Build time: 讀取 costs.jsonl
import { readFileSync, existsSync } from 'fs';
import { join } from 'path';

const costsPath = join(process.cwd(), 'data', 'costs.jsonl');
let costRecords: any[] = [];
if (existsSync(costsPath)) {
  costRecords = readFileSync(costsPath, 'utf-8')
    .split('\n')
    .filter(Boolean)
    .map(line => { try { return JSON.parse(line); } catch { return null; } })
    .filter(Boolean);
}

const buildTime = new Date().toISOString().slice(0, 16).replace('T', ' ');
---

<BaseLayout title="Dashboard — Paul Kuo" description="API 費用儀表板" showTicker={true}>

<div id="authGate" class="dashboard-auth">
  <div class="auth-card">
    <h2>🔒 Dashboard</h2>
    <p>輸入存取密碼</p>
    <input type="password" id="authInput" placeholder="Password" autofocus />
    <button id="authBtn">進入</button>
  </div>
</div>

<div id="dashboardMain" class="dashboard-container" style="display:none">
  <!-- ═══ B3：狀態總覽 ═══ -->
  <section class="dash-alerts" id="statusAlerts">
    <div class="dash-alerts-header">
      <span class="dash-alerts-indicator" id="statusIndicator" data-status="loading">●</span>
      <h3>狀態總覽</h3>
      <span class="dash-alerts-time" id="statusTime"></span>
    </div>
    <div class="dash-alerts-summary" id="statusSummary"></div>
    <div class="dash-alerts-list" id="statusList">
      <p class="dash-alerts-loading">載入中…</p>
    </div>
  </section>

  <header class="dash-header">
    <div>
      <h1>API Cost Dashboard</h1>
      <p class="dash-subtitle">自動化管線費用追蹤 · 資料更新：{buildTime}</p>
    </div>
    <div class="dash-actions">
      <label for="fileUpload" class="dash-btn">📂 載入新資料</label>
      <input type="file" id="fileUpload" accept=".jsonl,.json,.txt" style="display:none" />
    </div>
  </header>

  <div id="kpiGrid" class="kpi-grid"></div>

  <div id="quotaSection" class="quota-section" style="display:none">
    <h3>服務費用監控</h3>
    <div class="quota-grid">
      <div class="quota-card" id="quotaDg">
        <div class="quota-header"><span class="quota-icon">🎙️</span><span class="quota-name">Deepgram (付費)</span><span class="quota-pct" id="dgPct">—</span></div>
        <div class="quota-bar"><div class="quota-fill" id="dgFill"></div></div>
        <div class="quota-detail" id="dgDetail">—</div>
      </div>
      <div class="quota-card" id="quotaQwen">
        <div class="quota-header"><span class="quota-icon">🇨🇳</span><span class="quota-name">Qwen3-ASR</span><span class="quota-pct" id="qwenPct">—</span></div>
        <div class="quota-bar"><div class="quota-fill" id="qwenFill"></div></div>
        <div class="quota-detail" id="qwenDetail">—</div>
      </div>
      <div class="quota-card" id="quotaClaude">
        <div class="quota-header"><span class="quota-icon">🤖</span><span class="quota-name">Claude Haiku (付費)</span><span class="quota-pct" id="claudePct">—</span></div>
        <div class="quota-bar"><div class="quota-fill" id="claudeFill"></div></div>
        <div class="quota-detail" id="claudeDetail">—</div>
      </div>
    </div>
  </div>

  <div class="charts-row">
    <div class="chart-panel full-width">
      <h3>每日費用趨勢</h3>
      <div class="chart-wrap tall"><canvas id="dailyChart"></canvas></div>
    </div>
  </div>
  <div class="charts-row">
    <div class="chart-panel">
      <h3>依服務商</h3>
      <div class="chart-wrap"><canvas id="serviceChart"></canvas></div>
    </div>
    <div class="chart-panel">
      <h3>依管線來源</h3>
      <div class="chart-wrap"><canvas id="sourceChart"></canvas></div>
    </div>
  </div>
  <div class="charts-row">
    <div class="chart-panel">
      <h3>依動作類型</h3>
      <div class="chart-wrap"><canvas id="actionChart"></canvas></div>
    </div>
    <div class="chart-panel">
      <h3>月度趨勢</h3>
      <div class="chart-wrap"><canvas id="monthlyChart"></canvas></div>
    </div>
  </div>

  <div class="table-panel">
    <h3>明細記錄</h3>
    <div id="tableBody" style="overflow-x:auto"></div>
  </div>

  <TrafficAnalytics />

  <!-- ═══ B2：成本 vs 效益 ═══ -->
  <section class="dash-section" id="roiSection">
    <h3>投入 vs 產出（本月摘要）</h3>
    <p class="dash-subtitle">成本為即時數據；搜尋數據有 2-3 天延遲</p>

    <div class="dash-roi-grid">
      <div class="dash-roi-col">
        <h4>投入</h4>
        <div class="dash-roi-item"><span class="dash-roi-label">API 成本</span><span class="dash-roi-value" id="roiApiCost">—</span></div>
        <div class="dash-roi-item"><span class="dash-roi-label">Claude 方案</span><span class="dash-roi-value" id="roiClaudeCost">—</span></div>
        <div class="dash-roi-item"><span class="dash-roi-label">AI 協作時間</span><span class="dash-roi-value" id="roiAiTime">—</span></div>
      </div>
      <div class="dash-roi-col">
        <h4>產出</h4>
        <div class="dash-roi-item"><span class="dash-roi-label">GSC 點擊</span><span class="dash-roi-value" id="roiClicks">—</span></div>
        <div class="dash-roi-item"><span class="dash-roi-label">GSC 曝光</span><span class="dash-roi-value" id="roiImpressions">—</span></div>
        <div class="dash-roi-item"><span class="dash-roi-label">網站訪客</span><span class="dash-roi-value" id="roiVisitors">—</span></div>
      </div>
    </div>

    <div class="dash-roi-unit" id="roiUnitCosts">
      <span class="dash-roi-unit-item" id="roiCpc">—/click</span>
      <span class="dash-roi-unit-sep">·</span>
      <span class="dash-roi-unit-item" id="roiCpi">—/impression</span>
      <span class="dash-roi-unit-sep">·</span>
      <span class="dash-roi-unit-item" id="roiCpv">—/visitor</span>
    </div>

    <div class="dash-roi-chart">
      <h4>趨勢（過去 4 週）</h4>
      <div class="chart-wrap"><canvas id="roiTrendChart"></canvas></div>
    </div>
  </section>

  <!-- ═══ LINE Push Message ═══ -->
  <section class="dash-section" id="pushSection">
    <h3>LINE 推播訊息</h3>
    <p class="dash-subtitle">發送文字訊息給 Formosa ESG 用戶（URL 會自動變成可點擊連結）</p>
    <div class="push-form">
      <textarea id="pushText" class="push-textarea" rows="4" placeholder="輸入訊息內容（支援多行，URL 自動轉連結）"></textarea>
      <div class="push-controls">
        <select id="pushRole" class="push-select">
          <option value="all">全部用戶</option>
          <option value="participant">香客 Pilgrims</option>
          <option value="volunteer">志工 Volunteers</option>
          <option value="admin">管理員 Admins</option>
        </select>
        <button id="pushBtn" class="push-btn" disabled>發送推播</button>
      </div>
      <div id="pushStatus" class="push-status" style="display:none"></div>
    </div>
  </section>

  <!-- ═══ Push Confirmation Modal ═══ -->
  <div id="pushModal" class="push-modal-overlay" style="display:none">
    <div class="push-modal">
      <h3>確認發送推播</h3>
      <div id="pushModalPreview" class="push-modal-preview"></div>
      <div class="push-modal-actions">
        <button id="pushModalCancel" class="push-modal-btn cancel">取消</button>
        <button id="pushModalConfirm" class="push-modal-btn confirm">確認發送</button>
      </div>
    </div>
  </div>

  <section class="dash-section" id="claudeUsage">
    <h3>🤖 Claude Max 使用量</h3>
    <p class="dash-subtitle">訂閱方案費用追蹤 · <span id="claudeUpdated">載入中...</span></p>
    <div class="claude-kpis" id="claudeKpis"></div>
    <div class="claude-detail" id="claudeDetailSection"></div>
    <div class="charts-row" style="margin-top:1.25rem">
      <div class="chart-panel full-width">
        <h3>月度費用趨勢</h3>
        <div class="chart-wrap"><canvas id="claudeMonthlyChart"></canvas></div>
      </div>
    </div>
  </section>
</div>

</BaseLayout>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js" is:inline></script>

<script define:vars={{ costRecords }} is:inline>
// ── Auth (via Worker /validate-code — no hardcoded passwords) ──
const WORKER = 'https://api.paulkuo.tw';
const authGate = document.getElementById('authGate');
const dashMain = document.getElementById('dashboardMain');
const authInput = document.getElementById('authInput');
const authBtn = document.getElementById('authBtn');

var charts = {};
var dashCode = sessionStorage.getItem('dash_code') || '';

async function verifyCode(code) {
  try {
    const res = await fetch(WORKER + '/validate-code', {
      method: 'POST', headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({ code })
    });
    const d = await res.json();
    if (d.valid && d.role === 'admin') return d;
  } catch(e) {}
  return null;
}

async function checkAuth() {
  const urlKey = new URLSearchParams(window.location.search).get('key');
  const code = urlKey || dashCode;
  if (code) {
    const result = await verifyCode(code);
    if (result) {
      dashCode = code;
      sessionStorage.setItem('dash_code', code);
      authGate.style.display = 'none';
      dashMain.style.display = 'block';
      initDashboard();
      return;
    }
  }
}

authBtn.addEventListener('click', async () => {
  authBtn.textContent = '驗證中…'; authBtn.disabled = true;
  const result = await verifyCode(authInput.value.trim().toLowerCase());
  if (result) {
    dashCode = authInput.value.trim().toLowerCase();
    sessionStorage.setItem('dash_code', dashCode);
    authGate.style.display = 'none';
    dashMain.style.display = 'block';
    initDashboard();
  } else {
    authInput.style.borderColor = '#ef4444';
    authInput.value = '';
    authInput.placeholder = '密碼錯誤或非管理員';
    authBtn.textContent = '進入'; authBtn.disabled = false;
  }
});
authInput.addEventListener('keydown', e => { if (e.key === 'Enter') authBtn.click(); });

// File upload
document.getElementById('fileUpload').addEventListener('change', e => {
  const file = e.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = ev => {
    const records = ev.target.result.trim().split('\n').filter(Boolean)
      .map(l => { try { return JSON.parse(l); } catch { return null; } }).filter(Boolean);
    render(records);
  };
  reader.readAsText(file);
});

// ── Colors ──
const SVC_CLR = { anthropic:'#6366f1', openai:'#10b981', google:'#3b82f6', xai:'#f97316', perplexity:'#8b5cf6', deepgram:'#13EF93' };
const SRC_CLR = { 'debate-engine':'#f59e0b', 'translate-article':'#3b82f6', 'publish-social':'#ec4899', 'debate-to-article':'#06b6d4', 'translator':'#059669' };
const ACT_CLR = { debate:'#f59e0b', 'translate-en':'#3b82f6', 'translate-ja':'#60a5fa', 'translate-zh-cn':'#93c5fd',
  'social-summary':'#ec4899', 'image-gen':'#10b981', 'debate-to-article':'#06b6d4', factcheck:'#8b5cf6',
  stt:'#10b981', translate:'#6366f1', 'stt-stream':'#13EF93', summarize:'#0891b2' };
const ACT_LABEL = { debate:'辯論', 'translate-en':'翻譯 EN', 'translate-ja':'翻譯 JA', 'translate-zh-cn':'翻譯 簡中',
  'social-summary':'社群摘要', 'image-gen':'DALL-E 配圖', 'debate-to-article':'辯論轉文章', factcheck:'事實查核',
  stt:'語音辨識(Whisper)', translate:'即時翻譯', 'stt-stream':'串流辨識(Deepgram)', summarize:'會議摘要' };

// Fetch live costs from Worker and merge with static data
async function fetchLiveCosts() {
  try {
    const res = await fetch(WORKER + '/costs?days=90&code=' + encodeURIComponent(dashCode));
    if (!res.ok) return [];
    const data = await res.json();
    return data.records || [];
  } catch(e) { console.warn('Failed to fetch live costs:', e); return []; }
}

async function initClaudeUsage() {
  try {
    const res = await fetch(WORKER + '/claude-usage?code=' + encodeURIComponent(dashCode));
    if (!res.ok) { document.getElementById('claudeUpdated').textContent = '無法載入'; return; }
    const data = await res.json();
    const c = data.current;
    if (!c) { document.getElementById('claudeUpdated').textContent = '尚無資料'; return; }

    var total = c.planUSD + (c.extraSpent || 0);
    var pct = c.extraPct || 0;
    var pctColor = pct > 80 ? '#ef4444' : pct > 60 ? '#eab308' : '#10b981';

    document.getElementById('claudeKpis').innerHTML =
      '<div class="kpi"><span class="kpi-label">本月總費用</span><span class="kpi-value">$' + total.toFixed(0) + '</span><span class="kpi-sub">NT$' + Math.round(total * 32.5) + '</span></div>' +
      '<div class="kpi"><span class="kpi-label">Max 方案</span><span class="kpi-value kpi-purple">$' + c.planUSD + '</span><span class="kpi-sub">/月</span></div>' +
      '<div class="kpi"><span class="kpi-label">Extra 用量</span><span class="kpi-value" style="color:' + pctColor + '">$' + (c.extraSpent || 0).toFixed(2) + '</span><span class="kpi-sub">' + pct + '% of $' + c.extraLimit + '</span></div>' +
      '<div class="kpi"><span class="kpi-label">餘額</span><span class="kpi-value kpi-cyan">$' + (c.balance || 0).toFixed(2) + '</span><span class="kpi-sub">續約 ' + (c.renewalDate || '—') + '</span></div>';

    document.getElementById('claudeDetailSection').innerHTML =
      '<div class="claude-progress">' +
        '<div class="claude-progress-label">Extra 用量 $' + (c.extraSpent || 0).toFixed(2) + ' / $' + c.extraLimit + '</div>' +
        '<div class="claude-progress-bar-bg"><div class="claude-progress-bar" style="width:' + pct + '%;background:' + pctColor + '"></div></div>' +
      '</div>';

    document.getElementById('claudeUpdated').textContent =
      '更新：' + new Date(c.updatedAt).toLocaleString('zh-TW', { timeZone: 'Asia/Taipei', month: 'numeric', day: 'numeric', hour: '2-digit', minute: '2-digit' });

    // Monthly trend chart
    if (data.monthlyHistory && data.monthlyHistory.length >= 2) {
      var labels = data.monthlyHistory.map(function(m) { return m.period; });
      var values = data.monthlyHistory.map(function(m) { return (m.invoiceTotal != null) ? m.invoiceTotal : (m.subscriptionFee || 0) + (m.extraCharges || 0); });
      new Chart(document.getElementById('claudeMonthlyChart'), {
        type: 'bar',
        data: {
          labels: labels,
          datasets: [{
            label: '月費用 (USD)',
            data: values,
            backgroundColor: values.map(function(v) { return v > 200 ? 'rgba(139,92,246,0.7)' : 'rgba(99,102,241,0.5)'; }),
            borderRadius: 4
          }]
        },
        options: {
          responsive: true, maintainAspectRatio: false,
          scales: {
            x: { grid: { display: false }, ticks: { color: '#8A8A8A', font: { family: 'DM Sans', size: 10 } } },
            y: { grid: { color: '#E8E6E1' }, ticks: { color: '#8A8A8A', font: { family: 'DM Sans', size: 10 }, callback: function(v) { return '$' + v; } } }
          },
          plugins: {
            legend: { display: false },
            tooltip: { callbacks: { label: function(ctx) { return '$' + ctx.raw.toFixed(2); } } }
          }
        }
      });
    }
  } catch(e) {
    console.warn('Failed to load Claude usage:', e);
    document.getElementById('claudeUpdated').textContent = '載入失敗';
  }
}

// ═══ B3：狀態總覽 ═══
async function initStatus() {
  try {
    var resp = await fetch(WORKER + '/status');
    if (!resp.ok) throw new Error('Status API error');
    var data = await resp.json();

    var indicator = document.getElementById('statusIndicator');
    indicator.dataset.status = data.overall;

    if (data.checkedAt) {
      var t = new Date(data.checkedAt);
      document.getElementById('statusTime').textContent =
        t.toLocaleString('zh-TW', { hour: '2-digit', minute: '2-digit' });
    }

    var summary = document.getElementById('statusSummary');
    var critCount = data.alerts.filter(function(a) { return a.level === 'critical'; }).length;
    var warnCount = data.alerts.filter(function(a) { return a.level === 'warning'; }).length;
    var infoCount = data.alerts.filter(function(a) { return a.level === 'info'; }).length;

    var parts = [];
    if (critCount) parts.push('\uD83D\uDD34 ' + critCount + ' \u56B4\u91CD');
    if (warnCount) parts.push('\u26A0\uFE0F ' + warnCount + ' \u8B66\u544A');
    if (infoCount) parts.push('\u2139\uFE0F ' + infoCount + ' \u63D0\u9192');
    if (!parts.length) parts.push('\uD83D\uDFE2 \u6240\u6709\u7CFB\u7D71\u6B63\u5E38\u904B\u4F5C');
    summary.innerHTML = parts.join(' \u00B7 ');

    var list = document.getElementById('statusList');
    if (data.alerts.length === 0) {
      list.innerHTML = '<p class="dash-alerts-ok">\u2705 \u7121\u7570\u5E38\uFF0C\u6240\u6709\u6307\u6A19\u6B63\u5E38</p>';
    } else {
      var order = { critical: 0, warning: 1, info: 2 };
      var sorted = data.alerts.slice().sort(function(a, b) { return (order[a.level] || 9) - (order[b.level] || 9); });
      list.innerHTML = sorted.map(function(a) {
        var icon = a.level === 'critical' ? '\uD83D\uDD34' : a.level === 'warning' ? '\u26A0\uFE0F' : '\u2139\uFE0F';
        return '<div class="dash-alert dash-alert-' + a.level + '">' +
          '<span class="dash-alert-icon">' + icon + '</span>' +
          '<span class="dash-alert-msg">' + a.msg + '</span>' +
          '<span class="dash-alert-cat">' + a.category + '</span></div>';
      }).join('');
    }
  } catch (err) {
    console.warn('[Status] Load failed:', err);
    document.getElementById('statusList').innerHTML =
      '<p class="dash-alerts-error">\u72C0\u614B\u8F09\u5165\u5931\u6557\uFF0C\u7A0D\u5F8C\u518D\u8A66</p>';
  }
}

// ═══ B2：成本 vs 效益 ═══
async function initRoi() {
  try {
    var results = await Promise.all([
      fetch(WORKER + '/ticker'),
      fetch(WORKER + '/gsc'),
      fetch(WORKER + '/analytics')
    ]);
    var ticker = await results[0].json();
    var gsc = await results[1].json();
    var analytics = await results[2].json();

    var apiCost = (ticker && ticker.costs && ticker.costs.monthUSD) || 0;
    var claudePlan = (ticker && ticker.claudeSub && ticker.claudeSub.planUSD) || 0;
    var claudeExtra = (ticker && ticker.claudeSub && ticker.claudeSub.extraSpent) || 0;
    var claudeTotal = claudePlan + claudeExtra;
    var aiHours = (ticker && ticker.timing && ticker.timing.monthHours) || 0;
    var totalCost = apiCost + claudeTotal;

    document.getElementById('roiApiCost').textContent = '$' + apiCost.toFixed(2);
    document.getElementById('roiClaudeCost').textContent = '$' + claudeTotal.toFixed(0);
    document.getElementById('roiAiTime').textContent = aiHours.toFixed(1) + 'hr';

    var clicks = (gsc && gsc.analytics && gsc.analytics.clicks) || 0;
    var impressions = (gsc && gsc.analytics && gsc.analytics.impressions) || 0;
    var visitors = (analytics && analytics.overview && (analytics.overview.visits || analytics.overview.humanVisits)) || 0;

    document.getElementById('roiClicks').textContent = clicks.toLocaleString();
    document.getElementById('roiImpressions').textContent = impressions.toLocaleString();
    document.getElementById('roiVisitors').textContent = visitors.toLocaleString();

    var cpc = clicks > 0 ? '$' + (totalCost / clicks).toFixed(2) : '\u2014';
    var cpi = impressions > 0 ? '$' + (totalCost / impressions).toFixed(3) : '\u2014';
    var cpv = visitors > 0 ? '$' + (totalCost / visitors).toFixed(2) : '\u2014';

    document.getElementById('roiCpc').textContent = cpc + '/click';
    document.getElementById('roiCpi').textContent = cpi + '/impression';
    document.getElementById('roiCpv').textContent = cpv + '/visitor';

    // Trend chart
    var dailyClicks = (gsc && gsc.analytics && gsc.analytics.dailyClicks) || [];
    if (dailyClicks.length >= 7 && typeof Chart !== 'undefined') {
      var weeks = [];
      for (var i = 0; i < dailyClicks.length; i += 7) {
        var chunk = dailyClicks.slice(i, i + 7);
        if (chunk.length < 3) continue;
        weeks.push({
          label: (chunk[0].date || '').slice(5) || ('W' + (weeks.length + 1)),
          clicks: chunk.reduce(function(s, d) { return s + d.clicks; }, 0),
          impressions: chunk.reduce(function(s, d) { return s + d.impressions; }, 0)
        });
      }
      var weeklyCost = totalCost / 4;
      var ctx = document.getElementById('roiTrendChart').getContext('2d');
      new Chart(ctx, {
        type: 'line',
        data: {
          labels: weeks.map(function(w) { return w.label; }),
          datasets: [
            { label: '\u9031\u6210\u672C ($)', data: weeks.map(function() { return +weeklyCost.toFixed(2); }),
              borderColor: '#ef4444', backgroundColor: 'rgba(239,68,68,0.08)', yAxisID: 'yCost',
              tension: 0.3, borderWidth: 2, pointRadius: 3 },
            { label: '\u9031\u9EDE\u64CA', data: weeks.map(function(w) { return w.clicks; }),
              borderColor: '#3b82f6', backgroundColor: 'rgba(59,130,246,0.08)', yAxisID: 'yTraffic',
              tension: 0.3, borderWidth: 2, pointRadius: 3 },
            { label: '\u9031\u66DD\u5149', data: weeks.map(function(w) { return w.impressions; }),
              borderColor: '#10b981', backgroundColor: 'rgba(34,197,94,0.08)', yAxisID: 'yTraffic',
              tension: 0.3, borderWidth: 2, borderDash: [5, 5], pointRadius: 3 }
          ]
        },
        options: {
          responsive: true, maintainAspectRatio: false,
          interaction: { mode: 'index', intersect: false },
          plugins: { legend: { labels: { color: '#5A5A5A', font: { size: 11, family: 'DM Sans' } } } },
          scales: {
            yCost: { type: 'linear', position: 'left',
              title: { display: true, text: '\u6210\u672C ($)', color: '#ef4444' },
              ticks: { color: '#ef4444' }, grid: { color: '#E8E6E1' } },
            yTraffic: { type: 'linear', position: 'right',
              title: { display: true, text: '\u6D41\u91CF', color: '#3b82f6' },
              ticks: { color: '#3b82f6' }, grid: { drawOnChartArea: false } },
            x: { ticks: { color: '#8A8A8A' }, grid: { color: '#E8E6E1' } }
          }
        }
      });
    }
  } catch (err) {
    console.warn('[ROI] Load failed:', err);
  }
}

async function initDashboard() {
  const live = await fetchLiveCosts();
  // Merge: static (costs.jsonl) + live (Worker KV)
  const allRecords = [...costRecords, ...live];
  // Deduplicate by timestamp+service+action
  const seen = new Set();
  const merged = allRecords.filter(r => {
    const key = `${r.timestamp}_${r.service}_${r.action}_${r.costUSD}`;
    if (seen.has(key)) return false;
    seen.add(key); return true;
  });
  if (merged.length > 0) render(merged);
  initClaudeUsage();
  initStatus();
  initRoi();
}

// ═══ LINE Push Message ═══
(function initPush() {
  var pushText = document.getElementById('pushText');
  var pushRole = document.getElementById('pushRole');
  var pushBtn = document.getElementById('pushBtn');
  var pushStatus = document.getElementById('pushStatus');
  var pushModal = document.getElementById('pushModal');
  var pushModalPreview = document.getElementById('pushModalPreview');
  var pushModalCancel = document.getElementById('pushModalCancel');
  var pushModalConfirm = document.getElementById('pushModalConfirm');
  var pendingSend = null;

  // Enable button when text is entered
  pushText.addEventListener('input', function() {
    pushBtn.disabled = !pushText.value.trim();
  });

  // Step 1: Click send → dry run to get count → show confirmation modal
  pushBtn.addEventListener('click', async function() {
    var text = pushText.value.trim();
    if (!text) return;
    var role = pushRole.value;

    pushBtn.disabled = true;
    pushBtn.textContent = '查詢中…';

    try {
      var res = await fetch(WORKER + '/api/formosa/push', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-Admin-Token': dashCode },
        body: JSON.stringify({ role: role, text: text, mode: 'text', dry_run: true })
      });
      var data = await res.json();
      if (!res.ok) throw new Error(data.error || 'API error');

      var count = data.count || 0;
      if (count === 0) {
        showPushStatus('warn', '該群組沒有可推播的用戶');
        pushBtn.textContent = '發送推播';
        pushBtn.disabled = false;
        return;
      }

      var roleLabel = pushRole.options[pushRole.selectedIndex].text;
      var previewText = text.length > 200 ? text.substring(0, 200) + '…' : text;

      pushModalPreview.innerHTML =
        '<div class="push-preview-meta">' +
          '<span>對象：<strong>' + roleLabel + '</strong></span>' +
          '<span>人數：<strong>' + count + ' 人</strong></span>' +
        '</div>' +
        '<div class="push-preview-text">' + previewText.replace(/\n/g, '<br>') + '</div>';

      pendingSend = { text: text, role: role, count: count };
      pushModal.style.display = 'flex';
    } catch (e) {
      showPushStatus('error', '查詢失敗：' + e.message);
    }
    pushBtn.textContent = '發送推播';
    pushBtn.disabled = !pushText.value.trim();
  });

  // Step 2: Cancel modal
  pushModalCancel.addEventListener('click', function() {
    pushModal.style.display = 'none';
    pendingSend = null;
  });
  pushModal.addEventListener('click', function(e) {
    if (e.target === pushModal) {
      pushModal.style.display = 'none';
      pendingSend = null;
    }
  });

  // Step 3: Confirm → actually send
  pushModalConfirm.addEventListener('click', async function() {
    if (!pendingSend) return;
    pushModalConfirm.disabled = true;
    pushModalConfirm.textContent = '發送中…';

    try {
      var res = await fetch(WORKER + '/api/formosa/push', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-Admin-Token': dashCode },
        body: JSON.stringify({ role: pendingSend.role, text: pendingSend.text, mode: 'text' })
      });
      var data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Send failed');

      showPushStatus('ok', '已發送給 ' + data.sent + ' 位用戶（' + pendingSend.role + '）');
      pushText.value = '';
      pushBtn.disabled = true;
    } catch (e) {
      showPushStatus('error', '發送失敗：' + e.message);
    }

    pushModal.style.display = 'none';
    pushModalConfirm.disabled = false;
    pushModalConfirm.textContent = '確認發送';
    pendingSend = null;
  });

  function showPushStatus(type, msg) {
    pushStatus.style.display = 'block';
    pushStatus.className = 'push-status push-status-' + type;
    pushStatus.textContent = msg;
    setTimeout(function() { pushStatus.style.display = 'none'; }, 6000);
  }
})();

