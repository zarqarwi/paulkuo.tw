---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { readFileSync, existsSync } from 'fs';
import { join } from 'path';

const expPath = join(process.cwd(), 'ai-ready-opt', 'experiments.json');
let experiments: any[] = [];
if (existsSync(expPath)) {
  try {
    experiments = JSON.parse(readFileSync(expPath, 'utf-8'));
  } catch { experiments = []; }
}

const buildTime = new Date().toISOString().slice(0, 16).replace('T', ' ');
---

<BaseLayout title="AI-Ready Dashboard — Paul Kuo" description="AI-Ready SEO 持續優化儀表板">

<div id="authGate" class="dashboard-auth">
  <div class="auth-card">
    <h2>🔒 AI-Ready Dashboard</h2>
    <p>輸入存取密碼</p>
    <input type="password" id="authInput" placeholder="Password" autofocus />
    <button id="authBtn">進入</button>
  </div>
</div>

<div id="dashboardMain" class="dashboard-container" style="display:none">
  <header class="dash-header">
    <div>
      <h1>AI-Ready Optimizer</h1>
      <p class="dash-subtitle">持續優化儀表板 · 資料更新：{buildTime} · 策略版本：v2</p>
    </div>
  </header>

  <!-- KPI Cards -->
  <div id="kpiGrid" class="kpi-grid"></div>

  <!-- Score Trend Chart -->
  <div class="charts-row">
    <div class="chart-panel full-width">
      <h3>分數趨勢</h3>
      <div class="chart-wrap tall"><canvas id="scoreTrendChart"></canvas></div>
    </div>
  </div>

  <!-- Sub-score Trends -->
  <div class="charts-row">
    <div class="chart-panel">
      <h3>子分數趨勢</h3>
      <div class="chart-wrap tall"><canvas id="subScoreChart"></canvas></div>
    </div>
    <div class="chart-panel">
      <h3>實驗結果分佈</h3>
      <div class="chart-wrap"><canvas id="statusChart"></canvas></div>
    </div>
  </div>

  <!-- Experiment Log Table -->
  <div class="table-panel">
    <h3>實驗紀錄</h3>
    <div id="expTableBody" style="overflow-x:auto"></div>
  </div>

  <!-- Layer 5a Placeholder -->
  <div class="layer5-placeholder" style="margin-top:1.5rem;padding:2rem;background:var(--bg-section);border:1px dashed var(--border);border-radius:var(--radius);text-align:center;color:var(--text-muted);">
    <h3 style="font-size:0.95rem;margin-bottom:0.5rem;">🔬 外部 AI 交叉驗證（Layer 5a）</h3>
    <p style="font-size:0.85rem;">Step 2 完成後啟用 — Perplexity 交叉驗證 · discovery / grounding 追蹤 · 反幻覺測試</p>
    <div id="layer5aContent" style="display:none">
      <!-- Step 2 上線後填入 -->
    </div>
  </div>
</div>

</BaseLayout>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js" is:inline></script>

<script define:vars={{ experiments }} is:inline>
// ── Auth ──
const WORKER = 'https://api.paulkuo.tw';
const authGate = document.getElementById('authGate');
const dashMain = document.getElementById('dashboardMain');
const authInput = document.getElementById('authInput');
const authBtn = document.getElementById('authBtn');
var charts = {};

async function verifyCode(code) {
  try {
    const res = await fetch(WORKER + '/validate-code', {
      method: 'POST', headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({ code })
    });
    const d = await res.json();
    if (d.valid && d.role === 'admin') return d;
  } catch(e) {}
  return null;
}

async function checkAuth() {
  const urlKey = new URLSearchParams(window.location.search).get('key');
  const code = urlKey || sessionStorage.getItem('dash_code') || '';
  if (code) {
    const result = await verifyCode(code);
    if (result) {
      sessionStorage.setItem('dash_code', code);
      authGate.style.display = 'none';
      dashMain.style.display = 'block';
      renderDashboard();
      return;
    }
  }
}

authBtn.addEventListener('click', async () => {
  authBtn.textContent = '驗證中…'; authBtn.disabled = true;
  const result = await verifyCode(authInput.value.trim().toLowerCase());
  if (result) {
    sessionStorage.setItem('dash_code', authInput.value.trim().toLowerCase());
    authGate.style.display = 'none';
    dashMain.style.display = 'block';
    renderDashboard();
  } else {
    authInput.style.borderColor = '#ef4444';
    authInput.value = '';
    authInput.placeholder = '密碼錯誤或非管理員';
    authBtn.textContent = '進入'; authBtn.disabled = false;
  }
});
authInput.addEventListener('keydown', e => { if (e.key === 'Enter') authBtn.click(); });
checkAuth();

// ── Render ──
function renderDashboard() {
  const data = experiments || [];
  const successes = data.filter(e => e.evaluation_status === 'success');
  const latest = successes.length > 0 ? successes[successes.length - 1] : null;

  // KPIs
  const currentScore = latest ? (latest.preview_score || latest.baseline_score || 0) : 0;
  const latestSub = latest ? (latest.preview_sub_scores || latest.baseline_sub_scores || {}) : {};
  const totalRuns = data.length;
  const successRuns = successes.length;
  const keptRuns = data.filter(e => e.kept_or_reverted === 'keep').length;

  document.getElementById('kpiGrid').innerHTML = `
    <div class="kpi"><span class="kpi-label">當前總分</span><span class="kpi-value">${currentScore}</span><span class="kpi-sub">/ 100</span></div>
    <div class="kpi"><span class="kpi-label">JSON-LD</span><span class="kpi-value ${latestSub.json_ld >= 20 ? 'kpi-green' : 'kpi-amber'}">${latestSub.json_ld || 0}</span><span class="kpi-sub">/ 25</span></div>
    <div class="kpi"><span class="kpi-label">llms.txt</span><span class="kpi-value ${latestSub.llms_txt >= 25 ? 'kpi-green' : 'kpi-amber'}">${latestSub.llms_txt || 0}</span><span class="kpi-sub">/ 25</span></div>
    <div class="kpi"><span class="kpi-label">MCP+A2A</span><span class="kpi-value ${latestSub.mcp_a2a >= 25 ? 'kpi-green' : 'kpi-amber'}">${latestSub.mcp_a2a || 0}</span><span class="kpi-sub">/ 25</span></div>
    <div class="kpi"><span class="kpi-label">AI 理解度</span><span class="kpi-value ${latestSub.ai_comprehension >= 23 ? 'kpi-green' : 'kpi-amber'}">${latestSub.ai_comprehension || 0}</span><span class="kpi-sub">/ 25</span></div>
    <div class="kpi"><span class="kpi-label">實驗次數</span><span class="kpi-value kpi-cyan">${totalRuns}</span><span class="kpi-sub">${successRuns} 成功 · ${keptRuns} kept</span></div>
  `;

  // Score Trend Chart
  Object.values(charts).forEach(c => c.destroy()); charts = {};
  const chartDefaults = {
    responsive: true, maintainAspectRatio: false,
    plugins: { legend: { labels: { color: '#5A5A5A', font: { family: 'DM Sans', size: 11 }, padding: 12 } } },
  };

  if (successes.length > 0) {
    const labels = successes.map(e => e.iteration_id || e.timestamp?.slice(5, 16) || '');
    const baselines = successes.map(e => e.baseline_score || 0);
    const previews = successes.map(e => e.preview_score || 0);

    charts.trend = new Chart(document.getElementById('scoreTrendChart'), {
      type: 'line',
      data: {
        labels,
        datasets: [
          { label: 'Baseline', data: baselines, borderColor: '#94a3b8', borderDash: [5, 5], borderWidth: 2, pointRadius: 3, fill: false, tension: 0.2 },
          { label: 'After Change', data: previews, borderColor: '#6366f1', borderWidth: 2.5, pointRadius: 4, pointBackgroundColor: '#6366f1', fill: false, tension: 0.2 },
        ]
      },
      options: { ...chartDefaults,
        scales: {
          x: { grid: { display: false }, ticks: { color: '#8A8A8A', font: { size: 9 }, maxRotation: 45 } },
          y: { min: 0, max: 100, grid: { color: '#E8E6E1' }, ticks: { color: '#8A8A8A' } }
        },
      },
    });

    // Sub-score trends
    const jsonLd = successes.map(e => (e.preview_sub_scores || e.baseline_sub_scores || {}).json_ld || 0);
    const llmsTxt = successes.map(e => (e.preview_sub_scores || e.baseline_sub_scores || {}).llms_txt || 0);
    const mcpA2a = successes.map(e => (e.preview_sub_scores || e.baseline_sub_scores || {}).mcp_a2a || 0);
    const aiComp = successes.map(e => (e.preview_sub_scores || e.baseline_sub_scores || {}).ai_comprehension || 0);

    charts.sub = new Chart(document.getElementById('subScoreChart'), {
      type: 'line',
      data: {
        labels,
        datasets: [
          { label: 'JSON-LD', data: jsonLd, borderColor: '#f59e0b', borderWidth: 2, pointRadius: 3, fill: false, tension: 0.2 },
          { label: 'llms.txt', data: llmsTxt, borderColor: '#059669', borderWidth: 2, pointRadius: 3, fill: false, tension: 0.2 },
          { label: 'MCP+A2A', data: mcpA2a, borderColor: '#3b82f6', borderWidth: 2, pointRadius: 3, fill: false, tension: 0.2 },
          { label: 'AI 理解', data: aiComp, borderColor: '#8b5cf6', borderWidth: 2, pointRadius: 3, fill: false, tension: 0.2 },
        ]
      },
      options: { ...chartDefaults,
        scales: {
          x: { grid: { display: false }, ticks: { color: '#8A8A8A', font: { size: 9 }, maxRotation: 45 } },
          y: { min: 0, max: 25, grid: { color: '#E8E6E1' }, ticks: { color: '#8A8A8A' } }
        },
      },
    });
  }

  // Status distribution doughnut
  const statusCounts = {};
  data.forEach(e => {
    const s = e.evaluation_status || e.kept_or_reverted || 'unknown';
    statusCounts[s] = (statusCounts[s] || 0) + 1;
  });
  const statusColors = {
    success: '#059669', mutation_failed: '#dc2626', policy_violation: '#f59e0b',
    no_action: '#94a3b8', eval_failed: '#dc2626', keep: '#059669', revert: '#f59e0b',
    dry_run: '#6366f1', unknown: '#d1d5db',
  };
  const statusKeys = Object.keys(statusCounts);
  charts.status = new Chart(document.getElementById('statusChart'), {
    type: 'doughnut',
    data: {
      labels: statusKeys,
      datasets: [{ data: statusKeys.map(k => statusCounts[k]),
        backgroundColor: statusKeys.map(k => statusColors[k] || '#8A8A8A'), borderWidth: 2, borderColor: '#FFFFFF' }]
    },
    options: { ...chartDefaults, cutout: '55%',
      plugins: { ...chartDefaults.plugins, legend: { position: 'right', labels: chartDefaults.plugins.legend.labels } },
    },
  });

  // Experiment table
  const sorted = [...data].reverse();
  const statusBadge = (e) => {
    const s = e.kept_or_reverted || e.evaluation_status || '';
    const colors = { keep: '#059669', revert: '#f59e0b', success: '#059669', mutation_failed: '#dc2626', policy_violation: '#f97316', no_action: '#94a3b8', dry_run: '#6366f1' };
    const c = colors[s] || '#8A8A8A';
    return '<span style="display:inline-block;padding:2px 8px;border-radius:4px;font-size:0.7rem;font-weight:600;background:' + c + '20;color:' + c + '">' + (s || 'pending') + '</span>';
  };

  document.getElementById('expTableBody').innerHTML = `<table>
    <thead><tr><th>時間</th><th>Iteration</th><th>修改檔案</th><th>分析</th><th>Baseline</th><th>After</th><th>Diff</th><th>結果</th></tr></thead>
    <tbody>${sorted.map(e => {
      const files = (e.files_modified || []).map(f => f.split('/').pop()).join(', ') || '—';
      const analysis = (e.gap_analysis || e.change_summary || e.failure_reason || '').slice(0, 80);
      const baseline = e.baseline_score != null ? e.baseline_score : '—';
      const preview = e.preview_score != null ? e.preview_score : '—';
      const diff = e.score_diff != null ? (e.score_diff >= 0 ? '+' : '') + e.score_diff : '—';
      const diffColor = e.score_diff > 0 ? '#059669' : e.score_diff < 0 ? '#dc2626' : '#8A8A8A';
      return '<tr>' +
        '<td>' + (e.timestamp || '').slice(5, 16).replace('T', ' ') + '</td>' +
        '<td style="font-family:monospace;font-size:0.75rem">' + (e.iteration_id || '—') + '</td>' +
        '<td style="font-size:0.75rem">' + files + '</td>' +
        '<td style="font-size:0.72rem;color:var(--text-muted);max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="' + (analysis || '').replace(/"/g, '&quot;') + '">' + analysis + '</td>' +
        '<td>' + baseline + '</td>' +
        '<td>' + preview + '</td>' +
        '<td style="font-weight:600;color:' + diffColor + '">' + diff + '</td>' +
        '<td>' + statusBadge(e) + '</td>' +
      '</tr>';
    }).join('')}</tbody></table>`;
}
</script>
