---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { readFileSync, existsSync } from 'fs';
import { join } from 'path';

import { readdirSync } from 'fs';

const expPath = join(process.cwd(), 'ai-ready-opt', 'experiments.json');
let experiments: any[] = [];
if (existsSync(expPath)) {
  try {
    experiments = JSON.parse(readFileSync(expPath, 'utf-8'));
  } catch { experiments = []; }
}

// Load external eval data
const evalDir = join(process.cwd(), 'ai-ready-opt', 'external-eval-results');
const calPath = join(process.cwd(), 'ai-ready-opt', 'calibration_report.json');

let calibration: any = null;
if (existsSync(calPath)) {
  try { calibration = JSON.parse(readFileSync(calPath, 'utf-8')); } catch {}
}

let temporalRuns: any[] = [];
let calibrationRuns: any[] = [];
if (existsSync(evalDir)) {
  try {
    const allFiles = readdirSync(evalDir).filter(f => f.endsWith('.json')).sort();
    // Temporal runs (daily tracking)
    temporalRuns = allFiles.filter(f => f.startsWith('ext-temporal-')).map(f => {
      try { return JSON.parse(readFileSync(join(evalDir, f), 'utf-8')); } catch { return null; }
    }).filter(Boolean);
    // Calibration + test runs (historical baseline)
    calibrationRuns = allFiles.filter(f => f.startsWith('ext-calibration-') || f.startsWith('ext-test-run-')).map(f => {
      try { return JSON.parse(readFileSync(join(evalDir, f), 'utf-8')); } catch { return null; }
    }).filter(Boolean);
  } catch {}
}

const buildTime = new Date().toISOString().slice(0, 16).replace('T', ' ');
---

<BaseLayout title="AI-Ready Dashboard — Paul Kuo" description="AI-Ready SEO 持續優化儀表板">

<div id="authGate" class="ard-auth">
  <div class="ard-auth-card">
    <div class="ard-auth-icon">📐</div>
    <h2>AI-Ready Dashboard</h2>
    <p>管理員限定</p>
    <input type="password" id="authInput" placeholder="存取密碼" autofocus />
    <button id="authBtn">進入</button>
  </div>
</div>

<div id="dashboardMain" class="ard-container" style="display:none">

  <!-- Header -->
  <header class="ard-header">
    <div class="ard-header-left">
      <div class="ard-header-badge">v2</div>
      <div>
        <h1>AI-Ready Optimizer</h1>
        <p class="ard-header-sub">持續優化儀表板 · 更新 {buildTime}</p>
      </div>
    </div>
    <div class="ard-header-right">
      <a href="/projects" class="ard-back-link">← 返回專案</a>
    </div>
  </header>

  <!-- Score Ring + KPIs -->
  <section class="ard-score-section">
    <div class="ard-score-ring-wrap">
      <canvas id="scoreRing" width="200" height="200"></canvas>
      <div class="ard-score-ring-label">
        <span id="scoreRingValue" class="ard-ring-value">—</span>
        <span class="ard-ring-sub">/ 100</span>
      </div>
    </div>
    <div class="ard-kpi-col">
      <div class="ard-kpi" id="kpi-jsonld">
        <div class="ard-kpi-bar"><div class="ard-kpi-fill" data-color="#f59e0b"></div></div>
        <div class="ard-kpi-info"><span class="ard-kpi-name">JSON-LD</span><span class="ard-kpi-val">—</span><span class="ard-kpi-max">/ 25</span></div>
      </div>
      <div class="ard-kpi" id="kpi-llms">
        <div class="ard-kpi-bar"><div class="ard-kpi-fill" data-color="#059669"></div></div>
        <div class="ard-kpi-info"><span class="ard-kpi-name">llms.txt</span><span class="ard-kpi-val">—</span><span class="ard-kpi-max">/ 25</span></div>
      </div>
      <div class="ard-kpi" id="kpi-mcp">
        <div class="ard-kpi-bar"><div class="ard-kpi-fill" data-color="#3b82f6"></div></div>
        <div class="ard-kpi-info"><span class="ard-kpi-name">MCP+A2A</span><span class="ard-kpi-val">—</span><span class="ard-kpi-max">/ 25</span></div>
      </div>
      <div class="ard-kpi" id="kpi-ai">
        <div class="ard-kpi-bar"><div class="ard-kpi-fill" data-color="#8b5cf6"></div></div>
        <div class="ard-kpi-info"><span class="ard-kpi-name">AI 理解度</span><span class="ard-kpi-val">—</span><span class="ard-kpi-max">/ 25</span></div>
      </div>
    </div>
    <div class="ard-stats-col">
      <div class="ard-stat"><span class="ard-stat-val" id="statTotal">—</span><span class="ard-stat-label">總實驗</span></div>
      <div class="ard-stat"><span class="ard-stat-val" id="statSuccess">—</span><span class="ard-stat-label">成功評分</span></div>
      <div class="ard-stat"><span class="ard-stat-val" id="statKept">—</span><span class="ard-stat-label">保留</span></div>
      <div class="ard-stat"><span class="ard-stat-val" id="statReverted">—</span><span class="ard-stat-label">回退</span></div>
    </div>
  </section>

  <!-- Charts -->
  <section class="ard-charts">
    <div class="ard-panel ard-panel-wide">
      <h3 class="ard-panel-title">分數趨勢</h3>
      <div class="ard-chart-wrap ard-chart-tall"><canvas id="scoreTrendChart"></canvas></div>
    </div>
    <div class="ard-panel">
      <h3 class="ard-panel-title">子分數趨勢</h3>
      <div class="ard-chart-wrap ard-chart-tall"><canvas id="subScoreChart"></canvas></div>
    </div>
    <div class="ard-panel">
      <h3 class="ard-panel-title">結果分佈</h3>
      <div class="ard-chart-wrap"><canvas id="statusChart"></canvas></div>
    </div>
  </section>

  <!-- Experiment Log -->
  <section class="ard-panel ard-panel-wide">
    <h3 class="ard-panel-title">實驗紀錄 <span class="ard-panel-badge" id="expCount">0</span></h3>
    <div class="ard-table-wrap" id="expTableBody"></div>
  </section>

  <!-- Layer 5a: External AI Cross-Validation -->
  <section class="ard-ext-header">
    <div class="ard-ext-header-icon">🔬</div>
    <div>
      <h2 class="ard-ext-header-title">外部 AI 交叉驗證（Layer 5a）</h2>
      <p class="ard-ext-header-sub">Perplexity Sonar 獨立搜尋 · 13 題基準測試 · 每日自動追蹤</p>
    </div>
  </section>

  <!-- Narrative: Story Context -->
  <section class="ard-narrative" id="extNarrative">
    <div class="ard-narrative-context">
      <h4 class="ard-narrative-label">這是什麼？</h4>
      <p>這個網站有一套自動優化系統：AI 自動修改網站 → 自動評分 → 決定保留或回退。但如果是自己考自己，永遠不知道真的有沒有進步。</p>
      <p>所以我們引入「外部考官」：讓 Perplexity（一個獨立的 AI 搜尋引擎）回答 13 道關於 Paul Kuo 的問題，看它能找到多少正確資訊、會不會捏造假資料。這就是 Layer 5a。</p>
      <p class="ard-narrative-link">完整設計思路 → <a href="/articles/ai-ready-continuous-optimization/">把 paulkuo.tw 變成一個自己進化的網站</a></p>
    </div>
    <div class="ard-narrative-status" id="extNarrativeStatus">
      <!-- Dynamically populated -->
    </div>
  </section>

  <!-- External: Score Overview -->
  <section class="ard-ext-overview">
    <div class="ard-ext-score-card">
      <div class="ard-ext-score-big" id="extScoreValue">—</div>
      <div class="ard-ext-score-label">External Score</div>
      <div class="ard-ext-score-delta" id="extScoreDelta"></div>
    </div>
    <div class="ard-ext-metrics">
      <div class="ard-ext-metric">
        <span class="ard-ext-metric-val" id="extRecall">—</span>
        <span class="ard-ext-metric-label">Positive Recall</span>
      </div>
      <div class="ard-ext-metric">
        <span class="ard-ext-metric-val" id="extHallucination">—</span>
        <span class="ard-ext-metric-label">幻覺抵抗</span>
      </div>
      <div class="ard-ext-metric">
        <span class="ard-ext-metric-val" id="extDiscovery">—</span>
        <span class="ard-ext-metric-label">Discovery</span>
      </div>
    </div>
    <div class="ard-ext-observation">
      <div class="ard-ext-obs-title">觀察期進度</div>
      <div class="ard-ext-obs-bar"><div class="ard-ext-obs-fill" id="extObsFill"></div></div>
      <div class="ard-ext-obs-text" id="extObsText">— / 20 輪</div>
      <div class="ard-ext-obs-status" id="extObsStatus">觀察中</div>
    </div>
  </section>

  <!-- External: Trend Chart -->
  <section class="ard-charts" style="margin-top:1.25rem">
    <div class="ard-panel ard-panel-wide">
      <h3 class="ard-panel-title">External Score 趨勢 <span class="ard-panel-badge">校準均值 ± 噪音帶</span></h3>
      <div class="ard-chart-wrap ard-chart-tall"><canvas id="extTrendChart"></canvas></div>
    </div>
    <div class="ard-panel">
      <h3 class="ard-panel-title">分類表現</h3>
      <div class="ard-chart-wrap ard-chart-tall"><canvas id="extCategoryChart"></canvas></div>
    </div>
    <div class="ard-panel">
      <h3 class="ard-panel-title">分類 vs 校準基線</h3>
      <div class="ard-chart-wrap ard-chart-tall"><canvas id="extRadarChart"></canvas></div>
    </div>
  </section>

  <!-- Glossary -->
  <section class="ard-glossary">
    <h3 class="ard-glossary-title">附錄：詞彙表</h3>
    <dl class="ard-glossary-list">
      <dt>JSON-LD</dt>
      <dd>嵌入網頁的結構化資料格式，幫助 AI 與搜尋引擎理解頁面內容的語意（如人物、文章、組織）。</dd>

      <dt>llms.txt</dt>
      <dd>專為大型語言模型設計的網站摘要檔案，讓 AI 快速掌握網站的核心資訊，類似 robots.txt 之於搜尋引擎。</dd>

      <dt>MCP + A2A</dt>
      <dd>Model Context Protocol + Agent-to-Agent Protocol。兩種新興的 AI 互操作協議，讓 AI agent 能直接與網站交換結構化資訊。</dd>

      <dt>AI 理解度</dt>
      <dd>內部評分指標：讓 Claude 閱讀 llms.txt 後回答關於網站的問題，衡量 AI 是否能正確理解網站內容。</dd>

      <dt>External Score</dt>
      <dd>外部驗證分數：透過 Perplexity（獨立搜尋引擎）回答 13 道基準題，衡量外部 AI 對本站的認知準確度。</dd>

      <dt>Positive Recall</dt>
      <dd>正面召回率：10 道事實題中，外部 AI 能正確找到並回答的比例。越高代表網站資訊越容易被 AI 發現。</dd>

      <dt>Hallucination Resistance（幻覺抵抗）</dt>
      <dd>3 道反幻覺題中，外部 AI 正確拒絕捏造答案的比例。100% 代表 AI 不會編造關於你的虛假資訊。</dd>

      <dt>Discovery</dt>
      <dd>發現性指標：外部 AI 回答時是否引用了 paulkuo.tw 作為來源，衡量網站在 AI 搜尋中的可見度。</dd>

      <dt>校準基線 (Calibration Baseline)</dt>
      <dd>優化前的 10 次重複測試結果，建立統計參考基準。均值 = 系統的自然表現，標準差 = 自然波動幅度。</dd>

      <dt>噪音帶 (Noise Band)</dt>
      <dd>校準均值 ± 2 倍標準差。分數變化落在此範圍內視為隨機波動，超出此範圍才是真正的改善或退步訊號。</dd>

      <dt>觀察期</dt>
      <dd>Layer 5a 目前處於「只觀察、不決策」階段。累積 20 輪以上數據後，才考慮將外部分數納入自動 keep/revert 決策。</dd>

      <dt>Keep / Revert</dt>
      <dd>優化迴圈的核心決策：每次自動修改後評分，分數提升則保留 (keep)，下降則回退 (revert)。</dd>

      <dt>Mutation Agent</dt>
      <dd>自動產生網站優化修改的 AI 代理，根據差距分析提出具體的程式碼或內容變更。</dd>
    </dl>
  </section>

</div>
</BaseLayout>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js" is:inline></script>

<script define:vars={{ experiments, calibration, temporalRuns, calibrationRuns }} is:inline>
// ── Auth ──
const WORKER = 'https://api.paulkuo.tw';
const authGate = document.getElementById('authGate');
const dashMain = document.getElementById('dashboardMain');
const authInput = document.getElementById('authInput');
const authBtn = document.getElementById('authBtn');
var charts = {};

async function verifyCode(code) {
  try {
    const res = await fetch(WORKER + '/validate-code', {
      method: 'POST', headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({ code })
    });
    const d = await res.json();
    if (d.valid && d.role === 'admin') return d;
  } catch(e) {}
  return null;
}

async function checkAuth() {
  const urlKey = new URLSearchParams(window.location.search).get('key');
  const code = urlKey || sessionStorage.getItem('dash_code') || '';
  if (code) {
    const result = await verifyCode(code);
    if (result) {
      sessionStorage.setItem('dash_code', code);
      authGate.style.display = 'none';
      dashMain.style.display = 'block';
      renderDashboard();
      return;
    }
  }
}

authBtn.addEventListener('click', async () => {
  authBtn.textContent = '驗證中…'; authBtn.disabled = true;
  const result = await verifyCode(authInput.value.trim().toLowerCase());
  if (result) {
    sessionStorage.setItem('dash_code', authInput.value.trim().toLowerCase());
    authGate.style.display = 'none';
    dashMain.style.display = 'block';
    renderDashboard();
  } else {
    authInput.style.borderColor = '#ef4444';
    authInput.value = '';
    authInput.placeholder = '密碼錯誤或非管理員';
    authBtn.textContent = '進入'; authBtn.disabled = false;
  }
});
authInput.addEventListener('keydown', e => { if (e.key === 'Enter') authBtn.click(); });
checkAuth();

// ── Score Ring ──
function drawScoreRing(score) {
  const canvas = document.getElementById('scoreRing');
  const ctx = canvas.getContext('2d');
  const dpr = window.devicePixelRatio || 1;
  canvas.width = 200 * dpr; canvas.height = 200 * dpr;
  canvas.style.width = '200px'; canvas.style.height = '200px';
  ctx.scale(dpr, dpr);

  const cx = 100, cy = 100, r = 80, lw = 12;
  const pct = score / 100;
  const startAngle = -Math.PI / 2;
  const endAngle = startAngle + (2 * Math.PI * pct);

  // Background ring
  ctx.beginPath(); ctx.arc(cx, cy, r, 0, 2 * Math.PI);
  ctx.strokeStyle = '#e5e7eb'; ctx.lineWidth = lw; ctx.lineCap = 'round'; ctx.stroke();

  // Score arc
  const color = score >= 90 ? '#059669' : score >= 70 ? '#6366f1' : score >= 50 ? '#f59e0b' : '#dc2626';
  ctx.beginPath(); ctx.arc(cx, cy, r, startAngle, endAngle);
  ctx.strokeStyle = color; ctx.lineWidth = lw; ctx.lineCap = 'round'; ctx.stroke();

  document.getElementById('scoreRingValue').textContent = score;
  document.getElementById('scoreRingValue').style.color = color;
}

// ── KPI Bars ──
function setKpi(id, value, max) {
  const el = document.getElementById(id);
  const fill = el.querySelector('.ard-kpi-fill');
  const val = el.querySelector('.ard-kpi-val');
  val.textContent = value;
  const pct = Math.min(100, (value / max) * 100);
  fill.style.width = pct + '%';
  fill.style.background = fill.dataset.color;
  if (value >= max * 0.9) val.style.color = '#059669';
  else if (value >= max * 0.6) val.style.color = fill.dataset.color;
  else val.style.color = '#dc2626';
}

// ── Render ──
function renderDashboard() {
  const data = experiments || [];
  const successes = data.filter(e => e.evaluation_status === 'success');
  const latest = successes.length > 0 ? successes[successes.length - 1] : null;
  const currentScore = latest ? (latest.preview_score || latest.baseline_score || 0) : 0;
  const sub = latest ? (latest.preview_sub_scores || latest.baseline_sub_scores || {}) : {};

  // Score ring
  drawScoreRing(currentScore);

  // KPI bars
  setKpi('kpi-jsonld', sub.json_ld || 0, 25);
  setKpi('kpi-llms', sub.llms_txt || 0, 25);
  setKpi('kpi-mcp', sub.mcp_a2a || 0, 25);
  setKpi('kpi-ai', sub.ai_comprehension || 0, 25);

  // Stats
  document.getElementById('statTotal').textContent = data.length;
  document.getElementById('statSuccess').textContent = successes.length;
  document.getElementById('statKept').textContent = data.filter(e => e.kept_or_reverted === 'keep').length;
  document.getElementById('statReverted').textContent = data.filter(e => e.kept_or_reverted === 'revert').length;
  document.getElementById('expCount').textContent = data.length;

  // Charts
  Object.values(charts).forEach(c => c.destroy()); charts = {};
  const cDef = {
    responsive: true, maintainAspectRatio: false,
    plugins: { legend: { labels: { color: '#6b7280', font: { family: "'DM Sans',sans-serif", size: 11 }, padding: 14, usePointStyle: true, pointStyleWidth: 8 } } },
  };

  if (successes.length > 0) {
    const labels = successes.map(e => {
      const id = e.iteration_id || '';
      const m = id.match(/^(\d{4})(\d{2})(\d{2})(\d{2})(\d{2})-(\d+)$/);
      return m ? `${m[2]}-${m[3]} ${m[4]}:${m[5]}` : id.slice(0, 12);
    });
    const baselines = successes.map(e => e.baseline_score || 0);
    const previews = successes.map(e => e.preview_score || 0);

    charts.trend = new Chart(document.getElementById('scoreTrendChart'), {
      type: 'line',
      data: { labels, datasets: [
        { label: 'Baseline', data: baselines, borderColor: '#cbd5e1', borderDash: [6, 3], borderWidth: 2, pointRadius: 4, pointBackgroundColor: '#cbd5e1', fill: false, tension: 0.3 },
        { label: 'After Change', data: previews, borderColor: '#6366f1', borderWidth: 2.5, pointRadius: 5, pointBackgroundColor: '#6366f1', fill: { target: 'origin', above: 'rgba(99,102,241,0.06)' }, tension: 0.3 },
      ]},
      options: { ...cDef, scales: {
        x: { grid: { display: false }, ticks: { color: '#9ca3af', font: { size: 10 } } },
        y: { min: 0, max: 100, grid: { color: '#f3f4f6' }, ticks: { color: '#9ca3af', stepSize: 20 } },
      }},
    });

    const jsonLd = successes.map(e => (e.preview_sub_scores || e.baseline_sub_scores || {}).json_ld || 0);
    const llms = successes.map(e => (e.preview_sub_scores || e.baseline_sub_scores || {}).llms_txt || 0);
    const mcp = successes.map(e => (e.preview_sub_scores || e.baseline_sub_scores || {}).mcp_a2a || 0);
    const ai = successes.map(e => (e.preview_sub_scores || e.baseline_sub_scores || {}).ai_comprehension || 0);

    charts.sub = new Chart(document.getElementById('subScoreChart'), {
      type: 'line',
      data: { labels, datasets: [
        { label: 'JSON-LD', data: jsonLd, borderColor: '#f59e0b', borderWidth: 2, pointRadius: 3, fill: false, tension: 0.3 },
        { label: 'llms.txt', data: llms, borderColor: '#059669', borderWidth: 2, pointRadius: 3, fill: false, tension: 0.3 },
        { label: 'MCP+A2A', data: mcp, borderColor: '#3b82f6', borderWidth: 2, pointRadius: 3, fill: false, tension: 0.3 },
        { label: 'AI 理解', data: ai, borderColor: '#8b5cf6', borderWidth: 2, pointRadius: 3, fill: false, tension: 0.3 },
      ]},
      options: { ...cDef, scales: {
        x: { grid: { display: false }, ticks: { color: '#9ca3af', font: { size: 10 } } },
        y: { min: 0, max: 25, grid: { color: '#f3f4f6' }, ticks: { color: '#9ca3af', stepSize: 5 } },
      }},
    });
  }

  // Status doughnut
  const sc = {}; data.forEach(e => { const s = e.evaluation_status || 'unknown'; sc[s] = (sc[s] || 0) + 1; });
  const sClr = { success:'#059669', mutation_failed:'#dc2626', policy_violation:'#f59e0b', no_action:'#94a3b8', eval_failed:'#ef4444', dry_run:'#6366f1', unknown:'#d1d5db' };
  const sLabel = { success:'成功', mutation_failed:'生成失敗', policy_violation:'違規', no_action:'無動作', eval_failed:'評分失敗', dry_run:'試跑', unknown:'其他' };
  const sKeys = Object.keys(sc).sort((a,b) => sc[b] - sc[a]);
  charts.status = new Chart(document.getElementById('statusChart'), {
    type: 'doughnut',
    data: { labels: sKeys.map(k => sLabel[k] || k), datasets: [{ data: sKeys.map(k => sc[k]),
      backgroundColor: sKeys.map(k => sClr[k] || '#8A8A8A'), borderWidth: 3, borderColor: '#ffffff', borderRadius: 4 }] },
    options: { ...cDef, cutout: '60%', plugins: { ...cDef.plugins, legend: { position: 'right', labels: { ...cDef.plugins.legend.labels, padding: 16 } } } },
  });

  // ── External Eval (Layer 5a) ──
  renderExternalEval();

  // Table
  const sorted = [...data].reverse();
  const badge = (e) => {
    const s = e.kept_or_reverted || e.evaluation_status || '';
    const map = { keep:['保留','#059669'], revert:['回退','#f59e0b'], success:['成功','#059669'], mutation_failed:['生成失敗','#dc2626'], policy_violation:['違規','#f97316'], no_action:['無動作','#94a3b8'], dry_run:['試跑','#6366f1'] };
    const [label, color] = map[s] || [s || '—', '#8A8A8A'];
    return `<span class="ard-badge" style="--bc:${color}">${label}</span>`;
  };
  const fmtTime = (ts) => { if (!ts) return '—'; return ts.slice(5,16).replace('T',' '); };
  const fmtFile = (files) => { if (!files || !files.length) return '<span class="ard-muted">—</span>'; return files.map(f => f.split('/').pop()).join(', '); };

  document.getElementById('expTableBody').innerHTML = `<table class="ard-table">
    <thead><tr><th>時間</th><th>修改檔案</th><th>分析摘要</th><th style="text-align:center">Baseline</th><th style="text-align:center">After</th><th style="text-align:center">Diff</th><th style="text-align:center">結果</th></tr></thead>
    <tbody>${sorted.map(e => {
      const analysis = (e.gap_analysis || e.change_summary || e.failure_reason || '');
      const bl = e.baseline_score != null ? e.baseline_score : '—';
      const pv = e.preview_score != null ? e.preview_score : '—';
      const df = e.score_diff != null ? e.score_diff : null;
      const dfStr = df != null ? (df >= 0 ? '+' + df : '' + df) : '—';
      const dfCls = df > 0 ? 'ard-diff-up' : df < 0 ? 'ard-diff-down' : 'ard-diff-zero';
      return `<tr>
        <td class="ard-td-time">${fmtTime(e.timestamp)}</td>
        <td class="ard-td-file">${fmtFile(e.files_modified)}</td>
        <td class="ard-td-analysis" title="${analysis.replace(/"/g, '&quot;')}">${analysis.slice(0, 90)}${analysis.length > 90 ? '…' : ''}</td>
        <td style="text-align:center">${bl}</td>
        <td style="text-align:center">${pv}</td>
        <td style="text-align:center" class="${dfCls}">${dfStr}</td>
        <td style="text-align:center">${badge(e)}</td>
      </tr>`;
    }).join('')}</tbody></table>`;
}

// ── External Eval Renderer ──
function renderExternalEval() {
  const cal = calibration;
  const runs = temporalRuns || [];
  if (!cal && runs.length === 0) return;

  const latest = runs.length > 0 ? runs[runs.length - 1] : null;
  const agg = latest ? latest.aggregate : null;
  const calMean = cal ? cal.overall.mean : null;
  const noise2x = cal ? cal.threshold.stddev_2x : null;

  // Score card
  if (agg) {
    const scoreEl = document.getElementById('extScoreValue');
    scoreEl.textContent = agg.overall_score;
    const color = agg.overall_score >= 70 ? '#059669' : agg.overall_score >= 50 ? '#f59e0b' : '#dc2626';
    scoreEl.style.color = color;

    // Delta vs calibration mean
    if (calMean != null) {
      const delta = (agg.overall_score - calMean).toFixed(1);
      const deltaEl = document.getElementById('extScoreDelta');
      const sign = delta >= 0 ? '+' : '';
      deltaEl.textContent = sign + delta + ' vs 校準均值 (' + calMean + ')';
      if (noise2x && Math.abs(delta) > noise2x) {
        deltaEl.style.color = delta >= 0 ? '#059669' : '#dc2626';
        deltaEl.textContent += ' ⚡ 強訊號';
      } else {
        deltaEl.style.color = '#9ca3af';
        deltaEl.textContent += ' (噪音範圍內)';
      }
    }

    // Metrics
    document.getElementById('extRecall').textContent = agg.positive_recall + '%';
    document.getElementById('extHallucination').textContent = agg.hallucination_resistance + '%';
    document.getElementById('extHallucination').style.color = agg.hallucination_resistance >= 90 ? '#059669' : '#f59e0b';
    document.getElementById('extDiscovery').textContent = agg.discovery_aggregate + '%';
  }

  // Observation progress
  const totalRuns = runs.length;
  const target = 20;
  const pct = Math.min(100, (totalRuns / target) * 100);
  document.getElementById('extObsFill').style.width = pct + '%';
  document.getElementById('extObsText').textContent = totalRuns + ' / ' + target + ' 輪';
  const obsStatus = document.getElementById('extObsStatus');
  if (totalRuns >= target) {
    obsStatus.textContent = '可升級為 Soft Gate';
    obsStatus.style.color = '#059669';
  } else {
    obsStatus.textContent = '觀察中 — 不影響 keep/revert 決策';
    obsStatus.style.color = '#f59e0b';
  }

  // Narrative status
  if (agg && cal) {
    const narEl = document.getElementById('extNarrativeStatus');
    const recallPct = agg.positive_recall;
    const halPct = agg.hallucination_resistance;
    const cats = agg.per_category;

    // Find weakest and strongest categories (exclude negative_test)
    const posCats = ['identity','projects','content','tech_stack','expertise','articles','brand'];
    const catNames = {identity:'身份辨識',projects:'專案',content:'內容',tech_stack:'技術背景',expertise:'專業領域',articles:'文章',brand:'品牌'};
    const weakest = posCats.filter(c => cats[c] <= 25).map(c => catNames[c]);
    const strongest = posCats.filter(c => cats[c] >= 75).map(c => catNames[c]);

    // Determine phase description
    let phaseDesc = '';
    if (totalRuns < 20) {
      phaseDesc = '目前處於<strong>觀察期</strong>（第 ' + totalRuns + ' / 20 輪）。外部分數只記錄、不影響系統的保留／回退決策。累積足夠數據後，才會考慮讓外部分數參與自動決策。';
    } else {
      phaseDesc = '觀察期已完成（' + totalRuns + ' 輪）。可以考慮將外部分數升級為 Soft Gate，讓它參與自動決策。';
    }

    // Trend narrative (if multiple runs)
    let trendDesc = '';
    if (runs.length >= 3) {
      const first3 = runs.slice(0, 3).reduce((s, r) => s + r.aggregate.overall_score, 0) / 3;
      const last3 = runs.slice(-3).reduce((s, r) => s + r.aggregate.overall_score, 0) / 3;
      const diff = last3 - first3;
      if (Math.abs(diff) > noise2x) {
        trendDesc = diff > 0
          ? '<li>趨勢方向：<strong style="color:#059669">上升中</strong>，近期均分高於早期，超過噪音閾值，屬於有效訊號</li>'
          : '<li>趨勢方向：<strong style="color:#dc2626">下降中</strong>，近期均分低於早期，需要關注</li>';
      } else {
        trendDesc = '<li>趨勢方向：<strong>持平</strong>，分數波動仍在噪音範圍內，尚無法判定方向</li>';
      }
    }

    narEl.innerHTML = '<h4 class="ard-narrative-label">目前狀況</h4><ul class="ard-narrative-bullets">'
      + '<li>外部 AI <strong>答對了 ' + recallPct + '% 的事實</strong>——' + (recallPct >= 60 ? '多數資訊已被外界 AI 收錄' : recallPct >= 40 ? '部分資訊可被找到，但仍有改善空間' : '大部分資訊還沒被外界 AI 收錄，這是優化的重點方向') + '</li>'
      + '<li>' + (halPct >= 90 ? '<strong style="color:#059669">沒有捏造虛假資訊</strong>（幻覺抵抗 ' + halPct + '%）' : '幻覺抵抗 ' + halPct + '%，外部 AI 偶爾會編造不實內容，需要警覺') + '</li>'
      + (weakest.length > 0 ? '<li>最弱領域：<strong>' + weakest.join('、') + '</strong>——外部 AI 幾乎找不到這方面的資訊</li>' : '')
      + (strongest.length > 0 ? '<li>最強領域：<strong style="color:#059669">' + strongest.join('、') + '</strong>——外部 AI 能正確回答</li>' : '')
      + trendDesc
      + '<li>' + phaseDesc + '</li>'
      + '</ul>';
  }

  // Trend chart with noise band — includes calibration history + temporal runs
  const calRuns = (calibrationRuns || []).slice();
  const allRuns = [...calRuns, ...runs];
  if (allRuns.length > 0 && cal) {
    const labels = allRuns.map(r => {
      const ts = r.timestamp || '';
      return ts.slice(5, 10);
    });
    const allScores = allRuns.map(r => r.aggregate.overall_score);
    const meanLine = allRuns.map(() => calMean);
    const upperBand = allRuns.map(() => calMean + noise2x);
    const lowerBand = allRuns.map(() => Math.max(0, calMean - noise2x));

    // Separate calibration vs temporal data for distinct visual treatment
    const calCount = calRuns.length;
    const calScores = allScores.map((s, i) => i < calCount ? s : null);
    const temporalScores = allScores.map((s, i) => i >= calCount ? s : (i === calCount - 1 ? allScores[calCount - 1] : null));

    charts.extTrend = new Chart(document.getElementById('extTrendChart'), {
      type: 'line',
      data: { labels, datasets: [
        { label: '噪音上界', data: upperBand, borderColor: 'rgba(220,38,38,0.2)', borderWidth: 1, borderDash: [4, 4], pointRadius: 0, fill: false },
        { label: '噪音下界', data: lowerBand, borderColor: 'rgba(220,38,38,0.2)', borderWidth: 1, borderDash: [4, 4], pointRadius: 0, fill: '-1', backgroundColor: 'rgba(220,38,38,0.04)' },
        { label: '校準均值 (' + calMean + ')', data: meanLine, borderColor: '#9ca3af', borderWidth: 1.5, borderDash: [8, 4], pointRadius: 0, fill: false },
        { label: '校準期 (10 輪)', data: calScores, borderColor: '#f59e0b', borderWidth: 2, pointRadius: 4, pointBackgroundColor: '#f59e0b', fill: false, tension: 0.3, borderDash: [6, 3] },
        { label: '正式追蹤', data: temporalScores, borderColor: '#6366f1', borderWidth: 2.5, pointRadius: 6, pointBackgroundColor: '#6366f1', fill: false, tension: 0.3 },
      ]},
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { labels: { color: '#6b7280', font: { family: "'DM Sans',sans-serif", size: 11 }, padding: 14, usePointStyle: true, pointStyleWidth: 8 } } },
        scales: {
          x: { grid: { display: false }, ticks: { color: '#9ca3af', font: { size: 10 } } },
          y: { min: 0, max: 100, grid: { color: '#f3f4f6' }, ticks: { color: '#9ca3af', stepSize: 20 } },
        },
      },
    });
  }

  // Category bar chart (latest vs calibration)
  const categories = ['identity', 'projects', 'content', 'tech_stack', 'expertise', 'articles', 'brand', 'negative_test'];
  const catLabels = ['身份', '專案', '內容', '技術棧', '專業', '文章', '品牌', '反幻覺'];
  const catColors = ['#6366f1', '#3b82f6', '#059669', '#f59e0b', '#8b5cf6', '#06b6d4', '#ec4899', '#10b981'];

  if (agg && cal) {
    const latestCats = categories.map(c => agg.per_category[c] || 0);
    const calCats = categories.map(c => cal.per_category[c] ? cal.per_category[c].mean : 0);

    charts.extCat = new Chart(document.getElementById('extCategoryChart'), {
      type: 'bar',
      data: { labels: catLabels, datasets: [
        { label: '校準基線', data: calCats, backgroundColor: 'rgba(156,163,175,0.3)', borderColor: '#9ca3af', borderWidth: 1, borderRadius: 4 },
        { label: '最新', data: latestCats, backgroundColor: catColors.map(c => c + '33'), borderColor: catColors, borderWidth: 2, borderRadius: 4 },
      ]},
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { labels: { color: '#6b7280', font: { family: "'DM Sans',sans-serif", size: 11 }, padding: 14, usePointStyle: true, pointStyleWidth: 8 } } },
        scales: {
          x: { grid: { display: false }, ticks: { color: '#9ca3af', font: { size: 10 } } },
          y: { min: 0, max: 100, grid: { color: '#f3f4f6' }, ticks: { color: '#9ca3af', stepSize: 25 } },
        },
      },
    });

    // Radar chart
    charts.extRadar = new Chart(document.getElementById('extRadarChart'), {
      type: 'radar',
      data: { labels: catLabels, datasets: [
        { label: '校準基線', data: calCats, borderColor: '#9ca3af', backgroundColor: 'rgba(156,163,175,0.1)', borderWidth: 1.5, pointRadius: 3 },
        { label: '最新', data: latestCats, borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.1)', borderWidth: 2, pointRadius: 4 },
      ]},
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { labels: { color: '#6b7280', font: { family: "'DM Sans',sans-serif", size: 11 }, padding: 14, usePointStyle: true, pointStyleWidth: 8 } } },
        scales: {
          r: { min: 0, max: 100, ticks: { stepSize: 25, color: '#9ca3af', backdropColor: 'transparent', font: { size: 9 } }, grid: { color: '#e5e7eb' }, pointLabels: { color: '#6b7280', font: { size: 11 } } },
        },
      },
    });
  }
}
</script>

