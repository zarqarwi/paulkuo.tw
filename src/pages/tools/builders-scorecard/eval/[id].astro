---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import ScorecardResult from '../../../../components/scorecard/ScorecardResult';

// Static output: getStaticPaths returns [] so no pages are pre-built.
// Cloudflare Pages _redirects rewrites /eval/* → /eval/index.html
// The ScorecardResult component reads the ID from window.location at runtime.
export function getStaticPaths() {
  return [{ params: { id: 'index' } }];
}
const { id } = Astro.params;
---
<BaseLayout
  title="Builder's Scorecard 評估結果"
  description="Builder's Scorecard 產品評估報告 — 五維度加權評分"
  ogUrl="https://paulkuo.tw/tools/builders-scorecard/eval/"
>
  <ScorecardResult client:load />
</BaseLayout>
