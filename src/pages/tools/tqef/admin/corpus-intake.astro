---
// TQEF Channel C: Corpus Intake (audio + text)
---
<html lang="zh-TW">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Corpus 素材進件 — TQEF Admin</title>
  <meta name="robots" content="noindex, nofollow" />
  <style is:global>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #0f172a; color: #e2e8f0; min-height: 100vh; }
    .auth-gate { display: flex; justify-content: center; align-items: center; min-height: 100vh; }
    .auth-card { background: #1e293b; padding: 2rem; border-radius: 12px; text-align: center; }
    .auth-card h2 { margin-bottom: 1rem; font-size: 1.25rem; }
    .auth-card input { background: #0f172a; border: 1px solid #334155; color: #e2e8f0; padding: 0.5rem 1rem; border-radius: 6px; margin-right: 0.5rem; }
    .auth-card button { background: #3b82f6; color: white; border: none; padding: 0.5rem 1.5rem; border-radius: 6px; cursor: pointer; }
    .container { max-width: 900px; margin: 0 auto; padding: 1.5rem; }
    .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; }
    .header h1 { font-size: 1.5rem; }
    .header-actions a { color: #93c5fd; text-decoration: none; margin-left: 1rem; font-size: 0.875rem; }
    .card { background: #1e293b; border-radius: 10px; padding: 1.5rem; margin-bottom: 1.25rem; }
    .card h3 { font-size: 0.875rem; color: #94a3b8; margin-bottom: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; }

    /* Metadata row */
    .meta-row { display: flex; gap: 1rem; margin-bottom: 1.25rem; flex-wrap: wrap; }
    .meta-row label { font-size: 0.75rem; color: #94a3b8; display: block; margin-bottom: 0.25rem; }
    .meta-row select { background: #0f172a; border: 1px solid #334155; color: #e2e8f0; padding: 0.5rem 0.75rem; border-radius: 6px; font-size: 0.875rem; min-width: 140px; }

    /* Drop zone */
    .drop-zone { border: 2px dashed #334155; border-radius: 10px; padding: 2.5rem; text-align: center; cursor: pointer; transition: border-color 0.2s, background 0.2s; }
    .drop-zone:hover, .drop-zone.dragover { border-color: #3b82f6; background: rgba(59,130,246,0.05); }
    .drop-zone p { color: #64748b; font-size: 0.875rem; }
    .drop-zone .hint { font-size: 0.75rem; color: #475569; margin-top: 0.5rem; }
    .drop-zone input[type="file"] { display: none; }

    /* Progress / status */
    .status-bar { display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 1rem; background: #0f172a; border-radius: 8px; margin-bottom: 1rem; font-size: 0.875rem; }
    .status-bar .dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
    .dot-pending { background: #facc15; }
    .dot-processing { background: #3b82f6; animation: pulse 1s infinite; }
    .dot-done { background: #4ade80; }
    .dot-failed { background: #f87171; }
    @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }

    /* Text area for correction */
    .edit-area { width: 100%; min-height: 120px; background: #0f172a; border: 1px solid #334155; color: #e2e8f0; padding: 0.75rem; border-radius: 8px; font-size: 0.875rem; font-family: inherit; resize: vertical; }
    .edit-area:focus { outline: none; border-color: #3b82f6; }

    /* Sentence list for text intake */
    .sentence-list { list-style: none; max-height: 400px; overflow-y: auto; }
    .sentence-item { display: flex; align-items: flex-start; gap: 0.5rem; padding: 0.5rem 0; border-bottom: 1px solid #1e293b; font-size: 0.875rem; }
    .sentence-item:last-child { border-bottom: none; }
    .sentence-num { color: #64748b; font-size: 0.75rem; min-width: 2rem; padding-top: 0.15rem; }
    .sentence-text { flex: 1; }
    .sentence-text input { background: transparent; border: none; color: #e2e8f0; width: 100%; font-size: 0.875rem; font-family: inherit; }
    .sentence-text input:focus { outline: none; border-bottom: 1px solid #3b82f6; }
    .sentence-del { color: #64748b; cursor: pointer; font-size: 0.75rem; padding: 0.15rem 0.4rem; border-radius: 4px; }
    .sentence-del:hover { color: #f87171; background: rgba(248,113,113,0.1); }

    /* Buttons */
    .btn { border: none; padding: 0.5rem 1.25rem; border-radius: 6px; cursor: pointer; font-size: 0.875rem; font-weight: 500; transition: opacity 0.15s; }
    .btn:hover { opacity: 0.85; }
    .btn:disabled { opacity: 0.4; cursor: not-allowed; }
    .btn-primary { background: #3b82f6; color: white; }
    .btn-success { background: #22c55e; color: white; }
    .btn-ghost { background: transparent; color: #94a3b8; border: 1px solid #334155; }

    .actions { display: flex; gap: 0.75rem; margin-top: 1rem; }

    /* Corpus list */
    .corpus-table { width: 100%; border-collapse: collapse; font-size: 0.8rem; }
    .corpus-table th { text-align: left; padding: 0.5rem; border-bottom: 1px solid #334155; color: #94a3b8; font-weight: 500; font-size: 0.7rem; text-transform: uppercase; }
    .corpus-table td { padding: 0.5rem; border-bottom: 1px solid #1e293b; max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .badge { display: inline-block; padding: 0.15rem 0.5rem; border-radius: 4px; font-size: 0.7rem; font-weight: 500; }
    .badge-audio { background: rgba(59,130,246,0.15); color: #93c5fd; }
    .badge-text { background: rgba(74,222,128,0.15); color: #4ade80; }
    .badge-domain { background: rgba(148,163,184,0.1); color: #94a3b8; }

    .hidden { display: none !important; }
    .msg { padding: 0.75rem 1rem; border-radius: 8px; font-size: 0.875rem; margin-bottom: 1rem; }
    .msg-success { background: rgba(34,197,94,0.1); color: #4ade80; }
    .msg-error { background: rgba(248,113,113,0.1); color: #f87171; }
  </style>
</head>
<body>

<!-- Auth gate -->
<div id="authGate" class="auth-gate">
  <div class="auth-card">
    <h2>TQEF Admin</h2>
    <p style="color:#94a3b8;margin-bottom:1rem;font-size:0.875rem;">輸入 Admin 密碼</p>
    <input type="password" id="authInput" placeholder="Password" autofocus />
    <button id="authBtn">進入</button>
  </div>
</div>

<!-- Main content -->
<div id="main" class="container hidden">
  <div class="header">
    <h1>Corpus 素材進件</h1>
    <div class="header-actions">
      <a href="/tools/tqef/admin/">Dashboard</a>
      <a href="/tools/tqef/admin/feedback/">回饋審核</a>
      <a href="/tools/tqef/admin/meetings/">會議匯出</a>
    </div>
  </div>

  <!-- Metadata selectors -->
  <div class="meta-row">
    <div>
      <label>語言</label>
      <select id="selLang">
        <option value="zh" selected>中文</option>
        <option value="en">英文</option>
        <option value="ja">日文</option>
        <option value="other">其他</option>
      </select>
    </div>
    <div>
      <label>Domain</label>
      <select id="selDomain">
        <option value="semiconductor">半導體</option>
        <option value="circular">循環科技</option>
        <option value="business">商業</option>
        <option value="medical">醫學</option>
        <option value="general" selected>通用</option>
      </select>
    </div>
  </div>

  <!-- Drop zone -->
  <div class="card">
    <h3>上傳檔案</h3>
    <div id="dropZone" class="drop-zone">
      <p>拖曳檔案到這裡，或點擊選擇</p>
      <div class="hint">支援：mp3, m4a, wav, webm, ogg, mp4 (音檔) / txt (文字)</div>
      <input type="file" id="fileInput" accept=".mp3,.m4a,.wav,.webm,.ogg,.mp4,.txt" />
    </div>
  </div>

  <!-- Message area -->
  <div id="msgArea"></div>

  <!-- Audio processing section -->
  <div id="audioSection" class="card hidden">
    <h3>音檔辨識</h3>
    <div id="audioStatus" class="status-bar">
      <span class="dot dot-pending"></span>
      <span>等待上傳...</span>
    </div>
    <div id="audioResult" class="hidden">
      <label style="font-size:0.75rem;color:#94a3b8;display:block;margin-bottom:0.25rem;">STT 辨識結果（可編輯校正）</label>
      <textarea id="correctionArea" class="edit-area" placeholder="STT 辨識結果將顯示在這裡..."></textarea>
      <div class="actions">
        <button id="btnCorrect" class="btn btn-success" disabled>確認校正 → 寫入 Corpus</button>
      </div>
    </div>
  </div>

  <!-- Text preview section -->
  <div id="textSection" class="card hidden">
    <h3>文字預覽</h3>
    <div id="sentenceCount" style="font-size:0.75rem;color:#64748b;margin-bottom:0.5rem;"></div>
    <ul id="sentenceList" class="sentence-list"></ul>
    <div class="actions">
      <button id="btnConfirmText" class="btn btn-success" disabled>全部確認 → 寫入 Corpus</button>
      <button id="btnClearText" class="btn btn-ghost">清除</button>
    </div>
  </div>

  <!-- Recent corpus entries -->
  <div class="card">
    <h3>最近 Corpus 項目</h3>
    <div style="display:flex; gap:0.75rem; margin-bottom:0.75rem; align-items:center;">
      <select id="filterDomain" style="padding:0.3rem 0.5rem; background:#1e293b; color:#e2e8f0; border:1px solid #334155; border-radius:4px; font-size:0.8rem;">
        <option value="">全部 Domain</option>
        <option value="general">通用</option>
        <option value="semiconductor">半導體</option>
        <option value="circular">循環科技</option>
        <option value="medical">醫療</option>
        <option value="business">商業</option>
      </select>
      <select id="filterOrigin" style="padding:0.3rem 0.5rem; background:#1e293b; color:#e2e8f0; border:1px solid #334155; border-radius:4px; font-size:0.8rem;">
        <option value="">全部來源</option>
        <option value="manual">手動</option>
        <option value="intake_text">文字進件</option>
        <option value="intake_audio">音檔進件</option>
      </select>
      <button onclick="loadCorpusList()" style="padding:0.3rem 0.75rem; background:#334155; color:#e2e8f0; border:none; border-radius:4px; cursor:pointer; font-size:0.8rem;">篩選</button>
    </div>
    <table class="corpus-table">
      <thead><tr><th>ID</th><th>來源</th><th>Domain</th><th>語言</th><th>內容</th><th>建立時間</th><th></th></tr></thead>
      <tbody id="corpusBody"><tr><td colspan="6" style="color:#64748b;text-align:center;">載入中...</td></tr></tbody>
    </table>
  </div>
</div>

<script is:inline>
const API = 'https://api.paulkuo.tw';
let code = sessionStorage.getItem('tqef_code') || '';
let currentUploadId = null;
let pollTimer = null;

// ─── Auth ───
async function verifyCode(c) {
  try {
    const res = await fetch(API + '/validate-code', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ code: c }) });
    const d = await res.json();
    return d.valid && d.role === 'admin';
  } catch(e) { return false; }
}

async function checkAuth() {
  const urlKey = new URLSearchParams(window.location.search).get('key');
  const c = urlKey || code;
  if (c && await verifyCode(c)) {
    code = c;
    sessionStorage.setItem('tqef_code', c);
    document.getElementById('authGate').style.display = 'none';
    document.getElementById('main').classList.remove('hidden');
    loadCorpusList();
    return;
  }
  document.getElementById('authGate').style.display = 'flex';
}

document.getElementById('authBtn').onclick = async () => {
  const c = document.getElementById('authInput').value.trim();
  if (c && await verifyCode(c)) {
    code = c;
    sessionStorage.setItem('tqef_code', c);
    document.getElementById('authGate').style.display = 'none';
    document.getElementById('main').classList.remove('hidden');
    loadCorpusList();
  } else { alert('密碼錯誤'); }
};
document.getElementById('authInput').addEventListener('keydown', e => { if (e.key === 'Enter') document.getElementById('authBtn').click(); });

// ─── Helpers ───
function showMsg(text, type = 'success') {
  const el = document.getElementById('msgArea');
  el.innerHTML = `<div class="msg msg-${type}">${text}</div>`;
  setTimeout(() => { el.innerHTML = ''; }, 5000);
}

function apiUrl(path) {
  return API + path + (path.includes('?') ? '&' : '?') + 'code=' + encodeURIComponent(code);
}

// ─── Drop Zone ───
const dropZone = document.getElementById('dropZone');
const fileInput = document.getElementById('fileInput');

dropZone.addEventListener('click', () => fileInput.click());
dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('dragover'); });
dropZone.addEventListener('dragleave', () => dropZone.classList.remove('dragover'));
dropZone.addEventListener('drop', e => {
  e.preventDefault();
  dropZone.classList.remove('dragover');
  if (e.dataTransfer.files.length) handleFile(e.dataTransfer.files[0]);
});
fileInput.addEventListener('change', () => { if (fileInput.files.length) handleFile(fileInput.files[0]); });

function handleFile(file) {
  // Reset
  document.getElementById('audioSection').classList.add('hidden');
  document.getElementById('textSection').classList.add('hidden');
  if (pollTimer) { clearInterval(pollTimer); pollTimer = null; }
  currentUploadId = null;

  const isText = file.type === 'text/plain' || file.name.endsWith('.txt');
  if (isText) {
    handleTextFile(file);
  } else {
    handleAudioFile(file);
  }
}

// ─── Text Intake ───
async function handleTextFile(file) {
  const section = document.getElementById('textSection');
  section.classList.remove('hidden');

  const formData = new FormData();
  formData.append('file', file);

  try {
    const res = await fetch(apiUrl('/api/tqef/upload-text'), { method: 'POST', body: formData });
    const data = await res.json();
    if (!res.ok) { showMsg(data.error || '上傳失敗', 'error'); return; }

    renderSentences(data.sentences);
  } catch (e) {
    showMsg('上傳失敗: ' + e.message, 'error');
  }
}

let sentences = [];

function renderSentences(list) {
  sentences = [...list];
  const ul = document.getElementById('sentenceList');
  document.getElementById('sentenceCount').textContent = `共 ${sentences.length} 句`;
  ul.innerHTML = sentences.map((s, i) =>
    `<li class="sentence-item">
      <span class="sentence-num">${i + 1}</span>
      <span class="sentence-text"><input type="text" value="${s.replace(/"/g, '&quot;')}" data-idx="${i}" /></span>
      <span class="sentence-del" data-idx="${i}">✕</span>
    </li>`
  ).join('');

  // Edit handlers
  ul.querySelectorAll('input').forEach(inp => {
    inp.addEventListener('input', e => { sentences[parseInt(e.target.dataset.idx)] = e.target.value; });
  });
  ul.querySelectorAll('.sentence-del').forEach(btn => {
    btn.addEventListener('click', e => {
      const idx = parseInt(e.target.dataset.idx);
      sentences.splice(idx, 1);
      renderSentences(sentences);
    });
  });

  document.getElementById('btnConfirmText').disabled = sentences.length === 0;
}

document.getElementById('btnConfirmText').addEventListener('click', async () => {
  const validSentences = sentences.filter(s => s.trim());
  if (validSentences.length === 0) return;

  const domain = document.getElementById('selDomain').value;
  const language = document.getElementById('selLang').value;
  const btn = document.getElementById('btnConfirmText');
  btn.disabled = true;
  btn.textContent = '寫入中...';

  try {
    const res = await fetch(apiUrl('/api/tqef/corpus/batch'), {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ sentences: validSentences, domain, language }),
    });
    const data = await res.json();
    if (!res.ok) { showMsg(data.error || '寫入失敗', 'error'); return; }

    showMsg(`成功寫入 ${data.inserted} 筆 corpus 項目`);
    document.getElementById('textSection').classList.add('hidden');
    sentences = [];
    loadCorpusList();
  } catch (e) {
    showMsg('寫入失敗: ' + e.message, 'error');
  } finally {
    btn.disabled = false;
    btn.textContent = '全部確認 → 寫入 Corpus';
  }
});

document.getElementById('btnClearText').addEventListener('click', () => {
  sentences = [];
  document.getElementById('textSection').classList.add('hidden');
});

// ─── Audio Intake ───
async function handleAudioFile(file) {
  const section = document.getElementById('audioSection');
  const statusEl = document.getElementById('audioStatus');
  const resultEl = document.getElementById('audioResult');

  section.classList.remove('hidden');
  resultEl.classList.add('hidden');
  setAudioStatus('processing', `上傳中... (${(file.size / 1024 / 1024).toFixed(1)} MB)`);

  const language = document.getElementById('selLang').value;
  const domain = document.getElementById('selDomain').value;

  const formData = new FormData();
  formData.append('file', file);
  formData.append('language', language);
  formData.append('domain', domain);

  try {
    const res = await fetch(apiUrl('/api/tqef/upload-audio'), { method: 'POST', body: formData });
    const data = await res.json();
    if (!res.ok) { setAudioStatus('failed', data.error || '上傳失敗'); return; }

    currentUploadId = data.upload_id;

    if (data.stt_status === 'done') {
      // Sync engine completed immediately
      showSttResult(data.transcript, data.engine);
    } else if (data.stt_status === 'failed') {
      setAudioStatus('failed', `STT 失敗: ${data.error || '未知錯誤'} (${data.engine})`);
    } else {
      // Async — start polling
      setAudioStatus('processing', `STT 處理中 (${data.engine})...`);
      startPolling(data.upload_id);
    }
  } catch (e) {
    setAudioStatus('failed', '上傳失敗: ' + e.message);
  }
}

function setAudioStatus(status, text) {
  const statusEl = document.getElementById('audioStatus');
  const dotClass = status === 'done' ? 'dot-done' : status === 'failed' ? 'dot-failed' : status === 'processing' ? 'dot-processing' : 'dot-pending';
  statusEl.innerHTML = `<span class="dot ${dotClass}"></span><span>${text}</span>`;
}

function showSttResult(transcript, engine) {
  setAudioStatus('done', `辨識完成 (${engine})`);
  const resultEl = document.getElementById('audioResult');
  resultEl.classList.remove('hidden');
  document.getElementById('correctionArea').value = transcript || '';
  document.getElementById('btnCorrect').disabled = false;
}

function startPolling(uploadId) {
  let attempts = 0;
  const maxAttempts = 60;

  pollTimer = setInterval(async () => {
    attempts++;
    if (attempts > maxAttempts) {
      clearInterval(pollTimer);
      pollTimer = null;
      setAudioStatus('failed', 'STT 逾時（超過 3 分鐘）');
      return;
    }

    try {
      const res = await fetch(apiUrl(`/api/tqef/stt-status/${uploadId}`));
      const data = await res.json();

      if (data.stt_status === 'done') {
        clearInterval(pollTimer);
        pollTimer = null;
        showSttResult(data.transcript, data.engine);
      } else if (data.stt_status === 'failed') {
        clearInterval(pollTimer);
        pollTimer = null;
        setAudioStatus('failed', `STT 失敗 (${data.engine})`);
      }
      // else keep polling
    } catch (e) {
      // Ignore transient errors, keep polling
    }
  }, attempts < 2 ? 2000 : 3000); // First 2s, then 3s
}

document.getElementById('btnCorrect').addEventListener('click', async () => {
  if (!currentUploadId) return;
  const correctedText = document.getElementById('correctionArea').value.trim();
  if (!correctedText) { showMsg('請輸入校正後的文字', 'error'); return; }

  const btn = document.getElementById('btnCorrect');
  btn.disabled = true;
  btn.textContent = '寫入中...';

  try {
    const res = await fetch(apiUrl(`/api/tqef/audio/${currentUploadId}/correct`), {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ corrected_text: correctedText }),
    });
    const data = await res.json();
    if (!res.ok) { showMsg(data.error || '寫入失敗', 'error'); return; }

    showMsg(`成功寫入 corpus (ID: ${data.corpus_id?.slice(0, 8)}...)`);
    document.getElementById('audioSection').classList.add('hidden');
    currentUploadId = null;
    loadCorpusList();
  } catch (e) {
    showMsg('寫入失敗: ' + e.message, 'error');
  } finally {
    btn.disabled = false;
    btn.textContent = '確認校正 → 寫入 Corpus';
  }
});

// ─── Corpus List ───
async function loadCorpusList() {
  try {
    const params = new URLSearchParams();
    const domain = document.getElementById('filterDomain')?.value;
    const origin = document.getElementById('filterOrigin')?.value;
    if (domain) params.set('domain', domain);
    if (origin) params.set('source_origin', origin);
    const qs = params.toString();
    const res = await fetch(apiUrl('/api/tqef/corpus' + (qs ? '?' + qs : '')));
    const data = await res.json();
    const corpus = (data.corpus || []).slice(0, 20);
    const tbody = document.getElementById('corpusBody');

    if (corpus.length === 0) {
      tbody.innerHTML = '<tr><td colspan="7" style="color:#64748b;text-align:center;">尚無資料</td></tr>';
      return;
    }

    tbody.innerHTML = corpus.map(c => {
      const origin = c.source_origin || 'manual';
      const isAudio = origin.includes('audio') || c.has_audio;
      const badgeCls = isAudio ? 'badge-audio' : 'badge-text';
      const badgeText = isAudio ? '音檔' : '文字';
      const text = (c.source_text || c.ground_truth_transcript || '').slice(0, 60);
      return `<tr>
        <td style="font-family:monospace;font-size:0.7rem;color:#64748b;">${(c.id || '').slice(0, 8)}</td>
        <td><span class="badge ${badgeCls}">${badgeText}</span></td>
        <td><span class="badge badge-domain">${c.domain || '—'}</span></td>
        <td>${c.source_lang || '—'}</td>
        <td title="${(text || '').replace(/"/g, '&quot;')}">${text || '—'}</td>
        <td style="font-size:0.75rem;color:#64748b;">${(c.created_at || '').slice(0, 16)}</td>
        <td><button onclick="deleteCorpus('${c.id}')" style="background:none;border:none;color:#f87171;cursor:pointer;font-size:0.75rem;" title="刪除">✕</button></td>
      </tr>`;
    }).join('');
  } catch (e) {
    document.getElementById('corpusBody').innerHTML = '<tr><td colspan="7" style="color:#f87171;">載入失敗</td></tr>';
  }
}

async function deleteCorpus(id) {
  if (!confirm('確定刪除此 corpus 項目？')) return;
  try {
    const res = await fetch(apiUrl(`/api/tqef/corpus/${id}`), { method: 'DELETE' });
    if (!res.ok) throw new Error('Delete failed');
    showMsg('已刪除');
    loadCorpusList();
  } catch (e) {
    showMsg('刪除失敗: ' + e.message, 'error');
  }
}

checkAuth();
</script>

</body>
</html>
