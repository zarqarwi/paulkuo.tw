---
// TQEF Round Detail — per-sentence results
// Usage: /tools/tqef/admin/results/detail/?id=R11
---
<html lang="zh-TW">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>TQEF Round Detail</title>
  <meta name="robots" content="noindex, nofollow" />
  <style is:global>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #0f172a; color: #e2e8f0; min-height: 100vh; }
    .container { max-width: 1400px; margin: 0 auto; padding: 1.5rem; }
    .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; flex-wrap: wrap; gap: 0.5rem; }
    .header h1 { font-size: 1.5rem; }
    .header a { color: #93c5fd; text-decoration: none; font-size: 0.875rem; }
    .summary-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 0.75rem; margin-bottom: 1.5rem; }
    .sum-card { background: #1e293b; border-radius: 8px; padding: 1rem; text-align: center; }
    .sum-label { font-size: 0.7rem; color: #94a3b8; text-transform: uppercase; }
    .sum-val { font-size: 1.5rem; font-weight: 700; }
    .good { color: #4ade80; } .ok { color: #facc15; } .bad { color: #f87171; }
    .table-wrap { overflow-x: auto; }
    .results-table { width: 100%; border-collapse: collapse; font-size: 0.8rem; white-space: nowrap; }
    .results-table th { text-align: left; padding: 0.6rem; border-bottom: 1px solid #334155; color: #94a3b8; font-weight: 500; font-size: 0.7rem; text-transform: uppercase; position: sticky; top: 0; background: #0f172a; cursor: pointer; user-select: none; }
    .results-table th:hover { color: #e2e8f0; }
    .results-table td { padding: 0.6rem; border-bottom: 1px solid #1e293b; vertical-align: top; }
    .results-table tr:hover { background: #1e293b; }
    .src-text { max-width: 250px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: #94a3b8; font-size: 0.75rem; }
    .trans-text { max-width: 350px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .error-badge { display: inline-block; font-size: 0.65rem; padding: 1px 6px; border-radius: 4px; margin: 1px; }
    .err-TERM_ERR { background: #7c3aed33; color: #c4b5fd; }
    .err-UNNATURAL { background: #0ea5e933; color: #67e8f9; }
    .err-DISTORT { background: #f5970033; color: #fdba74; }
    .err-critical { background: #dc262633; color: #fca5a5; }
    .filter-bar { display: flex; gap: 0.5rem; margin-bottom: 1rem; flex-wrap: wrap; }
    .filter-bar select, .filter-bar input { background: #1e293b; border: 1px solid #334155; color: #e2e8f0; padding: 0.4rem 0.75rem; border-radius: 6px; font-size: 0.8rem; }
  </style>
</head>
<body>

<div class="container" id="main" style="display:none">
  <div class="header">
    <h1 id="roundTitle">Round —</h1>
    <div>
      <a href="/tools/tqef/admin/results/">← Rounds</a>
      <a href="/tools/tqef/admin/" style="margin-left:1rem">Dashboard</a>
    </div>
  </div>

  <div id="summaryGrid" class="summary-grid"></div>

  <div class="filter-bar">
    <select id="filterDomain"><option value="">全部領域</option></select>
    <input type="text" id="filterSearch" placeholder="搜尋 ID 或文字..." />
  </div>

  <div class="table-wrap">
    <table class="results-table">
      <thead>
        <tr>
          <th data-sort="sentence_id">ID</th>
          <th data-sort="domain">Domain</th>
          <th>Source</th>
          <th>Translation</th>
          <th data-sort="l2_term">Term</th>
          <th data-sort="l2_fluency">Fluency</th>
          <th data-sort="l2_context">Context</th>
          <th data-sort="l2_format">Format</th>
          <th data-sort="overall">Overall</th>
          <th>Errors</th>
        </tr>
      </thead>
      <tbody id="resultsBody"></tbody>
    </table>
  </div>
</div>

<script is:inline>
const API = 'https://api.paulkuo.tw';
const code = sessionStorage.getItem('tqef_code') || new URLSearchParams(window.location.search).get('key') || '';
if (!code) { window.location.href = '/tools/tqef/admin/'; }

const roundId = new URLSearchParams(window.location.search).get('id') || '';
if (!roundId) { window.location.href = '/tools/tqef/admin/results/'; }

function sc(v) { return v >= 4.5 ? 'good' : v >= 4.0 ? 'ok' : 'bad'; }

let allResults = [];
let sortKey = 'sentence_id';
let sortAsc = true;

function avg(r) {
  const vals = [r.l2_term, r.l2_fluency, r.l2_context, r.l2_format].filter(v => v != null);
  return vals.length ? vals.reduce((a,b)=>a+b,0)/vals.length : null;
}

function esc(s) { return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

function renderTable() {
  const domain = document.getElementById('filterDomain').value;
  const search = document.getElementById('filterSearch').value.toLowerCase();

  let filtered = allResults;
  if (domain) filtered = filtered.filter(r => r.domain === domain);
  if (search) filtered = filtered.filter(r =>
    (r.sentence_id||'').toLowerCase().includes(search) ||
    (r.translation||'').toLowerCase().includes(search) ||
    (r.source_text||'').toLowerCase().includes(search)
  );

  filtered.sort((a, b) => {
    let va = sortKey === 'overall' ? avg(a) : a[sortKey];
    let vb = sortKey === 'overall' ? avg(b) : b[sortKey];
    if (va == null) return 1; if (vb == null) return -1;
    if (typeof va === 'string') return sortAsc ? va.localeCompare(vb) : vb.localeCompare(va);
    return sortAsc ? va - vb : vb - va;
  });

  document.getElementById('resultsBody').innerHTML = filtered.map(r => {
    let errors = [];
    try { const n = typeof r.notes === 'string' ? JSON.parse(r.notes) : r.notes; errors = n?.errors || []; } catch(e) {}
    const overall = avg(r);
    return `<tr>
      <td>${r.sentence_id}</td>
      <td>${(r.domain||'').replace(/_/g,' ')}</td>
      <td class="src-text" title="${esc(r.source_text)}">${esc((r.source_text||'').slice(0,50))}</td>
      <td class="trans-text" title="${esc(r.translation)}">${esc((r.translation||'').slice(0,70))}</td>
      <td class="${sc(r.l2_term)}">${r.l2_term ?? '—'}</td>
      <td class="${sc(r.l2_fluency)}">${r.l2_fluency ?? '—'}</td>
      <td class="${sc(r.l2_context)}">${r.l2_context ?? '—'}</td>
      <td class="${sc(r.l2_format)}">${r.l2_format ?? '—'}</td>
      <td class="${sc(overall)}"><strong>${overall?.toFixed(1) ?? '—'}</strong></td>
      <td>${errors.map(e => `<span class="error-badge err-${e.type||'critical'}">${e.type||'ERR'} ${e.severity||''}</span>`).join(' ')}</td>
    </tr>`;
  }).join('');
}

document.querySelectorAll('th[data-sort]').forEach(th => {
  th.onclick = () => {
    const key = th.dataset.sort;
    if (sortKey === key) sortAsc = !sortAsc;
    else { sortKey = key; sortAsc = key === 'sentence_id'; }
    renderTable();
  };
});
document.getElementById('filterDomain').onchange = () => renderTable();
document.getElementById('filterSearch').oninput = () => renderTable();

(async () => {
  const res = await fetch(API + '/api/tqef/rounds/' + encodeURIComponent(roundId) + '?code=' + encodeURIComponent(code));
  if (res.status === 403) { window.location.href = '/tools/tqef/admin/'; return; }
  if (res.status === 404) { alert('Round not found'); window.location.href = '/tools/tqef/admin/results/'; return; }
  const data = await res.json();
  const round = data.round;
  allResults = data.results || [];

  document.getElementById('main').style.display = 'block';
  document.title = `TQEF ${round.round_id}`;
  document.getElementById('roundTitle').textContent = `Round ${round.round_id}`;

  // Summary cards
  const items = [
    { label: 'Overall', value: round.l2_overall },
    { label: 'Terminology', value: round.l2_term },
    { label: 'Fluency', value: round.l2_fluency },
    { label: 'Context', value: round.l2_context },
    { label: 'Format', value: round.l2_format },
    { label: 'Critical', value: round.l2_critical_errors, isCrit: true },
  ];
  document.getElementById('summaryGrid').innerHTML = items.map(m => {
    const cls = m.isCrit ? (m.value === 0 ? 'good' : 'bad') : sc(m.value);
    const display = m.isCrit ? m.value : (m.value?.toFixed(2) || '—');
    return `<div class="sum-card"><div class="sum-label">${m.label}</div><div class="sum-val ${cls}">${display}</div></div>`;
  }).join('');

  // Domain filter
  const domains = [...new Set(allResults.map(r => r.domain).filter(Boolean))].sort();
  const sel = document.getElementById('filterDomain');
  domains.forEach(d => { const o = document.createElement('option'); o.value = d; o.textContent = d.replace(/_/g, ' '); sel.appendChild(o); });

  renderTable();
})();
</script>

</body>
</html>
