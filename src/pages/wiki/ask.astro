---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="知識問答 — Paul Kuo" description="向 Paul Kuo 的個人知識庫提問">
  <style>
    * {
      box-sizing: border-box;
    }

    .container {
      max-width: 800px;
      margin: 0 auto;
      padding: 2rem 1.5rem;
    }

    .breadcrumb {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-bottom: 2.5rem;
      font-size: 0.875rem;
      color: var(--text-secondary);
    }

    .breadcrumb a {
      color: var(--accent-ai);
      text-decoration: none;
    }

    .breadcrumb a:hover {
      text-decoration: underline;
    }

    /* Search box */
    .search-wrap {
      display: flex;
      gap: 0.75rem;
      margin-bottom: 1.5rem;
    }

    .search-input {
      flex: 1;
      padding: 0.875rem 1.25rem;
      border: 1px solid var(--border);
      border-radius: 0.75rem;
      background-color: var(--bg-card);
      color: var(--text-primary);
      font-size: 1rem;
      font-family: system-ui, -apple-system, sans-serif;
      transition: border-color 0.2s;
    }

    .search-input:focus {
      outline: none;
      border-color: var(--accent-ai);
    }

    .ask-btn {
      padding: 0.875rem 1.5rem;
      background-color: var(--accent-ai);
      color: white;
      border: none;
      border-radius: 0.75rem;
      font-weight: 600;
      font-size: 0.95rem;
      cursor: pointer;
      transition: background-color 0.2s;
      white-space: nowrap;
    }

    .ask-btn:hover:not(:disabled) {
      background-color: #1d4ed8;
    }

    .ask-btn:disabled {
      opacity: 0.6;
      cursor: not-allowed;
    }

    /* Spinner */
    .spinner-wrap {
      display: none;
      align-items: center;
      gap: 0.625rem;
      margin-bottom: 1.5rem;
      color: var(--text-secondary);
      font-size: 0.9rem;
    }

    .spinner-wrap.visible {
      display: flex;
    }

    .spinner {
      width: 18px;
      height: 18px;
      border: 2px solid var(--border);
      border-top-color: var(--accent-ai);
      border-radius: 50%;
      animation: spin 0.7s linear infinite;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    /* Example chips */
    .example-section {
      margin-bottom: 2rem;
    }

    .example-label {
      font-size: 0.8rem;
      color: var(--text-secondary);
      margin-bottom: 0.625rem;
    }

    .chips-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .example-chip {
      padding: 0.5rem 0.875rem;
      border: 1px solid var(--border);
      border-radius: 1.5rem;
      font-size: 0.875rem;
      color: var(--text-secondary);
      background: transparent;
      cursor: pointer;
      transition: border-color 0.2s, color 0.2s;
    }

    .example-chip:hover {
      border-color: var(--accent-ai);
      color: var(--accent-ai);
    }

    /* Answer section */
    #answerSection {
      display: none;
    }

    #answerSection.visible {
      display: block;
    }

    .answer-question {
      font-size: 1.375rem;
      font-weight: 700;
      color: var(--text-primary);
      margin: 0 0 1.25rem 0;
    }

    .answer-body {
      font-size: 1rem;
      line-height: 1.75;
      color: var(--text-primary);
      margin-bottom: 1.75rem;
    }

    :global(.answer-body a) {
      color: var(--accent-ai);
      text-decoration: underline;
    }

    :global(.answer-body a:hover) {
      opacity: 0.8;
    }

    /* Sources */
    .sources-section {
      margin-bottom: 1.5rem;
    }

    .section-label {
      font-size: 0.8rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--text-secondary);
      margin-bottom: 0.625rem;
    }

    .source-chip {
      display: inline-block;
      padding: 0.375rem 0.75rem;
      border: 1px solid var(--border);
      border-radius: 0.5rem;
      font-size: 0.875rem;
      color: var(--text-primary);
      text-decoration: none;
      margin: 0 0.375rem 0.375rem 0;
      transition: border-color 0.2s;
    }

    .source-chip:hover {
      border-color: var(--accent-ai);
      color: var(--accent-ai);
    }

    /* Follow-up */
    .followup-section {
      margin-bottom: 1.5rem;
    }

    .followup-chip {
      display: inline-block;
      padding: 0.5rem 0.875rem;
      background-color: rgba(37, 99, 235, 0.08);
      border: 1px solid rgba(37, 99, 235, 0.25);
      border-radius: 1.5rem;
      font-size: 0.875rem;
      color: var(--accent-ai);
      cursor: pointer;
      margin: 0 0.375rem 0.375rem 0;
      transition: background-color 0.2s;
    }

    .followup-chip:hover {
      background-color: rgba(37, 99, 235, 0.18);
    }

    /* Error */
    .error-box {
      padding: 0.875rem 1rem;
      background-color: #fee2e2;
      border: 1px solid #fecaca;
      border-radius: 0.75rem;
      color: #991b1b;
      font-size: 0.875rem;
      margin-bottom: 1.25rem;
    }

    html[data-theme="dark"] .error-box {
      background-color: #7c2d12;
      border-color: #92400e;
      color: #fed7aa;
    }

    /* Divider */
    .answer-divider {
      border: none;
      border-top: 1px solid var(--border);
      margin: 1.75rem 0;
    }

    @media (max-width: 768px) {
      .container {
        padding: 1.5rem 1rem;
      }

      .search-wrap {
        flex-direction: column;
      }

      .ask-btn {
        width: 100%;
      }
    }
  </style>

  <div class="container">
    <!-- Breadcrumb -->
    <nav class="breadcrumb">
      <a href="/">首頁</a>
      <span>/</span>
      <a href="/wiki/">知識圖譜</a>
      <span>/</span>
      <span>知識問答</span>
    </nav>

    <!-- Search box -->
    <div class="search-wrap">
      <input
        type="text"
        id="questionInput"
        class="search-input"
        placeholder="輸入你的問題，例如：AI 時代需要什麼能力？"
        autocomplete="off"
      />
      <button class="ask-btn" id="askBtn">問</button>
    </div>

    <!-- Spinner -->
    <div class="spinner-wrap" id="spinnerWrap">
      <div class="spinner"></div>
      <span>搜尋中…</span>
    </div>

    <!-- Example chips (hidden after first question) -->
    <div class="example-section" id="exampleSection">
      <p class="example-label">範例問題</p>
      <div class="chips-row">
        <button class="example-chip" data-q="什麼是 AI Agent 經濟？">什麼是 AI Agent 經濟？</button>
        <button class="example-chip" data-q="Paul 怎麼看一人公司？">Paul 怎麼看一人公司？</button>
        <button class="example-chip" data-q="循環經濟在台灣怎麼實踐？">循環經濟在台灣怎麼實踐？</button>
        <button class="example-chip" data-q="AI 時代需要什麼能力？">AI 時代需要什麼能力？</button>
      </div>
    </div>

    <!-- Answer section -->
    <div id="answerSection">
      <hr class="answer-divider" />
      <h2 class="answer-question" id="answerQuestion"></h2>
      <div class="answer-body" id="answerBody"></div>

      <!-- Sources -->
      <div class="sources-section" id="sourcesSection">
        <p class="section-label">來源</p>
        <div id="sourcesChips"></div>
      </div>

      <!-- Follow-up -->
      <div class="followup-section" id="followupSection">
        <p class="section-label">繼續探索</p>
        <div id="followupChips"></div>
      </div>
    </div>
  </div>

  <script is:inline>
    const API_URL = 'https://api.paulkuo.tw/api/wiki/ask';

    const questionInput = document.getElementById('questionInput');
    const askBtn = document.getElementById('askBtn');
    const spinnerWrap = document.getElementById('spinnerWrap');
    const exampleSection = document.getElementById('exampleSection');
    const answerSection = document.getElementById('answerSection');
    const answerQuestion = document.getElementById('answerQuestion');
    const answerBody = document.getElementById('answerBody');
    const sourcesSection = document.getElementById('sourcesSection');
    const sourcesChips = document.getElementById('sourcesChips');
    const followupSection = document.getElementById('followupSection');
    const followupChips = document.getElementById('followupChips');

    let exampleHidden = false;

    // Convert [[slug]] to blue anchor links
    function convertSlugsToLinks(text) {
      const slugPattern = /\[\[([^\]]+)\]\]/g;
      const container = document.createElement('span');
      let lastIndex = 0;

      const matches = Array.from(text.matchAll(slugPattern));

      if (matches.length === 0) {
        container.textContent = text;
        return container;
      }

      matches.forEach((match) => {
        const slug = match[1];
        const before = text.substring(lastIndex, match.index);
        if (before) {
          container.appendChild(document.createTextNode(before));
        }
        const a = document.createElement('a');
        a.href = `/wiki/${slug}/`;
        a.textContent = slug;
        container.appendChild(a);
        lastIndex = match.index + match[0].length;
      });

      const remaining = text.substring(lastIndex);
      if (remaining) {
        container.appendChild(document.createTextNode(remaining));
      }

      return container;
    }

    async function submitQuestion(question) {
      if (!question) return;

      // Hide examples permanently on first submit
      if (!exampleHidden) {
        exampleSection.style.display = 'none';
        exampleHidden = true;
      }

      // UI state
      askBtn.disabled = true;
      spinnerWrap.classList.add('visible');
      answerSection.classList.remove('visible');

      try {
        const response = await fetch(API_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ question }),
        });

        if (!response.ok) throw new Error(`API error: ${response.status}`);

        const data = await response.json();

        // Render question
        answerQuestion.textContent = question;

        // Render answer body
        answerBody.innerHTML = '';
        const converted = convertSlugsToLinks(data.answer || '');
        answerBody.appendChild(converted);

        // Sources
        const sources = data.sources || [];
        if (sources.length > 0) {
          sourcesChips.innerHTML = '';
          sources.forEach((src) => {
            const a = document.createElement('a');
            a.href = `/wiki/${src.slug}/`;
            a.className = 'source-chip';
            a.textContent = '🔗 ' + src.title;
            sourcesChips.appendChild(a);
          });
          sourcesSection.style.display = '';
        } else {
          sourcesSection.style.display = 'none';
        }

        // Follow-up
        const related = (data.related_concepts || []).slice(0, 3);
        if (related.length > 0) {
          followupChips.innerHTML = '';
          related.forEach((concept) => {
            const btn = document.createElement('button');
            btn.className = 'followup-chip';
            btn.textContent = '什麼是 ' + concept.title + '？';
            btn.addEventListener('click', () => {
              const q = '什麼是 ' + concept.title + '？';
              questionInput.value = q;
              submitQuestion(q);
            });
            followupChips.appendChild(btn);
          });
          followupSection.style.display = '';
        } else {
          followupSection.style.display = 'none';
        }

        answerSection.classList.add('visible');
      } catch (err) {
        // Show error inside answer area
        answerQuestion.textContent = question;
        answerBody.innerHTML = '';
        const errBox = document.createElement('div');
        errBox.className = 'error-box';
        errBox.textContent = '發生錯誤，請稍後再試。' + (err.message ? ` (${err.message})` : '');
        answerBody.appendChild(errBox);
        sourcesSection.style.display = 'none';
        followupSection.style.display = 'none';
        answerSection.classList.add('visible');
      } finally {
        spinnerWrap.classList.remove('visible');
        askBtn.disabled = false;
        questionInput.focus();
      }
    }

    // Submit handlers
    askBtn.addEventListener('click', () => submitQuestion(questionInput.value.trim()));

    questionInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        submitQuestion(questionInput.value.trim());
      }
    });

    // Example chip handlers
    document.querySelectorAll('.example-chip').forEach((chip) => {
      chip.addEventListener('click', () => {
        const q = chip.dataset.q;
        questionInput.value = q;
        submitQuestion(q);
      });
    });

    // Initial focus
    questionInput.focus();
  </script>
</BaseLayout>
