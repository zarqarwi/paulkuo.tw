---
/**
 * /wiki/[slug] — Wiki 概念頁
 * Phase 2A (routing) + 2C (rendering)
 * Only builds public concept pages.
 *
 * Visibility filter rules: see docs/wiki-visibility-rules.md (SSOT).
 */
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { PILLAR_MAP, SITE } from '../../config';

export async function getStaticPaths() {
  const concepts = await getCollection('wiki_concepts', ({ data }) => data.visibility === 'public');
  const entities = await getCollection('wiki_entities', ({ data }) => data.visibility === 'public');
  const allSources = await getCollection('wiki_sources');

  // Merge concepts + entities as routable wiki pages
  const allPages = [...concepts, ...entities];

  // Load graph for mini graph
  const graphRaw = await import('../../content/wiki/meta/graph.json');

  return allPages.map((page) => {
    const slug = page.data.slug || page.id.replace(/\.md$/, '');

    // Find sources that link to this page
    const linkedSources = allSources.filter(s =>
      s.data.links_to.includes(slug)
    );
    const publicSources = linkedSources.filter(s => s.data.visibility === 'public');
    const internalCount = linkedSources.length - publicSources.length;

    // Find linked concepts/entities (from links_to field, only public)
    const linkedConcepts = page.data.links_to
      .map(id => allPages.find(c => (c.data.slug || c.id.replace(/\.md$/, '')) === id))
      .filter(Boolean);

    // Build mini graph (1-hop from this page, public only)
    const miniNodes = graphRaw.default.nodes.filter((n: any) => {
      if (n.visibility !== 'public') return false;
      if (n.id === slug) return true;
      return graphRaw.default.edges.some((e: any) =>
        (e.source === slug && e.target === n.id) || (e.target === slug && e.source === n.id)
      );
    });
    const miniNodeIds = new Set(miniNodes.map((n: any) => n.id));
    const miniEdges = graphRaw.default.edges.filter((e: any) =>
      miniNodeIds.has(e.source) && miniNodeIds.has(e.target)
    );

    return {
      params: { slug },
      props: {
        concept: page,
        publicSources,
        internalCount,
        linkedConcepts,
        miniGraph: { nodes: miniNodes, edges: miniEdges },
      },
    };
  });
}

const { concept, publicSources, internalCount, linkedConcepts, miniGraph } = Astro.props;
const slug = concept.data.slug || concept.id.replace(/\.md$/, '');
const { Content } = await render(concept);
const { title, pillar, confidence, source_count, tags } = concept.data;
const p = PILLAR_MAP[pillar as keyof typeof PILLAR_MAP];

const PILLAR_COLORS: Record<string, string> = {
  ai: '#2563eb',
  circular: '#059669',
  faith: '#b45309',
  startup: '#dc2626',
  life: '#7c3aed',
};
const pillarColor = PILLAR_COLORS[pillar] || '#64748b';

// Group sources by type
const sourcesByType = new Map<string, typeof publicSources>();
for (const s of publicSources) {
  const t = s.data.raw_source_type || 'other';
  if (!sourcesByType.has(t)) sourcesByType.set(t, []);
  sourcesByType.get(t)!.push(s);
}
const sourceTypeIcons: Record<string, string> = {
  article: '\u{1F4C4}',
  getnote: '\u{1F4DD}',
  clip: '\u{1F310}',
  get_note: '\u{1F4DD}',
};
const sourceTypeLabels: Record<string, string> = {
  article: '文章',
  getnote: '筆記',
  clip: '剪報',
  get_note: '筆記',
};

// JSON-LD
const schemaJson = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'DefinedTerm',
  name: title,
  description: concept.body ? concept.body.replace(/\[\[([^\]|]+\|)?([^\]]+)\]\]/g, '$2').slice(0, 200) : title,
  url: `${SITE.url}/wiki/${slug}/`,
  inDefinedTermSet: {
    '@type': 'DefinedTermSet',
    name: 'Paul Kuo 知識圖譜',
    url: `${SITE.url}/wiki/`,
  },
});
---

<BaseLayout
  title={`${title} — 知識圖譜`}
  description={`Paul Kuo 知識圖譜：${title}。${source_count} 篇來源引用，屬於「${p.label}」支柱。`}
  ogUrl={`${SITE.url}/wiki/${slug}/`}
  ogImage={`${SITE.url}/og/wiki/${slug}.png`}
  schemaJson={schemaJson}
>
  <article class="wiki-concept-page">
    <nav class="wiki-breadcrumb" aria-label="breadcrumb">
      <a href="/">首頁</a> <span aria-hidden="true">›</span>
      <a href="/wiki/">知識圖譜</a> <span aria-hidden="true">›</span>
      <span>{title}</span>
    </nav>

    <header class="concept-header">
      <h1 class="concept-title">{title}</h1>
      <div class="concept-meta">
        <span class="concept-pillar-badge" style={`color: ${pillarColor}; border-color: ${pillarColor}40; background: ${pillarColor}10;`}>
          {p.label}
        </span>
        {confidence && (
          <span class={`concept-confidence concept-confidence-${confidence}`}>
            {confidence}
          </span>
        )}
        {source_count > 0 && (
          <span class="concept-source-count">{source_count} 篇來源引用</span>
        )}
      </div>
      {tags.length > 0 && (
        <div class="concept-tags">
          {tags.map(tag => (
            <span class="concept-tag">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <div class="wiki-share-bar">
      <button class="share-btn share-copy" data-url={`${SITE.url}/wiki/${slug}/`}>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
        複製連結
      </button>
      <a class="share-btn" href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(SITE.url + '/wiki/' + slug + '/')}&text=${encodeURIComponent(title + ' — Paul Kuo 知識圖譜')}`} target="_blank" rel="noopener">
        X
      </a>
      <a class="share-btn" href={`https://social-plugins.line.me/lineit/share?url=${encodeURIComponent(SITE.url + '/wiki/' + slug + '/')}`} target="_blank" rel="noopener">
        LINE
      </a>
      <a class="share-btn" href={`https://www.threads.net/intent/post?text=${encodeURIComponent(title + ' ' + SITE.url + '/wiki/' + slug + '/')}`} target="_blank" rel="noopener">
        Threads
      </a>
    </div>

    <div class="concept-body">
      <Content />
    </div>

    <!-- Source References -->
    {publicSources.length > 0 && (
      <section class="concept-sources">
        <h2>來源引用（{publicSources.length} 篇）</h2>
        {Array.from(sourcesByType.entries()).map(([type, sources]) => (
          <div class="source-type-group">
            <h3 class="source-type-label">
              {sourceTypeIcons[type] || '\u{1F4C1}'} {sourceTypeLabels[type] || type}（{sources.length}）
            </h3>
            <ul class="source-list">
              {sources.map(s => {
                const isArticle = s.data.raw_source_type === 'article';
                const articleSlug = isArticle ? (s.data.slug || s.id.replace(/\.md$/, '')).replace(/^article-/, '') : null;
                return (
                <li class="source-item">
                  {isArticle && articleSlug ? (
                    <a href={`/articles/${articleSlug}/`} class="source-title source-link">{s.data.title}</a>
                  ) : (
                    <span class="source-title">{s.data.title}</span>
                  )}
                  {s.data.pillar !== pillar && (
                    <span class="source-pillar" style={`color: ${PILLAR_COLORS[s.data.pillar] || '#64748b'};`}>
                      {PILLAR_MAP[s.data.pillar as keyof typeof PILLAR_MAP]?.label}
                    </span>
                  )}
                </li>
                );
              })}
            </ul>
          </div>
        ))}
        {internalCount > 0 && (
          <p class="source-internal-note">另有 {internalCount} 篇 internal 來源未公開顯示。</p>
        )}
      </section>
    )}

    <!-- Related Concepts -->
    {linkedConcepts.length > 0 && (
      <section class="concept-related">
        <h2>延伸連結</h2>
        <div class="related-grid">
          {linkedConcepts.map((c: any) => {
            const cSlug = c.data.slug || c.id.replace(/\.md$/, '');
            const cColor = PILLAR_COLORS[c.data.pillar] || '#64748b';
            return (
              <a href={`/wiki/${cSlug}/`} class="related-card">
                <span class="related-dot" style={`background: ${cColor};`}></span>
                <span class="related-title">{c.data.title}</span>
                {c.data.source_count > 0 && (
                  <span class="related-count">{c.data.source_count} 篇</span>
                )}
              </a>
            );
          })}
        </div>
      </section>
    )}

    <!-- Mini Graph -->
    {miniGraph.nodes.length > 1 && (
      <section class="concept-mini-graph">
        <h2>概念關聯圖</h2>
        <div id="mini-graph-stage" class="mini-graph-stage" role="img" aria-label={`${title} 的關聯概念視覺化`}></div>
      </section>
    )}
  </article>
</BaseLayout>

<script is:inline define:vars={{ miniGraph, slug: slug, PILLAR_COLORS }}>
// === Mini Graph — simplified 2D force layout ===
(function() {
  var stage = document.getElementById('mini-graph-stage');
  if (!stage || !miniGraph || miniGraph.nodes.length <= 1) return;

  var canvas = document.createElement('canvas');
  canvas.style.cssText = 'width:100%;height:100%;display:block;';
  stage.appendChild(canvas);
  var ctx = canvas.getContext('2d');

  var W = 0, H = 0;
  function resize() {
    var rect = stage.getBoundingClientRect();
    W = rect.width; H = rect.height;
    canvas.width = W * devicePixelRatio;
    canvas.height = H * devicePixelRatio;
    ctx.setTransform(devicePixelRatio, 0, 0, devicePixelRatio, 0, 0);
  }
  resize();

  var nodes = miniGraph.nodes.map(function(n, i) {
    var isCurrent = n.id === slug;
    return {
      id: n.id, title: n.title, type: n.type, pillar: n.pillar,
      x: isCurrent ? 0 : (Math.random() - 0.5) * 300,
      y: isCurrent ? 0 : (Math.random() - 0.5) * 200,
      vx: 0, vy: 0,
      radius: isCurrent ? 12 : (n.type === 'concept' ? 7 : 3),
      isCurrent: isCurrent,
    };
  });

  var byId = new Map(nodes.map(function(n) { return [n.id, n]; }));
  var edges = miniGraph.edges.map(function(e) {
    return { source: byId.get(e.source), target: byId.get(e.target) };
  }).filter(function(e) { return e.source && e.target; });

  function simulate() {
    for (var i = 0; i < nodes.length; i++) {
      for (var j = i + 1; j < nodes.length; j++) {
        var a = nodes[i], b = nodes[j];
        var dx = a.x - b.x, dy = a.y - b.y;
        var d2 = dx * dx + dy * dy + 1;
        var f = 2000 / d2;
        var inv = 1 / Math.sqrt(d2);
        a.vx += dx * inv * f * 0.3; a.vy += dy * inv * f * 0.3;
        b.vx -= dx * inv * f * 0.3; b.vy -= dy * inv * f * 0.3;
      }
    }
    for (var i = 0; i < edges.length; i++) {
      var a = edges[i].source, b = edges[i].target;
      var dx = b.x - a.x, dy = b.y - a.y;
      var d = Math.sqrt(dx * dx + dy * dy) || 1;
      var target = 80;
      var f = (d - target) * 0.03 * 0.3;
      a.vx += dx / d * f; a.vy += dy / d * f;
      b.vx -= dx / d * f; b.vy -= dy / d * f;
    }
    for (var i = 0; i < nodes.length; i++) {
      nodes[i].vx *= 0.82; nodes[i].vy *= 0.82;
      nodes[i].x += nodes[i].vx; nodes[i].y += nodes[i].vy;
    }
  }

  function draw() {
    ctx.clearRect(0, 0, W, H);
    ctx.save();
    ctx.translate(W / 2, H / 2);

    // Edges
    ctx.strokeStyle = '#cbd5e1';
    ctx.lineWidth = 0.8;
    ctx.globalAlpha = 0.4;
    for (var i = 0; i < edges.length; i++) {
      ctx.beginPath();
      ctx.moveTo(edges[i].source.x, edges[i].source.y);
      ctx.lineTo(edges[i].target.x, edges[i].target.y);
      ctx.stroke();
    }

    // Nodes
    ctx.globalAlpha = 1;
    for (var i = 0; i < nodes.length; i++) {
      var n = nodes[i];
      var color = PILLAR_COLORS[n.pillar] || '#64748b';
      ctx.beginPath();
      ctx.arc(n.x, n.y, n.radius, 0, Math.PI * 2);
      ctx.fillStyle = n.type === 'source' ? color + '60' : color;
      ctx.fill();

      if (n.isCurrent) {
        ctx.strokeStyle = '#f59e0b';
        ctx.lineWidth = 2;
        ctx.beginPath();
        ctx.arc(n.x, n.y, n.radius + 3, 0, Math.PI * 2);
        ctx.stroke();
      }

      // Labels for concepts
      if (n.type === 'concept') {
        ctx.fillStyle = '#0f172a';
        ctx.font = n.isCurrent ? 'bold 12px system-ui' : '11px system-ui';
        ctx.textAlign = 'center';
        ctx.fillText(n.title, n.x, n.y - n.radius - 5);
      }
    }

    ctx.restore();
  }

  // Click to navigate
  canvas.style.cursor = 'default';
  canvas.addEventListener('click', function(e) {
    var rect = canvas.getBoundingClientRect();
    var mx = e.clientX - rect.left - W / 2;
    var my = e.clientY - rect.top - H / 2;
    for (var i = 0; i < nodes.length; i++) {
      var n = nodes[i];
      if (n.type !== 'concept' || n.isCurrent) continue;
      var dx = n.x - mx, dy = n.y - my;
      if (Math.sqrt(dx * dx + dy * dy) < n.radius + 8) {
        window.location.href = '/wiki/' + n.id + '/';
        return;
      }
    }
  });

  canvas.addEventListener('mousemove', function(e) {
    var rect = canvas.getBoundingClientRect();
    var mx = e.clientX - rect.left - W / 2;
    var my = e.clientY - rect.top - H / 2;
    var hit = false;
    for (var i = 0; i < nodes.length; i++) {
      var n = nodes[i];
      if (n.type !== 'concept' || n.isCurrent) continue;
      var dx = n.x - mx, dy = n.y - my;
      if (Math.sqrt(dx * dx + dy * dy) < n.radius + 8) { hit = true; break; }
    }
    canvas.style.cursor = hit ? 'pointer' : 'default';
  });

  var count = 0;
  function frame() {
    count++;
    if (count < 300) simulate(); // Stop after stabilization
    draw();
    if (count < 300) requestAnimationFrame(frame);
  }
  frame();
})();
</script>

<style>
  .wiki-concept-page {
    max-width: 780px;
    margin: 2rem auto;
    padding: 0 1.2rem;
  }
  .wiki-breadcrumb {
    font-size: 0.82rem;
    color: var(--text-secondary, #64748b);
    margin-bottom: 1rem;
  }
  .wiki-breadcrumb a { color: var(--text-secondary, #64748b); text-decoration: none; }
  .wiki-breadcrumb a:hover { color: var(--accent-ai, #2563eb); }

  .concept-header { margin-bottom: 2rem; }
  .concept-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--text-primary, #0f172a);
    margin: 0 0 0.6rem;
    line-height: 1.3;
  }
  .concept-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.6rem;
  }
  .concept-pillar-badge {
    font-size: 0.75rem;
    padding: 0.1rem 0.4rem;
    border-radius: 999px;
    border: 1px solid;
    font-weight: 600;
  }
  .concept-confidence {
    font-size: 0.68rem;
    padding: 0.08rem 0.3rem;
    border-radius: 999px;
    border: 1px solid;
  }
  .concept-confidence-high { color: #059669; border-color: #a7f3d0; background: #ecfdf5; }
  .concept-confidence-medium { color: #d97706; border-color: #fde68a; background: #fffbeb; }
  .concept-confidence-low { color: #64748b; border-color: #e2e8f0; background: #f8fafc; }
  .concept-source-count {
    font-size: 0.78rem;
    color: var(--text-secondary, #64748b);
  }
  .concept-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }
  .concept-tag {
    font-size: 0.72rem;
    padding: 0.08rem 0.35rem;
    border-radius: 999px;
    border: 1px solid var(--border, #e2e8f0);
    background: var(--bg-subtle, #f8fafc);
    color: var(--text-secondary, #64748b);
  }

  /* Body — rendered markdown */
  .concept-body {
    line-height: 1.8;
    color: var(--text-primary, #1e293b);
    font-size: 0.95rem;
    margin-bottom: 2rem;
  }
  .concept-body :global(h2) {
    font-size: 1.2rem;
    font-weight: 700;
    margin: 1.8rem 0 0.6rem;
    color: var(--text-primary, #0f172a);
    border-bottom: 1px solid var(--border, #e2e8f0);
    padding-bottom: 0.3rem;
  }
  .concept-body :global(h3) {
    font-size: 1.05rem;
    font-weight: 600;
    margin: 1.4rem 0 0.4rem;
    color: var(--text-primary, #0f172a);
  }
  .concept-body :global(p) {
    margin: 0.6rem 0;
  }
  .concept-body :global(strong) {
    color: var(--text-primary, #0f172a);
  }
  .concept-body :global(a) {
    color: var(--accent-ai, #2563eb);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .concept-body :global(ul), .concept-body :global(ol) {
    padding-left: 1.4rem;
    margin: 0.6rem 0;
  }
  .concept-body :global(li) {
    margin: 0.3rem 0;
  }
  /* Wikilinks — routable concepts/entities */
  .concept-body :global(a.wikilink) {
    color: var(--accent-ai, #2563eb);
    text-decoration: underline;
    text-decoration-style: dotted;
    text-underline-offset: 2px;
  }
  .concept-body :global(a.wikilink:hover) {
    text-decoration-style: solid;
  }
  /* Wikilinks — known but non-routable (sources etc.) */
  .concept-body :global(.wikilink-ref) {
    color: var(--text-secondary, #64748b);
    font-style: italic;
  }
  /* Wikilinks — unknown slug */
  .concept-body :global(.wikilink-missing) {
    color: var(--text-secondary, #94a3b8);
    background: var(--bg-subtle, #f8fafc);
    padding: 0 0.15rem;
    border-radius: 2px;
    border-bottom: 1px dashed #cbd5e1;
  }

  /* Sources */
  .concept-sources {
    margin-bottom: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border, #e2e8f0);
  }
  .concept-sources h2 {
    font-size: 1.15rem;
    font-weight: 700;
    margin: 0 0 0.8rem;
    color: var(--text-primary, #0f172a);
  }
  .source-type-group { margin-bottom: 1rem; }
  .source-type-label {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--text-secondary, #475569);
    margin: 0 0 0.4rem;
  }
  .source-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .source-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0;
    border-bottom: 1px solid var(--border, #f1f5f9);
    font-size: 0.85rem;
  }
  .source-title {
    color: var(--text-primary, #1e293b);
    flex: 1;
  }
  .source-link {
    color: var(--accent-ai, #2563eb);
    text-decoration: none;
  }
  .source-link:hover {
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .source-pillar {
    font-size: 0.7rem;
    white-space: nowrap;
  }
  .source-internal-note {
    font-size: 0.8rem;
    color: var(--text-secondary, #94a3b8);
    font-style: italic;
    margin-top: 0.5rem;
  }

  /* Related concepts */
  .concept-related {
    margin-bottom: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border, #e2e8f0);
  }
  .concept-related h2 {
    font-size: 1.15rem;
    font-weight: 700;
    margin: 0 0 0.8rem;
    color: var(--text-primary, #0f172a);
  }
  .related-grid {
    display: grid;
    gap: 0.4rem;
  }
  .related-card {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.7rem;
    border: 1px solid var(--border, #e2e8f0);
    border-radius: 0.5rem;
    text-decoration: none;
    color: var(--text-primary, #0f172a);
    transition: border-color 0.15s;
  }
  .related-card:hover {
    border-color: var(--accent-ai, #2563eb);
  }
  .related-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 999px;
    flex-shrink: 0;
  }
  .related-title { font-weight: 600; font-size: 0.88rem; flex: 1; }
  .related-count {
    font-size: 0.72rem;
    color: var(--text-secondary, #64748b);
  }

  /* Mini graph */
  .concept-mini-graph {
    margin-bottom: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border, #e2e8f0);
  }
  .concept-mini-graph h2 {
    font-size: 1.15rem;
    font-weight: 700;
    margin: 0 0 0.8rem;
    color: var(--text-primary, #0f172a);
  }
  .mini-graph-stage {
    height: 280px;
    border: 1px solid var(--border, #e2e8f0);
    border-radius: 0.75rem;
    background: radial-gradient(circle at 30% 20%, #f8fafc, #fff 60%);
    overflow: hidden;
  }

  /* Share bar */
  .wiki-share-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.8rem;
  }
  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.25rem 0.6rem;
    font-size: 0.75rem;
    border: 1px solid var(--border, #e2e8f0);
    border-radius: 999px;
    background: var(--bg-subtle, #f8fafc);
    color: var(--text-secondary, #64748b);
    text-decoration: none;
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s;
    font-family: inherit;
  }
  .share-btn:hover {
    border-color: var(--accent-ai, #2563eb);
    color: var(--text-primary, #0f172a);
  }
</style>

<script is:inline>
document.querySelectorAll('.share-copy').forEach(function(btn) {
  btn.addEventListener('click', function() {
    var url = btn.dataset.url;
    navigator.clipboard.writeText(url).then(function() {
      var orig = btn.innerHTML;
      btn.textContent = '已複製！';
      setTimeout(function() { btn.innerHTML = orig; }, 1500);
    });
  });
});
</script>
