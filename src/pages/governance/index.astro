---
import BaseLayout from '../../layouts/BaseLayout.astro';

const API_BASE = 'https://api.paulkuo.tw';
---

<BaseLayout title="專案治理 Dashboard" lang="zh-Hant">
  <div id="auth-gate" class="auth-wrapper">
    <div class="auth-box">
      <div class="auth-icon">🎛️</div>
      <h2>專案治理 Dashboard</h2>
      <p class="auth-hint">輸入 Governance Token 以繼續</p>
      <div class="auth-row">
        <input
          id="token-input"
          type="password"
          placeholder="Bearer token"
          autocomplete="current-password"
        />
        <button id="token-submit">進入</button>
      </div>
      <p id="auth-error" class="auth-error" hidden>Token 無效，請重試</p>
      <p class="auth-footnote">登入後可見：專案健康度 · 自動化覆蓋率 · 跨專案稽核</p>
    </div>
  </div>

  <div id="dashboard" hidden>
    <div class="dash-header">
      <h1>🎛️ 專案治理 Dashboard</h1>
      <span id="last-updated" class="last-updated"></span>
    </div>

    <!-- Project cards -->
    <section class="section">
      <h2 class="section-title">專案狀態</h2>
      <div id="project-cards" class="card-grid"></div>
    </section>

    <!-- Automation coverage -->
    <section class="section two-col">
      <div>
        <h2 class="section-title">自動化覆蓋率</h2>
        <div class="donut-wrap">
          <canvas id="donut-chart" width="180" height="180"></canvas>
          <div class="donut-label">
            <span id="coverage-pct"></span>
          </div>
        </div>
        <div id="candidates-list" class="candidates"></div>
      </div>

      <div>
        <h2 class="section-title">各專案累計 commits</h2>
        <canvas id="trend-chart" width="400" height="200"></canvas>
      </div>
    </section>

    <!-- Audit health -->
    <section class="section">
      <h2 class="section-title">跨專案稽核</h2>
      <div class="audit-panel two-col">
        <div>
          <div class="audit-summary">
            <div class="audit-stat">
              <span id="audit-scanner-status" class="scanner-badge loading">⏳ 載入中</span>
            </div>
            <div class="audit-stat">
              <span id="audit-open-issues" class="audit-number">—</span>
              <span class="audit-label">待處理問題</span>
            </div>
          </div>
          <div id="audit-flagged-list" class="audit-flagged"></div>
        </div>
        <div>
          <canvas id="audit-trend-chart" width="400" height="160"></canvas>
        </div>
      </div>
    </section>

    <!-- 文件庫（登入後才顯示） -->
    <section class="docs-library">
      <h2 class="section-title">文件庫</h2>
      <div class="docs-library-grid">
        <a href="/governance/harness-process.html" target="_blank" rel="noopener" class="doc-card">
          <h3>Harness Engineering 開發歷程</h3>
          <p>從 Phase 0 裸奔到 Phase 5 自動化，六階段演進記錄</p>
          <span class="doc-cta">閱讀文件 →</span>
        </a>
        <a href="/governance/skill-overview.html" target="_blank" rel="noopener" class="doc-card">
          <h3>session-handoff Skill v4.8 總覽</h3>
          <p>13 條護欄、Exit Gate / Reconciliation 雙閘門、不可逆操作清單</p>
          <span class="doc-cta">閱讀文件 →</span>
        </a>
      </div>
    </section>
  </div>
</BaseLayout>

<script is:inline>
(function () {
  const API_BASE = 'https://api.paulkuo.tw';
  const SESSION_KEY = 'gov_token';

  // ── Utilities ──────────────────────────────────────────
  function daysSince(dateStr) {
    return Math.floor((Date.now() - new Date(dateStr).getTime()) / 86400000);
  }

  function healthEmoji(health) {
    return { green: '🟢', yellow: '🟡', red: '🔴' }[health] || '⏸️';
  }

  function formatDate(dateStr) {
    if (!dateStr) return '—';
    const d = new Date(dateStr);
    return `${d.getFullYear()}/${String(d.getMonth() + 1).padStart(2, '0')}/${String(d.getDate()).padStart(2, '0')}`;
  }

  // ── Fetch with Bearer token ────────────────────────────
  async function govFetch(path, token) {
    const res = await fetch(API_BASE + path, {
      headers: { 'Authorization': 'Bearer ' + token }
    });
    return res;
  }

  // ── Render project cards ───────────────────────────────
  function renderCards(projects) {
    const grid = document.getElementById('project-cards');
    grid.innerHTML = projects.map(p => `
      <div class="proj-card health-${p.health}">
        <div class="proj-card-top">
          <span class="health-dot">${healthEmoji(p.health)}</span>
          <span class="proj-name">${p.name}</span>
        </div>
        <div class="proj-stat">${p.total_commits}<small> commits</small></div>
        <div class="proj-meta">
          <span>${p.total_deploys} deploys</span>
          <span>${p.total_files_changed} files</span>
        </div>
        <div class="proj-activity">最後活動：${formatDate(p.last_activity)}</div>
      </div>
    `).join('');
  }

  // ── Render automation donut ────────────────────────────
  function renderDonut(auto) {
    const canvas = document.getElementById('donut-chart');
    if (!canvas || !canvas.getContext) return;
    const ctx = canvas.getContext('2d');
    const pct = auto.coverage_rate;
    const pctStr = Math.round(pct * 100) + '%';
    document.getElementById('coverage-pct').textContent = pctStr;

    const total = auto.automated_count + auto.manual_count;
    const autoAngle = (auto.automated_count / total) * Math.PI * 2;
    const cx = 90, cy = 90, r = 70, innerR = 46;

    ctx.clearRect(0, 0, 180, 180);

    // Automated slice
    ctx.beginPath();
    ctx.moveTo(cx, cy);
    ctx.arc(cx, cy, r, -Math.PI / 2, -Math.PI / 2 + autoAngle);
    ctx.closePath();
    ctx.fillStyle = '#22c55e';
    ctx.fill();

    // Manual slice
    ctx.beginPath();
    ctx.moveTo(cx, cy);
    ctx.arc(cx, cy, r, -Math.PI / 2 + autoAngle, -Math.PI / 2 + Math.PI * 2);
    ctx.closePath();
    ctx.fillStyle = '#e5e7eb';
    ctx.fill();

    // Inner hole
    ctx.beginPath();
    ctx.arc(cx, cy, innerR, 0, Math.PI * 2);
    ctx.fillStyle = '#fff';
    ctx.fill();

    // Candidates list
    const list = document.getElementById('candidates-list');
    if (auto.candidates && auto.candidates.length > 0) {
      list.innerHTML = '<p class="cand-title">可自動化但尚未：</p>' +
        auto.candidates.map(c => `<span class="cand-tag">${c}</span>`).join('');
    }
  }

  // ── Render trend chart ─────────────────────────────────
  function renderTrend(projects) {
    const canvas = document.getElementById('trend-chart');
    if (!canvas || !canvas.getContext) return;
    const ctx = canvas.getContext('2d');

    // Build simple bar chart from total commits per project
    const labels = projects.map(p => p.name.length > 5 ? p.name.slice(0, 5) + '…' : p.name);
    const values = projects.map(p => p.total_commits);
    const maxVal = Math.max(...values, 1);

    const W = 400, H = 180;
    const padL = 32, padB = 36, padT = 10, padR = 10;
    const chartW = W - padL - padR;
    const chartH = H - padB - padT;
    const barW = Math.floor(chartW / labels.length) - 6;

    ctx.clearRect(0, 0, W, H);
    ctx.font = '11px sans-serif';
    ctx.fillStyle = '#6b7280';

    // Gridlines
    for (let i = 0; i <= 4; i++) {
      const y = padT + chartH - (chartH / 4 * i);
      const val = Math.round((maxVal / 4) * i);
      ctx.strokeStyle = '#f3f4f6';
      ctx.beginPath(); ctx.moveTo(padL, y); ctx.lineTo(W - padR, y); ctx.stroke();
      ctx.fillStyle = '#9ca3af';
      ctx.fillText(val, 2, y + 4);
    }

    // Bars
    labels.forEach((label, i) => {
      const x = padL + i * (chartW / labels.length) + 3;
      const barH = (values[i] / maxVal) * chartH;
      const y = padT + chartH - barH;

      ctx.fillStyle = '#3b82f6';
      ctx.beginPath();
      ctx.roundRect(x, y, barW, barH, 3);
      ctx.fill();

      // Label
      ctx.fillStyle = '#6b7280';
      ctx.fillText(label, x, H - 4);
    });

    // Axis label
    ctx.fillStyle = '#9ca3af';
    ctx.font = '10px sans-serif';
    ctx.fillText('累計 commits（各專案）', padL, H - padB + 14);
  }

  // ── Main render ────────────────────────────────────────
  function renderDashboard(summary) {
    document.getElementById('auth-gate').hidden = true;
    document.getElementById('dashboard').removeAttribute('hidden');

    const updatedStr = summary.last_updated
      ? '最後更新：' + formatDate(summary.last_updated.slice(0, 10))
      : '';
    document.getElementById('last-updated').textContent = updatedStr;

    renderCards(summary.projects || []);
    renderDonut(summary.automation || {});
    renderTrend(summary.projects || []);

    // Fetch audit data (non-blocking — dashboard still loads if audit unavailable)
    const storedToken = sessionStorage.getItem(SESSION_KEY);
    govFetch('/api/governance/audit', storedToken).then(async res => {
      if (!res.ok) {
        document.getElementById('audit-scanner-status').textContent = '⚠️ 無資料';
        document.getElementById('audit-scanner-status').className = 'scanner-badge warn';
        return;
      }
      const audit = await res.json();
      renderAudit(audit);
    }).catch(() => {
      document.getElementById('audit-scanner-status').textContent = '❌ 連線失敗';
      document.getElementById('audit-scanner-status').className = 'scanner-badge error';
    });
  }

  // ── Render audit panel ─────────────────────────────────
  function renderAudit(audit) {
    // 1. Scanner badge
    const badge = document.getElementById('audit-scanner-status');
    if (audit.scanner_health && audit.scanner_health.is_healthy) {
      badge.textContent = '✅ 正常';
      badge.className = 'scanner-badge ok';
    } else {
      badge.textContent = '⚠️ 48h 未更新';
      badge.className = 'scanner-badge warn';
    }

    // 2. 待處理數字
    const issueEl = document.getElementById('audit-open-issues');
    const latest = audit.recent && audit.recent[0];
    if (latest) {
      const openCount = (latest.missing_tags || 0) + (latest.missing_smoke_tests || 0);
      issueEl.textContent = openCount;
      if (openCount > 0) issueEl.classList.add('warn');
    } else {
      issueEl.textContent = '0';
    }

    // 3. Flagged list (from most recent audit result)
    // We need flagged detail — if not in recent summary, show summary-level info
    const flaggedEl = document.getElementById('audit-flagged-list');
    if (!latest) {
      flaggedEl.innerHTML = '<p style="color:#9ca3af;font-size:0.8rem">✅ 近期無稽核資料</p>';
    } else if ((latest.missing_tags || 0) + (latest.missing_smoke_tests || 0) === 0) {
      flaggedEl.innerHTML = '<p style="color:#22c55e;font-size:0.8rem">✅ 近期無異常</p>';
    } else {
      flaggedEl.innerHTML = `
        <div class="flagged-item">
          <span class="flagged-hash">${latest.date}</span>
          <span class="flagged-msg">缺 tag: ${latest.missing_tags}，缺 smoke test: ${latest.missing_smoke_tests}</span>
        </div>`;
    }

    // 4. 趨勢折線圖
    if (audit.trend && audit.trend.dates && audit.trend.dates.length > 0) {
      renderAuditTrend(audit.trend);
    }
  }

  // ── Render audit trend line chart ─────────────────────
  function renderAuditTrend(trend) {
    const canvas = document.getElementById('audit-trend-chart');
    if (!canvas || !canvas.getContext) return;
    const ctx = canvas.getContext('2d');

    const W = 400, H = 160;
    const padL = 28, padB = 30, padT = 10, padR = 10;
    const chartW = W - padL - padR;
    const chartH = H - padB - padT;

    const dates = trend.dates;
    const tagsData = trend.missing_tags;
    const smokeData = trend.missing_smoke_tests;
    const maxVal = Math.max(...tagsData, ...smokeData, 1);
    const n = dates.length;

    ctx.clearRect(0, 0, W, H);

    // Gridlines
    ctx.font = '10px sans-serif';
    for (let i = 0; i <= 4; i++) {
      const y = padT + chartH - (chartH / 4 * i);
      const val = Math.round((maxVal / 4) * i);
      ctx.strokeStyle = '#f3f4f6';
      ctx.lineWidth = 1;
      ctx.beginPath(); ctx.moveTo(padL, y); ctx.lineTo(W - padR, y); ctx.stroke();
      ctx.fillStyle = '#9ca3af';
      ctx.fillText(val, 2, y + 4);
    }

    // Helper: draw polyline
    function drawLine(data, color) {
      if (n < 1) return;
      ctx.beginPath();
      ctx.strokeStyle = color;
      ctx.lineWidth = 2;
      data.forEach((v, i) => {
        const x = padL + (i / Math.max(n - 1, 1)) * chartW;
        const y = padT + chartH - (v / maxVal) * chartH;
        i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
      });
      ctx.stroke();
      // Dots
      data.forEach((v, i) => {
        const x = padL + (i / Math.max(n - 1, 1)) * chartW;
        const y = padT + chartH - (v / maxVal) * chartH;
        ctx.beginPath();
        ctx.arc(x, y, 3, 0, Math.PI * 2);
        ctx.fillStyle = color;
        ctx.fill();
      });
    }

    drawLine(tagsData, '#3b82f6');      // 藍：missing tags
    drawLine(smokeData, '#f97316');     // 橘：missing smoke tests

    // X-axis date labels (first and last)
    ctx.fillStyle = '#9ca3af';
    ctx.font = '9px sans-serif';
    if (dates.length > 0) {
      ctx.fillText(dates[0].slice(5), padL, H - 4);
      if (dates.length > 1) {
        const lastLabel = dates[dates.length - 1].slice(5);
        const lw = ctx.measureText(lastLabel).width;
        ctx.fillText(lastLabel, W - padR - lw, H - 4);
      }
    }

    // Legend
    ctx.fillStyle = '#3b82f6';
    ctx.fillRect(padL, padT - 2, 8, 8);
    ctx.fillStyle = '#374151';
    ctx.font = '9px sans-serif';
    ctx.fillText('缺 tag', padL + 10, padT + 6);

    ctx.fillStyle = '#f97316';
    ctx.fillRect(padL + 50, padT - 2, 8, 8);
    ctx.fillStyle = '#374151';
    ctx.fillText('缺 smoke test', padL + 60, padT + 6);
  }

  // ── Auth flow ──────────────────────────────────────────
  async function tryLogin(token) {
    try {
      const res = await govFetch('/api/governance/summary', token);
      if (res.status === 401) {
        document.getElementById('auth-error').hidden = false;
        return;
      }
      if (!res.ok) {
        document.getElementById('auth-error').textContent = `伺服器錯誤 (${res.status})`;
        document.getElementById('auth-error').hidden = false;
        return;
      }
      sessionStorage.setItem(SESSION_KEY, token);
      const summary = await res.json();
      renderDashboard(summary);
    } catch (e) {
      document.getElementById('auth-error').textContent = '連線失敗，請確認網路';
      document.getElementById('auth-error').hidden = false;
    }
  }

  // ── Bind events ────────────────────────────────────────
  document.getElementById('token-submit').addEventListener('click', () => {
    const token = document.getElementById('token-input').value.trim();
    if (!token) return;
    document.getElementById('auth-error').hidden = true;
    tryLogin(token);
  });

  document.getElementById('token-input').addEventListener('keydown', (e) => {
    if (e.key === 'Enter') document.getElementById('token-submit').click();
  });

  // Auto-login if token stored in session
  const stored = sessionStorage.getItem(SESSION_KEY);
  if (stored) tryLogin(stored);
})();
</script>

<style>
  /* ── Auth Gate ── */
  .auth-wrapper {
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .auth-box {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    padding: 2rem 2.5rem;
    max-width: 380px;
    width: 100%;
    text-align: center;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
  }

  .auth-icon { font-size: 2.5rem; margin-bottom: 0.5rem; }

  .auth-box h2 {
    margin: 0.25rem 0 0.5rem;
    font-size: 1.25rem;
    color: #111827;
  }

  .auth-hint { color: #6b7280; font-size: 0.875rem; margin-bottom: 1.25rem; }

  .auth-row { display: flex; gap: 0.5rem; }

  .auth-row input {
    flex: 1;
    padding: 0.6rem 0.75rem;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    font-size: 0.9rem;
    outline: none;
    transition: border-color 0.15s;
  }
  .auth-row input:focus { border-color: #3b82f6; }

  .auth-row button {
    padding: 0.6rem 1rem;
    background: #3b82f6;
    color: #fff;
    border: none;
    border-radius: 6px;
    font-size: 0.9rem;
    cursor: pointer;
    transition: background 0.15s;
  }
  .auth-row button:hover { background: #2563eb; }

  .auth-error {
    color: #dc2626;
    font-size: 0.8rem;
    margin-top: 0.75rem;
  }

  .auth-footnote {
    color: #9ca3af;
    font-size: 0.72rem;
    margin-top: 1.25rem;
    padding-top: 1rem;
    border-top: 1px solid #f3f4f6;
    letter-spacing: 0.02em;
  }

  /* ── Dashboard ── */
  #dashboard {
    max-width: 1000px;
    margin: 0 auto;
    padding: 1.5rem 1rem 3rem;
  }

  .dash-header {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .dash-header h1 {
    margin: 0;
    font-size: 1.5rem;
    color: #111827;
  }

  .last-updated { font-size: 0.8rem; color: #9ca3af; }

  .section { margin-bottom: 2.5rem; }

  .section-title {
    font-size: 1rem;
    font-weight: 600;
    color: #374151;
    margin: 0 0 1rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid #f3f4f6;
  }

  /* ── Project cards ── */
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 0.75rem;
  }

  .proj-card {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    padding: 0.875rem;
    position: relative;
  }

  .proj-card.health-green { border-left: 3px solid #22c55e; }
  .proj-card.health-yellow { border-left: 3px solid #f59e0b; }
  .proj-card.health-red { border-left: 3px solid #ef4444; }

  .proj-card-top {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.5rem;
  }

  .health-dot { font-size: 0.85rem; }

  .proj-name {
    font-size: 0.85rem;
    font-weight: 600;
    color: #111827;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .proj-stat {
    font-size: 1.5rem;
    font-weight: 700;
    color: #1d4ed8;
    line-height: 1.2;
  }

  .proj-stat small { font-size: 0.75rem; font-weight: 400; color: #6b7280; }

  .proj-meta {
    display: flex;
    gap: 0.5rem;
    font-size: 0.72rem;
    color: #9ca3af;
    margin-top: 0.25rem;
  }

  .proj-activity {
    font-size: 0.7rem;
    color: #9ca3af;
    margin-top: 0.4rem;
    padding-top: 0.4rem;
    border-top: 1px solid #f3f4f6;
  }

  /* ── Two-column section ── */
  .two-col {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 2rem;
    align-items: start;
  }

  /* ── Donut ── */
  .donut-wrap {
    position: relative;
    display: inline-block;
    margin-bottom: 0.75rem;
  }

  .donut-label {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 1.4rem;
    font-weight: 700;
    color: #111827;
    pointer-events: none;
  }

  .candidates { margin-top: 0.5rem; }
  .cand-title { font-size: 0.75rem; color: #9ca3af; margin: 0 0 0.4rem; }
  .cand-tag {
    display: inline-block;
    background: #fef3c7;
    color: #92400e;
    border-radius: 4px;
    font-size: 0.7rem;
    padding: 0.15rem 0.4rem;
    margin: 0.15rem 0.15rem 0 0;
  }

  /* ── Trend chart ── */
  #trend-chart {
    display: block;
    max-width: 100%;
    border-radius: 8px;
    background: #fafafa;
    border: 1px solid #f3f4f6;
  }

  /* ── Audit Panel ── */
  .audit-summary { display: flex; gap: 1.5rem; margin-bottom: 1rem; }
  .audit-stat { display: flex; flex-direction: column; gap: 0.25rem; }
  .audit-label { font-size: 0.75rem; color: #9ca3af; }
  .audit-number { font-size: 2rem; font-weight: 700; color: #111827; }
  :global(.audit-number.warn) { color: #ef4444; }

  .scanner-badge {
    display: inline-block; padding: 0.3rem 0.75rem;
    border-radius: 999px; font-size: 0.8rem; font-weight: 500;
  }
  .scanner-badge.ok { background: #dcfce7; color: #166534; }
  .scanner-badge.warn { background: #fef3c7; color: #92400e; }
  .scanner-badge.error { background: #fee2e2; color: #991b1b; }
  .scanner-badge.loading { background: #f3f4f6; color: #6b7280; }

  .audit-flagged { margin-top: 0.75rem; }
  :global(.flagged-item) {
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 0.8rem; padding: 0.4rem 0;
    border-bottom: 1px solid #f3f4f6;
  }
  :global(.flagged-hash) { font-family: monospace; color: #6b7280; }
  :global(.flagged-msg) { flex: 1; color: #374151; }

  #audit-trend-chart {
    display: block; max-width: 100%;
    border-radius: 8px; background: #fafafa;
    border: 1px solid #f3f4f6;
