  // ── Participant Status (pause / complete) ──
  window.setParticipantStatus = function(status) {
    var userId = lineUserId || lsGet('formosa_line_user_id');
    if (!userId) return;
    var btn = status === 'paused' ? document.getElementById('pauseBtn') : document.getElementById('completeBtn');
    if (btn) { btn.disabled = true; btn.textContent = '處理中…'; }
    fetch(API_BASE + '/api/formosa/participant-status', {
