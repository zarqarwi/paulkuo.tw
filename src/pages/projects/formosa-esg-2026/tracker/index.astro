    }).then(function(r) { return r.json(); }).then(function(data) {
      if (data.ok) {
        lsSet('formosa_participant_status', status);
        if (status === 'paused') {
          if (btn) { btn.textContent = '已暫離'; }
          // Stop GPS tracking
          if (window.__gpsWatchId) { navigator.geolocation.clearWatch(window.__gpsWatchId); window.__gpsWatchId = null; }
          var gpsEl = document.getElementById('gpsStatus');
          if (gpsEl) gpsEl.textContent = '⏸️ 已暫離（重新進入即恢復）';
        } else if (status === 'completed') {
          showCompletedOverlay();
        }
      } else {
        if (btn) { btn.textContent = data.error || '操作失敗'; }
      }
    }).catch(function(e) {
      console.warn('Status sync failed:', e);
      if (btn) { btn.disabled = false; btn.textContent = status === 'paused' ? '⏸️ 暫離' : '✅ 完成進香'; }
