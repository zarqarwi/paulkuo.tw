  async function saveFileToDevice(f) {
    var ts = new Date().toISOString().replace(/[:.]/g, '-').slice(0, 19);
    var ext = (f.name.split('.').pop() || 'jpg').toLowerCase();
    var shareFile = new File([f], 'formosa-' + ts + '.' + ext, { type: f.type });

    if (!isLineBrowser && navigator.share && navigator.canShare && navigator.canShare({ files: [shareFile] })) {
      await navigator.share({ files: [shareFile] });
      return true;
    } else {
      var url = URL.createObjectURL(f);
      var a = document.createElement('a');
      a.href = url;
      a.download = shareFile.name;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
      return true;
    }
  }

  async function autoSavePhotos() {
    if (pendingSaveFiles.length === 0) return;

    if (isLineBrowser) {
      // LINE WebView 不支援自動存檔，提示使用者用按鈕長按儲存
      lastSavedFile = pendingSaveFiles[pendingSaveFiles.length - 1];
      pendingSaveFiles = [];
      updateSaveBtn();
      showPhotoToast('點「📥 活動照存檔」長按儲存照片', 3500);
      return;
    }

    var saved = false;
    for (var i = 0; i < pendingSaveFiles.length; i++) {
      var f = pendingSaveFiles[i];
      try {
        saved = await saveFileToDevice(f);
        lastSavedFile = f;
      } catch (e) {
        if (e.name === 'AbortError') { saved = false; break; }
        console.warn('Photo save failed:', e);
      }
    }
    pendingSaveFiles = [];
    updateSaveBtn();

    if (saved) {
      showPhotoToast('📸 照片已儲存', 2500);
    }
  }

  window.saveLastPhoto = async function() {
    if (!lastSavedFile) return;

    if (isLineBrowser) {
      // LINE WebView 不支援 <a download>，改用長按儲存模式
      var overlay = document.createElement('div');
      overlay.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.9);z-index:9999;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:16px;';

      var hint = document.createElement('p');
      hint.textContent = '長按照片 → 儲存圖片';
      hint.style.cssText = 'color:white;font-size:16px;margin-bottom:12px;';

      var img = document.createElement('img');
      img.src = URL.createObjectURL(lastSavedFile);
      img.style.cssText = 'max-width:90%;max-height:70vh;border-radius:8px;';

      var closeBtn = document.createElement('button');
      closeBtn.textContent = '✕ 關閉';
      closeBtn.style.cssText = 'margin-top:16px;padding:10px 24px;background:#666;color:white;border:none;border-radius:8px;font-size:16px;';
      closeBtn.onclick = function() {
        URL.revokeObjectURL(img.src);
        document.body.removeChild(overlay);
      };

      overlay.appendChild(hint);
      overlay.appendChild(img);
      overlay.appendChild(closeBtn);
      document.body.appendChild(overlay);
    } else {
      try {
        var saved = await saveFileToDevice(lastSavedFile);
        if (saved) {
          showPhotoToast('📸 照片已儲存', 2500);
        }
      } catch (e) {
        if (e.name !== 'AbortError') console.warn('Photo save failed:', e);
      }
    }
  };

  async function handlePhotos(files, statusEl) {
    if (!statusEl) statusEl = document.getElementById('photoStatusMini');
    if (!statusEl) return;
    var count = 0;
    var gpsCount = 0;

    // Show uploading state
    statusEl.innerHTML = '<span class="photo-status-text photo-status-loading">📷 讀取 GPS 中...</span>';

    pendingSaveFiles = []; // reset for this batch
    var failed = false;
    for (var i = 0; i < files.length; i++) {
      var file = files[i];
      if (!file.type.match(/^image\/(jpe?g|png|heic|heif)$/)) continue;

      count++;
      pendingSaveFiles.push(file);
      lastSavedFile = file; // always track latest for manual save

      // Store for sharing (keep file ref but no objectURL thumbnail)
      uploadedPhotos.push({ file: file, name: file.name });

      // Try extract GPS
      try {
        var buf = await readFileAsArrayBuffer(file);
        var data = parseExifGPS(buf);
        if (data && data.hasGPS) {
          gpsCount++;

          // Add to track points and calculate distance
          var last = getLastCheckinCoords();
          if (last) {
            var dist = haversine(last.lat, last.lng, data.lat, data.lng);
            if (dist > 0.01) addKm(dist);
          }
          saveLastCheckinCoords(data.lat, data.lng);

          gpsTrackPoints.push({
            lat: data.lat, lng: data.lng,
            altitude: data.altitude,
            datetime: data.datetime,
            source: 'photo',
            filename: file.name
          });
        }
      } catch (e) { /* no GPS */ }
    }

    if (count > 0) {
      // Update cumulative count
      cumulativePhotoCount += count;
      lsSet('formosa_photo_count', cumulativePhotoCount);

      // Increment on server
      var userId = lineUserId || lsGet('formosa_user_id') || '';
      if (userId) {
        try {
          await fetch(API_BASE + '/api/formosa/photos/count', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-Line-User-Id': userId },
            body: JSON.stringify({ line_user_id: userId, count: count })
          });
        } catch (e) { /* offline — localStorage is source of truth */ }
      }

      // Show success text
      updatePhotoStatusDisplay();

      // Auto-save photos
      await autoSavePhotos();

      // Update stats display
      var km = getSavedKm();
      var checkins = getSavedCheckins();
      var t = getTitle(checkins, km);
      var statsEl2 = document.getElementById('checkinStats');
      if (statsEl2) {
        statsEl2.innerHTML = '<div class="done-stats">' +
          '<div class="done-stat"><strong>' + checkins + '</strong><span>打卡次數</span></div>' +
          '<div class="done-stat"><strong>' + km.toFixed(1) + '</strong><span>公里</span></div>' +
          getCarbonStatsHtml() +
          '</div>' + getTransportBreakdownHtml();
      }
      updateCheckinProgress(t);

      // Persist photo GPS points to localStorage for route map
      try {
        var savedTrack = JSON.parse(lsGet('formosa_gps_track') || '[]');
        gpsTrackPoints.filter(function(p) { return p.source === 'photo'; }).forEach(function(p) {
          var exists = savedTrack.some(function(s) { return s.lat === p.lat && s.lng === p.lng && s.source === 'photo'; });
          if (!exists) savedTrack.push({ lat: p.lat, lng: p.lng, datetime: p.datetime, source: 'photo' });
        });
        lsSet('formosa_gps_track', JSON.stringify(savedTrack));
      } catch(e) {}
    } else if (failed) {
      statusEl.innerHTML = '<span class="photo-status-text photo-status-error">⚠️ 讀取失敗，請重試</span><button class="photo-retry-btn" onclick="document.getElementById(\'photoCameraMini\').click()">重試</button>';
    }
  }

  // ── Returning User: Check-in Mode ──
  function enterCheckinMode() {
    showCard('checkin');

    var checkins = getSavedCheckins();
    var km = getSavedKm();
    var t = getTitle(checkins, km);

    document.getElementById('checkinBadge').innerHTML = '<img src="' + MASCOT_BASE + t.current.img + '" class="mascot-badge" alt="' + t.current.name + '"><span>' + t.current.name + '</span>';

    // Hide GPS banner check-in button (replaced by big button in checkin mode)
    var gpsBannerBtn = document.getElementById('gpsCheckinBtn');
    if (gpsBannerBtn) gpsBannerBtn.style.display = 'none';

    var statsHtml = '<div class="done-stats">' +
      '<div class="done-stat"><strong>' + checkins + '</strong><span>打卡次數</span></div>' +
      '<div class="done-stat"><strong>' + km.toFixed(1) + '</strong><span>公里</span></div>' +
      getCarbonStatsHtml() +
      '</div>' + getTransportBreakdownHtml();
    document.getElementById('checkinStats').innerHTML = statsHtml;

    updateCheckinProgress(t);

    // Fetch GPS-derived carbon stats from server
    loadUserStats();

    var cameraBtn = document.getElementById('cameraBtnMini');
    var cameraInput = document.getElementById('photoCameraMini');
    var statusMini = document.getElementById('photoStatusMini');
    if (cameraBtn && cameraInput) {
      cameraBtn.addEventListener('click', function() { cameraInput.click(); });
      cameraInput.addEventListener('change', function() {
        if (this.files.length > 0) handlePhotos(this.files, statusMini);
        this.value = ''; // reset so same photo can re-trigger
      });
    }

    // Show existing photo count on page load
    updatePhotoStatusDisplay();

    // Load today's daily report data and cumulative stats
    var drUserId = lineUserId || lsGet('formosa_user_id') || '';
    if (drUserId) {
      loadTodayReport(drUserId);
      loadDailyCumulative(drUserId);
    }
  }

  // Override manualCheckin to calculate distance and update stats
  window.manualCheckin = function() {
    // Immediate loading feedback on both buttons
    var btn = document.getElementById('gpsCheckinBtn');
    var bigBtn = document.querySelector('.checkin-big-btn');
    var activeBtn = bigBtn || btn;
    if (activeBtn) {
      activeBtn.disabled = true;
      activeBtn.dataset.origText = activeBtn.textContent;
      activeBtn.textContent = '📍 定位中...';
    }

    navigator.geolocation.getCurrentPosition(
      function(pos) {
        var lat = pos.coords.latitude;
        var lng = pos.coords.longitude;

        // Calculate distance from last check-in
        var last = getLastCheckinCoords();
        if (last) {
          var dist = haversine(last.lat, last.lng, lat, lng);
          if (dist > 0.01) { // ignore < 10m (noise)
            addKm(dist);
          }
        }
        saveLastCheckinCoords(lat, lng);

        // Push to GPS track
        var newPt = {
          lat: lat, lng: lng,
          altitude: pos.coords.altitude,
          accuracy: pos.coords.accuracy,
          datetime: new Date().toISOString(),
          source: 'manual',
          filename: '手動打卡 #' + (gpsTrackPoints.filter(function(p){return p.source==='manual'}).length + 1)
        };
        gpsTrackPoints.push(newPt);

        // Persist to localStorage for route map
        var savedTrack = JSON.parse(lsGet('formosa_gps_track') || '[]');
        savedTrack.push({ lat: lat, lng: lng, datetime: newPt.datetime, source: 'manual' });
        lsSet('formosa_gps_track', JSON.stringify(savedTrack));

        // Sync checkin to server
        var userId = lineUserId || lsGet('formosa_user_id') || '';
        if (userId) {
          fetch(API_BASE + '/api/formosa/checkin', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              user_id: userId,
              lat: lat, lng: lng,
              altitude: pos.coords.altitude,
              accuracy: pos.coords.accuracy,
              source: 'manual',
              checkins: getSavedCheckins() + 1,
              km: getSavedKm()
            })
          }).then(function(res) {
            if (!res.ok) {
              console.warn('打卡 API 回應異常:', res.status);
              if (res.status === 429) {
                showPhotoToast('⏳ 打卡太頻繁，請稍後再試', 3000);
              }
            }
          }).catch(function(err) {
            console.warn('打卡 API 失敗（離線？）:', err);
          });
        }

        var countEl = document.getElementById('gpsCount');
        if (countEl) countEl.textContent = gpsTrackPoints.length + ' 次 GPS 記錄';

        // Button success feedback
        if (activeBtn) {
          activeBtn.textContent = '✓ 已打卡';
          activeBtn.disabled = true;
          setTimeout(function() {
            activeBtn.textContent = activeBtn.dataset.origText || '打卡 📍';
            activeBtn.disabled = false;
          }, 1500);
        }

        // Update stats
        var n = incrementCheckins();
        var km = getSavedKm();
        var t = getTitle(n, km);

        var badgeEl = document.getElementById('checkinBadge');
        if (badgeEl) badgeEl.innerHTML = '<img src="' + MASCOT_BASE + t.current.img + '" class="mascot-badge" alt="' + t.current.name + '"><span>' + t.current.name + '</span>';

        var statsEl = document.getElementById('checkinStats');
        if (statsEl) {
          statsEl.innerHTML = '<div class="done-stats">' +
            '<div class="done-stat"><strong>' + n + '</strong><span>打卡次數</span></div>' +
            '<div class="done-stat"><strong>' + km.toFixed(1) + '</strong><span>公里</span></div>' +
            getCarbonStatsHtml() +
            '</div>' + getTransportBreakdownHtml();
        }

        updateCheckinProgress(t);
      },
      function(err) {
        // Restore button on failure
        if (activeBtn) {
          activeBtn.textContent = activeBtn.dataset.origText || '打卡 📍';
          activeBtn.disabled = false;
        }
        if (err.code === 1) {
          alert('定位權限被拒絕，請到手機設定開啟定位權限。');
        } else if (err.code === 3) {
          showPhotoToast('📍 GPS 訊號弱，請到空曠處再試', 3000);
        } else {
          showPhotoToast('📍 暫時無法定位，請稍後再試', 3000);
        }
      },
      { enableHighAccuracy: true, timeout: 10000 }
    );
  };

  function updateCheckinProgress(t) {
    var progEl = document.getElementById('checkinProgress');
    if (!progEl) return;
    if (t.next) {
      var needKm = Math.max(0, t.next.km - t.km);
      var needCheckins = Math.max(0, t.next.checkins - t.checkins);
      var parts = [];
      if (needKm > 0) parts.push('走 ' + needKm.toFixed(1) + ' 公里');
      if (needCheckins > 0) parts.push('打卡 ' + needCheckins + ' 次');
      progEl.innerHTML = '<p style="color:#b45309;margin-top:1.5rem;">再' + parts.join('、') + '升級為 <img src="' + MASCOT_BASE + t.next.img + '" style="width:28px;height:28px;vertical-align:middle;"> ' + t.next.name + '</p>';
    } else {
      progEl.innerHTML = '<p style="color:#059669;margin-top:1.5rem;"><img src="' + MASCOT_BASE + 'level-9.png" style="width:28px;height:28px;vertical-align:middle;"> 恭喜飛升！已達最高等級！</p>';
    }
  }

  // ── Page Init ──

  if (lsGet('formosa_survey_done') === 'true') {
    enterCheckinMode();
    checkParticipantStatus();
  } else {
    showCard(1);
  }

  // ── Minimal EXIF GPS parser ──
  function readFileAsArrayBuffer(file) {
    return new Promise(function(resolve, reject) {
      var reader = new FileReader();
      reader.onload = function() { resolve(reader.result); };
      reader.onerror = reject;
      reader.readAsArrayBuffer(file);
    });
  }

  function parseExifGPS(arrayBuffer) {
    var view = new DataView(arrayBuffer);
    if (view.getUint16(0) !== 0xFFD8) return null;

    var offset = 2;
    var length = view.byteLength;

    while (offset < length) {
      if (view.getUint8(offset) !== 0xFF) break;
      var marker = view.getUint8(offset + 1);

      if (marker === 0xE1) {
        var exifLength = view.getUint16(offset + 2);
        return parseExifBlock(view, offset + 4, exifLength - 2);
      }

      if (marker === 0xD8 || marker === 0xD9) {
        offset += 2;
      } else {
        var segLen = view.getUint16(offset + 2);
        offset += 2 + segLen;
      }
    }
    return null;
  }

  function parseExifBlock(view, start, length) {
    var exifHeader = '';
    for (var i = 0; i < 4; i++) exifHeader += String.fromCharCode(view.getUint8(start + i));
    if (exifHeader !== 'Exif') return null;

    var tiffStart = start + 6;
    var bigEndian = view.getUint16(tiffStart) === 0x4D4D;

    function read16(off) { return view.getUint16(off, !bigEndian); }
    function read32(off) { return view.getUint32(off, !bigEndian); }
    function readRational(off) {
      var num = read32(off);
      var den = read32(off + 4);
      return den ? num / den : 0;
    }

    var ifd0Offset = read32(tiffStart + 4);
    var ifd0Abs = tiffStart + ifd0Offset;

    var gpsIFDOffset = null;
    var exifIFDOffset = null;
    var numEntries = read16(ifd0Abs);

    for (var i = 0; i < numEntries; i++) {
      var entryOff = ifd0Abs + 2 + i * 12;
      var tag = read16(entryOff);
      if (tag === 0x8825) gpsIFDOffset = read32(entryOff + 8);
      if (tag === 0x8769) exifIFDOffset = read32(entryOff + 8);
    }

    var result = { hasGPS: false, datetime: null };

    if (exifIFDOffset !== null) {
      try {
        var exifAbs = tiffStart + exifIFDOffset;
        var exifEntries = read16(exifAbs);
        for (var i = 0; i < exifEntries; i++) {
          var entryOff = exifAbs + 2 + i * 12;
          var tag = read16(entryOff);
          if (tag === 0x9003) {
            var count = read32(entryOff + 4);
            var valOffset = count > 4 ? tiffStart + read32(entryOff + 8) : entryOff + 8;
            var dt = '';
            for (var c = 0; c < Math.min(count - 1, 19); c++) dt += String.fromCharCode(view.getUint8(valOffset + c));
            result.datetime = dt;
          }
        }
      } catch (e) {}
    }

    if (gpsIFDOffset === null) return result;

    var gpsAbs = tiffStart + gpsIFDOffset;
    var gpsEntries = read16(gpsAbs);
    var gps = {};

    for (var i = 0; i < gpsEntries; i++) {
      try {
        var entryOff = gpsAbs + 2 + i * 12;
        var tag = read16(entryOff);

        if (tag === 1) gps.latRef = String.fromCharCode(view.getUint8(entryOff + 8));
        else if (tag === 2) { var off = tiffStart + read32(entryOff + 8); gps.lat = [readRational(off), readRational(off + 8), readRational(off + 16)]; }
        else if (tag === 3) gps.lngRef = String.fromCharCode(view.getUint8(entryOff + 8));
        else if (tag === 4) { var off = tiffStart + read32(entryOff + 8); gps.lng = [readRational(off), readRational(off + 8), readRational(off + 16)]; }
        else if (tag === 6) { var off = tiffStart + read32(entryOff + 8); gps.altitude = readRational(off); }
        else if (tag === 16) { var off = tiffStart + read32(entryOff + 8); gps.direction = readRational(off); }
      } catch (e) {}
    }

    if (gps.lat && gps.lng) {
      var lat = gps.lat[0] + gps.lat[1] / 60 + gps.lat[2] / 3600;
      var lng = gps.lng[0] + gps.lng[1] / 60 + gps.lng[2] / 3600;
      if (gps.latRef === 'S') lat = -lat;
      if (gps.lngRef === 'W') lng = -lng;
      result.hasGPS = true;
      result.lat = lat;
      result.lng = lng;
      result.altitude = gps.altitude || null;
      result.direction = gps.direction || null;
    }

    return result;
  }

  // ── Photo Upload UI ──
  var uploadArea = document.getElementById('uploadArea');
  var photoInput = document.getElementById('photoInput');
  var statusEl = document.getElementById('status');
  var resultsSection = document.getElementById('resultsSection');
  var resultsSummary = document.getElementById('resultsSummary');
  var resultsList = document.getElementById('resultsList');
  var mapSection = document.getElementById('mapSection');
  var map = null;
  var markers = [];
  var allPoints = [];

  if (uploadArea) {
    uploadArea.addEventListener('click', function() { photoInput.click(); });
    uploadArea.addEventListener('dragover', function(e) {
      e.preventDefault();
      uploadArea.classList.add('drag-over');
    });
    uploadArea.addEventListener('dragleave', function() {
      uploadArea.classList.remove('drag-over');
    });
    uploadArea.addEventListener('drop', function(e) {
      e.preventDefault();
      uploadArea.classList.remove('drag-over');
      if (e.dataTransfer.files.length) processFiles(e.dataTransfer.files);
    });
  }

  if (photoInput) {
    photoInput.addEventListener('change', function() {
      if (photoInput.files.length) processFiles(photoInput.files);
    });
  }

  function showStatus(msg, type) {
    statusEl.style.display = 'block';
    statusEl.className = 'tracker-status status-' + (type || 'info');
    statusEl.textContent = msg;
  }

  async function processFiles(files) {
    var total = files.length;
    var withGPS = 0;
    var withoutGPS = 0;

    showStatus('正在解析 ' + total + ' 張照片的 EXIF 資料...', 'info');

    for (var i = 0; i < files.length; i++) {
      var file = files[i];
      if (!file.type.match(/^image\/jpe?g$/)) { withoutGPS++; continue; }

      try {
        var buf = await readFileAsArrayBuffer(file);
        var data = parseExifGPS(buf);

        if (data && data.hasGPS) {
          withGPS++;
          allPoints.push({
            lat: data.lat, lng: data.lng,
            altitude: data.altitude, direction: data.direction,
            datetime: data.datetime, filename: file.name
          });
        } else { withoutGPS++; }
      } catch (e) { withoutGPS++; }
    }

    showStatus(
      '解析完成：' + withGPS + ' 張有 GPS，' + withoutGPS + ' 張無 GPS',
      withGPS > 0 ? 'success' : 'warn'
    );

    renderResults();
    if (allPoints.length > 0) renderMap();
  }

  function renderResults() {
    resultsSection.style.display = 'block';
    resultsSummary.innerHTML =
      '<div class="summary-stat"><strong>' + allPoints.length + '</strong><span>GPS 座標點</span></div>';

    var html = '';
    allPoints.forEach(function(pt, i) {
      html += '<div class="result-item">' +
        '<div class="result-num">' + (i + 1) + '</div>' +
        '<div class="result-info">' +
          '<div class="result-filename">' + pt.filename + '</div>' +
          '<div class="result-coords">' + pt.lat.toFixed(6) + ', ' + pt.lng.toFixed(6) + '</div>' +
          (pt.datetime ? '<div class="result-time">' + pt.datetime + '</div>' : '') +
          (pt.altitude ? '<div class="result-alt">海拔 ' + pt.altitude.toFixed(1) + 'm</div>' : '') +
        '</div>' +
      '</div>';
    });
    resultsList.innerHTML = html;
  }

  function renderMap() {
    mapSection.style.display = 'block';

    if (!map) {
      map = L.map('map').setView([24.0, 120.5], 10);
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; OpenStreetMap contributors',
        maxZoom: 19
      }).addTo(map);
    }

    markers.forEach(function(m) { map.removeLayer(m); });
    markers = [];

    var bounds = [];
    allPoints.forEach(function(pt, i) {
      var marker = L.marker([pt.lat, pt.lng]).addTo(map);
      marker.bindPopup(
        '<strong>#' + (i + 1) + ' ' + pt.filename + '</strong><br>' +
        pt.lat.toFixed(6) + ', ' + pt.lng.toFixed(6) +
        (pt.datetime ? '<br>' + pt.datetime : '') +
        (pt.altitude ? '<br>海拔 ' + pt.altitude.toFixed(1) + 'm' : '')
      );
      markers.push(marker);
      bounds.push([pt.lat, pt.lng]);
    });

    if (bounds.length > 1) {
      var sorted = allPoints.slice().sort(function(a, b) {
        if (a.datetime && b.datetime) return a.datetime.localeCompare(b.datetime);
        return 0;
      });
      var sortedBounds = sorted.map(function(pt) { return [pt.lat, pt.lng]; });
      L.polyline(sortedBounds, { color: '#B45309', weight: 3, opacity: 0.7 }).addTo(map);
    }

    if (bounds.length === 1) map.setView(bounds[0], 16);
    else if (bounds.length > 1) map.fitBounds(bounds, { padding: [30, 30] });

    setTimeout(function() { map.invalidateSize(); }, 100);
  }

})();
</script>

</BaseLayout>

<style>
  /* Prevent LINE LIFF pull-to-close gesture */
  html, body {
    overscroll-behavior-y: contain;
  }

  .tracker {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 1rem 4rem;
  }

  /* Test Mode Banner */
  .test-banner {
    position: sticky; top: 0; z-index: 100;
    background: #f59e0b; color: #78350f;
    text-align: center; padding: 0.6rem 1rem;
    font-size: 0.8rem; font-weight: 600;
    letter-spacing: 0.02em;
  }
  .test-checkin-label {
    color: #f59e0b; font-size: 0.78rem; font-weight: 600; margin-top: 0.25rem;
  }

  /* Photo Save Toast */
  .photo-toast {
    position: fixed; bottom: 2rem; left: 50%; transform: translateX(-50%);
    background: rgba(30,58,38,0.9); color: #d1fae5; padding: 0.5rem 1rem;
    border-radius: 8px; font-size: 0.78rem; z-index: 9999;
    opacity: 0; transition: opacity 0.3s;
    pointer-events: none; max-width: 85vw;
  }
  .photo-toast.show { opacity: 1; }

  /* Breadcrumb */
  .tracker-breadcrumb { padding: 1.5rem 0; }
  .tracker-breadcrumb a {
    font-size: 0.85rem;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .tracker-breadcrumb a:hover { color: var(--accent-faith); }

  /* Header */
  .tracker-header {
    text-align: center;
    padding: 2rem 0 2rem;
    margin-bottom: 1.5rem;
  }
  .tracker-badge {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent-faith);
    background: rgba(180,83,9,0.08);
    padding: 4px 14px;
    border-radius: 16px;
    margin-bottom: 1rem;
  }
  .tracker-header h1 {
    font-family: var(--font-cjk);
    font-size: 1.75rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
  }
  .tracker-header p {
    font-size: 1rem;
    color: var(--text-secondary);
  }

  /* ═══ Linear Progress Bar ═══ */
  .q-progress {
    margin-bottom: 2rem;
    padding: 0 0.25rem;
  }
  .q-progress-bar {
    height: 6px;
    background: var(--border-light, #e5e7eb);
    border-radius: 3px;
    overflow: hidden;
    margin-bottom: 0.5rem;
  }
  .q-progress-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--accent-faith), #d97706);
    border-radius: 3px;
    transition: width 0.4s ease;
  }
  .q-progress-text {
    font-size: 0.78rem;
    color: var(--text-muted);
    text-align: right;
    font-family: 'DM Sans', sans-serif;
    font-weight: 500;
  }

  /* ═══ Question Cards ═══ */
  .q-card {
    display: none;
    min-height: 50vh;
  }
  .q-card.active {
    display: block;
    animation: qFadeIn 0.35s ease;
  }
  @keyframes qFadeIn {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .q-section-tag {
    font-family: var(--font-cjk);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--accent-faith);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid rgba(180,83,9,0.15);
  }

  .q-error {
    background: rgba(220,38,38,0.08);
    border: 1px solid rgba(220,38,38,0.2);
    border-radius: 8px;
    padding: 0.5rem 0.75rem;
    margin-top: 0.75rem;
    font-size: 0.82rem;
    color: #DC2626;
  }
  .q-error-shake {
    animation: qShake 0.4s ease;
  }
  @keyframes qShake {
    0%, 100% { transform: translateX(0); }
    20% { transform: translateX(-6px); }
    40% { transform: translateX(6px); }
    60% { transform: translateX(-4px); }
    80% { transform: translateX(4px); }
  }

  .q-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-light);
  }

  /* ── GPS Tracking Banner ── */
  .gps-banner {
    background: linear-gradient(135deg, #065F46, #047857);
    border-radius: 12px;
    padding: 0.75rem 1rem;
    margin-bottom: 1.5rem;
    color: white;
  }
  .gps-banner-inner {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .gps-pulse {
    width: 12px; height: 12px;
    border-radius: 50%;
    background: #6EE7B7;
    flex-shrink: 0;
  }
  .gps-pulse.active {
    animation: pulse 2s infinite;
  }
  .gps-pulse.off {
    background: #F87171;
    animation: none;
  }
  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(110,231,183,0.6); }
    50% { box-shadow: 0 0 0 8px rgba(110,231,183,0); }
  }
  .gps-banner-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    font-size: 0.85rem;
    line-height: 1.4;
  }
  .gps-count {
    font-size: 0.75rem;
    opacity: 0.8;
  }
  .gps-checkin-btn {
    background: rgba(255,255,255,0.2);
    border: 1px solid rgba(255,255,255,0.4);
    color: white;
    padding: 0.4rem 0.85rem;
    border-radius: 8px;
    font-size: 0.8rem;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.2s;
    font-weight: 600;
  }
  .gps-checkin-btn:hover { background: rgba(255,255,255,0.3); }
  .gps-checkin-btn:disabled { opacity: 0.6; cursor: default; }

  /* ── Form Elements ── */
  .form-label {
    display: block;
    font-family: var(--font-cjk);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text-primary) !important;
    margin-bottom: 1rem;
    line-height: 1.6;
  }
  .tracker .form-group label {
    color: var(--text-primary);
    margin-bottom: 0;
  }
  .tracker .form-group input,
  .tracker .form-group textarea {
    background: var(--bg-card) !important;
    border: 1px solid var(--border) !important;
    color: var(--text-primary) !important;
    padding: 0.5rem 0.75rem !important;
  }
  .form-hint {
    font-weight: 400;
    font-size: 0.82rem;
    color: var(--text-muted);
  }

  /* Checkbox & Radio */
  .checkbox-group, .radio-group {
    display: grid;
    gap: 0.5rem;
  }
  .checkbox-item, .radio-item {
    display: flex !important;
    align-items: flex-start;
    gap: 0.6rem;
    padding: 0.75rem 1rem;
    background: var(--bg-card);
    border: 2px solid var(--border-light);
    border-radius: 12px;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s, transform 0.15s;
    font-size: 0.9rem;
    line-height: 1.45;
    color: var(--text-primary) !important;
    margin-bottom: 0 !important;
  }
  .checkbox-item:hover, .radio-item:hover {
    border-color: var(--accent-faith);
    background: rgba(180,83,9,0.02);
  }
  .checkbox-item.selected, .radio-item.selected {
    border-color: var(--accent-faith);
    background: rgba(180,83,9,0.06);
    transform: scale(1.01);
  }
  .checkbox-item input[type="checkbox"],
  .checkbox-item input[type="radio"],
  .radio-item input[type="checkbox"],
  .radio-item input[type="radio"] {
    width: auto !important;
    padding: 0 !important;
    margin-top: 3px;
    flex-shrink: 0;
    accent-color: var(--accent-faith);
    background: none !important;
    border: none !important;
  }
  .other-input {
    width: 100%;
    margin-top: 0.5rem;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    font-size: 0.85rem;
    font-family: var(--font-body);
    outline: none;
  }
  .other-input:focus { border-color: var(--accent-faith); }

  /* Textarea */
  .form-textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    font-size: 0.9rem;
    font-family: var(--font-body);
    line-height: 1.6;
    resize: vertical;
    outline: none;
    box-sizing: border-box;
    background: var(--bg-card);
    color: var(--text-primary);
  }
  .form-textarea:focus { border-color: var(--accent-faith); }

  /* ── Transport Grid ── */
  .transport-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }
  .transport-grid.cols-2 { grid-template-columns: 1fr 1fr; }
  .transport-item {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius);
    padding: 0.75rem;
  }
  .transport-label {
    display: block;
    font-size: 0.82rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }
  .transport-input-wrap {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .transport-input {
    width: 100%;
    padding: 0.45rem 0.6rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    font-size: 0.95rem;
    font-family: 'DM Sans', sans-serif;
    text-align: right;
    outline: none;
    box-sizing: border-box;
    background: var(--bg-card);
    color: var(--text-primary);
  }
  .transport-input:focus { border-color: var(--accent-faith); }
  .transport-unit {
    font-size: 0.78rem;
    color: var(--text-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ── Carbon Card ── */
  .carbon-card {
    background: linear-gradient(135deg, rgba(5,150,105,0.06), rgba(5,150,105,0.02));
    border: 1px solid rgba(5,150,105,0.2);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    margin-top: 0.5rem;
  }
  .carbon-title {
    font-family: var(--font-cjk);
    font-size: 1rem;
    font-weight: 700;
    color: #059669;
    margin-bottom: 0.75rem;
  }
  .carbon-total {
    font-family: 'DM Sans', sans-serif;
    font-size: 2.2rem;
    font-weight: 800;
    color: #059669;
    margin-bottom: 1rem;
  }
  .carbon-total small {
    font-size: 0.9rem;
    font-weight: 500;
  }
  .carbon-breakdown {
    display: grid;
    gap: 0.35rem;
    margin-bottom: 0.75rem;
  }
  .carbon-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.82rem;
    color: var(--text-secondary);
    padding: 0.25rem 0;
    border-bottom: 1px solid rgba(5,150,105,0.08);
  }
  .carbon-row.carbon-offset { color: #059669; font-weight: 600; }
  .carbon-note {
    font-size: 0.72rem;
    color: var(--text-muted);
    font-style: italic;
  }

  /* ── Navigation Buttons ── */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.7rem 1.5rem;
    border: none;
    border-radius: 10px;
    font-family: var(--font-cjk);
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    text-decoration: none;
  }
  .btn-next {
    background: var(--accent-faith);
    color: white;
  }
  .btn-next:hover { background: #9a4408; }
  .btn-back {
    background: var(--bg-section);
    color: var(--text-secondary);
  }
  .btn-back:hover { background: var(--border-light); }
  .btn-submit {
    background: #059669;
    color: white;
    padding: 0.9rem 2.5rem;
    font-size: 1.1rem;
    border-radius: 14px;
  }
  .btn-submit:hover { background: #047857; }
  .btn-submit:disabled { opacity: 0.6; cursor: default; }

  /* ── Upload Area ── */
  .upload-area {
    border: 2px dashed var(--border);
    border-radius: var(--radius-lg);
    padding: 3rem 2rem;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
    background: var(--bg-card);
    margin-bottom: 1.5rem;
  }
  .upload-area:hover,
  .upload-area.drag-over {
    border-color: var(--accent-faith);
    background: rgba(180,83,9,0.03);
  }
  .upload-icon { font-size: 2.5rem; margin-bottom: 1rem; }
  .upload-text {
    font-family: var(--font-cjk);
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }
  .upload-hint {
    font-size: 0.82rem;
    color: var(--text-muted);
  }

  /* Status */
  .tracker-status {
    padding: 0.75rem 1rem;
    border-radius: 8px;
    font-size: 0.88rem;
    margin-bottom: 1.5rem;
    font-weight: 500;
  }
  .status-info { background: rgba(37,99,235,0.08); color: var(--accent-ai); }
  .status-success { background: rgba(5,150,105,0.08); color: #059669; }
  .status-warn { background: rgba(245,158,11,0.08); color: #B45309; }

  /* Results */
  .summary-stat {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius);
    padding: 0.75rem 1.25rem;
    margin-bottom: 1rem;
  }
  .summary-stat strong {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--accent-faith);
  }
  .summary-stat span { font-size: 0.85rem; color: var(--text-secondary); }

  .results-list { display: grid; gap: 0.5rem; }
  .result-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius);
    padding: 0.75rem;
  }
  .result-num {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    color: white;
    background: var(--accent-faith);
    width: 22px; height: 22px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .result-filename { font-size: 0.85rem; font-weight: 600; margin-bottom: 0.15rem; }
  .result-coords { font-family: 'DM Sans', monospace; font-size: 0.8rem; color: var(--accent-ai); }
  .result-time, .result-alt { font-size: 0.75rem; color: var(--text-muted); }

  /* Map */
  .tracker-map {
    height: 400px;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-light);
    overflow: hidden;
  }

  /* ── Done Screen ── */
  .done-icon { font-size: 4rem; margin-bottom: 1rem; margin-top: 2rem; }
  .done-title {
    font-family: var(--font-cjk);
    font-size: 1.5rem;
    font-weight: 800;
    margin-bottom: 0.75rem;
  }
  .done-text {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }
  .done-stats {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
  }
  .done-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    background: var(--bg-section);
    padding: 1rem 1.5rem;
    border-radius: var(--radius);
  }
  .done-stat strong {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--accent-faith);
  }
  .done-stat span { font-size: 0.8rem; color: var(--text-secondary); }

  /* Back link */
  .tracker-back-link { text-align: center; margin-top: 1rem; }
  .tracker-back-link a {
    font-size: 0.88rem;
    color: var(--text-muted);
    text-decoration: none;
  }
  .tracker-back-link a:hover { color: var(--accent-faith); }

  /* ── Reward Card ── */
  .reward-card {
    margin: 1.5rem auto;
    max-width: 340px;
  }
  .reward-card-inner {
    background: linear-gradient(135deg, #fef3c7 0%, #fffbeb 50%, #fef3c7 100%);
    border: 2px solid #d97706;
    border-radius: 16px;
    padding: 1.5rem;
    text-align: center;
    box-shadow: 0 4px 20px rgba(217, 119, 6, 0.15);
  }
  .reward-badge { margin-bottom: 0.5rem; text-align: center; }
  .reward-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: #92400e;
    margin-bottom: 0.25rem;
  }
  .reward-subtitle {
    font-size: 0.8rem;
    color: #b45309;
    margin-bottom: 1rem;
  }
  .reward-stats {
    font-size: 0.82rem;
    color: #78350f;
    margin-bottom: 0.5rem;
  }
  .reward-date {
    font-size: 0.78rem;
    color: #a16207;
    margin-bottom: 1rem;
  }
  .reward-next {
    font-size: 0.78rem;
    color: #b45309;
    padding-top: 0.75rem;
    border-top: 1px solid rgba(217, 119, 6, 0.2);
  }

  /* ── Share Section ── */
  .share-section {
    margin-top: 1.5rem;
    padding-top: 1rem;
  }
  .share-primary-btn {
    width: 100%;
    padding: 1rem;
    background: linear-gradient(135deg, #B45309, #92400e);
    color: #fff;
    border: none;
    border-radius: 14px;
    font-size: 1.1rem;
    font-weight: 700;
    cursor: pointer;
  }
  .share-toast {
    margin-top: 0.75rem;
    font-size: 0.8rem;
    color: #059669;
    font-weight: 600;
    animation: qFadeIn 0.3s ease;
  }

  /* ── Check-in Mode (Returning User) ── */
  .checkin-mode { padding: 1rem 0; }
  .checkin-badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }
  .checkin-badge span {
    font-size: 1.1rem;
    font-weight: 600;
    color: #92400e;
    background: linear-gradient(135deg, #fef3c7, #fffbeb);
    border: 1px solid #d97706;
    border-radius: 20px;
    padding: 0.3rem 1rem;
  }
  .mascot-badge {
    width: 120px;
    height: 120px;
    object-fit: contain;
  }
  .mascot-reward {
    width: 150px;
    height: 150px;
    object-fit: contain;
  }
  .checkin-subtitle {
    color: var(--text-secondary);
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }
  .checkin-big-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    width: 100%;
    max-width: 300px;
    margin: 1.5rem auto;
    padding: 1.2rem 2rem;
    background: #059669;
    color: white;
    border: none;
    border-radius: 16px;
    font-size: 1.3rem;
    font-weight: 700;
    cursor: pointer;
    box-shadow: 0 4px 15px rgba(5, 150, 105, 0.3);
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .checkin-big-btn:active {
    transform: scale(0.97);
    box-shadow: 0 2px 8px rgba(5, 150, 105, 0.3);
  }
  .checkin-big-icon { font-size: 1.6rem; }
  .checkin-upload-section {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }
  .upload-zone-mini {
    border: 2px dashed var(--border);
    border-radius: 12px;
    padding: 1rem;
    cursor: pointer;
    color: var(--text-secondary);
    font-size: 0.9rem;
    transition: border-color 0.2s;
  }
  .upload-zone-mini:hover { border-color: var(--accent-faith); }
  .photo-action-row {
    display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem;
  }
  .photo-btn {
    flex: 1; padding: 0.75rem 0.5rem; border: 2px solid var(--border);
    border-radius: 12px; background: var(--bg-card); cursor: pointer;
    font-size: 0.95rem; color: var(--text-primary); transition: all 0.2s;
  }
  .photo-btn:active { transform: scale(0.97); }
  .photo-btn-camera { border-color: var(--accent-faith); color: var(--accent-faith); font-weight: 600; }
  .photo-btn-camera:hover { background: rgba(76,175,80,0.08); }
  .photo-btn-save { border-color: #f59e0b; color: #f59e0b; font-weight: 600; font-size: 0.88rem; }
  .photo-btn-save:hover { background: rgba(245,158,11,0.08); }
  .photo-btn-save:disabled { opacity: 0.35; pointer-events: none; }
  .photo-save-toggle {
    display: flex; align-items: center; gap: 0.5rem;
    cursor: pointer; white-space: nowrap; user-select: none;
  }
  .photo-save-toggle input { display: none; }
  .toggle-slider {
    width: 44px; height: 24px; background: #ccc; border-radius: 12px;
    position: relative; transition: background 0.2s; flex-shrink: 0;
  }
  .toggle-slider::after {
    content: ''; position: absolute; top: 2px; left: 2px;
    width: 20px; height: 20px; background: white; border-radius: 50%;
    transition: transform 0.2s;
  }
  .photo-save-toggle input:checked + .toggle-slider {
    background: #059669;
  }
  .photo-save-toggle input:checked + .toggle-slider::after {
    transform: translateX(20px);
  }
  .toggle-text {
    font-size: 0.85rem; font-weight: 600; color: var(--text-secondary);
  }

  /* Photo status text (replaces thumbnails) */
  .photo-status {
    margin-top: 0.5rem;
    text-align: center;
  }
  .photo-status-text {
    display: block;
    font-size: 0.82rem;
    color: #888;
  }
  .photo-status-check {
    color: #059669;
    font-weight: 600;
  }
  .photo-status-thanks {
    display: block;
    font-size: 0.75rem;
    color: #aaa;
    margin-top: 0.15rem;
  }
  .photo-status-loading {
    color: #666;
  }
  .photo-status-error {
    color: #dc2626;
  }
  .photo-retry-btn {
    display: inline-block;
    margin-top: 0.4rem;
    padding: 0.3rem 0.8rem;
    font-size: 0.8rem;
    border: 1px solid #dc2626;
    border-radius: 6px;
    background: transparent;
    color: #dc2626;
    cursor: pointer;
  }
  .photo-retry-btn:hover { background: rgba(220,38,38,0.08); }

  .my-journey-link {
    display: inline-block;
    margin-top: 1.5rem;
    padding: 0.75rem 1.5rem;
    background: linear-gradient(135deg, #B45309, #92400e);
    color: #fff;
    border-radius: 12px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
  }

  .checkin-stats { margin: 1rem 0; }

  /* ── Daily Report Section ── */
  .daily-report-section {
    margin-top: 2rem;
    border: 1px solid var(--border-light);
    border-radius: 14px;
    overflow: hidden;
    background: var(--bg-card);
  }
  .daily-report-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.85rem 1rem;
    cursor: pointer;
    background: linear-gradient(135deg, rgba(5,150,105,0.06), rgba(5,150,105,0.02));
    font-weight: 600;
    font-size: 0.95rem;
    color: #059669;
    user-select: none;
    transition: background 0.2s;
  }
  .daily-report-header:hover {
    background: linear-gradient(135deg, rgba(5,150,105,0.1), rgba(5,150,105,0.04));
  }
  .daily-report-toggle {
    font-size: 0.8rem;
    color: var(--text-muted);
    font-weight: 500;
  }
  .daily-report-body {
    padding: 1rem;
  }
  .daily-report-hint {
    font-size: 0.82rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
    text-align: center;
  }
  .daily-section-label {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
    margin-top: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .daily-grid {
    gap: 0.5rem;
  }
  .daily-grid .transport-item {
    padding: 0.6rem 0.7rem;
  }
  .daily-grid .transport-label {
    font-size: 0.78rem;
    margin-bottom: 0.35rem;
  }
  .daily-carbon-result {
    background: linear-gradient(135deg, rgba(5,150,105,0.06), rgba(5,150,105,0.02));
    border: 1px solid rgba(5,150,105,0.15);
    border-radius: 12px;
    padding: 1rem;
    margin-top: 1rem;
  }
  .daily-submit-btn {
    width: 100%;
    margin-top: 1rem;
  }
  .daily-submit-status {
    text-align: center;
    font-size: 0.82rem;
    margin-top: 0.5rem;
    min-height: 1.2em;
  }
  .daily-cumulative {
    text-align: center;
    margin-top: 0.75rem;
    padding: 0.6rem;
    background: rgba(5,150,105,0.04);
    border-radius: 8px;
  }
  .hotel-toggle {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
    user-select: none;
  }
  .hotel-toggle input { display: none; }
  .hotel-toggle input:checked + .toggle-slider {
    background: #059669;
  }
  .hotel-toggle input:checked + .toggle-slider::after {
    transform: translateX(20px);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .tracker-map { height: 300px; }
    .upload-area { padding: 2rem 1rem; }
    .transport-grid { grid-template-columns: 1fr; }
    .transport-grid.cols-2 { grid-template-columns: 1fr 1fr; }
    .daily-grid { grid-template-columns: 1fr 1fr; }
    .done-stats { flex-direction: column; align-items: center; }
  }

  /* Participant Status Actions */
  .participant-actions { margin-top: 2rem; text-align: center; }
  .participant-divider { border-top: 1px solid var(--border); margin-bottom: 1.5rem; }
  .participant-btn {
    display: inline-block;
    padding: 0.6rem 1.5rem;
    border: none;
    border-radius: 8px;
    font-size: 0.9rem;
    cursor: pointer;
    margin: 0 0.25rem;
    transition: background 0.2s;
  }
  .participant-pause-btn { background: #f3f4f6; color: #666; border: 1px solid var(--border); }
  .participant-pause-btn:hover { background: #e5e7eb; }
  .participant-complete-btn { background: var(--accent-faith); color: white; }
  .participant-complete-btn:hover { background: #9a4408; }
