---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import AuthGate from '../_components/AuthGate.astro';
---

<BaseLayout
  title="活動紀錄 — 2026 白沙屯媽祖 ESG 永續進香"
  description="填寫問卷並上傳繞境照片，記錄你的進香足跡與善行體悟。"
  ogUrl="https://paulkuo.tw/projects/formosa-esg-2026/tracker/"
  ogImage="https://paulkuo.tw/images/formosa-esg-2026-og.png"
>

<AuthGate title="活動參與足跡紀錄" lineLogin={true}>

<div class="tracker">

  <!-- Test Mode Banner -->
  <div class="test-banner" id="testBanner" style="display:none">
    🔧 測試模式 — 資料可能隨時清除，正式活動 4/12 開始
  </div>

  <!-- Breadcrumb -->
  <nav class="tracker-breadcrumb">
    <a href="/projects/formosa-esg-2026/">← 回到專案總覽</a>
  </nav>

  <!-- Header -->
  <header class="tracker-header">
    <div class="tracker-badge">4/12 – 4/20 活動紀錄</div>
    <h1>2026 白沙屯媽祖徒步進香</h1>
    <p>活動參與足跡紀錄</p>
  </header>

  <!-- GPS Tracking Banner -->
  <div class="gps-banner" id="gpsBanner">
    <div class="gps-banner-inner">
      <div class="gps-pulse" id="gpsPulse"></div>
      <div class="gps-banner-text">
        <span id="gpsStatus">📍 定位中（自動記錄行走路線）...</span>
        <span class="gps-count" id="gpsCount"></span>
      </div>
      <button class="gps-checkin-btn" id="gpsCheckinBtn" style="display:none" onclick="manualCheckin()">打卡 📍</button>
    </div>
  </div>

  <!-- ═══ Linear Progress Bar ═══ -->
  <div class="q-progress" id="qProgress">
    <div class="q-progress-bar">
      <div class="q-progress-fill" id="qProgressFill"></div>
    </div>
    <div class="q-progress-text" id="qProgressText">第 1 / 11 題</div>
  </div>

  <!-- ═══════════════════════════════════════════ -->
  <!-- ONE QUESTION PER CARD                      -->
  <!-- ═══════════════════════════════════════════ -->

  <!-- Q1 -->
  <div class="q-card active" data-q="1" data-section="善行體悟">
    <div class="q-section-tag">第一部份：善行、行善</div>
    <label class="form-label">Q1. 您於此次進香期間，有參與以下哪些善行活動？<span class="form-hint">（可複選，選完請按下一題）</span></label>
    <div class="checkbox-group" data-name="q1" data-required="true">
      <label class="checkbox-item"><input type="checkbox" name="q1" value="環球境地志工，協助整理沿路環境設施"><span>環球境地志工，協助整理沿路環境設施</span></label>
      <label class="checkbox-item"><input type="checkbox" name="q1" value="提供飲水/補給品給香客"><span>提供飲水/補給品給香客</span></label>
      <label class="checkbox-item"><input type="checkbox" name="q1" value="參與環境清潔或垃圾分類"><span>參與環境清潔或垃圾分類</span></label>
      <label class="checkbox-item"><input type="checkbox" name="q1" value="協助老人、小孩、安全引導"><span>協助老人、小孩、安全引導</span></label>
      <label class="checkbox-item"><input type="checkbox" name="q1" value="默禱/祈福"><span>默禱/祈福</span></label>
      <label class="checkbox-item"><input type="checkbox" name="q1" value="協助他人搬運物資"><span>協助他人搬運物資</span></label>
      <label class="checkbox-item"><input type="checkbox" name="q1" value="協助環球境地夥伴-參與奉獻佈施"><span>協助環球境地夥伴 - 參與奉獻佈施</span></label>
      <label class="checkbox-item other-item">
        <input type="checkbox" name="q1" value="__other__"><span>其他</span>
        <input type="text" class="other-input" placeholder="請說明..." style="display:none" />
      </label>
    </div>
    <div class="q-nav">
      <div></div>
      <button class="btn btn-next" onclick="goQ(1)">下一題 →</button>
    </div>
  </div>

  <!-- Q2 -->
  <div class="q-card" data-q="2">
    <label class="form-label">Q2. 您於此次進香期間，被感動的事情？<span class="form-hint">（可複選，選完請按下一題）</span></label>
    <div class="checkbox-group" data-name="q2" data-required="true">
      <label class="checkbox-item"><input type="checkbox" name="q2" value="看到或感受到媽祖的神跡"><span>看到或感受到媽祖的神跡</span></label>
      <label class="checkbox-item"><input type="checkbox" name="q2" value="看到彼此扶助的行為"><span>看到彼此扶助的行為</span></label>
      <label class="checkbox-item"><input type="checkbox" name="q2" value="看到自我約束的自律行為"><span>看到自我約束的自律行為</span></label>
      <label class="checkbox-item"><input type="checkbox" name="q2" value="看到自我改變、改善或悔改的行為"><span>看到自我改變、改善或悔改的行為</span></label>
      <label class="checkbox-item"><input type="checkbox" name="q2" value="善心開導、包容關愛"><span>善心開導、包容關愛</span></label>
      <label class="checkbox-item"><input type="checkbox" name="q2" value="自備餐具容器、自覺減少垃圾"><span>自備餐具容器、自覺減少垃圾</span></label>
      <label class="checkbox-item"><input type="checkbox" name="q2" value="協助清理垃圾、撿拾廢棄物"><span>協助清理垃圾、撿拾廢棄物</span></label>
      <label class="checkbox-item"><input type="checkbox" name="q2" value="協助減少污染、自覺減少環境影響"><span>協助減少污染、自覺減少環境影響</span></label>
      <label class="checkbox-item"><input type="checkbox" name="q2" value="自願共乘、互相協助解決交通問題"><span>自願共乘、互相協助解決交通問題</span></label>
      <label class="checkbox-item other-item">
        <input type="checkbox" name="q2" value="__other__"><span>其他</span>
        <input type="text" class="other-input" placeholder="請說明..." style="display:none" />
      </label>
    </div>
    <div class="q-nav">
      <button class="btn btn-back" onclick="goQ(-1)">← 上一題</button>
      <button class="btn btn-next" onclick="goQ(1)">下一題 →</button>
    </div>
  </div>

  <!-- Q2-1 -->
  <div class="q-card" data-q="3">
    <label class="form-label">Q2-1. 請分享您被感動幾次及最讓您感動的一次「善的經驗」？<span class="form-hint">（選填，可跳過）</span></label>
    <textarea class="form-textarea" id="q2_1" rows="5" placeholder="在這裡分享您的故事..."></textarea>
    <div class="q-nav">
      <button class="btn btn-back" onclick="goQ(-1)">← 上一題</button>
      <button class="btn btn-next" onclick="goQ(1)">下一題 →</button>
    </div>
  </div>

  <!-- Q3 -->
  <div class="q-card" data-q="4">
    <label class="form-label">Q3. 此次活動是否讓您更深刻體會到「行善」的價值？</label>
    <div class="radio-group" data-name="q3" data-required="true" data-auto="true">
      <label class="radio-item"><input type="radio" name="q3" value="非常同意"><span>非常同意</span></label>
      <label class="radio-item"><input type="radio" name="q3" value="同意"><span>同意</span></label>
      <label class="radio-item"><input type="radio" name="q3" value="普通"><span>普通</span></label>
      <label class="radio-item"><input type="radio" name="q3" value="不同意"><span>不同意</span></label>
      <label class="radio-item"><input type="radio" name="q3" value="非常不同意"><span>非常不同意</span></label>
    </div>
    <div class="q-nav">
      <button class="btn btn-back" onclick="goQ(-1)">← 上一題</button>
      <button class="btn btn-next" onclick="goQ(1)">下一題 →</button>
    </div>
  </div>

  <!-- Q4 -->
  <div class="q-card" data-q="5" data-section="活動後的改變">
    <div class="q-section-tag">第二部份：活動後的改變</div>
    <label class="form-label">Q4. 進香結束後，您是否有意願在日常生活中延續「行善」的心？</label>
    <div class="radio-group" data-name="q4" data-required="true" data-auto="true">
      <label class="radio-item"><input type="radio" name="q4" value="有，會更積極參與"><span>有，會更積極參與</span></label>
      <label class="radio-item"><input type="radio" name="q4" value="可能會有影響"><span>可能會有影響</span></label>
      <label class="radio-item"><input type="radio" name="q4" value="不確定"><span>不確定</span></label>
      <label class="radio-item"><input type="radio" name="q4" value="沒有特別改變"><span>沒有特別改變</span></label>
    </div>
    <div class="q-nav">
      <button class="btn btn-back" onclick="goQ(-1)">← 上一題</button>
      <button class="btn btn-next" onclick="goQ(1)">下一題 →</button>
    </div>
  </div>

  <!-- Q5 -->
  <div class="q-card" data-q="6">
    <label class="form-label">Q5. 您計畫在未來做哪些善的行動？<span class="form-hint">（可複選，選完請按下一題）</span></label>
    <div class="checkbox-group" data-name="q5" data-required="true">
      <label class="checkbox-item"><input type="checkbox" name="q5" value="志工服務"><span>志工服務</span></label>
      <label class="checkbox-item"><input type="checkbox" name="q5" value="捐款或物資支持公益團體"><span>捐款或物資支持公益團體</span></label>
      <label class="checkbox-item"><input type="checkbox" name="q5" value="鼓勵親友參與善行"><span>鼓勵親友參與善行</span></label>
      <label class="checkbox-item"><input type="checkbox" name="q5" value="在公司/組織內推動CSR或ESG相關善行"><span>在公司/組織內推動 CSR 或 ESG 相關善行</span></label>
      <label class="checkbox-item"><input type="checkbox" name="q5" value="日常生活中更多關懷他人"><span>日常生活中更多關懷他人</span></label>
      <label class="checkbox-item other-item">
        <input type="checkbox" name="q5" value="__other__"><span>其他</span>
        <input type="text" class="other-input" placeholder="請說明..." style="display:none" />
      </label>
    </div>
    <div class="q-nav">
      <button class="btn btn-back" onclick="goQ(-1)">← 上一題</button>
      <button class="btn btn-next" onclick="goQ(1)">下一題 →</button>
    </div>
  </div>

  <!-- Q6 -->
  <div class="q-card" data-q="7">
    <label class="form-label">Q6. 若您來自企業或組織，是否會考慮將此次體驗轉化為企業的社會責任行動？</label>
    <div class="radio-group" data-name="q6" data-required="true" data-auto="true">
      <label class="radio-item"><input type="radio" name="q6" value="會，並已著手規劃"><span>會，並已著手規劃</span></label>
      <label class="radio-item"><input type="radio" name="q6" value="有此想法，尚在討論"><span>有此想法，尚在討論</span></label>
      <label class="radio-item"><input type="radio" name="q6" value="我是個人參與者，非企業身份，但願意投入"><span>我是個人參與者，非企業身份，但願意投入</span></label>
      <label class="radio-item"><input type="radio" name="q6" value="不可能"><span>不可能</span></label>
    </div>
    <div class="q-nav">
      <button class="btn btn-back" onclick="goQ(-1)">← 上一題</button>
      <button class="btn btn-next" onclick="goQ(1)">下一題 →</button>
    </div>
  </div>

  <!-- Q7: 身分 -->
  <div class="q-card" data-q="8" data-section="基本資料與環境影響">
    <div class="q-section-tag">第三部份：基本資料與環境影響</div>
    <label class="form-label">請問您是以什麼身分參與本活動？</label>
    <div class="radio-group" data-name="role" data-auto="true">
      <label class="radio-item"><input type="radio" name="role" value="主辦方"><span>主辦方</span></label>
      <label class="radio-item"><input type="radio" name="role" value="參與人" checked><span>參與人</span></label>
    </div>
    <div class="q-nav">
      <button class="btn btn-back" onclick="goQ(-1)">← 上一題</button>
      <button class="btn btn-next" onclick="goQ(1)">下一題 →</button>
    </div>
  </div>

  <!-- (Q8-Q10 交通/碳足跡已移至每日回報，不在一次性問卷中) -->

  <!-- Q11: 照片上傳 -->
  <div class="q-card" data-q="9" data-section="照片上傳">
    <div class="q-section-tag">第四部份：照片上傳與足跡定位</div>
    <label class="form-label">上傳進香途中拍攝的照片<span class="form-hint">（需開啟定位，系統自動提取 GPS 座標）</span></label>

    <div class="upload-area" id="uploadArea">
      <div class="upload-icon">📷</div>
      <p class="upload-text">點擊選取照片或拖曳到這裡</p>
      <p class="upload-hint">支援 JPEG 格式，會自動讀取照片中的 GPS 資訊</p>
      <p class="upload-hint" style="color:#aaa;font-size:0.72rem;margin-top:0.25rem">照片不會上傳到伺服器，僅讀取照片中的 GPS 定位資訊作為路徑紀錄</p>
      <input type="file" id="photoInput" accept="image/jpeg,image/jpg" multiple hidden />
    </div>

    <div id="status" class="tracker-status" style="display:none"></div>

    <section id="resultsSection" style="display:none">
      <h3 class="form-label">提取結果</h3>
      <div class="results-summary" id="resultsSummary"></div>
      <div class="results-list" id="resultsList"></div>
    </section>

    <section id="mapSection" style="display:none;margin-top:1.5rem">
      <h3 class="form-label">地圖標記</h3>
      <div id="map" class="tracker-map"></div>
    </section>

    <div class="q-nav" style="margin-top:2rem">
      <button class="btn btn-back" onclick="goQ(-1)">← 上一題</button>
      <button class="btn btn-next" onclick="goQ(1)">下一題 →</button>
    </div>
  </div>

  <!-- Q12: 手機號碼（選填） -->
  <div class="q-card" data-q="10">
    <label class="form-label">手機號碼<span class="form-hint">（選填）</span></label>
    <p style="color:var(--text-secondary);font-size:0.82rem;margin-bottom:1rem;line-height:1.5">用於活動後續通知與合作夥伴優惠</p>
    <input type="tel" id="phoneInput" class="transport-input" placeholder="0912-345-678" style="width:100%;max-width:280px;font-size:1rem;padding:0.6rem 0.8rem;border:1px solid var(--border);border-radius:8px;background:var(--card-bg);color:var(--text-primary)">
    <div class="q-nav">
      <button class="btn btn-back" onclick="goQ(-1)">← 上一題</button>
      <button class="btn btn-next" onclick="goQ(1)">下一題 →</button>
    </div>
  </div>

  <!-- Q13: 確認提交 -->
  <div class="q-card" data-q="11">
    <div style="text-align:center;padding:1rem 0">
      <div style="font-size:3rem;margin-bottom:1rem">✅</div>
      <label class="form-label" style="text-align:center;font-size:1.2rem">確認提交</label>
      <p style="color:var(--text-secondary);font-size:0.9rem;margin-bottom:2rem;line-height:1.6">
        您已完成所有問題。<br>點擊下方按鈕提交您的活動紀錄。
      </p>
      <button class="btn btn-submit" id="submitBtn" onclick="handleSubmit()">完成提交 ✓</button>
    </div>
    <div class="q-nav" style="margin-top:1.5rem">
      <button class="btn btn-back" onclick="goQ(-1)">← 回到上一題</button>
      <div></div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════ -->
  <!-- SUCCESS SCREEN                              -->
  <!-- ═══════════════════════════════════════════ -->
  <div class="q-card" data-q="done" id="stepDone" style="text-align:center">
    <div class="done-icon">🙏</div>
    <h2 class="done-title">感謝您的參與！</h2>
    <p class="done-text">您的活動紀錄已成功提交。<br>願媽祖保佑平安順利。</p>
    <div class="done-summary" id="doneSummary"></div>
    <!-- 善行者獎勵卡 -->
    <div class="reward-card" id="rewardCard">
      <div class="reward-card-inner">
        <div class="reward-badge"><img src="/images/formosa/level-1.png" class="mascot-reward" alt="煉氣香客"></div>
        <div class="reward-title">✦ 煉氣香客 ✦</div>
        <div class="reward-subtitle">白沙屯媽祖 ESG 進香 2026</div>
        <div class="reward-stats" id="rewardStats"></div>
        <div class="reward-date" id="rewardDate"></div>
        <div class="reward-next">📍 持續打卡，升級為 🧱 築基香客</div>
      </div>
    </div>
    <!-- Share button (simplified) -->
    <div class="share-section" id="shareSection">
      <button class="share-primary-btn" id="sharePrimaryBtn" onclick="smartShare()">📤 分享給朋友一起參與</button>
      <div class="share-toast" id="shareToast" style="display:none">已複製到剪貼簿！</div>
    </div>
    <a href="/projects/formosa-esg-2026/my/" class="my-journey-link">📊 查看我的進香足跡</a>
  </div>

  <!-- ═══════════════════════════════════════════ -->
  <!-- RETURNING USER: CHECK-IN MODE               -->
  <!-- ═══════════════════════════════════════════ -->
  <div class="q-card" data-q="checkin" id="stepCheckin" style="text-align:center">
    <div class="checkin-mode">
      <div class="checkin-badge" id="checkinBadge"><img src="/images/formosa/level-1.png" class="mascot-badge" alt="煉氣香客"><span>煉氣香客</span></div>
      <h2>歡迎回來！</h2>
      <p class="checkin-subtitle">問卷已完成。您可以繼續打卡記錄足跡。</p>

      <div class="checkin-stats" id="checkinStats"></div>

      <button class="checkin-big-btn" onclick="manualCheckin()">
        <span class="checkin-big-icon">📍</span>
        <span>立即打卡</span>
      </button>
      <div class="test-checkin-label" id="testCheckinLabel" style="display:none">（測試中）</div>

      <div class="checkin-upload-section">
        <p style="margin-bottom:0.25rem;color:#888;font-size:0.85rem;">或拍照記錄位置</p>
        <p style="margin-bottom:0.5rem;color:#aaa;font-size:0.72rem;">照片不會上傳到伺服器，僅讀取 GPS 定位資訊作為路徑紀錄</p>
        <div class="photo-action-row">
          <button type="button" class="photo-btn photo-btn-camera" id="cameraBtnMini">📷 拍照</button>
          <button type="button" class="photo-btn photo-btn-save" id="photoSaveBtn" disabled onclick="saveLastPhoto()">📥 活動照存檔</button>
        </div>
        <input type="file" accept="image/jpeg,image/png,image/heic,image/heif" capture="environment" id="photoCameraMini" style="display:none">
        <div id="photoStatusMini" class="photo-status"></div>
      </div>

      <div class="checkin-progress" id="checkinProgress"></div>

      <!-- Daily Carbon Report -->
      <div class="daily-report-section" id="dailyReportSection">
        <div class="daily-report-header" onclick="toggleDailyReport()">
          <span>🌱 今日善足跡回報</span>
          <span class="daily-report-toggle" id="dailyReportToggle">展開 ▼</span>
        </div>
        <div class="daily-report-body" id="dailyReportBody" style="display:none">
          <p class="daily-report-hint">每天花 30 秒記錄，碳足跡更精確</p>

          <div class="daily-section-label">環境影響</div>
          <p class="daily-report-hint" style="font-size:0.85rem;color:#6b7280;margin:0 0 0.5rem;">交通碳排由 GPS 軌跡自動推算，不需手動填寫</p>
          <div class="transport-grid daily-grid cols-2">
            <div class="transport-item"><label class="transport-label">🧴 瓶裝水</label><div class="transport-input-wrap"><input type="number" class="transport-input dr-input" id="dr_water" value="0" min="0" step="1" /><span class="transport-unit">瓶</span></div></div>
            <div class="transport-item"><label class="transport-label">♻️ 回收水瓶</label><div class="transport-input-wrap"><input type="number" class="transport-input dr-input" id="dr_recycle" value="0" min="0" step="1" /><span class="transport-unit">瓶</span></div></div>
            <div class="transport-item"><label class="transport-label">🏨 今天有住宿</label><div class="transport-input-wrap"><label class="hotel-toggle"><input type="checkbox" id="dr_hotel" /><span class="toggle-slider"></span><span class="toggle-text">有</span></label></div></div>
          </div>

          <div class="daily-carbon-result" id="dailyCarbonResult" style="display:none">
            <div class="carbon-title">今日碳足跡</div>
            <div class="carbon-total" id="dailyCarbonTotal">0.00 <small>kg CO₂e</small></div>
