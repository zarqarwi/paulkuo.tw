      '<button type="button" class="photo-save-dismiss" id="dismissSaveBtn">✕</button>' +
      '</div>';
    container.style.display = 'block';

    document.getElementById('saveToDeviceBtn').addEventListener('click', async function() {
      for (var i = 0; i < pendingSaveFiles.length; i++) {
        var f = pendingSaveFiles[i];
        try {
          var ts = new Date().toISOString().replace(/[:.]/g, '-').slice(0, 19);
          var ext = (f.name.split('.').pop() || 'jpg').toLowerCase();
          var shareFile = new File([f], 'formosa-' + ts + '-' + i + '.' + ext, { type: f.type });
          if (navigator.canShare({ files: [shareFile] })) {
            await navigator.share({ files: [shareFile] });
          }
        } catch (e) {
          if (e.name === 'AbortError') break; // user cancelled
        }
      }
      pendingSaveFiles = [];
      container.style.display = 'none';
    });

    document.getElementById('dismissSaveBtn').addEventListener('click', function() {
      pendingSaveFiles = [];
      container.style.display = 'none';
    });
