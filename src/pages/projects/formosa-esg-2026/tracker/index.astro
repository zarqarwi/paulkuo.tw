<!-- Leaflet CSS + JS -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" />
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>

<!-- All logic (LIFF SDK loaded by AuthGate) -->
<script is:inline>
(function() {
  // ── LINE LIFF pull-to-close prevention ──
  var lastTouchY = 0;
  document.addEventListener('touchstart', function(e) {
    lastTouchY = e.touches[0].clientY;
  }, { passive: true });
  document.addEventListener('touchmove', function(e) {
    var touchY = e.touches[0].clientY;
    if (window.scrollY === 0 && touchY > lastTouchY) {
      e.preventDefault();
    }
  }, { passive: false });

  // ── Config ──
  var TEST_MODE = new URLSearchParams(location.search).has('test');
  var API_BASE = 'https://paulkuo-ticker.paul-4bf.workers.dev';

  // ── Safe localStorage helpers (LINE in-app privacy mode safe) ──
  function lsGet(key, fallback) {
    try { return localStorage.getItem(key) || fallback; } catch(e) { return fallback; }
  }
  function lsSet(key, val) {
    try { localStorage.setItem(key, val); } catch(e) {}
  }
  function lsRemove(key) {
    try { localStorage.removeItem(key); } catch(e) {}
  }

  // ── Test Mode Banner ──
  if (TEST_MODE) {
    var tb = document.getElementById('testBanner');
    if (tb) tb.style.display = 'block';
    var tcl = document.getElementById('testCheckinLabel');
    if (tcl) tcl.style.display = 'block';
  }

  // ── LINE User Identity (set by AuthGate LIFF login) ──
  var lineUserId = window.__lineUserId || lsGet('formosa_line_user_id') || null;

  // ── Background GPS Tracking ──
  // Restore saved GPS track from localStorage
  var gpsTrackPoints = [];
  try {
    var saved = JSON.parse(lsGet('formosa_gps_track') || '[]');
    gpsTrackPoints = saved.map(function(p) { return { lat: p.lat, lng: p.lng, datetime: p.datetime, source: p.source || 'saved' }; });
  } catch(e) {}
  var gpsReady = false;

  function startGPSTracking() {
    var statusEl = document.getElementById('gpsStatus');
    var countEl = document.getElementById('gpsCount');
    var pulseEl = document.getElementById('gpsPulse');
    var checkinBtn = document.getElementById('gpsCheckinBtn');

    if (!navigator.geolocation) {
      statusEl.textContent = '⚠️ 此裝置不支援定位';
      pulseEl.classList.add('off');
      return;
    }

    window.__gpsWatchId = navigator.geolocation.watchPosition(
      function(pos) {
        gpsReady = true;
        pulseEl.classList.add('active');
        checkinBtn.style.display = 'inline-block';

        var pt = {
          lat: pos.coords.latitude,
          lng: pos.coords.longitude,
          altitude: pos.coords.altitude,
          accuracy: pos.coords.accuracy,
          datetime: new Date().toISOString(),
          source: 'auto',
          filename: 'GPS 自動追蹤'
        };

        var last = gpsTrackPoints[gpsTrackPoints.length - 1];
        if (last) {
          var dist = haversine(last.lat, last.lng, pt.lat, pt.lng);
          var timeDiff = new Date(pt.datetime) - new Date(last.datetime);
          if (dist < 0.01 && timeDiff < 30000) {
            statusEl.textContent = '📍 追蹤中 — 等待移動...';
            return;
          }
        }

        gpsTrackPoints.push(pt);
        statusEl.textContent = '📍 追蹤中';
        countEl.textContent = gpsTrackPoints.length + ' 次 GPS 記錄';
      },
      function(err) {
        if (err.code === 1) {
          // Permission denied — show clear warning
          pulseEl.classList.remove('active');
          pulseEl.classList.add('off');
          statusEl.textContent = '⚠️ 定位權限被拒絕，請到設定開啟';
          checkinBtn.style.display = 'none';
        } else {
          // Temporary failure (signal weak / timeout) — keep calm
          if (!gpsReady) {
            statusEl.textContent = '📍 GPS 搜尋中...';
          }
          // watchPosition will auto-retry, no action needed
        }
      },
      { enableHighAccuracy: true, maximumAge: 10000, timeout: 15000 }
    );
  }

  window.manualCheckin = function() {
    var btn = document.getElementById('gpsCheckinBtn');
    if (btn) {
      btn.disabled = true;
      btn.dataset.origText = btn.textContent;
      btn.textContent = '📍 定位中...';
    }

    navigator.geolocation.getCurrentPosition(
      function(pos) {
        gpsTrackPoints.push({
          lat: pos.coords.latitude,
          lng: pos.coords.longitude,
          altitude: pos.coords.altitude,
          accuracy: pos.coords.accuracy,
          datetime: new Date().toISOString(),
          source: 'manual',
          filename: '手動打卡 #' + (gpsTrackPoints.filter(function(p){return p.source==='manual'}).length + 1)
        });
        var countEl = document.getElementById('gpsCount');
        countEl.textContent = gpsTrackPoints.length + ' 次 GPS 記錄';

        if (btn) {
          btn.textContent = '✓ 已打卡';
          btn.disabled = true;
          setTimeout(function() { btn.textContent = btn.dataset.origText || '打卡 📍'; btn.disabled = false; }, 1500);
        }
      },
      function(err) {
        if (btn) {
          btn.textContent = btn.dataset.origText || '打卡 📍';
          btn.disabled = false;
        }
        if (err.code === 1) {
          alert('定位權限被拒絕，請到手機設定開啟定位權限。');
        } else if (err.code === 3) {
          showPhotoToast('📍 GPS 訊號弱，請到空曠處再試', 3000);
        } else {
          showPhotoToast('📍 暫時無法定位，請稍後再試', 3000);
        }
      },
      { enableHighAccuracy: true, timeout: 10000 }
    );
  };

  function haversine(lat1, lng1, lat2, lng2) {
    var R = 6371;
    var dLat = (lat2 - lat1) * Math.PI / 180;
    var dLng = (lng2 - lng1) * Math.PI / 180;
    var a = Math.sin(dLat/2) * Math.sin(dLat/2) +
            Math.cos(lat1 * Math.PI/180) * Math.cos(lat2 * Math.PI/180) *
            Math.sin(dLng/2) * Math.sin(dLng/2);
    return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
  }

  startGPSTracking();

  // ── One-Question-Per-Card System ──
  var cards = document.querySelectorAll('.q-card[data-q]');
  var totalQ = 11; // numbered questions (1-11, Q8-Q10 transport/carbon moved to daily report)
  var curQ = 1;
  var autoTimer = null;

  function showCard(q) {
    cards.forEach(function(c) {
      var cq = c.getAttribute('data-q');
      if (cq === String(q)) {
        c.classList.add('active');
      } else {
        c.classList.remove('active');
      }
    });

    // Update progress bar
    if (typeof q === 'number' && q >= 1 && q <= totalQ) {
      var pct = ((q - 1) / (totalQ - 1)) * 100;
      document.getElementById('qProgressFill').style.width = pct + '%';
      document.getElementById('qProgressText').textContent = '第 ' + q + ' / ' + totalQ + ' 題';
      document.getElementById('qProgress').style.display = '';
    } else {
      document.getElementById('qProgress').style.display = 'none';
    }

    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  // Navigate: direction = +1 or -1
  window.goQ = function(dir) {
    if (autoTimer) { clearTimeout(autoTimer); autoTimer = null; }
    var next = curQ + dir;
    if (next < 1 || next > totalQ) return;

    // Validate current question before going forward
    if (dir > 0 && !validateQuestion(curQ)) return;

    curQ = next;
    showCard(curQ);
  };

  function validateQuestion(q) {
    var card = document.querySelector('.q-card[data-q="' + q + '"]');
    if (!card) return true;

    var req = card.querySelector('[data-required="true"]');
    if (!req) return true;

    var name = req.getAttribute('data-name');
    if (!name) return true;

    var checked = card.querySelectorAll('input[name="' + name + '"]:checked');
    if (checked.length === 0) {
      // Show inline error with scroll + shake animation
      var existing = card.querySelector('.q-error');
      if (!existing) {
        var err = document.createElement('div');
        err.className = 'q-error q-error-shake';
        err.textContent = '⚠ 請至少選擇一個選項';
        req.parentNode.insertBefore(err, req.nextSibling);
      } else {
        existing.classList.remove('q-error-shake');
        void existing.offsetWidth;
        existing.classList.add('q-error-shake');
      }
      var errEl2 = card.querySelector('.q-error');
      if (errEl2) errEl2.scrollIntoView({ behavior: 'smooth', block: 'center' });
      return false;
    }
    // Clear error if exists
    var errEl = card.querySelector('.q-error');
    if (errEl) errEl.remove();
    return true;
  }

  // Auto-advance on radio selection
  document.querySelectorAll('.radio-group[data-auto="true"] input[type="radio"]').forEach(function(radio) {
    radio.addEventListener('change', function() {
      if (autoTimer) clearTimeout(autoTimer);
      // Highlight selected item
      var group = this.closest('.radio-group');
      group.querySelectorAll('.radio-item').forEach(function(item) {
        item.classList.remove('selected');
      });
      this.closest('.radio-item').classList.add('selected');

      // Auto advance after 400ms
      autoTimer = setTimeout(function() {
        goQ(1);
      }, 400);
    });
  });

  // Highlight checkbox items on change
  document.querySelectorAll('.checkbox-group input[type="checkbox"]').forEach(function(cb) {
    cb.addEventListener('change', function() {
      this.closest('.checkbox-item').classList.toggle('selected', this.checked);
    });
  });

  // Other checkbox toggle
  document.querySelectorAll('.other-item input[type="checkbox"]').forEach(function(cb) {
    cb.addEventListener('change', function() {
      var textInput = this.closest('.other-item').querySelector('.other-input');
      if (textInput) textInput.style.display = this.checked ? 'block' : 'none';
    });
  });

  // ── Daily Report Carbon Calculator (SSBTi / Ecoinvent 3.10) ──
  var DR_FACTORS = {
    walk: 0, car: 0.30479, scooter: 0.13734, bike: 0.01220,
    bus: 0.47515, mrt: 0.07575, train: 0.07575, hsr: 0.07487,
    water: 0.10974, recycle: -0.00265, hotel: 12.5
  };
  var DR_LABELS = {
    walk: '步行', car: '開車', scooter: '機車', bike: '腳踏車',
    bus: '公車', mrt: '捷運', train: '火車', hsr: '高鐵',
    water: '瓶裝水', recycle: '♻️ 回收水瓶', hotel: '旅宿'
  };

  function getDrVal(id) {
    var el = document.getElementById(id);
    if (!el) return 0;
    if (el.type === 'checkbox') return el.checked ? 1 : 0;
    return parseFloat(el.value) || 0;
  }

  function calcDailyCarbon() {
    // Transport is now GPS-inferred; daily report only covers non-transport items
    var breakdown = {};
    breakdown.water = getDrVal('dr_water') * DR_FACTORS.water;
    breakdown.recycle = getDrVal('dr_recycle') * DR_FACTORS.recycle;
    breakdown.hotel = getDrVal('dr_hotel') * DR_FACTORS.hotel;

    var total = 0;
    for (var k in breakdown) total += breakdown[k];

    // Update UI
    var resultEl = document.getElementById('dailyCarbonResult');
    if (resultEl) resultEl.style.display = '';

    var totalEl = document.getElementById('dailyCarbonTotal');
    if (totalEl) totalEl.innerHTML = total.toFixed(2) + ' <small>kg CO₂e</small>';

    var bdEl = document.getElementById('dailyCarbonBreakdown');
    if (bdEl) {
      var html = '';
      for (var k in breakdown) {
        if (breakdown[k] > 0) {
          html += '<div class="carbon-row"><span>' + DR_LABELS[k] + '</span><span>' + breakdown[k].toFixed(2) + ' kg</span></div>';
        } else if (breakdown[k] < 0) {
          html += '<div class="carbon-row carbon-offset"><span>' + DR_LABELS[k] + '</span><span>♻️ ' + breakdown[k].toFixed(4) + ' kg</span></div>';
        }
      }
      bdEl.innerHTML = html;
    }

    return { total: total, breakdown: breakdown };
  }

  // Live preview carbon as user types
  document.querySelectorAll('.dr-input').forEach(function(input) {
    input.addEventListener('input', calcDailyCarbon);
  });
  // Hotel checkbox also triggers
  var hotelCb = document.getElementById('dr_hotel');
  if (hotelCb) hotelCb.addEventListener('change', calcDailyCarbon);

  // ── Toggle daily report panel ──
  window.toggleDailyReport = function() {
    var body = document.getElementById('dailyReportBody');
    var toggle = document.getElementById('dailyReportToggle');
    if (!body) return;
    if (body.style.display === 'none') {
      body.style.display = '';
      toggle.textContent = '收合 ▲';
    } else {
      body.style.display = 'none';
      toggle.textContent = '展開 ▼';
    }
  };

  // ── Submit daily report ──
  window.submitDailyReport = async function() {
    var userId = lineUserId || lsGet('formosa_user_id') || '';
    if (!userId) { alert('請先完成 LINE 登入'); return; }

    var btn = document.getElementById('dailySubmitBtn');
    var statusEl = document.getElementById('dailySubmitStatus');
    if (btn) { btn.disabled = true; btn.textContent = '送出中...'; }

    var today = new Date().toISOString().slice(0, 10); // YYYY-MM-DD

    var payload = {
      line_user_id: userId,
      report_date: today,
      water_bottles: getDrVal('dr_water'),
      recycle_bottles: getDrVal('dr_recycle'),
      hotel: getDrVal('dr_hotel')
    };

    try {
      var resp = await fetch(API_BASE + '/api/formosa/daily-report', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      var result = await resp.json();

      if (resp.ok) {
        if (statusEl) statusEl.innerHTML = '<span style="color:#059669">✓ 已儲存 ' + today + ' 的回報</span>';
        // Update local carbon cache
        if (result.gwp !== undefined) {
          lsSet('formosa_carbon_today', result.gwp.toFixed(2));
        }
        // Show cumulative
        loadDailyCumulative(userId);
        // Update checkin stats carbon display
        var statsCarbon = document.querySelector('#checkinStats .done-stat:last-child strong');
        if (statsCarbon && result.gwp !== undefined) {
          statsCarbon.textContent = result.gwp.toFixed(1);
        }
      } else {
        if (statusEl) statusEl.innerHTML = '<span style="color:#dc2626">⚠ 儲存失敗：' + (result.error || '請稍後再試') + '</span>';
      }
    } catch (e) {
      if (statusEl) statusEl.innerHTML = '<span style="color:#dc2626">⚠ 網路錯誤，請稍後再試</span>';
    }

    if (btn) { btn.disabled = false; btn.textContent = '送出今日回報'; }
  };

  // ── Load existing daily report for today + cumulative ──
  async function loadTodayReport(userId) {
    if (!userId) return;
    try {
      var resp = await fetch(API_BASE + '/api/formosa/daily-report?user_id=' + encodeURIComponent(userId));
      if (!resp.ok) return;
      var data = await resp.json();
      if (!data || !data.reports) return;

      // Find today's report
      var today = new Date(Date.now() + 8 * 3600 * 1000).toISOString().slice(0, 10); // TW timezone
      var todayReport = data.reports.find(function(r) { return r.report_date === today; });
      if (todayReport) {
        var r = todayReport;
        var fields = { dr_water: r.water_bottles, dr_recycle: r.recycle_bottles };
        for (var id in fields) {
          var el = document.getElementById(id);
          if (el && fields[id]) el.value = fields[id];
        }
        var hotelEl = document.getElementById('dr_hotel');
        if (hotelEl) hotelEl.checked = !!r.hotel;
        calcDailyCarbon();
      }

      // Update cumulative display
      if (data.reports.length > 0) {
        var totalCarbon = data.total_gwp || 0;
        var cumEl = document.getElementById('dailyCumulative');
        if (cumEl) cumEl.style.display = '';
        var totalEl = document.getElementById('dailyCumulativeTotal');
        if (totalEl) totalEl.textContent = totalCarbon.toFixed(2);
        var daysEl = document.getElementById('dailyReportDays');
        if (daysEl) daysEl.textContent = data.count || data.reports.length;
        lsSet('formosa_carbon', totalCarbon.toFixed(2));
      }
    } catch (e) { /* offline */ }
  }

  // Alias for backward compat
  var loadDailyCumulative = loadTodayReport;

  // ── Collect all form data ──
  function collectCheckbox(name) {
    var vals = [];
    document.querySelectorAll('input[name="' + name + '"]:checked').forEach(function(cb) {
      if (cb.value === '__other__') {
        var t = cb.closest('.other-item').querySelector('.other-input');
        if (t && t.value.trim()) vals.push(t.value.trim());
      } else {
        vals.push(cb.value);
      }
    });
    return vals;
  }

  function collectRadio(name) {
    var el = document.querySelector('input[name="' + name + '"]:checked');
    return el ? el.value : '';
  }

  function collectAllData() {
    return {
      timestamp: new Date().toISOString(),
      survey: {
        q1: collectCheckbox('q1'),
        q2: collectCheckbox('q2'),
        q2_1: document.getElementById('q2_1').value.trim(),
        q3: collectRadio('q3'),
        q4: collectRadio('q4'),
        q5: collectCheckbox('q5'),
        q6: collectRadio('q6')
      },
      profile: {
        role: collectRadio('role')
      },
      gps_points: gpsTrackPoints.concat(allPoints).sort(function(a, b) {
        if (a.datetime && b.datetime) return a.datetime.localeCompare(b.datetime);
        return 0;
      }),
      phone: (document.getElementById('phoneInput') ? document.getElementById('phoneInput').value.trim() : '') || null
    };
  }

  // ── Gamification: 9-Level Pilgrim Ranking ──
  var MASCOT_BASE = '/images/formosa/';
  var TITLES = [
    { km: 0,   checkins: 1,  icon: '🔥', img: 'level-1.png', name: '煉氣香客', sub: '啟程入門者' },
    { km: 15,  checkins: 5,  icon: '🧱', img: 'level-2.png', name: '築基香客', sub: '開始上路者' },
    { km: 45,  checkins: 10, icon: '💛', img: 'level-3.png', name: '金丹香客', sub: '穩定行腳者' },
    { km: 90,  checkins: 15, icon: '👶', img: 'level-4.png', name: '元嬰香客', sub: '深度參與者' },
    { km: 135, checkins: 20, icon: '✨', img: 'level-5.png', name: '化神香客', sub: '高里程行者' },
    { km: 180, checkins: 25, icon: '🌀', img: 'level-6.png', name: '煉虛香客', sub: '進階完成者' },
    { km: 225, checkins: 30, icon: '🤝', img: 'level-7.png', name: '合體香客', sub: '高階完成者' },
    { km: 270, checkins: 35, icon: '🏆', img: 'level-8.png', name: '大乘香客', sub: '榮譽進階者' },
    { km: 300, checkins: 40, icon: '🚀', img: 'level-9.png', name: '飛升香客', sub: '圓滿認證者' }
  ];

  function getTitle(checkins, km) {
    if (typeof km === 'undefined') km = getSavedKm();
    var title = TITLES[0];
    for (var i = TITLES.length - 1; i >= 0; i--) {
      if (km >= TITLES[i].km && checkins >= TITLES[i].checkins) {
        title = TITLES[i];
        break;
      }
    }
    // Find next achievable level
    var next = null;
    for (var j = 0; j < TITLES.length; j++) {
      if (km < TITLES[j].km || checkins < TITLES[j].checkins) {
        next = TITLES[j];
        break;
      }
    }
    return { current: title, next: next, checkins: checkins, km: km };
  }

  function getSavedCheckins() {
    return parseInt(lsGet('formosa_checkins') || '0');
  }

  function getSavedKm() {
    return parseFloat(lsGet('formosa_km') || '0');
  }

  function getLastCheckinCoords() {
    var raw = lsGet('formosa_last_coords');
    if (!raw) return null;
    try { return JSON.parse(raw); } catch(e) { return null; }
  }

  function saveLastCheckinCoords(lat, lng) {
    lsSet('formosa_last_coords', JSON.stringify({ lat: lat, lng: lng }));
  }

  function addKm(dist) {
    var total = getSavedKm() + dist;
    lsSet('formosa_km', total.toFixed(2));
    return total;
  }

  function incrementCheckins() {
    var n = getSavedCheckins() + 1;
    lsSet('formosa_checkins', n);
    return n;
  }

  // ── Load GPS-derived carbon stats from user API ──
  async function loadUserStats() {
    var userId = lineUserId || lsGet('formosa_user_id') || '';
    if (!userId) return;
    try {
      var resp = await fetch(API_BASE + '/api/formosa/user/' + encodeURIComponent(userId), {
        headers: { 'X-Line-User-Id': userId }
      });
      if (!resp.ok) return;
      var data = await resp.json();
      if (!data || !data.stats) return;
      var s = data.stats;
      lsSet('formosa_carbon', s.carbon_kg.toFixed(2));
      lsSet('formosa_carbon_saved', (s.carbon_saved_kg || 0).toFixed(2));
      lsSet('formosa_km', s.total_km.toFixed(2));
      lsSet('formosa_checkins', s.checkins);
      if (s.transport_breakdown) {
        lsSet('formosa_transport_breakdown', JSON.stringify(s.transport_breakdown));
      }
      updateCarbonStatsDisplay();
      // Upload personalized OG image for FB sharing
      uploadOgImage();
    } catch (e) { /* offline */ }
  }

  // ── OG Image Generation (canvas → R2) for FB sharing ──
  function uploadOgImage() {
    if (!lineUserId) return;
    var checkins = getSavedCheckins();
    var km = getSavedKm();
    if (checkins < 2) return;
    // Deduplicate: at most once per hour
    var lastUpload = parseInt(lsGet('formosa_og_uploaded_at') || '0');
    if (Date.now() - lastUpload < 3600000) return;
    var t = getTitle(checkins, km);
    var carbon = parseFloat(lsGet('formosa_carbon') || '0');

    var W = 1200, H = 630;
    var c = document.createElement('canvas');
    c.width = W; c.height = H;
    var ctx = c.getContext('2d');

    // Background gradient
    var grad = ctx.createLinearGradient(0, 0, W, H);
    grad.addColorStop(0, '#1a1a2e');
    grad.addColorStop(1, '#16213e');
    ctx.fillStyle = grad;
    ctx.fillRect(0, 0, W, H);

    // Decorative top bar
    ctx.fillStyle = '#f59e0b';
    ctx.fillRect(0, 0, W, 6);

    // Title
    ctx.fillStyle = '#f59e0b';
    ctx.font = 'bold 36px sans-serif';
    ctx.fillText('白沙屯媽祖 ESG 進香 2026', 60, 70);

    // Level icon + name
    ctx.fillStyle = '#ffffff';
    ctx.font = 'bold 64px sans-serif';
    ctx.fillText(t.current.icon + ' ' + t.current.name, 60, 180);

    // Sub title
    ctx.fillStyle = '#94a3b8';
    ctx.font = '28px sans-serif';
    ctx.fillText(t.current.sub, 60, 225);

    // Stats
    ctx.fillStyle = '#e2e8f0';
    ctx.font = 'bold 48px sans-serif';
    var statsY = 340;
    ctx.fillText(km.toFixed(1) + ' 公里', 60, statsY);
    ctx.fillText(checkins + ' 打卡', 420, statsY);
    ctx.fillText(carbon.toFixed(1) + ' kg CO₂e', 720, statsY);

    // Stats labels
    ctx.fillStyle = '#64748b';
    ctx.font = '22px sans-serif';
    ctx.fillText('總里程', 60, statsY + 35);
    ctx.fillText('打卡次數', 420, statsY + 35);
    ctx.fillText('碳足跡', 720, statsY + 35);

    // Divider
    ctx.strokeStyle = '#334155';
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(60, 420);
    ctx.lineTo(W - 60, 420);
    ctx.stroke();

    // CTA
    ctx.fillStyle = '#f59e0b';
    ctx.font = 'bold 26px sans-serif';
    ctx.fillText('點擊加入活動 →', 60, 470);

    // Bottom URL
    ctx.fillStyle = '#475569';
    ctx.font = '20px sans-serif';
    ctx.fillText('paulkuo.tw/projects/formosa-esg-2026/tracker/', 60, 590);

    // Load and draw NET-ZERO logo
    var logoImg = new Image();
    logoImg.crossOrigin = 'anonymous';
    logoImg.onload = function() {
      var logoSize = 120;
      // Draw circular logo
      ctx.save();
      ctx.beginPath();
      ctx.arc(W - 60 - logoSize/2, 530 - logoSize/2, logoSize/2, 0, Math.PI * 2);
      ctx.closePath();
      ctx.clip();
      ctx.drawImage(logoImg, W - 60 - logoSize, 530 - logoSize, logoSize, logoSize);
      ctx.restore();
      doUpload();
    };
    logoImg.onerror = function() { doUpload(); };
    logoImg.src = '/images/formosa/logo-netzero.jpg';

    function doUpload() {
      c.toBlob(function(blob) {
        if (!blob || blob.size > 2 * 1024 * 1024) return;
        fetch(API_BASE + '/api/formosa/og-image', {
          method: 'POST',
          headers: { 'Content-Type': 'image/png', 'X-User-Id': lineUserId },
          body: blob
        }).then(function(r) { return r.json(); }).then(function(d) {
          if (d.ok) {
            lsSet('formosa_og_uploaded_at', String(Date.now()));
            console.log('OG image uploaded:', d.url);
          }
        }).catch(function(e) { console.warn('OG upload failed:', e); });
      }, 'image/png');
    }
  }

