---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import AuthGate from '../_components/AuthGate.astro';
---

<BaseLayout
  title="活動紀錄 — 2026 白沙屯媽祖 ESG 永續進香"
  description="填寫問卷並上傳繞境照片，記錄你的進香足跡與善行體悟。"
  ogUrl="https://paulkuo.tw/projects/formosa-esg-2026/tracker/"
  ogImage="https://paulkuo.tw/images/formosa-esg-2026-og.png"
>

<AuthGate title="活動參與足跡紀錄" lineLogin={true}>

<div class="tracker">

  <!-- Test Mode Banner -->
  <div class="test-banner" id="testBanner" style="display:none">
    🔧 測試模式 — 資料可能隨時清除，正式活動 4/12 開始
  </div>

  <!-- Breadcrumb -->
  <nav class="tracker-breadcrumb">
    <a href="/projects/formosa-esg-2026/">← 回到專案總覽</a>
  </nav>

  <!-- Header -->
  <header class="tracker-header">
    <div class="tracker-badge">4/12 – 4/20 活動紀錄</div>
    <h1>2026 白沙屯媽祖徒步進香</h1>
    <p>活動參與足跡紀錄</p>
  </header>

  <!-- GPS Tracking Banner -->
  <div class="gps-banner" id="gpsBanner">
    <div class="gps-banner-inner">
      <div class="gps-pulse" id="gpsPulse"></div>
      <div class="gps-banner-text">
        <span id="gpsStatus">📍 定位中（自動記錄行走路線）...</span>
        <span class="gps-count" id="gpsCount"></span>
      </div>
      <button class="gps-checkin-btn" id="gpsCheckinBtn" style="display:none" onclick="manualCheckin()">打卡 📍</button>
    </div>
  </div>

  <!-- ═══ Linear Progress Bar ═══ -->
  <div class="q-progress" id="qProgress">
    <div class="q-progress-bar">
      <div class="q-progress-fill" id="qProgressFill"></div>
    </div>