  async function handlePhotos(files, statusEl) {
    if (!statusEl) statusEl = document.getElementById('photoStatusMini');
    if (!statusEl) return;
    var count = 0;
    var gpsCount = 0;

    // Show uploading state
    statusEl.innerHTML = '<span class="photo-status-text photo-status-loading">📷 上傳中...</span>';

    pendingSaveFiles = []; // reset for this batch
    var failed = false;
    for (var i = 0; i < files.length; i++) {
      var file = files[i];
      if (!file.type.match(/^image\/(jpe?g|png|heic|heif)$/)) continue;

      count++;
      pendingSaveFiles.push(file);

      // Store for sharing (keep file ref but no objectURL thumbnail)
      uploadedPhotos.push({ file: file, name: file.name });

      // Try extract GPS
      try {
        var buf = await readFileAsArrayBuffer(file);
        var data = parseExifGPS(buf);
        if (data && data.hasGPS) {
          gpsCount++;

          // Add to track points and calculate distance
          var last = getLastCheckinCoords();
          if (last) {
            var dist = haversine(last.lat, last.lng, data.lat, data.lng);
            if (dist > 0.01) addKm(dist);
          }
          saveLastCheckinCoords(data.lat, data.lng);

          gpsTrackPoints.push({
            lat: data.lat, lng: data.lng,
            altitude: data.altitude,
            datetime: data.datetime,
            source: 'photo',
            filename: file.name
          });
        }
      } catch (e) { /* no GPS */ }
    }

    if (count > 0) {
      // Update cumulative count
      cumulativePhotoCount += count;
      localStorage.setItem('formosa_photo_count', cumulativePhotoCount);

      // Increment on server
      var userId = lineUserId || localStorage.getItem('formosa_user_id') || '';
      if (userId) {
        try {
          await fetch(API_BASE + '/api/formosa/photos/count', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ line_user_id: userId, count: count })
          });
        } catch (e) { /* offline — localStorage is source of truth */ }
      }

      // Show success text
      updatePhotoStatusDisplay();

      // Prompt user to save photos to device (iOS needs Web Share API)
      showSavePhotoPrompt();

      // Update stats display
      var km = getSavedKm();
      var checkins = getSavedCheckins();
      var t = getTitle(checkins, km);
      var statsEl2 = document.getElementById('checkinStats');
      if (statsEl2) {
        statsEl2.innerHTML = '<div class="done-stats">' +
          '<div class="done-stat"><strong>' + checkins + '</strong><span>打卡次數</span></div>' +
          '<div class="done-stat"><strong>' + km.toFixed(1) + '</strong><span>公里</span></div>' +
          '<div class="done-stat"><strong>' + (localStorage.getItem('formosa_carbon') || '0') + '</strong><span>kg CO₂e</span></div>' +
          '</div>';
      }
      updateCheckinProgress(t);

      // Persist photo GPS points to localStorage for route map
      try {
        var savedTrack = JSON.parse(localStorage.getItem('formosa_gps_track') || '[]');
        gpsTrackPoints.filter(function(p) { return p.source === 'photo'; }).forEach(function(p) {
          var exists = savedTrack.some(function(s) { return s.lat === p.lat && s.lng === p.lng && s.source === 'photo'; });
          if (!exists) savedTrack.push({ lat: p.lat, lng: p.lng, datetime: p.datetime, source: 'photo' });
        });
        localStorage.setItem('formosa_gps_track', JSON.stringify(savedTrack));
      } catch(e) {}
    } else if (failed) {
      statusEl.innerHTML = '<span class="photo-status-text photo-status-error">⚠️ 上傳失敗，請重試</span><button class="photo-retry-btn" onclick="document.getElementById(\'photoCameraMini\').click()">重試</button>';
    }
  }

