<!-- All logic (LIFF SDK loaded by AuthGate) -->
<script is:inline>
(function() {
  // ── Config ──
  var API_BASE = 'https://paulkuo-ticker.paul-4bf.workers.dev';

  // ── LINE User Identity (set by AuthGate LIFF login) ──
  var lineUserId = window.__lineUserId || localStorage.getItem('formosa_line_user_id') || null;

  // ── Background GPS Tracking ──
  // Restore saved GPS track from localStorage
  var gpsTrackPoints = [];
  try {
    var saved = JSON.parse(localStorage.getItem('formosa_gps_track') || '[]');
    gpsTrackPoints = saved.map(function(p) { return { lat: p.lat, lng: p.lng, datetime: p.datetime, source: p.source || 'saved' }; });
  } catch(e) {}
  var watchId = null;
  var gpsReady = false;

  function startGPSTracking() {
    var statusEl = document.getElementById('gpsStatus');
    var countEl = document.getElementById('gpsCount');
    var pulseEl = document.getElementById('gpsPulse');
    var checkinBtn = document.getElementById('gpsCheckinBtn');

    if (!navigator.geolocation) {
      statusEl.textContent = '⚠️ 此裝置不支援定位';
      pulseEl.classList.add('off');
      return;
    }

    watchId = navigator.geolocation.watchPosition(
      function(pos) {
        gpsReady = true;
        pulseEl.classList.add('active');
        checkinBtn.style.display = 'inline-block';

        var pt = {
          lat: pos.coords.latitude,
          lng: pos.coords.longitude,
          altitude: pos.coords.altitude,
          accuracy: pos.coords.accuracy,
          datetime: new Date().toISOString(),
          source: 'auto',
          filename: 'GPS 自動追蹤'
        };

        var last = gpsTrackPoints[gpsTrackPoints.length - 1];
        if (last) {
          var dist = haversine(last.lat, last.lng, pt.lat, pt.lng);
          var timeDiff = new Date(pt.datetime) - new Date(last.datetime);
          if (dist < 0.01 && timeDiff < 30000) {
            statusEl.textContent = '📍 追蹤中 — 等待移動...';
            return;
          }
        }

        gpsTrackPoints.push(pt);
        statusEl.textContent = '📍 追蹤中';
        countEl.textContent = gpsTrackPoints.length + ' 次 GPS 記錄';
      },
      function(err) {
        pulseEl.classList.add('off');
        if (err.code === 1) {
          statusEl.textContent = '⚠️ 定位權限被拒絕';
          checkinBtn.style.display = 'none';
        } else {
          statusEl.textContent = '⚠️ 無法取得定位';
        }
      },
      { enableHighAccuracy: true, maximumAge: 10000, timeout: 15000 }
    );
  }

  window.manualCheckin = function() {
    navigator.geolocation.getCurrentPosition(
      function(pos) {
        gpsTrackPoints.push({
          lat: pos.coords.latitude,
          lng: pos.coords.longitude,
          altitude: pos.coords.altitude,
          accuracy: pos.coords.accuracy,
          datetime: new Date().toISOString(),
          source: 'manual',
          filename: '手動打卡 #' + (gpsTrackPoints.filter(function(p){return p.source==='manual'}).length + 1)
        });
        var countEl = document.getElementById('gpsCount');
        countEl.textContent = gpsTrackPoints.length + ' 次 GPS 記錄';

        var btn = document.getElementById('gpsCheckinBtn');
        btn.textContent = '✓ 已打卡';
        btn.disabled = true;
        setTimeout(function() { btn.textContent = '打卡 📍'; btn.disabled = false; }, 1500);
      },
      function() { alert('無法取得定位，請確認已開啟定位權限。'); },
      { enableHighAccuracy: true, timeout: 10000 }
    );
  };

  function haversine(lat1, lng1, lat2, lng2) {
    var R = 6371;
    var dLat = (lat2 - lat1) * Math.PI / 180;
    var dLng = (lng2 - lng1) * Math.PI / 180;
    var a = Math.sin(dLat/2) * Math.sin(dLat/2) +
            Math.cos(lat1 * Math.PI/180) * Math.cos(lat2 * Math.PI/180) *
            Math.sin(dLng/2) * Math.sin(dLng/2);
    return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
  }

  startGPSTracking();

  // ── One-Question-Per-Card System ──
  var cards = document.querySelectorAll('.q-card[data-q]');
  var totalQ = 14; // numbered questions (1-14)
  var curQ = 1;
  var autoTimer = null;

  function showCard(q) {
    cards.forEach(function(c) {
      var cq = c.getAttribute('data-q');
      if (cq === String(q)) {
        c.classList.add('active');
      } else {
        c.classList.remove('active');
      }
    });

    // Update progress bar
    if (typeof q === 'number' && q >= 1 && q <= totalQ) {
      var pct = ((q - 1) / (totalQ - 1)) * 100;
      document.getElementById('qProgressFill').style.width = pct + '%';
      document.getElementById('qProgressText').textContent = '第 ' + q + ' / ' + totalQ + ' 題';
      document.getElementById('qProgress').style.display = '';
    } else {
      document.getElementById('qProgress').style.display = 'none';
    }

    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  // Navigate: direction = +1 or -1
  window.goQ = function(dir) {
    if (autoTimer) { clearTimeout(autoTimer); autoTimer = null; }
    var next = curQ + dir;
    if (next < 1 || next > totalQ) return;

    // Validate current question before going forward
    if (dir > 0 && !validateQuestion(curQ)) return;

    // Recalculate carbon when arriving at Q11
    if (next === 11) updateCarbon();

    curQ = next;
    showCard(curQ);
  };

  function validateQuestion(q) {
    var card = document.querySelector('.q-card[data-q="' + q + '"]');
    if (!card) return true;

    var req = card.querySelector('[data-required="true"]');
    if (!req) return true;

    var name = req.getAttribute('data-name');
    if (!name) return true;

    var checked = card.querySelectorAll('input[name="' + name + '"]:checked');
    if (checked.length === 0) {
      // Show inline error
      var existing = card.querySelector('.q-error');
      if (!existing) {
        var err = document.createElement('div');
        err.className = 'q-error';
        err.textContent = '⚠ 請至少選擇一個選項';
        req.parentNode.insertBefore(err, req.nextSibling);
      }
      return false;
    }
    // Clear error if exists
    var errEl = card.querySelector('.q-error');
    if (errEl) errEl.remove();
    return true;
  }

  // Auto-advance on radio selection
  document.querySelectorAll('.radio-group[data-auto="true"] input[type="radio"]').forEach(function(radio) {
    radio.addEventListener('change', function() {
      if (autoTimer) clearTimeout(autoTimer);
      // Highlight selected item
      var group = this.closest('.radio-group');
      group.querySelectorAll('.radio-item').forEach(function(item) {
        item.classList.remove('selected');
      });
      this.closest('.radio-item').classList.add('selected');

      // Auto advance after 400ms
      autoTimer = setTimeout(function() {
        goQ(1);
      }, 400);
    });
  });

  // Highlight checkbox items on change
  document.querySelectorAll('.checkbox-group input[type="checkbox"]').forEach(function(cb) {
    cb.addEventListener('change', function() {
      this.closest('.checkbox-item').classList.toggle('selected', this.checked);
    });
  });

  // Other checkbox toggle
  document.querySelectorAll('.other-item input[type="checkbox"]').forEach(function(cb) {
    cb.addEventListener('change', function() {
      var textInput = this.closest('.other-item').querySelector('.other-input');
      if (textInput) textInput.style.display = this.checked ? 'block' : 'none';
    });
  });

  // ── Carbon Calculator ──
  var FACTORS = {
    walk: 0, car: 0.30479, scooter: 0.13734, bike: 0.01220,
    bus: 0.47515, mrt: 0.07575, train: 0.07575, hsr: 0.07487,
    water: 0.10974, recycle: -0.00265, hotel: 12.5
  };
  var LABELS = {
    walk: '步行', car: '開車', scooter: '機車', bike: '腳踏車',
    bus: '公車', mrt: '捷運', train: '火車', hsr: '高鐵',
    water: '瓶裝水', recycle: '♻️ 回收水瓶', hotel: '旅宿'
  };

  function getVal(id) { return parseFloat(document.getElementById(id).value) || 0; }

  function updateCarbon() {
    var walk = getVal('t_walk');
    var car = getVal('t_car');
    var carpool = Math.max(1, getVal('t_carpool'));
    var scooter = getVal('t_scooter');
    var bike = getVal('t_bike');
    var bus = getVal('t_bus');
    var mrt = getVal('t_mrt');
    var train = getVal('t_train');
    var hsr = getVal('t_hsr');
    var water = getVal('t_water');
    var recycle = getVal('t_recycle');
    var hotel = getVal('t_hotel');

    var breakdown = {};
    breakdown.walk = walk * FACTORS.walk;
    breakdown.car = (car * FACTORS.car) / carpool;
    breakdown.scooter = scooter * FACTORS.scooter;
    breakdown.bike = bike * FACTORS.bike;
    breakdown.bus = bus * FACTORS.bus;
    breakdown.mrt = mrt * FACTORS.mrt;
    breakdown.train = train * FACTORS.train;
    breakdown.hsr = hsr * FACTORS.hsr;
    breakdown.water = water * FACTORS.water;
    breakdown.recycle = recycle * FACTORS.recycle;
    breakdown.hotel = hotel * FACTORS.hotel;

    var total = 0;
    for (var k in breakdown) total += breakdown[k];

    document.getElementById('carbonTotal').innerHTML =
      total.toFixed(2) + ' <small>kg CO₂e</small>';

    var html = '';
    for (var k in breakdown) {
      if (breakdown[k] > 0) {
        html += '<div class="carbon-row"><span>' + LABELS[k] + '</span><span>' + breakdown[k].toFixed(2) + ' kg</span></div>';
      } else if (breakdown[k] < 0) {
        html += '<div class="carbon-row carbon-offset"><span>' + LABELS[k] + '</span><span>♻️ ' + breakdown[k].toFixed(4) + ' kg</span></div>';
      }
    }
    if (!html) html = '<div class="carbon-row"><span>尚未填寫交通資料</span><span>—</span></div>';
    document.getElementById('carbonBreakdown').innerHTML = html;

    return { total: total, breakdown: breakdown };
  }

  document.querySelectorAll('.transport-input').forEach(function(input) {
    input.addEventListener('input', updateCarbon);
  });

  // ── Collect all form data ──
  function collectCheckbox(name) {
    var vals = [];
    document.querySelectorAll('input[name="' + name + '"]:checked').forEach(function(cb) {
      if (cb.value === '__other__') {
        var t = cb.closest('.other-item').querySelector('.other-input');
        if (t && t.value.trim()) vals.push(t.value.trim());
      } else {
        vals.push(cb.value);
      }
    });
    return vals;
  }

  function collectRadio(name) {
    var el = document.querySelector('input[name="' + name + '"]:checked');
    return el ? el.value : '';
  }

  function collectAllData() {
    var carbon = updateCarbon();

    return {
      timestamp: new Date().toISOString(),
      survey: {
        q1: collectCheckbox('q1'),
        q2: collectCheckbox('q2'),
        q2_1: document.getElementById('q2_1').value.trim(),
        q3: collectRadio('q3'),
        q4: collectRadio('q4'),
        q5: collectCheckbox('q5'),
        q6: collectRadio('q6')
      },
      profile: {
        role: collectRadio('role'),
        transport: {
          walk_km: getVal('t_walk'),
          car_km: getVal('t_car'),
          carpool_count: getVal('t_carpool'),
          scooter_km: getVal('t_scooter'),
          bus_km: getVal('t_bus'),
          mrt_km: getVal('t_mrt'),
          train_km: getVal('t_train'),
          hsr_km: getVal('t_hsr'),
          bike_km: getVal('t_bike')
        },
        water_bottles: getVal('t_water'),
        recycle_bottles: getVal('t_recycle'),
        hotel_nights: getVal('t_hotel')
      },
      carbon: {
        total_kg: carbon.total,
        breakdown: carbon.breakdown
      },
      gps_points: gpsTrackPoints.concat(allPoints).sort(function(a, b) {
        if (a.datetime && b.datetime) return a.datetime.localeCompare(b.datetime);
        return 0;
      }),
      phone: (document.getElementById('phoneInput') ? document.getElementById('phoneInput').value.trim() : '') || null
    };
  }

  // ── Gamification: 9-Level Pilgrim Ranking ──
  var MASCOT_BASE = '/images/formosa/';
  var TITLES = [
    { km: 0,   checkins: 1,  icon: '🔥', img: 'level-1.png', name: '煉氣香客', sub: '啟程入門者' },
    { km: 15,  checkins: 3,  icon: '🧱', img: 'level-2.png', name: '築基香客', sub: '開始上路者' },
    { km: 45,  checkins: 5,  icon: '💛', img: 'level-3.png', name: '金丹香客', sub: '穩定行腳者' },
    { km: 90,  checkins: 6,  icon: '👶', img: 'level-4.png', name: '元嬰香客', sub: '深度參與者' },
    { km: 135, checkins: 8,  icon: '✨', img: 'level-5.png', name: '化神香客', sub: '高里程行者' },
    { km: 180, checkins: 10, icon: '🌀', img: 'level-6.png', name: '煉虛香客', sub: '進階完成者' },
    { km: 225, checkins: 12, icon: '🤝', img: 'level-7.png', name: '合體香客', sub: '高階完成者' },
    { km: 270, checkins: 14, icon: '🏆', img: 'level-8.png', name: '大乘香客', sub: '榮譽進階者' },
    { km: 300, checkins: 14, icon: '🚀', img: 'level-9.png', name: '飛升香客', sub: '圓滿認證者' }
  ];

  function getTitle(checkins, km) {
    if (typeof km === 'undefined') km = getSavedKm();
    var title = TITLES[0];
    for (var i = TITLES.length - 1; i >= 0; i--) {
      if (km >= TITLES[i].km && checkins >= TITLES[i].checkins) {
        title = TITLES[i];
        break;
      }
    }
    // Find next achievable level
    var next = null;
    for (var j = 0; j < TITLES.length; j++) {
      if (km < TITLES[j].km || checkins < TITLES[j].checkins) {
        next = TITLES[j];
        break;
      }
    }
    return { current: title, next: next, checkins: checkins, km: km };
  }

  function getSavedCheckins() {
    return parseInt(localStorage.getItem('formosa_checkins') || '0');
  }

  function getSavedKm() {
    return parseFloat(localStorage.getItem('formosa_km') || '0');
  }

  function getLastCheckinCoords() {
    var raw = localStorage.getItem('formosa_last_coords');
    if (!raw) return null;
    try { return JSON.parse(raw); } catch(e) { return null; }
  }

  function saveLastCheckinCoords(lat, lng) {
    localStorage.setItem('formosa_last_coords', JSON.stringify({ lat: lat, lng: lng }));
  }

  function addKm(dist) {
    var total = getSavedKm() + dist;
    localStorage.setItem('formosa_km', total.toFixed(2));
    return total;
  }

  function incrementCheckins() {
    var n = getSavedCheckins() + 1;
    localStorage.setItem('formosa_checkins', n);
    return n;
  }

  // ── Share Functions ──
  var SHARE_URL = 'https://paulkuo.tw/projects/formosa-esg-2026/tracker/';
  var SHARE_TITLE = '2026 白沙屯媽祖 ESG 進香';

  function getShareText() {
    var checkins = getSavedCheckins();
    var km = getSavedKm();
    var t = getTitle(checkins, km);
    return '我參加了 2026 白沙屯媽祖 ESG 進香，已走 ' + km.toFixed(1) + ' 公里，獲得' + t.current.icon + '「' + t.current.name + '」稱號！一起來記錄你的進香足跡 🙏';
  }

  window.shareNative = function() {
    if (navigator.share) {
      navigator.share({
        title: SHARE_TITLE,
        text: getShareText(),
        url: SHARE_URL
      }).catch(function() {});
    }
  };

  window.shareLine = function() {
    // Use LIFF shareTargetPicker if in LINE app
    if (window.__liffReady && typeof liff !== 'undefined' && liff.isInClient() && liff.isApiAvailable('shareTargetPicker')) {
      liff.shareTargetPicker([
        {
          type: 'text',
          text: getShareText() + '\n' + SHARE_URL
        }
      ]).catch(function(e) {
        console.warn('shareTargetPicker failed:', e);
      });
    } else {
      var text = encodeURIComponent(getShareText() + '\n' + SHARE_URL);
      window.open('https://social-plugins.line.me/lineit/share?url=' + encodeURIComponent(SHARE_URL) + '&text=' + text, '_blank');
    }
  };

  window.shareFB = function() {
    // On mobile, use native share (user picks FB app from share sheet)
    if (navigator.share) {
      navigator.share({
        title: SHARE_TITLE,
        text: getShareText(),
        url: SHARE_URL
      }).catch(function() {});
    } else {
      // Desktop fallback
      window.open('https://www.facebook.com/sharer/sharer.php?u=' + encodeURIComponent(SHARE_URL) + '&quote=' + encodeURIComponent(getShareText()), '_blank');
    }
  };

  window.shareCopy = function() {
    var text = getShareText() + '\n' + SHARE_URL;
    if (navigator.clipboard) {
      navigator.clipboard.writeText(text).then(function() {
        showToast();
      });
    } else {
      // Fallback
      var ta = document.createElement('textarea');
      ta.value = text;
      document.body.appendChild(ta);
      ta.select();
      document.execCommand('copy');
      document.body.removeChild(ta);
      showToast();
    }
  };

