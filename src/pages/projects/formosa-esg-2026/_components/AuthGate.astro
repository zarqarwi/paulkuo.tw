---
/**
 * AuthGate — Client-side auth gate for Formosa ESG 2026 pages
 * Supports LINE login (for participants) and password (for admins)
 */
import { t } from '@/i18n/utils';
import { LOCALE_PREFIX } from '@/i18n/config';
import type { Locale } from '@/i18n/config';

interface Props {
  title?: string;
  subtitle?: string;
  lineLogin?: boolean;
  liffId?: string;
  lang?: Locale;
}

const {
  title,
  subtitle = '',
  lineLogin = false,
  liffId = '2009588321-rXVntTKg',
  lang = 'zh-Hant',
} = Astro.props;

const authTitle = title || t(lang, 'brand.systemName');
const prefix = LOCALE_PREFIX[lang];

// Build i18n strings for client-side JS
const authI18n = {
  verify: t(lang, 'auth.verify'),
  verifying: t(lang, 'auth.verifying'),
  invalidPassword: t(lang, 'auth.invalidPassword'),
  processing: t(lang, 'auth.processing'),
  loggingIn: t(lang, 'auth.loggingIn'),
  enterEvent: t(lang, 'auth.enterEvent'),
  lineLoginBtn: t(lang, 'auth.lineLoginBtn'),
};
---

<!-- LIFF SDK (only for LINE login mode) -->
{lineLogin && <script is:inline src="https://static.line-scdn.net/liff/edge/versions/2.24.0/sdk.js"></script>}

<!-- Auth Gate (visible by default) -->
<div id="authGate" class="formosa-auth">
  <div class="auth-card">
    <div class="auth-icon">⛩️</div>
    <h2>{authTitle}</h2>

    {lineLogin ? (
      <!-- LINE Login Mode -->
      <div id="lineLoginSection">
        <p>{t(lang, 'auth.lineLoginDesc')}</p>
        <button id="lineLoginBtn" class="line-login-btn">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="white" style="vertical-align:middle;margin-right:8px"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/></svg>
          {t(lang, 'auth.lineLoginBtn')}
        </button>
      </div>

      <!-- LINE Profile + Privacy Consent (merged into one step) -->
      <div id="lineProfileSection" style="display:none">
        <img id="lineAvatar" class="line-avatar" src="" alt="" />
        <div id="lineDisplayName" class="line-name"></div>
        <div id="privacySummary" class="privacy-summary">
          <p class="privacy-summary-text" set:html={t(lang, 'auth.privacyConsentText').replace('{link}', `<a href="${prefix}/projects/formosa-esg-2026/privacy/" target="_blank" rel="noopener">${t(lang, 'privacy.title')}</a>`)} />
          <label class="privacy-checkbox-label">
            <input type="checkbox" id="privacyCheckbox" />
            <span>{t(lang, 'auth.privacyCheckboxLabel')}</span>
          </label>
        </div>
        <button id="lineEnterBtn" class="line-enter-btn" disabled>{t(lang, 'auth.enterEvent')}</button>
        <div id="privacyDeclineMsg" class="privacy-decline-msg" style="display:none">{t(lang, 'auth.privacyRequired')}</div>
        <div id="privacyFetchFallback" class="privacy-fetch-fallback" style="display:none" set:html={t(lang, 'auth.networkError').replace('{link}', `<a href="${prefix}/projects/formosa-esg-2026/tracker/?demo=1">${t(lang, 'ui.retry')}</a>`)} />
      </div>

      <!-- Admin fallback -->
      <div class="admin-fallback">
        <a href="#" id="showAdminLogin">{t(lang, 'auth.adminLogin')}</a>
      </div>
      <div id="adminLoginSection" style="display:none">
        <input type="password" id="authInput" placeholder={t(lang, 'auth.adminPassword')} />
        <div class="admin-btn-row">
          <button id="authBtn" class="admin-login-btn">{t(lang, 'auth.verify')}</button>
          <button id="adminCancelBtn" class="admin-cancel-btn">{t(lang, 'auth.cancel')}</button>
        </div>
      </div>
    ) : (
      <!-- Password Mode (admin pages) -->
      <p class="auth-subtitle">{t(lang, 'auth.adminOnly')}</p>
      <input type="password" id="authInput" placeholder={t(lang, 'auth.password')} autofocus />
      <button id="authBtn">{t(lang, 'auth.enter')}</button>
      <p class="auth-note" set:html={t(lang, 'auth.adminNote').replace('{link}', `<a href="${prefix}/projects/formosa-esg-2026/my/">${t(lang, 'page.my')}</a>`)} />
    )}
  </div>
</div>

<!-- Protected content slot (kept in <template> until verified — not in DOM, not crawlable) -->
<template id="mainContentTpl">
  <slot />
</template>
<div id="mainContent"></div>

<script is:inline define:vars={{ lineLogin, liffId, authI18n }}>
(function() {
  var WORKER = 'https://api.paulkuo.tw';
  var STORAGE_KEY = 'formosa_esg_code';
  var authGate = document.getElementById('authGate');
  var mainContent = document.getElementById('mainContent');

  // Hide NavBar and Footer while auth gate is showing
  var nav = document.getElementById('main-nav');
  if (nav) nav.style.display = 'none';
  function hideFooter() { var f = document.querySelector('footer'); if (f) f.style.display = 'none'; }
  hideFooter();
  if (!document.querySelector('footer')) document.addEventListener('DOMContentLoaded', hideFooter);

  function unlock() {
    authGate.style.display = 'none';
    // Inject content from <template> into DOM (content was not in DOM until now)
    var tpl = document.getElementById('mainContentTpl');
    if (tpl) mainContent.appendChild(tpl.content.cloneNode(true));
    mainContent.style.display = 'block';
    if (nav) nav.style.display = '';
    var f = document.querySelector('footer'); if (f) f.style.display = '';
    // Notify child scripts that protected DOM is now available
    document.dispatchEvent(new CustomEvent('formosa-unlocked'));
  }

  // ── Password verification (admin pages + admin fallback) ──
  async function verifyCode(code) {
    try {
      var res = await fetch(WORKER + '/validate-code', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ code: code })
      });
      var d = await res.json();
      if (d.valid && d.name === 'Formosa ESG 2026') return d;
      if (d.valid && d.role === 'admin') return d;
    } catch (e) {}
    return null;
  }

  var authInput = document.getElementById('authInput');
  var authBtn = document.getElementById('authBtn');

  if (authBtn) {
    authBtn.addEventListener('click', async function() {
      authBtn.textContent = authI18n.verifying;
      authBtn.disabled = true;
      var code = authInput.value.trim().toLowerCase();
      var result = await verifyCode(code);
      if (result) {
        sessionStorage.setItem(STORAGE_KEY, code);
        unlock();
      } else {
        authInput.style.borderColor = '#ef4444';
        authInput.value = '';
        authInput.placeholder = authI18n.invalidPassword;
        authBtn.textContent = authI18n.verify;
        authBtn.disabled = false;
      }
    });
  }
  if (authInput) {
    authInput.addEventListener('keydown', function(e) { if (e.key === 'Enter' && authBtn) authBtn.click(); });
  }

  // ── Auto-check stored code (both modes) ──
  async function checkStoredCode() {
    var urlKey = new URLSearchParams(window.location.search).get('key');
    var stored = sessionStorage.getItem(STORAGE_KEY);
    var code = urlKey || stored;
    if (code) {
      var result = await verifyCode(code);
      if (result) { sessionStorage.setItem(STORAGE_KEY, code); unlock(); return true; }
    }
    return false;
  }

  // ── LINE Login Mode ──
  if (lineLogin) {
    var lineLoginBtn = document.getElementById('lineLoginBtn');
    var lineProfileSection = document.getElementById('lineProfileSection');
    var lineLoginSection = document.getElementById('lineLoginSection');
    var showAdminLogin = document.getElementById('showAdminLogin');
    var adminLoginSection = document.getElementById('adminLoginSection');

    // Toggle admin login form
    if (showAdminLogin) {
      showAdminLogin.addEventListener('click', function(e) {
        e.preventDefault();
        adminLoginSection.style.display = adminLoginSection.style.display === 'none' ? 'block' : 'none';
      });
    }
    // Admin cancel button
    var adminCancelBtn = document.getElementById('adminCancelBtn');
    if (adminCancelBtn) {
      adminCancelBtn.addEventListener('click', function() {
        adminLoginSection.style.display = 'none';
        if (authInput) { authInput.value = ''; authInput.style.borderColor = ''; }
      });
    }

    function showProfile(profile) {
      lineLoginSection.style.display = 'none';
      lineProfileSection.style.display = 'block';
      document.getElementById('lineAvatar').src = profile.pictureUrl || '';
      document.getElementById('lineDisplayName').textContent = profile.displayName;

      // Store globally for tracker script to pick up
      window.__lineUserId = profile.userId;
      window.__lineProfile = profile;
      localStorage.setItem('formosa_line_user_id', profile.userId);
      localStorage.setItem('formosa_line_display_name', profile.displayName);
      localStorage.setItem('formosa_line_picture', profile.pictureUrl || '');

      // Check if privacy already agreed
      checkExistingPrivacy();

      // Sync to server
      fetch(WORKER + '/api/formosa/user/sync', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          line_user_id: profile.userId,
          display_name: profile.displayName,
          picture_url: profile.pictureUrl || ''
        })
      }).then(function(r) { return r.json(); }).then(function(data) {
        if (data.user_id) localStorage.setItem('formosa_user_id', data.user_id);
        if (data.checkins) localStorage.setItem('formosa_checkins', data.checkins);
        if (data.km) localStorage.setItem('formosa_km', data.km);
        if (data.survey_done) localStorage.setItem('formosa_survey_done', 'true');
        if (data.photo_count != null) localStorage.setItem('formosa_photo_count', data.photo_count);
        if (data.gps_track && data.gps_track.length > 0) localStorage.setItem('formosa_gps_track', JSON.stringify(data.gps_track));
        if (data.privacy_agreed) localStorage.setItem('formosa_privacy_agreed', '1');
        if (data.participant_status) localStorage.setItem('formosa_participant_status', data.participant_status);
      }).catch(function() {});
    }

    // Privacy checkbox enables/disables enter button
    var privacyCheckbox = document.getElementById('privacyCheckbox');
    var lineEnterBtn = document.getElementById('lineEnterBtn');
    var privacyDeclineMsg = document.getElementById('privacyDeclineMsg');
    var privacySummary = document.getElementById('privacySummary');

    // If user already agreed, skip checkbox
    function checkExistingPrivacy() {
      var localAgreed = localStorage.getItem('formosa_privacy_agreed');
      if (localAgreed === '1') {
        privacySummary.style.display = 'none';
        lineEnterBtn.disabled = false;
      }
    }

    if (privacyCheckbox) {
      privacyCheckbox.addEventListener('change', function() {
        lineEnterBtn.disabled = !privacyCheckbox.checked;
        if (privacyCheckbox.checked) privacyDeclineMsg.style.display = 'none';
      });
    }

    // Enter button: agree privacy + unlock
    lineEnterBtn.addEventListener('click', function() {
      var userId = window.__lineUserId || localStorage.getItem('formosa_line_user_id');
      var localAgreed = localStorage.getItem('formosa_privacy_agreed');
      if (localAgreed === '1') { unlock(); return; }
      // Record privacy consent
      lineEnterBtn.textContent = authI18n.processing;
      lineEnterBtn.disabled = true;
      fetch(WORKER + '/api/formosa/privacy', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ line_user_id: userId })
      }).then(function(r) { return r.json(); }).then(function(data) {
        if (data.ok) {
          localStorage.setItem('formosa_privacy_agreed', '1');
          unlock();
        }
      }).catch(function() {
        // Fallback: show manual link instead of blocking
        lineEnterBtn.textContent = authI18n.enterEvent;
        lineEnterBtn.disabled = false;
        var fallback = document.getElementById('privacyFetchFallback');
        if (fallback) fallback.style.display = 'block';
        // Also allow entry on network failure
        localStorage.setItem('formosa_privacy_agreed', '1');
        unlock();
      });
    });

    // LIFF init
    var LINE_ICON_SVG = '<svg viewBox="0 0 24 24" width="22" height="22" fill="white" style="vertical-align:middle;margin-right:8px"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/></svg>';

    function resetLoginBtn() {
      if (lineLoginBtn) {
        lineLoginBtn.disabled = false;
        lineLoginBtn.innerHTML = LINE_ICON_SVG + ' ' + authI18n.lineLoginBtn;
      }
    }

    function doLiffLogin() {
      try {
        liff.login({ redirectUri: window.location.href });
      } catch (e) {
        console.warn('liff.login error:', e);
        resetLoginBtn();
        // Show friendly error below the button
        var errEl = document.getElementById('liffErrorMsg');
        if (!errEl) {
          errEl = document.createElement('p');
          errEl.id = 'liffErrorMsg';
          errEl.style.cssText = 'color:#ef4444;font-size:0.85rem;margin-top:0.75rem;line-height:1.5';
          lineLoginBtn.parentNode.appendChild(errEl);
        }
        errEl.textContent = '登入時發生錯誤，請稍後再試，或在 LINE App 中開啟此連結。';
      }
    }

    function initLIFF() {
      if (typeof liff === 'undefined') {
        setTimeout(initLIFF, 200);
        return;
      }
      liff.init({ liffId: liffId }).then(function() {
        window.__liffReady = true;

        // ── i18n: auto-redirect by LINE language ──
        (function autoRedirectByLanguage() {
          try {
            var lineLang = (typeof liff !== 'undefined' && typeof liff.getAppLanguage === 'function')
              ? liff.getAppLanguage()
              : null;

            if (!lineLang) return; // 非 LIFF 環境（外部瀏覽器），不做 redirect

            var langMap = {
              'en': '/en', 'ja': '/ja',
              'zh-CN': '/zh-cn', 'zh-Hans': '/zh-cn',
              'zh-TW': '', 'zh-Hant': '',
            };

            // BCP 47 完整比對 → 前兩碼 fallback
            var prefix = langMap[lineLang] !== undefined ? langMap[lineLang] : (langMap[lineLang.split('-')[0]] !== undefined ? langMap[lineLang.split('-')[0]] : null);
            if (prefix === null || prefix === '') return; // 繁中或不支援的語言，不 redirect

            var currentPath = window.location.pathname;
            // 已經在語系路徑上了，不重複 redirect
            if (currentPath.startsWith('/en/') || currentPath.startsWith('/ja/') || currentPath.startsWith('/zh-cn/')) return;

            window.location.replace(prefix + currentPath + window.location.search + window.location.hash);
          } catch (e) {
            console.warn('[i18n] auto-redirect failed:', e);
            // 失敗不影響正常使用，繼續顯示繁中版
          }
        })();

        if (liff.isLoggedIn()) {
          liff.getProfile().then(function(profile) {
            showProfile(profile);
          }).catch(function(e) { console.warn('LIFF getProfile error:', e); });
        } else if (liff.isInClient()) {
          liff.login();
        }
        // If pending login from button click, trigger it now
        if (window.__pendingLiffLogin) {
          window.__pendingLiffLogin = false;
          doLiffLogin();
        }
      }).catch(function(e) {
        console.warn('LIFF init error:', e);
        resetLoginBtn();
        // Show error message for non-LINE browsers
        var errEl = document.getElementById('liffErrorMsg');
        if (!errEl) {
          errEl = document.createElement('p');
          errEl.id = 'liffErrorMsg';
          errEl.style.cssText = 'color:#ef4444;font-size:0.85rem;margin-top:0.75rem;line-height:1.5';
          if (lineLoginBtn) lineLoginBtn.parentNode.appendChild(errEl);
        }
        errEl.textContent = 'LINE 登入初始化失敗，請重新整理頁面，或在 LINE App 中開啟此連結。';
      });
    }

    // LINE login button click
    if (lineLoginBtn) {
      lineLoginBtn.addEventListener('click', function() {
        lineLoginBtn.disabled = true;
        lineLoginBtn.innerHTML = '<span class="line-spinner"></span> ' + authI18n.loggingIn;
        // Clear previous error
        var errEl = document.getElementById('liffErrorMsg');
        if (errEl) errEl.textContent = '';
        if (typeof liff !== 'undefined' && window.__liffReady) {
          doLiffLogin();
        } else {
          // LIFF not ready yet — flag pending login and wait for init
          window.__pendingLiffLogin = true;
          if (!window.__liffInitStarted) {
            window.__liffInitStarted = true;
            initLIFF();
          }
          // Timeout fallback: if LIFF doesn't init within 5s, show error
          setTimeout(function() {
            if (!window.__liffReady) {
              resetLoginBtn();
              var errEl2 = document.getElementById('liffErrorMsg');
              if (!errEl2) {
                errEl2 = document.createElement('p');
                errEl2.id = 'liffErrorMsg';
                errEl2.style.cssText = 'color:#ef4444;font-size:0.85rem;margin-top:0.75rem;line-height:1.5';
                lineLoginBtn.parentNode.appendChild(errEl2);
              }
              errEl2.textContent = 'LINE 登入載入逾時，請重新整理頁面再試。';
            }
          }, 5000);
        }
      });
    }

    // Boot sequence: check stored code first, then shared link, then LIFF
    checkStoredCode().then(function(unlocked) {
      if (!unlocked) {
        // Shared link guest mode: ?u= param unlocks page for viewing
        var sharedUserId = new URLSearchParams(window.location.search).get('u');
        if (sharedUserId) {
          window.__guestMode = true;
          unlock();
          return;
        }
        var storedLineId = localStorage.getItem('formosa_line_user_id');
        var storedName = localStorage.getItem('formosa_line_display_name');
        if (storedLineId && storedName) {
          showProfile({
            userId: storedLineId,
            displayName: storedName,
            pictureUrl: localStorage.getItem('formosa_line_picture') || ''
          });
        }
        initLIFF();
      }
    });

  } else {
    // Demo mode bypasses auth gate (read-only, no real data)
    if (new URLSearchParams(window.location.search).get('demo') === '1') {
      unlock();
    } else {
      checkStoredCode();
    }
  }
})();
</script>

<style is:global>
  .formosa-auth {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
    padding: 2rem;
    background: var(--bg);
  }
  .formosa-auth .auth-card {
    text-align: center;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 3rem;
    max-width: 400px;
    width: 100%;
    box-shadow: var(--shadow-md);
    overflow: hidden;
    position: relative;
  }
  .formosa-auth .auth-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--brand-navy), var(--accent-faith));
  }
  .formosa-auth .auth-icon { font-size: 3rem; margin-bottom: 1rem; }
  .formosa-auth .auth-card h2 {
    font-family: var(--font-cjk);
    font-size: 1.35rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: var(--text-primary);
  }
  .formosa-auth .auth-card p {
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }
  .formosa-auth .auth-subtitle {
    color: var(--text-secondary);
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .formosa-auth .auth-card input[type="password"] {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    font-size: 1rem;
    text-align: center;
    background: var(--bg);
    transition: border-color 0.2s;
  }
  .formosa-auth .auth-card input:focus { outline: none; border-color: var(--accent-faith); }
  .formosa-auth .auth-card button {
    margin-top: 1rem;
    width: 100%;
    padding: 0.75rem;
    background: var(--accent-faith);
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 0.95rem;
    cursor: pointer;
    transition: background 0.2s;
  }
  .formosa-auth .auth-card button:hover { background: #9a4408; }
  .line-login-btn {
    background: #06C755 !important;
    color: white !important;
    font-size: 1rem !important;
    font-weight: 600;
    padding: 0.85rem 1.5rem !important;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    border: none;
    cursor: pointer;
    transition: background 0.2s;
  }
  .line-login-btn:hover { background: #05a648 !important; }
  .line-avatar {
    width: 72px;
    height: 72px;
    border-radius: 50%;
