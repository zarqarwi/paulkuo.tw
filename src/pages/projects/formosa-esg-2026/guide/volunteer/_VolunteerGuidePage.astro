---
import type { Locale } from '@/i18n/config';
import { LOCALE_PREFIX } from '@/i18n/config';
import { t } from '@/i18n/utils';
import BaseLayout from '../../../../../layouts/BaseLayout.astro';
import AuthGate from '../../_components/AuthGate.astro';
import '../../../../../styles/guide-template.css';

interface Props { lang: Locale; }
const { lang } = Astro.props;
const prefix = LOCALE_PREFIX[lang];

const guideLink = `${prefix}/projects/formosa-esg-2026/guide/`;
const dashboardLink = 'https://mazu.today/dashboard/';
const trackerLink = `${prefix}/projects/formosa-esg-2026/tracker/`;
---

<BaseLayout
  title={t(lang, 'volunteerGuidePage.title')}
  description={t(lang, 'volunteerGuidePage.description')}
  ogUrl="https://mazu.today/guide/volunteer/"
  ogImage="https://mazu.today/images/formosa-esg-2026-og.png"
  eventMode={true}
>

<AuthGate title={t(lang, 'volunteerGuidePage.authTitle')} subtitle={t(lang, 'volunteerGuidePage.authSubtitle')} lang={lang}>

<article class="guide-content">

<h1>{t(lang, 'volunteerGuidePage.heading')}</h1>
<div class="guide-meta">
  <span class="guide-version-badge">{t(lang, 'volunteerGuidePage.version')}</span>
  <time datetime="2026-04-06">2026-04-06</time>
  <span class="guide-changelog">{t(lang, 'volunteerGuidePage.changelog')}</span>
</div>

<blockquote>
  <p>{t(lang, 'volunteerGuidePage.introP1')}</p>
  <p>{t(lang, 'volunteerGuidePage.introP2')}</p>
</blockquote>

<nav class="guide-toc">
  <details open>
    <summary>{t(lang, 'volunteerGuidePage.tocSummary')}</summary>
    <ol>
      <li><a href="#section-1">{t(lang, 'volunteerGuidePage.tocItem1')}</a></li>
      <li><a href="#section-2">{t(lang, 'volunteerGuidePage.tocItem2')}</a></li>
      <li><a href="#section-3">{t(lang, 'volunteerGuidePage.tocItem3')}</a></li>
      <li><a href="#section-4">{t(lang, 'volunteerGuidePage.tocItem4')}</a></li>
      <li><a href="#section-5">{t(lang, 'volunteerGuidePage.tocItem5')}</a></li>
      <li><a href="#section-6">{t(lang, 'volunteerGuidePage.tocItem6')}</a></li>
      <li><a href="#section-7">{t(lang, 'volunteerGuidePage.tocItem7')}</a></li>
      <li><a href="#section-8">{t(lang, 'volunteerGuidePage.tocItem8')}</a></li>
      <li><a href="#section-9">{t(lang, 'volunteerGuidePage.tocItem9')}</a></li>
      <li><a href="#section-sedan">{t(lang, 'volunteerGuidePage.tocItemSedan')}</a></li>
      <li><a href="#section-10">{t(lang, 'volunteerGuidePage.tocItem10')}</a></li>
      <li><a href="#section-11">{t(lang, 'volunteerGuidePage.tocItem11')}</a></li>
      <li><a href="#section-12">{t(lang, 'volunteerGuidePage.tocItem12')}</a></li>
      <li><a href="#section-13">{t(lang, 'volunteerGuidePage.tocItem13')}</a></li>
    </ol>
  </details>
</nav>

<hr />

<h2 id="section-1">{t(lang, 'volunteerGuidePage.sec1Title')}</h2>

<p>{t(lang, 'volunteerGuidePage.sec1Intro')}</p>

<ul>
