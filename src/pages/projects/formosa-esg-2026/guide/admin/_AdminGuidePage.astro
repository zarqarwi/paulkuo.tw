---
import type { Locale } from '@/i18n/config';
import { LOCALE_PREFIX } from '@/i18n/config';
import { t } from '@/i18n/utils';
import BaseLayout from '../../../../../layouts/BaseLayout.astro';
import AuthGate from '../../_components/AuthGate.astro';
import '../../../../../styles/guide-template.css';

interface Props { lang: Locale; }
const { lang } = Astro.props;
const prefix = LOCALE_PREFIX[lang];

const guideLink = `${prefix}/projects/formosa-esg-2026/guide/`;
const flowLink = `${prefix}/projects/formosa-esg-2026/guide/admin-flow/`;
const feedbackFlowLink = `${prefix}/projects/formosa-esg-2026/guide/feedback-flow/`;
const dashboardLink = `${prefix}/projects/formosa-esg-2026/dashboard/`;

/* helper: replace {prefix} placeholders in sec5 strings */
const rp = (key: string) => t(lang, key).replace(/\{prefix\}/g, prefix);
---

<BaseLayout
  title={t(lang, 'adminGuidePage.title')}
  description={t(lang, 'adminGuidePage.description')}
  ogUrl="https://mazu.today/guide/admin/"
  ogImage="https://mazu.today/images/formosa-esg-2026-og.png"
  eventMode={true}
>

<AuthGate title={t(lang, 'adminGuidePage.authTitle')} subtitle={t(lang, 'adminGuidePage.authSubtitle')} lang={lang}>

<article class="guide-content">

<h1>{t(lang, 'adminGuidePage.heading')}</h1>
<div class="guide-meta">
  <span class="guide-version-badge">{t(lang, 'adminGuidePage.version')}</span>
  <time datetime="2026-03-30">2026-03-30</time>
  <span class="guide-changelog">{t(lang, 'adminGuidePage.changelog')}</span>
</div>

<blockquote>
  <p>{t(lang, 'adminGuidePage.introP1')}</p>
  <p set:html={t(lang, 'adminGuidePage.introP2').replace('{guideLink}', guideLink)} />
</blockquote>

<p style="margin:1.5rem 0;font-size:1.05rem;" set:html={t(lang, 'adminGuidePage.flowchartIntro').replace('{flowLink}', flowLink)} />
<p style="margin:1.5rem 0;font-size:1.05rem;">🔄 <strong><a href={feedbackFlowLink}>Bug 修復流程</a></strong> — 從回報、分類、風險分級到驗收的完整 pipeline</p>

<nav class="guide-toc">
