---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import '../../../../styles/guide-template.css';
import { t } from '@/i18n/utils';
import { LOCALE_PREFIX } from '@/i18n/config';
import type { Locale } from '@/i18n/config';

interface Props {
  lang?: Locale;
}

const lang: Locale = Astro.props.lang ?? 'zh-Hant';
const prefix = LOCALE_PREFIX[lang];
---

<BaseLayout
  title={`${t(lang, 'guidePage.title')}`}
  description={t(lang, 'guidePage.description')}
  ogUrl={`https://paulkuo.tw${prefix}/projects/formosa-esg-2026/guide/`}
  ogImage="https://paulkuo.tw/images/formosa-esg-2026-og.png"
  eventMode={true}
>

<article class="guide-content">

<h1>{t(lang, 'guidePage.title')}</h1>
<div class="guide-meta">
  <span class="guide-last-updated">{t(lang, 'guidePage.lastUpdated')}</span>
  <span class="guide-changelog">{t(lang, 'guidePage.changelog')}</span>
</div>

<blockquote>
  <p>{t(lang, 'guidePage.introP1')}</p>
  <p>{t(lang, 'guidePage.introP2')}</p>
  <p>{t(lang, 'guidePage.introP3')}</p>
</blockquote>

<p style="margin:1.5rem 0;font-size:1.05rem;">👉 <strong><a href={`${prefix}/projects/formosa-esg-2026/guide/user-flow/`}>{t(lang, 'guidePage.userFlowLink')}</a></strong> — {t(lang, 'guidePage.userFlowDesc')}</p>

<nav class="guide-toc">
  <details open>
    <summary>📑 {t(lang, 'guidePage.tocTitle')}</summary>
    <ol>
      <li><a href="#section-1">{t(lang, 'guidePage.toc1')}</a></li>
      <li><a href="#section-2">{t(lang, 'guidePage.toc2')}</a></li>
      <li><a href="#section-3">{t(lang, 'guidePage.toc3')}</a></li>
      <li><a href="#section-4">{t(lang, 'guidePage.toc4')}</a></li>
      <li><a href="#section-5">{t(lang, 'guidePage.toc5')}</a></li>
      <li><a href="#section-6">{t(lang, 'guidePage.toc6')}</a></li>
      <li><a href="#section-7">{t(lang, 'guidePage.toc7')}</a></li>
      <li><a href="#section-8">{t(lang, 'guidePage.toc8')}</a></li>
      <li><a href="#section-9">{t(lang, 'guidePage.toc9')}</a></li>
      <li><a href="#section-10">{t(lang, 'guidePage.toc10')}</a></li>
      <li><a href="#section-11">{t(lang, 'guidePage.toc11')}</a></li>
      <li><a href="#section-12">{t(lang, 'guidePage.toc12')}</a></li>
    </ol>
  </details>
</nav>

<hr />

<h2 id="section-1">{t(lang, 'guidePage.s1Title')}</h2>

<p>{t(lang, 'guidePage.s1P1')}</p>

<p>{t(lang, 'guidePage.s1P2')}</p>

<p>{t(lang, 'guidePage.s1P3')}</p>

<p>{t(lang, 'guidePage.s1ConditionsIntro')}</p>
<ol class="guide-conditions">
  <li><Fragment set:html={t(lang, 'guidePage.s1Condition1')} /></li>
  <li>{t(lang, 'guidePage.s1Condition2')}</li>
  <li>{t(lang, 'guidePage.s1Condition3')}</li>
</ol>
<p>{t(lang, 'guidePage.s1ConditionsNote')}</p>

<p><Fragment set:html={t(lang, 'guidePage.s1ProofNote')} /></p>

<hr />

<h2 id="section-2"><span class="step-badge">1</span>{t(lang, 'guidePage.s2Title')}</h2>

