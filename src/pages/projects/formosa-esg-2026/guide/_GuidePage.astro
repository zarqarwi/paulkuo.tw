  <li>{t(lang, 'guidePage.s2Method2Step3')}</li>
</ol>

<a href="https://line.me/R/ti/p/@539fkwjd" class="guide-cta-line" target="_blank" rel="noopener">
  {t(lang, 'guidePage.s2AddLineFriend')}
</a>

<p>{t(lang, 'guidePage.s2AfterLogin')}</p>

<p>{t(lang, 'guidePage.s2DataSafe')}</p>

<hr />

<h2 id="section-3"><span class="step-badge">2</span>{t(lang, 'guidePage.s3Title')}</h2>

