<div class="level-grid">
  {[1,2,3,4,5,6,7,8,9].map((n) => (
    <div class:list={['level-card', { 'level-card-max': n === 9 }]}>
      <img src={`/images/formosa/level-${n}.webp`} alt={`${t(lang, `levels.${n}.name`)}${t(lang, 'levels.mascot')}`} class="level-mascot" width="120" height="120" loading="lazy" />
      <div class="level-info">
        <span class:list={['level-badge', { 'level-badge-max': n === 9 }]}>Lv.{n}</span>
        <strong>{t(lang, `levels.${n}.name`)}</strong>
        <span class="level-req">{t(lang, `levels.${n}.req`)}</span>
        <span class="level-desc">{t(lang, `levels.${n}.approxDays`)}</span>
      </div>
    </div>
