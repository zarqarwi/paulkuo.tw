---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="香客使用流程圖 — 2026 白沙屯媽祖 ESG 永續進香"
  description="白沙屯媽祖 ESG 進香追蹤系統香客使用流程圖"
  ogUrl="https://paulkuo.tw/projects/formosa-esg-2026/guide/user-flow/"
  ogImage="https://paulkuo.tw/images/formosa-esg-2026-og.png"
  eventMode={true}
>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;700&display=swap');

  :root {
    --green: #2E7D32;
    --green-light: #E8F5E9;
    --green-border: #66BB6A;
    --orange: #E65100;
    --orange-light: #FFF3E0;
    --orange-border: #FF9800;
    --blue: #1565C0;
    --blue-light: #E3F2FD;
    --blue-border: #42A5F5;
    --purple: #6A1B9A;
    --purple-light: #F3E5F5;
    --purple-border: #AB47BC;
    --gray: #455A64;
    --gray-light: #ECEFF1;
    --gray-border: #90A4AE;
    --gold: #F57F17;
    --gold-light: #FFFDE7;
    --gold-border: #FFCA28;
    --flow-bg: #FAFAFA;
    --flow-text: #212121;
    --flow-text-sub: #616161;
    --flow-radius: 14px;
  }

  .flow-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 40px 20px 80px;
    font-family: 'Noto Sans TC', -apple-system, sans-serif;
    color: var(--flow-text);
    line-height: 1.6;
  }

  .flow-header {
    text-align: center;
    margin-bottom: 48px;
  }
  .flow-header h1 {
    font-size: 28px;
    font-weight: 700;
    letter-spacing: 1px;
    margin-bottom: 8px;
  }
  .flow-header .meta {
    font-size: 13px;
    color: var(--flow-text-sub);
  }

  .legend {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    justify-content: center;
    margin-bottom: 40px;
  }
  .legend-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: var(--flow-text-sub);
  }
  .legend-dot {
    width: 14px;
    height: 14px;
    border-radius: 4px;
    border: 2px solid;
  }
  .legend-dot.green { background: var(--green-light); border-color: var(--green-border); }
  .legend-dot.orange { background: var(--orange-light); border-color: var(--orange-border); }
  .legend-dot.blue { background: var(--blue-light); border-color: var(--blue-border); }
  .legend-dot.purple { background: var(--purple-light); border-color: var(--purple-border); }
  .legend-dot.gold { background: var(--gold-light); border-color: var(--gold-border); }

  .connector {
    display: flex;
    justify-content: center;
    padding: 12px 0;
  }
  .connector .arrow {
    width: 3px;
    height: 36px;
    background: linear-gradient(to bottom, #bbb, #999);
    position: relative;
    border-radius: 2px;
  }
  .connector .arrow::after {
    content: '';
    position: absolute;
    bottom: -6px;
    left: 50%;
    transform: translateX(-50%);
    border-left: 7px solid transparent;
    border-right: 7px solid transparent;
    border-top: 8px solid #999;
  }

  .step {
    border-radius: var(--flow-radius);
    padding: 24px 28px;
    border: 2px solid;
    position: relative;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .step:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0,0,0,0.1);
  }
  .step-number {
    position: absolute;
    top: -14px;
    left: 24px;
    font-size: 12px;
    font-weight: 700;
    padding: 2px 12px;
    border-radius: 20px;
    color: white;
  }
  .step-title {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 4px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .step-subtitle {
    font-size: 13px;
    color: var(--flow-text-sub);
    margin-bottom: 14px;
  }
  .step-content { font-size: 14px; }

  .step.green { background: var(--green-light); border-color: var(--green-border); }
  .step.green .step-number { background: var(--green); }
  .step.green .step-title { color: var(--green); }

  .step.orange { background: var(--orange-light); border-color: var(--orange-border); }
  .step.orange .step-number { background: var(--orange); }
  .step.orange .step-title { color: var(--orange); }

  .step.blue { background: var(--blue-light); border-color: var(--blue-border); }
  .step.blue .step-number { background: var(--blue); }
  .step.blue .step-title { color: var(--blue); }

  .step.purple { background: var(--purple-light); border-color: var(--purple-border); }
  .step.purple .step-number { background: var(--purple); }
  .step.purple .step-title { color: var(--purple); }

  .step.gold { background: var(--gold-light); border-color: var(--gold-border); }
  .step.gold .step-number { background: var(--gold); }
  .step.gold .step-title { color: var(--gold); }

  .step.gray { background: var(--gray-light); border-color: var(--gray-border); }
  .step.gray .step-number { background: var(--gray); }
  .step.gray .step-title { color: var(--gray); }

  .sub-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 10px;
    margin-top: 14px;
  }
  .sub-item {
    background: rgba(255,255,255,0.7);
    border-radius: 10px;
    padding: 12px 14px;
    font-size: 13px;
  }
  .sub-item .sub-label { font-weight: 600; margin-bottom: 2px; }
  .sub-item .sub-desc { color: var(--flow-text-sub); font-size: 12px; }

  .decision {
    display: flex;
    justify-content: center;
    padding: 8px 0;
  }
  .diamond {
    background: white;
    border: 2px solid var(--green-border);
    border-radius: 10px;
    padding: 10px 24px;
    font-size: 14px;
    font-weight: 500;
    color: var(--green);
  }
  .diamond-branches {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    max-width: 600px;
    margin: 0 auto;
  }
  .branch {
    background: white;
    border: 1.5px solid #ddd;
    border-radius: 10px;
    padding: 12px 16px;
    font-size: 13px;
    text-align: center;
  }
  .branch-label { font-weight: 600; font-size: 12px; margin-bottom: 4px; }
  .branch-label.yes { color: var(--green); }
  .branch-label.no { color: var(--orange); }

  .info-box {
    background: white;
    border: 1.5px dashed #ccc;
    border-radius: 10px;
    padding: 16px 20px;
    margin-top: 14px;
    font-size: 13px;
    color: var(--flow-text-sub);
  }
  .info-box strong { color: var(--flow-text); }

  .level-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0 4px;
    margin-top: 10px;
    font-size: 12px;
  }
  .level-table th {
    text-align: left;
    padding: 6px 10px;
    font-weight: 600;
    color: var(--flow-text-sub);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .level-table td {
    padding: 6px 10px;
    background: rgba(255,255,255,0.7);
  }
  .level-table tr td:first-child { border-radius: 6px 0 0 6px; }
  .level-table tr td:last-child { border-radius: 0 6px 6px 0; }

  .badge {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 12px;
    margin-left: 8px;
    vertical-align: middle;
  }
  .badge.server { background: var(--blue-light); color: var(--blue); }
  .badge.liff { background: var(--green-light); color: var(--green); }
  .badge.client { background: var(--orange-light); color: var(--orange); }

  .conditions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 10px;
  }
  .condition {
    display: flex;
    align-items: center;
    gap: 6px;
    background: rgba(255,255,255,0.7);
    border-radius: 8px;
    padding: 8px 14px;
    font-size: 13px;
    font-weight: 500;
  }
  .condition .check {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    flex-shrink: 0;
  }

  .loop-indicator {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 6px 0;
    font-size: 12px;
    color: var(--flow-text-sub);
  }
  .loop-line { height: 1.5px; width: 40px; background: #ccc; }

  .flow-footer {
    text-align: center;
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid #eee;
    font-size: 12px;
    color: var(--flow-text-sub);
  }
  .flow-footer a {
    display: inline-block;
    margin-top: 16px;
    padding: 10px 24px;
    background: var(--green);
    color: white;
    border-radius: 8px;
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
  }
  .flow-footer a:hover { opacity: 0.9; }

  @media (max-width: 600px) {
    .flow-container { padding: 24px 12px 60px; }
    .flow-header h1 { font-size: 22px; }
    .step { padding: 20px 18px; }
    .sub-grid { grid-template-columns: 1fr; }
    .diamond-branches { grid-template-columns: 1fr; }
    .conditions { flex-direction: column; }
  }
</style>

<div class="flow-container">

  <div class="flow-header">
    <h1>Formosa ESG 2026 — 使用者流程圖</h1>
    <div class="meta">v2.0 ｜ 2026-03-30 ｜ paulkuo.tw ｜ 香客端</div>
  </div>

  <div class="legend">
    <div class="legend-item"><div class="legend-dot green"></div>LINE 相關</div>
    <div class="legend-item"><div class="legend-dot orange"></div>主要流程</div>
    <div class="legend-item"><div class="legend-dot blue"></div>資料 / 伺服器</div>
    <div class="legend-item"><div class="legend-dot purple"></div>等級 / 成就</div>
    <div class="legend-item"><div class="legend-dot gold"></div>碳足跡</div>
  </div>

  <!-- Step 1: Entry -->
  <div class="step orange">
    <div class="step-number">1</div>
    <div class="step-title">開啟頁面</div>
    <div class="step-subtitle">使用者從 QR Code 或 LINE Rich Menu 進入 Tracker</div>
    <div class="sub-grid">
      <div class="sub-item">
        <div class="sub-label">📱 QR Code 掃碼</div>
        <div class="sub-desc">實體海報 / 社群分享連結</div>
      </div>
      <div class="sub-item">
        <div class="sub-label">💬 LINE 圖文選單</div>
        <div class="sub-desc">LINE Bot @539fkwjd 下方按鈕</div>
      </div>
    </div>
  </div>

  <div class="connector"><div class="arrow"></div></div>

  <!-- Step 2: LINE Login -->
  <div class="step green">
    <div class="step-number">2</div>
    <div class="step-title">LINE 登入 <span class="badge liff">LIFF SDK</span></div>
    <div class="step-subtitle">透過 LIFF 自動觸發 LINE Login，免密碼、免註冊</div>
    <div class="step-content">
      <div class="info-box">
        LIFF init → 檢查登入狀態 → 自動取得 LINE 頭像與名稱<br>
        首次登入時自動在 D1 建立使用者（<strong>formosa_users</strong> upsert）<br>
        本機存入 <strong>formosa_user_id</strong> + <strong>formosa_access_token</strong>
      </div>
    </div>
  </div>

  <div class="connector"><div class="arrow"></div></div>

  <!-- Decision: logged in? -->
  <div class="decision">
    <div class="diamond">已登入？</div>
  </div>
  <div class="diamond-branches">
    <div class="branch">
      <div class="branch-label yes">✅ Yes</div>
      自動顯示頭像 + 名稱，直接進入
    </div>
    <div class="branch">
      <div class="branch-label no">❌ No</div>
      跳轉 LINE 授權頁 → 授權後回到 Tracker
    </div>
  </div>

  <div class="connector"><div class="arrow"></div></div>

  <!-- Step 3: Privacy Consent -->
  <div class="step orange">
    <div class="step-number">3</div>
    <div class="step-title">隱私同意 + AuthGate</div>
    <div class="step-subtitle">說明資料蒐集範圍，取得使用者同意後解鎖功能</div>
    <div class="step-content">
      <div class="info-box">
        蒐集項目：LINE 個人資料、GPS 軌跡、問卷答案、每日碳排回報<br>
        照片僅讀取 EXIF GPS 座標（<strong>不上傳伺服器</strong>）<br>
        使用者隨時可透過「完成進香」按鈕停止追蹤
      </div>
    </div>
  </div>

  <div class="connector"><div class="arrow"></div></div>

  <!-- Step 4: Survey -->
  <div class="step orange">
    <div class="step-number">4</div>
    <div class="step-title">問卷填寫（14 題）<span class="badge client">一題一頁卡片</span></div>
    <div class="step-subtitle">線性進度條 ＋ 可中斷存檔（localStorage 自動保存）</div>
    <div class="step-content">
      <div class="sub-grid">
        <div class="sub-item">
          <div class="sub-label">Q1-Q3</div>
          <div class="sub-desc">善行與感動時刻、慈善理解度</div>
        </div>
        <div class="sub-item">
          <div class="sub-label">Q4-Q6</div>
          <div class="sub-desc">活動後生活改變意願</div>
        </div>
        <div class="sub-item">
          <div class="sub-label">Q7-Q8</div>
          <div class="sub-desc">交通方式 + 距離（步行/開車/機車/公車/捷運/火車/高鐵）</div>
        </div>
        <div class="sub-item">
          <div class="sub-label">Q9-Q14</div>
          <div class="sub-desc">瓶裝水 / 回收 / 旅宿 / 電話 / 碳排試算</div>
        </div>
      </div>
      <div class="info-box" style="margin-top:12px;">
        ⚡ 碳排試算即時運算（SBTi 善足跡 / Ecoinvent 3.10）<br>
        📞 電話欄位是解鎖成就卡的三大條件之一
      </div>
    </div>
  </div>

  <div class="connector"><div class="arrow"></div></div>

  <!-- Step 5: Submit -->
  <div class="step blue">
    <div class="step-number">5</div>
    <div class="step-title">提交問卷 <span class="badge server">Server Sync</span></div>
    <div class="step-subtitle">問卷答案綁定 LINE userId，寫入 Cloudflare D1</div>
    <div class="step-content">
      <div class="info-box">
        Rate limit：每 10 分鐘最多 2 次提交<br>
        提交後進入打卡模式（主畫面）
      </div>
    </div>
  </div>

  <div class="connector"><div class="arrow"></div></div>

  <!-- Step 6: Check-in Mode -->
  <div class="step orange">
    <div class="step-number">6</div>
    <div class="step-title">打卡模式（Check-in Mode）</div>
    <div class="step-subtitle">進香期間的主要操作畫面，GPS 持續追蹤</div>
    <div class="step-content">
      <div class="sub-grid">
        <div class="sub-item">
          <div class="sub-label">📍 GPS 自動追蹤</div>
          <div class="sub-desc">背景持續記錄路線，KV Buffer 暫存 → 批次寫入 D1</div>
        </div>
        <div class="sub-item">
          <div class="sub-label">✋ 手動打卡</div>
          <div class="sub-desc">按鈕觸發 + 定位，累積里程與打卡次數</div>
        </div>
        <div class="sub-item">
          <div class="sub-label">📷 拍照打卡</div>
          <div class="sub-desc">選照片 → 讀取 EXIF GPS → 照片不上傳（僅文字示意）</div>
        </div>
        <div class="sub-item">
          <div class="sub-label">⏸️ 暫離 / 完成</div>
          <div class="sub-desc">暫停追蹤不結束 session；「完成進香」結算成就卡</div>
        </div>
      </div>
      <div class="info-box" style="margin-top:12px;">
        Rate limit：5 次打卡 / 60 秒（KV 滑動窗口計數器）<br>
        GPS 點先寫 KV（TTL 24hr），每晚批次 flush 到 D1
      </div>
    </div>
  </div>

  <div class="loop-indicator">
    <div class="loop-line"></div>
    <span>持續循環（活動期間每天重複操作）</span>
    <div class="loop-line"></div>
  </div>

  <div class="connector"><div class="arrow"></div></div>

  <!-- Step 6.5: Daily Carbon Report -->
  <div class="step gold">
    <div class="step-number">6.5</div>
    <div class="step-title">每日碳足跡回報 🌱</div>
    <div class="step-subtitle">GPS 速度自動判斷 + 手動補充，即時換算碳排</div>
    <div class="step-content">
      <div class="sub-grid">
        <div class="sub-item">
          <div class="sub-label">🚶 零碳移動（自動）</div>
          <div class="sub-desc">速度 &lt;15 km/h → 判定步行/騎車 → CO₂ = 0</div>
        </div>
        <div class="sub-item">
          <div class="sub-label">🚗 交通碳排（手動）</div>
          <div class="sub-desc">開車 0.21 / 機車 0.10 / 公車 0.05 / 捷運 0.03 kg CO₂e/km</div>
        </div>
        <div class="sub-item">
          <div class="sub-label">🧴 日常碳排</div>
          <div class="sub-desc">塑膠瓶 0.3 kg/瓶、旅宿 2.5 kg/晚</div>
        </div>
        <div class="sub-item">
          <div class="sub-label">📊 即時試算</div>
          <div class="sub-desc">碳足跡 + 碳減量（vs. 全程開車）</div>
        </div>
      </div>
      <div class="info-box" style="margin-top:12px;">
        資料來源：<strong>SBTi 善足跡 / Ecoinvent 3.10</strong><br>
        每日可重新提交（覆蓋前次紀錄）
      </div>
    </div>
  </div>

  <div class="connector"><div class="arrow"></div></div>

  <!-- Step 7: Level System -->
  <div class="step purple">
    <div class="step-number">7</div>
    <div class="step-title">等級系統 + AI 公仔</div>
    <div class="step-subtitle">雙條件升級（公里數 + 打卡次數），9 級進化</div>
    <div class="step-content">
      <table class="level-table">
        <thead>
          <tr><th>等級</th><th>名稱</th><th>公里</th><th>打卡</th><th>對應</th></tr>
        </thead>
        <tbody>
          <tr><td>Lv.1</td><td>🔥 煉氣香客</td><td>0</td><td>1</td><td>起步</td></tr>
          <tr><td>Lv.2</td><td>🧱 築基香客</td><td>15</td><td>3</td><td>≈ Day 1</td></tr>
          <tr><td>Lv.3</td><td>💛 金丹香客</td><td>45</td><td>5</td><td>≈ Day 2</td></tr>
          <tr><td>Lv.4</td><td>👶 元嬰香客</td><td>90</td><td>6</td><td>≈ Day 3</td></tr>
          <tr><td>Lv.5</td><td>✨ 化神香客</td><td>135</td><td>8</td><td>≈ Day 4</td></tr>
          <tr><td>Lv.6</td><td>🌀 煉虛香客</td><td>180</td><td>10</td><td>≈ Day 5</td></tr>
          <tr><td>Lv.7</td><td>🤝 合體香客</td><td>225</td><td>12</td><td>≈ Day 6</td></tr>
          <tr><td>Lv.8</td><td>🏆 大乘香客</td><td>270</td><td>14</td><td>≈ Day 7</td></tr>
          <tr><td>Lv.9</td><td>🚀 飛升香客</td><td>300</td><td>14+</td><td>全程走完</td></tr>
        </tbody>
      </table>
      <div class="info-box" style="margin-top:12px;">
        每級對應一張 <strong>AI 生成粉色頭巾公仔</strong>（1200px WebP）<br>
        <strong>雙條件邏輯</strong>：公里數 AND 打卡數都要達標才升級
      </div>
    </div>
  </div>

  <div class="connector"><div class="arrow"></div></div>

  <!-- Step 8: Achievement Card -->
  <div class="step purple">
    <div class="step-number">8</div>
    <div class="step-title">成就卡解鎖 🏅</div>
    <div class="step-subtitle">三大條件全部達成才會解鎖</div>
    <div class="step-content">
      <div class="conditions">
        <div class="condition">
          <div class="check" style="background:#E8F5E9;color:#2E7D32;">✓</div>
          打卡 ≥ 3 次
        </div>
        <div class="condition">
          <div class="check" style="background:#E3F2FD;color:#1565C0;">✓</div>
          完成問卷
        </div>
        <div class="condition">
          <div class="check" style="background:#F3E5F5;color:#6A1B9A;">✓</div>
          留電話號碼
        </div>
      </div>
