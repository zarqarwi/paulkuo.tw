  }
  .map-toggle.active { background: #B45309; color: #fff; border-color: #B45309; }

  /* Carbon */
  .carbon-saved-big { font-size: 2.5rem; font-weight: 800; color: #2E7D32; text-align: center; }
  .carbon-saved-big small { font-size: 1rem; font-weight: 400; }
  .carbon-saved-sub { text-align: center; color: #555; font-size: 0.85rem; margin: 0.5rem 0 1rem; }
  .donut-wrap { display: flex; justify-content: center; margin: 1rem 0; }
