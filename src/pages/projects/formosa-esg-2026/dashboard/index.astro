---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import AuthGate from '../_components/AuthGate.astro';
---

<BaseLayout
  title="管理後台 — 2026 白沙屯媽祖 ESG 進香"
  description="進香數據儀表板：即時路徑、碳減量、問卷洞察。"
  ogUrl="https://paulkuo.tw/projects/formosa-esg-2026/dashboard/"
  ogImage="https://paulkuo.tw/images/formosa-esg-2026-og.png"
  eventMode={true}
>

<AuthGate title="進香數據儀表板" subtitle="請輸入管理密碼">

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" />
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>

<div class="admin-dash">
  <nav class="dash-breadcrumb">
    <a href="/projects/formosa-esg-2026/">← 回到專案總覽</a>
    <a href="/projects/formosa-esg-2026/tracker/" class="dash-breadcrumb-right">📍 打卡頁面</a>
  </nav>

  <header class="dash-header">
    <div>
      <span class="dash-badge">管理後台</span>
      <h1>進香數據儀表板</h1>
    </div>
    <div class="dash-refresh">
      <span class="dash-pulse" id="refreshPulse"></span>
      <label><input type="checkbox" id="autoRefresh" checked> 自動更新</label>
      <span class="dash-updated" id="lastUpdated">載入中...</span>
    </div>
  </header>

  <!-- KPI Cards -->
  <div class="kpi-row" id="kpiRow">
    <div class="kpi-card"><div class="kpi-num" id="kpiUsers">-</div><div class="kpi-label">總參與人數</div></div>
    <div class="kpi-card"><div class="kpi-num" id="kpiActive">-</div><div class="kpi-label">今日活躍</div></div>
    <div class="kpi-card"><div class="kpi-num" id="kpiCheckins">-</div><div class="kpi-label">總打卡次數</div></div>
    <div class="kpi-card"><div class="kpi-num" id="kpiWalkKm">-</div><div class="kpi-label">總步行公里</div></div>
    <div class="kpi-card kpi-green"><div class="kpi-num" id="kpiSaved">-</div><div class="kpi-label">碳減量 kg</div></div>
  </div>

  <!-- Live Map -->
  <section class="dash-section">
    <div class="dash-section-header">
      <h2>📍 即時路徑圖</h2>
      <div class="map-toggles">
        <button class="map-toggle active" id="toggleHeat" onclick="setMapMode('heat')">熱力圖</button>
        <button class="map-toggle" id="toggleMarkers" onclick="setMapMode('markers')">標記</button>
        <button class="map-toggle" id="toggleCluster" onclick="setMapMode('cluster')">聚類</button>
      </div>
    </div>
    <div id="adminMap" class="admin-map admin-map-dark"></div>
    <div class="map-info-bar map-info-dark">
      <div class="map-info-item" id="mapFront">🟢 前鋒：--</div>
      <div class="map-info-item" id="mapTail">🔴 尾巴：--</div>
      <div class="map-info-item" id="mapSpread">📏 展開：--</div>
      <div class="map-info-item" id="mapLost">⚠️ 失聯：--</div>
    </div>
    <div class="route-progress-wrap">
      <div class="route-progress-labels"><span>🔴 白沙屯</span><span id="routeProgressPct">--</span><span>🟡 北港</span></div>
      <div class="route-progress-track"><div class="route-progress-fill" id="routeProgressBar" style="width:0%"></div><div class="route-progress-mazu" id="routeProgressMazu" style="left:0%">👑</div></div>
    </div>
  </section>

  <!-- Two columns: Carbon + Rank -->
  <div class="dash-grid-2">
    <section class="dash-section">
      <h2>🌱 累積碳減量</h2>
      <div id="carbonPanel" class="carbon-panel"></div>
    </section>
    <section class="dash-section">
      <h2>🏆 等級分布</h2>
      <div id="rankPanel" class="rank-panel"></div>
    </section>
  </div>

  <!-- Two columns: Survey + Timeline -->
  <div class="dash-grid-2">
    <section class="dash-section">
      <h2>📋 問卷洞察</h2>
      <div id="surveyPanel" class="survey-panel"></div>
    </section>
    <section class="dash-section">
      <h2>📈 活動時間軸</h2>
      <div id="timelinePanel" class="timeline-panel"></div>
    </section>
  </div>

  <!-- Push Notification -->
  <section class="dash-section">
    <h2>📤 推播通知</h2>
    <div class="push-form">
      <div class="push-row">
        <label>對象</label>
        <select id="pushRole" class="push-input">
          <option value="all">全部</option>
          <option value="participant">🚶 香客</option>
          <option value="volunteer">🙋 志工</option>
          <option value="admin">🔑 管理者</option>
        </select>
      </div>
      <div class="push-row">
        <label>標題</label>
        <input type="text" id="pushTitle" class="push-input" value="📍 進香打卡提醒" maxlength="40">
      </div>
      <div class="push-row">
        <label>內容</label>
        <textarea id="pushText" class="push-input push-textarea" maxlength="160">媽祖保佑 🙏
記錄您的進香足跡吧！</textarea>
      </div>
      <button id="pushBtn" class="push-send-btn" onclick="sendPush()">📤 發送推播</button>
    </div>
  </section>

  <!-- User Table -->
  <section class="dash-section">
    <div class="dash-section-header">
      <h2>👥 參與者列表</h2>
      <input type="text" class="dash-search" id="userSearch" placeholder="搜尋..." oninput="filterUsers(this.value)">
    </div>
    <div class="table-wrap">
      <table class="dash-table" id="userTable">
        <thead>
          <tr>
            <th onclick="sortTable(0)">名稱 ↕</th>
            <th onclick="sortTable(1)">打卡 ↕</th>
            <th onclick="sortTable(2)">碳排 ↕</th>
            <th onclick="sortTable(3)">最後活躍 ↕</th>
            <th>角色</th>
            <th>狀態</th>
          </tr>
        </thead>
        <tbody id="userTableBody"></tbody>
      </table>
    </div>
  </section>
</div>

<script is:inline>
(function() {
  var API = 'https://paulkuo-ticker.paul-4bf.workers.dev';
  // Read admin token from sessionStorage (set by AuthGate on login)
  var ADMIN_HEADERS = { 'X-Admin-Token': sessionStorage.getItem('formosa_esg_code') || '' };
  var TITLES = [
    { km: 0,   checkins: 1,  icon: '🔥', name: '煉氣香客' },
    { km: 15,  checkins: 3,  icon: '🧱', name: '築基香客' },
    { km: 45,  checkins: 5,  icon: '💛', name: '金丹香客' },
    { km: 90,  checkins: 6,  icon: '👶', name: '元嬰香客' },
    { km: 135, checkins: 8,  icon: '✨', name: '化神香客' },
    { km: 180, checkins: 10, icon: '🌀', name: '煉虛香客' },
    { km: 225, checkins: 12, icon: '🤝', name: '合體香客' },
    { km: 270, checkins: 14, icon: '🏆', name: '大乘香客' },
    { km: 300, checkins: 14, icon: '🚀', name: '飛升香客' }
  ];

  var map = null, markerLayer = null, heatLayer = null;
  var mapMode = 'markers';
  var allUsers = [];

  // ── Fetch all data ──
  async function fetchAll() {
    try {
      var [dataRes, carbonRes, timelineRes, usersRes, surveyRes] = await Promise.all([
        fetch(API + '/api/formosa/data', { headers: ADMIN_HEADERS }).then(r => r.json()),
        fetch(API + '/api/formosa/admin/carbon', { headers: ADMIN_HEADERS }).then(r => r.json()),
        fetch(API + '/api/formosa/admin/timeline', { headers: ADMIN_HEADERS }).then(r => r.json()),
        fetch(API + '/api/formosa/admin/users', { headers: ADMIN_HEADERS }).then(r => r.json()),
        fetch(API + '/api/formosa/admin/surveys', { headers: ADMIN_HEADERS }).then(r => r.json())
      ]);

      renderKPI(dataRes, carbonRes, timelineRes);
      renderMap(dataRes.gps_points || []);
      renderCarbon(carbonRes);
      renderRanks(usersRes.users || []);
      renderSurvey(surveyRes);
      renderTimeline(timelineRes);
      renderUserTable(usersRes.users || []);

      document.getElementById('lastUpdated').textContent = '更新: ' + new Date().toLocaleTimeString('zh-TW');
    } catch (e) {
      document.getElementById('lastUpdated').textContent = '⚠️ 載入失敗';
      console.error('Dashboard fetch error:', e);
    }
  }

  // ── KPI Cards ──
  function renderKPI(data, carbon, timeline) {
    document.getElementById('kpiUsers').textContent = data.stats.total_users || 0;
    document.getElementById('kpiActive').textContent = timeline.active_today || 0;
    document.getElementById('kpiCheckins').textContent = data.stats.total_gps_points || 0;
    document.getElementById('kpiWalkKm').textContent = (carbon.transport_totals?.walk?.km || 0).toFixed(0);
    document.getElementById('kpiSaved').textContent = (carbon.carbon_saved_kg || 0);
  }

  // ── Live Map: Dark Theme + Pilgrimage Route ──
  var clusterLayer = null;
  var frontTailLayer = null;
  var routeLayer = null;
  var mazuMarker = null;

  // Pilgrimage route waypoints: 白沙屯 → 北港
  var ROUTE_WAYPOINTS = [
    { name: '白沙屯', lat: 24.5965, lng: 120.6560 },
    { name: '通霄',   lat: 24.4890, lng: 120.6830 },
    { name: '苑裡',   lat: 24.4410, lng: 120.6540 },
    { name: '大甲',   lat: 24.3490, lng: 120.6220 },
    { name: '清水',   lat: 24.2680, lng: 120.5590 },
    { name: '沙鹿',   lat: 24.2330, lng: 120.5660 },
    { name: '台中',   lat: 24.1480, lng: 120.6740 },
    { name: '彰化',   lat: 24.0810, lng: 120.5380 },
    { name: '西螺',   lat: 23.7980, lng: 120.4660 },
    { name: '北港',   lat: 23.5710, lng: 120.3020 }
  ];

  // Total route distance (cumulative km between waypoints)
  var ROUTE_DISTS = []; // cumulative km at each waypoint
  (function() {
    ROUTE_DISTS.push(0);
    for (var i = 1; i < ROUTE_WAYPOINTS.length; i++) {
      var d = _hav(ROUTE_WAYPOINTS[i-1].lat, ROUTE_WAYPOINTS[i-1].lng, ROUTE_WAYPOINTS[i].lat, ROUTE_WAYPOINTS[i].lng);
      ROUTE_DISTS.push(ROUTE_DISTS[i-1] + d);
    }
  })();
  var ROUTE_TOTAL_KM = ROUTE_DISTS[ROUTE_DISTS.length - 1];

  // Haversine (global helper)
  function _hav(lat1, lng1, lat2, lng2) {
    var R = 6371;
    var dLat = (lat2 - lat1) * Math.PI / 180;
    var dLng = (lng2 - lng1) * Math.PI / 180;
    var a = Math.sin(dLat/2) * Math.sin(dLat/2) + Math.cos(lat1*Math.PI/180) * Math.cos(lat2*Math.PI/180) * Math.sin(dLng/2) * Math.sin(dLng/2);
    return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
  }

  // Find progress % along route for a given lat/lng
  function routeProgress(lat, lng) {
    var bestDist = Infinity, bestIdx = 0;
    for (var i = 0; i < ROUTE_WAYPOINTS.length; i++) {
      var d = _hav(lat, lng, ROUTE_WAYPOINTS[i].lat, ROUTE_WAYPOINTS[i].lng);
      if (d < bestDist) { bestDist = d; bestIdx = i; }
    }
    // Interpolate between nearest waypoint and neighbors
    var cumKm = ROUTE_DISTS[bestIdx];
    // Check if closer to next or prev segment
    if (bestIdx > 0) {
      var prevD = _hav(lat, lng, ROUTE_WAYPOINTS[bestIdx-1].lat, ROUTE_WAYPOINTS[bestIdx-1].lng);
      var segLen = ROUTE_DISTS[bestIdx] - ROUTE_DISTS[bestIdx-1];
      if (prevD < segLen) {
        var frac = 1 - (prevD / (prevD + bestDist));
        cumKm = ROUTE_DISTS[bestIdx-1] + frac * segLen;
      }
    }
    return Math.min(100, Math.max(0, (cumKm / ROUTE_TOTAL_KM) * 100));
  }

  function renderMap(points) {
    if (!map) {
      map = L.map('adminMap', { zoomControl: false }).setView([24.1, 120.5], 9);
      // Dark tile layer (Carto Dark Matter)
      L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
        attribution: '&copy; <a href="https://carto.com/">CARTO</a>', maxZoom: 19, subdomains: 'abcd'
      }).addTo(map);
      L.control.zoom({ position: 'topright' }).addTo(map);

      // Draw pilgrimage route polyline
      routeLayer = L.layerGroup().addTo(map);
      var routeCoords = ROUTE_WAYPOINTS.map(function(w) { return [w.lat, w.lng]; });
      // Outer glow line
      L.polyline(routeCoords, { color: '#ffd700', weight: 6, opacity: 0.25, lineCap: 'round' }).addTo(routeLayer);
      // Main route line
      L.polyline(routeCoords, { color: '#ffd700', weight: 2.5, opacity: 0.8, lineCap: 'round', dashArray: null }).addTo(routeLayer);
      // Waypoint dots
      ROUTE_WAYPOINTS.forEach(function(w, i) {
        var isEnd = (i === 0 || i === ROUTE_WAYPOINTS.length - 1);
        L.circleMarker([w.lat, w.lng], {
          radius: isEnd ? 6 : 3,
          color: isEnd ? '#ffd700' : 'rgba(255,215,0,0.5)',
          fillColor: isEnd ? '#ffd700' : 'rgba(255,215,0,0.3)',
          fillOpacity: 1, weight: isEnd ? 2 : 1
        }).bindTooltip(w.name, {
          permanent: isEnd, direction: 'top', className: 'route-tooltip',
          offset: [0, -8]
        }).addTo(routeLayer);
      });
    }

    window._mapPoints = points;
    if (!points || points.length === 0) return;

    // Get latest point per user (their current position)
    var userLatest = {};
    points.forEach(function(p) {
      var uid = p.user_id || 'unknown';
      if (!userLatest[uid] || p.timestamp > userLatest[uid].timestamp) {
        userLatest[uid] = p;
      }
    });
    var currentPositions = Object.values(userLatest);

    // Baishatun reference for distance
    var BAISHATUN = { lat: 24.5965, lng: 120.656 };
    currentPositions.forEach(function(p) {
      p._distFromStart = _hav(BAISHATUN.lat, BAISHATUN.lng, p.lat, p.lng);
      p._routePct = routeProgress(p.lat, p.lng);
    });
    currentPositions.sort(function(a, b) { return b._distFromStart - a._distFromStart; });

    var front = currentPositions[0];
    var tail = currentPositions[currentPositions.length - 1];
    var spread = front && tail ? _hav(front.lat, front.lng, tail.lat, tail.lng) : 0;

    // Lost signal: no update > 30 min
    var now = Date.now();
    var lostCount = currentPositions.filter(function(p) {
      return p.timestamp && (now - new Date(p.timestamp).getTime()) > 30 * 60 * 1000;
    }).length;

    // Update info bar
    document.getElementById('mapFront').textContent = '🟢 前鋒：' + (front ? front._distFromStart.toFixed(1) + ' km' : '--');
    document.getElementById('mapTail').textContent = '🔴 尾巴：' + (tail ? tail._distFromStart.toFixed(1) + ' km' : '--');
    document.getElementById('mapSpread').textContent = '📏 展開：' + spread.toFixed(1) + ' km';
    document.getElementById('mapLost').textContent = '⚠️ 失聯：' + lostCount + ' 人';

    // Update route progress bar
    var avgPct = 0;
    currentPositions.forEach(function(p) { avgPct += p._routePct; });
    avgPct = currentPositions.length ? (avgPct / currentPositions.length) : 0;
    var frontPct = front ? front._routePct : 0;
    document.getElementById('routeProgressBar').style.width = avgPct.toFixed(1) + '%';
    document.getElementById('routeProgressMazu').style.left = frontPct.toFixed(1) + '%';
    document.getElementById('routeProgressPct').textContent = avgPct.toFixed(0) + '%';

    // Build all layers
    buildMarkerLayer(points);
    buildHeatLayer(currentPositions);
    buildClusterLayer(currentPositions);
    buildFrontTailLayer(front, tail);

    // Show default mode
    setMapMode(mapMode);

    // Include route waypoints in bounds so we always see the pilgrimage route
    var bounds = currentPositions.map(function(p) { return [p.lat, p.lng]; });
    ROUTE_WAYPOINTS.forEach(function(w) { bounds.push([w.lat, w.lng]); });
    if (bounds.length > 0) map.fitBounds(bounds, { padding: [30, 30] });
  }

  function buildMarkerLayer(points) {
    if (markerLayer) map.removeLayer(markerLayer);
    markerLayer = L.layerGroup();

    var userGroups = {};
    points.forEach(function(p) {
      var uid = p.user_id || 'unknown';
      if (!userGroups[uid]) userGroups[uid] = [];
      userGroups[uid].push(p);
    });

    Object.keys(userGroups).forEach(function(uid) {
      var pts = userGroups[uid];
      var hue = simpleHash(uid) % 360;
      var color = 'hsl(' + hue + ', 80%, 65%)';
      pts.forEach(function(p) {
        L.circleMarker([p.lat, p.lng], {
          radius: 4, color: color, fillColor: color, fillOpacity: 0.8, weight: 1
        }).bindPopup('<span style="color:#ccc">' + uid.substring(0, 8) + '</span><br><span style="color:#888">' + (p.timestamp || '') + '</span>').addTo(markerLayer);
      });
    });
  }

  function buildHeatLayer(positions) {
    if (heatLayer) map.removeLayer(heatLayer);
    heatLayer = L.layerGroup();

    // Multi-layer circles for dark-theme heat effect (orange/gold/red)
    positions.forEach(function(p) {
      // Wide outer glow
      L.circleMarker([p.lat, p.lng], {
        radius: 30, color: 'transparent', fillColor: '#ff4500', fillOpacity: 0.06, weight: 0
      }).addTo(heatLayer);
      // Mid glow
      L.circleMarker([p.lat, p.lng], {
        radius: 18, color: 'transparent', fillColor: '#ff6b00', fillOpacity: 0.15, weight: 0
      }).addTo(heatLayer);
      // Core
      L.circleMarker([p.lat, p.lng], {
        radius: 7, color: 'transparent', fillColor: '#ffd700', fillOpacity: 0.4, weight: 0
      }).addTo(heatLayer);
    });
  }

  function buildClusterLayer(positions) {
    if (clusterLayer) map.removeLayer(clusterLayer);
    clusterLayer = L.layerGroup();

    var gridSize = 0.02;
    var cells = {};
    positions.forEach(function(p) {
      var key = Math.round(p.lat / gridSize) + ',' + Math.round(p.lng / gridSize);
      if (!cells[key]) cells[key] = { lat: 0, lng: 0, count: 0 };
      cells[key].lat += p.lat;
      cells[key].lng += p.lng;
      cells[key].count++;
    });

    Object.values(cells).forEach(function(c) {
      var lat = c.lat / c.count;
      var lng = c.lng / c.count;
      var r = Math.min(35, 10 + Math.sqrt(c.count) * 3);
      var opacity = Math.min(0.8, 0.3 + c.count / 100);

      // Outer glow
      L.circleMarker([lat, lng], {
        radius: r + 6, color: 'transparent', fillColor: '#f59e0b', fillOpacity: opacity * 0.2, weight: 0
      }).addTo(clusterLayer);
      // Bubble
      L.circleMarker([lat, lng], {
        radius: r, color: '#f59e0b', fillColor: '#f59e0b', fillOpacity: opacity, weight: 2
      }).bindPopup('<span style="color:#ccc">此區域 ' + c.count + ' 人</span>').addTo(clusterLayer);

      if (c.count >= 2) {
        var icon = L.divIcon({
          className: 'cluster-label',
          html: '<span>' + c.count + '</span>',
          iconSize: [40, 20],
          iconAnchor: [20, 10]
        });
        L.marker([lat, lng], { icon: icon }).addTo(clusterLayer);
      }
    });
  }

  function buildFrontTailLayer(front, tail) {
    if (frontTailLayer) map.removeLayer(frontTailLayer);
    frontTailLayer = L.layerGroup();

    if (front) {
      // Glow ring
      L.circleMarker([front.lat, front.lng], {
        radius: 18, color: 'transparent', fillColor: '#10b981', fillOpacity: 0.2, weight: 0
      }).addTo(frontTailLayer);
      L.circleMarker([front.lat, front.lng], {
        radius: 10, color: '#10b981', fillColor: '#10b981', fillOpacity: 1, weight: 2
      }).bindPopup('<span style="color:#10b981;font-weight:700">🟢 前鋒</span><br>' + front._distFromStart.toFixed(1) + ' km').addTo(frontTailLayer);
      L.marker([front.lat, front.lng], {
        icon: L.divIcon({ className: 'front-tail-label front-label-dark', html: '前鋒', iconSize: [40, 16], iconAnchor: [20, -12] })
      }).addTo(frontTailLayer);
    }
    if (tail) {
      // Glow ring
      L.circleMarker([tail.lat, tail.lng], {
        radius: 18, color: 'transparent', fillColor: '#ef4444', fillOpacity: 0.2, weight: 0
      }).addTo(frontTailLayer);
      L.circleMarker([tail.lat, tail.lng], {
        radius: 10, color: '#ef4444', fillColor: '#ef4444', fillOpacity: 1, weight: 2
      }).bindPopup('<span style="color:#ef4444;font-weight:700">🔴 尾巴</span><br>' + tail._distFromStart.toFixed(1) + ' km').addTo(frontTailLayer);
      L.marker([tail.lat, tail.lng], {
        icon: L.divIcon({ className: 'front-tail-label tail-label-dark', html: '尾巴', iconSize: [40, 16], iconAnchor: [20, -12] })
      }).addTo(frontTailLayer);
    }

    // 神轎 (Mazu palanquin) marker — median position of all users
    if (front && tail) {
      var allLats = [], allLngs = [];
      (window._mapPoints || []).forEach(function(p) { allLats.push(p.lat); allLngs.push(p.lng); });
      if (allLats.length > 0) {
        allLats.sort(function(a,b){return a-b;});
        allLngs.sort(function(a,b){return a-b;});
        var medLat = allLats[Math.floor(allLats.length / 2)];
        var medLng = allLngs[Math.floor(allLngs.length / 2)];
        // Gold glow
        L.circleMarker([medLat, medLng], {
          radius: 22, color: 'transparent', fillColor: '#ffd700', fillOpacity: 0.15, weight: 0
        }).addTo(frontTailLayer);
        L.circleMarker([medLat, medLng], {
          radius: 12, color: '#ffd700', fillColor: '#ffd700', fillOpacity: 1, weight: 2
        }).bindPopup('<span style="color:#ffd700;font-weight:700">👑 神轎（媽祖）</span>').addTo(frontTailLayer);
        L.marker([medLat, medLng], {
          icon: L.divIcon({ className: 'front-tail-label mazu-label-dark', html: '👑 神轎', iconSize: [56, 18], iconAnchor: [28, -14] })
        }).addTo(frontTailLayer);
      }
    }
  }

  function simpleHash(str) {
    var hash = 0;
    for (var i = 0; i < str.length; i++) {
      hash = ((hash << 5) - hash) + str.charCodeAt(i);
      hash |= 0;
    }
    return Math.abs(hash);
  }

  window.setMapMode = function(mode) {
    mapMode = mode;
    document.getElementById('toggleMarkers').className = 'map-toggle' + (mode === 'markers' ? ' active' : '');
    document.getElementById('toggleHeat').className = 'map-toggle' + (mode === 'heat' ? ' active' : '');
    document.getElementById('toggleCluster').className = 'map-toggle' + (mode === 'cluster' ? ' active' : '');

    // Remove data layers (keep route)
    if (markerLayer) map.removeLayer(markerLayer);
    if (heatLayer) map.removeLayer(heatLayer);
    if (clusterLayer) map.removeLayer(clusterLayer);
    if (frontTailLayer) map.removeLayer(frontTailLayer);

    // Add selected + front/tail always on
    if (mode === 'markers' && markerLayer) markerLayer.addTo(map);
    if (mode === 'heat' && heatLayer) heatLayer.addTo(map);
    if (mode === 'cluster' && clusterLayer) clusterLayer.addTo(map);
    if (frontTailLayer) frontTailLayer.addTo(map);
  };

  // ── Carbon Panel ──
  function renderCarbon(data) {
    var panel = document.getElementById('carbonPanel');
    var saved = data.carbon_saved_kg || 0;
    var trees = Math.max(0.01, saved / 22).toFixed(2);

    var modes = [
      { key: 'walk', label: '步行', color: '#059669' },
      { key: 'car', label: '汽車', color: '#DC2626' },
      { key: 'bus', label: '公車', color: '#2563EB' },
      { key: 'scooter', label: '機車', color: '#D97706' },
      { key: 'train', label: '火車', color: '#7C3AED' },
      { key: 'hsr', label: '高鐵', color: '#0891B2' },
      { key: 'mrt', label: '捷運', color: '#059669' }
    ];

    var totalKm = 0;
    modes.forEach(function(m) { totalKm += (data.transport_totals?.[m.key]?.km || 0); });

    var html = '<div class="carbon-saved-big">' + saved + '<small> kg CO₂</small></div>' +
      '<p class="carbon-saved-sub">碳減量（相當於 🌳 ' + trees + ' 棵樹年吸收量）</p>';

    // Donut chart with conic-gradient
    if (totalKm > 0) {
      var gradientParts = [];
      var cumPct = 0;
      modes.forEach(function(m) {
        var km = data.transport_totals?.[m.key]?.km || 0;
        if (km > 0) {
          var pct = (km / totalKm * 100);
          gradientParts.push(m.color + ' ' + cumPct.toFixed(1) + '% ' + (cumPct + pct).toFixed(1) + '%');
          cumPct += pct;
        }
      });

      html += '<div class="donut-wrap"><div class="donut" style="background:conic-gradient(' + gradientParts.join(',') + ')"></div></div>';

      // Legend
      html += '<div class="donut-legend">';
      modes.forEach(function(m) {
        var km = data.transport_totals?.[m.key]?.km || 0;
        if (km > 0) {
          html += '<span class="legend-item"><span class="legend-dot" style="background:' + m.color + '"></span>' + m.label + ' ' + km.toFixed(0) + 'km</span>';
        }
      });
      html += '</div>';
    }

    html += '<div class="carbon-meta">人均碳足跡: ' + (data.avg_carbon_kg || 0) + ' kg ｜ 水瓶: ' + (data.water_bottles_total || 0) + ' 瓶 ｜ 住宿: ' + (data.hotel_nights_total || 0) + ' 晚</div>';
    panel.innerHTML = html;
  }

  // ── Rank Distribution ──
  function renderRanks(users) {
    var counts = {};
    TITLES.forEach(function(t) { counts[t.name] = 0; });

    users.forEach(function(u) {
      // Estimate rank from gps_count (as checkin proxy) and walk_km
      var checkins = u.gps_count || 0;
      var km = u.walk_km || 0;
      var rank = TITLES[0];
      for (var i = TITLES.length - 1; i >= 0; i--) {
        if (km >= TITLES[i].km && checkins >= TITLES[i].checkins) { rank = TITLES[i]; break; }
      }
      counts[rank.name]++;
    });

    var maxCount = Math.max.apply(null, Object.values(counts).concat([1]));
    var html = '';
    TITLES.forEach(function(t) {
      var pct = (counts[t.name] / maxCount * 100).toFixed(0);
      html += '<div class="rank-bar-row">' +
        '<span class="rank-bar-label">' + t.icon + ' ' + t.name + '</span>' +
        '<div class="rank-bar-track"><div class="rank-bar-fill" style="width:' + pct + '%"></div></div>' +
        '<span class="rank-bar-val">' + counts[t.name] + '</span>' +
      '</div>';
    });

    document.getElementById('rankPanel').innerHTML = html;
  }

  // ── Survey Insights ──
  function renderSurvey(data) {
    var panel = document.getElementById('surveyPanel');
    if (!data.total_surveys) {
      panel.innerHTML = '<p style="color:#888;">尚無問卷資料</p>';
      return;
    }

    var html = '<p class="survey-total">共 ' + data.total_surveys + ' 份問卷</p>';

    // Top 5 善行 (Q1)
    html += '<h4>Top 善行活動</h4>';
    var q1 = Object.entries(data.q1_deeds || {}).sort(function(a, b) { return b[1] - a[1]; }).slice(0, 5);
    var maxQ1 = q1.length ? q1[0][1] : 1;
    q1.forEach(function(item) {
      var pct = (item[1] / maxQ1 * 100).toFixed(0);
      html += '<div class="survey-bar-row"><span class="survey-bar-label">' + item[0] + '</span>' +
        '<div class="survey-bar-track"><div class="survey-bar-fill" style="width:' + pct + '%"></div></div>' +
        '<span class="survey-bar-val">' + item[1] + '</span></div>';
    });

    // CSR (Q6)
    html += '<h4 style="margin-top:1rem;">CSR 意願</h4>';
    var q6 = Object.entries(data.q6_csr || {}).sort(function(a, b) { return b[1] - a[1]; });
    var maxQ6 = q6.length ? q6[0][1] : 1;
    q6.forEach(function(item) {
      var pct = (item[1] / maxQ6 * 100).toFixed(0);
      html += '<div class="survey-bar-row"><span class="survey-bar-label">' + item[0] + '</span>' +
        '<div class="survey-bar-track"><div class="survey-bar-fill survey-fill-green" style="width:' + pct + '%"></div></div>' +
        '<span class="survey-bar-val">' + item[1] + '</span></div>';
    });

    panel.innerHTML = html;
  }

  // ── Timeline ──
  function renderTimeline(data) {
    var panel = document.getElementById('timelinePanel');
    var days = data.by_day || [];
    if (!days.length) {
      panel.innerHTML = '<p style="color:#888;">尚無時間軸資料</p>';
      return;
    }

    var maxCnt = Math.max.apply(null, days.map(function(d) { return d.cnt; }).concat([1]));
    var svgW = 500, svgH = 150, pad = 30;
    var stepX = days.length > 1 ? (svgW - pad * 2) / (days.length - 1) : 0;

    var points = days.map(function(d, i) {
      var x = pad + i * stepX;
      var y = svgH - pad - (d.cnt / maxCnt) * (svgH - pad * 2);
      return x + ',' + y;
    });

    var svg = '<svg viewBox="0 0 ' + svgW + ' ' + svgH + '" class="timeline-svg">' +
      '<polyline points="' + points.join(' ') + '" fill="none" stroke="#B45309" stroke-width="2.5" />';

    // Dots + labels
    days.forEach(function(d, i) {
      var x = pad + i * stepX;
      var y = svgH - pad - (d.cnt / maxCnt) * (svgH - pad * 2);
      svg += '<circle cx="' + x + '" cy="' + y + '" r="4" fill="#B45309" />';
      var label = d.d ? d.d.substring(5) : '';
      svg += '<text x="' + x + '" y="' + (svgH - 5) + '" text-anchor="middle" font-size="10" fill="#888">' + label + '</text>';
      svg += '<text x="' + x + '" y="' + (y - 8) + '" text-anchor="middle" font-size="10" fill="#555">' + d.cnt + '</text>';
    });

    svg += '</svg>';

    var html = svg;
    html += '<div class="timeline-meta">今日活躍: <strong>' + (data.active_today || 0) + '</strong> 人 ｜ 總 GPS 點: <strong>' + (data.total_gps_points || 0) + '</strong></div>';

    panel.innerHTML = html;
  }

  // ── User Table ──
  function renderUserTable(users) {
    allUsers = users;
    var tbody = document.getElementById('userTableBody');
    var today = new Date().toISOString().split('T')[0];

    var html = '';
    var roleLabels = { admin: '🔑 管理', volunteer: '🙋 志工', participant: '🚶 香客' };
    users.forEach(function(u) {
      var isToday = u.last_active && u.last_active.startsWith(today);
      var statusDot = isToday ? '<span class="status-dot active"></span>' : '<span class="status-dot"></span>';
      var lastTime = u.last_active ? new Date(u.last_active).toLocaleString('zh-TW', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) : '-';
      var role = u.role || 'participant';
      var roleSelect = '<select class="role-select role-' + role + '" onchange="changeRole(\'' + u.user_id + '\', this.value)">' +
        '<option value="participant"' + (role === 'participant' ? ' selected' : '') + '>🚶 香客</option>' +
        '<option value="volunteer"' + (role === 'volunteer' ? ' selected' : '') + '>🙋 志工</option>' +
        '<option value="admin"' + (role === 'admin' ? ' selected' : '') + '>🔑 管理</option>' +
        '</select>';

      html += '<tr>' +
        '<td>' + (u.display_name || u.user_id.substring(0, 10)) + '</td>' +
        '<td>' + u.gps_count + '</td>' +
        '<td>' + u.carbon_kg + '</td>' +
        '<td>' + lastTime + '</td>' +
        '<td>' + roleSelect + '</td>' +
        '<td>' + statusDot + '</td>' +
      '</tr>';
    });

    tbody.innerHTML = html || '<tr><td colspan="6" style="text-align:center;color:#888;">尚無參與者</td></tr>';
  }

  window.filterUsers = function(q) {
    q = q.toLowerCase();
    var filtered = allUsers.filter(function(u) {
      return (u.display_name || u.user_id).toLowerCase().indexOf(q) >= 0;
    });
    renderUserTable(filtered);
  };

  var sortDir = 1;
  window.sortTable = function(col) {
    sortDir *= -1;
    var keys = ['display_name', 'gps_count', 'carbon_kg', 'last_active'];
    allUsers.sort(function(a, b) {
      var va = a[keys[col]] || '', vb = b[keys[col]] || '';
      if (typeof va === 'number') return (va - vb) * sortDir;
      return String(va).localeCompare(String(vb)) * sortDir;
    });
    renderUserTable(allUsers);
  };

  // ── Role Management ──
  window.changeRole = function(userId, newRole) {
    fetch(API + '/api/formosa/admin/roles', {
      method: 'POST',
      headers: { ...ADMIN_HEADERS, 'Content-Type': 'application/json' },
      body: JSON.stringify({ user_id: userId, role: newRole })
    }).then(function(r) { return r.json(); }).then(function(d) {
      if (d.ok) {
        // Update local data
        allUsers.forEach(function(u) { if (u.user_id === userId) u.role = newRole; });
        renderUserTable(allUsers);
      } else { alert('角色更新失敗: ' + (d.error || '未知錯誤')); }
    }).catch(function(e) { alert('角色更新失敗: ' + e.message); });
  };

  // ── Push Notification ──
  window.sendPush = function() {
    var role = document.getElementById('pushRole').value;
    var title = document.getElementById('pushTitle').value || '📍 進香打卡提醒';
    var text = document.getElementById('pushText').value || '媽祖保佑 🙏\n記錄您的進香足跡吧！';
    if (!confirm('確定推播給' + (role === 'all' ? '所有人' : role) + '？')) return;
    var btn = document.getElementById('pushBtn');
    btn.disabled = true; btn.textContent = '推播中...';
    fetch(API + '/api/formosa/push', {
      method: 'POST',
      headers: { ...ADMIN_HEADERS, 'Content-Type': 'application/json' },
      body: JSON.stringify({ role: role, title: title, text: text })
    }).then(function(r) { return r.json(); }).then(function(d) {
      btn.disabled = false; btn.textContent = '📤 發送推播';
      if (d.ok) { alert('推播成功！已發送 ' + d.sent + ' 人'); }
      else { alert('推播失敗: ' + (d.error || '未知錯誤')); }
    }).catch(function(e) { btn.disabled = false; btn.textContent = '📤 發送推播'; alert('推播失敗: ' + e.message); });
  };

  // ── Demo Mode: ?demo=1 ──
  function generateDemoData() {
    var N = 10000;
    var now = new Date();

    // Box-Muller normal distribution
    function randn() {
      var u = 0, v = 0;
      while (u === 0) u = Math.random();
      while (v === 0) v = Math.random();
      return Math.sqrt(-2.0 * Math.log(u)) * Math.cos(2.0 * Math.PI * v);
    }
    function clamp(x, lo, hi) { return Math.max(lo, Math.min(hi, x)); }

    // Interpolate a point along the route at a given fraction (0-1)
    function routePoint(frac) {
      frac = clamp(frac, 0, 1);
      var targetKm = frac * ROUTE_TOTAL_KM;
      var seg = 0;
      for (var i = 1; i < ROUTE_DISTS.length; i++) {
        if (ROUTE_DISTS[i] >= targetKm) { seg = i - 1; break; }
        if (i === ROUTE_DISTS.length - 1) seg = i - 1;
      }
      var segLen = ROUTE_DISTS[seg + 1] - ROUTE_DISTS[seg];
      var segFrac = segLen > 0 ? (targetKm - ROUTE_DISTS[seg]) / segLen : 0;
      var a = ROUTE_WAYPOINTS[seg], b = ROUTE_WAYPOINTS[seg + 1];
      return {
        lat: a.lat + (b.lat - a.lat) * segFrac + randn() * 0.008,
        lng: a.lng + (b.lng - a.lng) * segFrac + randn() * 0.008
      };
    }

    // Generate users with normal distributions
    var users = [];
    var gpsPoints = [];
    var surnames = ['陳','林','黃','張','李','王','吳','劉','蔡','楊','許','鄭','謝','洪','郭','邱','曾','廖','賴','徐','周','葉','蘇','莊','江','呂','何','羅','高','蕭'];
    var names2 = ['志明','淑芬','俊傑','美玲','建宏','雅婷','家豪','怡君','宗翰','佳蓉','冠宇','惠如','柏翰','雪芳','承翰','玉華','宇翔','麗華','彥廷','素珍','育丞','淑惠','博文','秀英','鈺翔','月娥','子軒','玉蘭','宥翔','秋香'];

    // Activity dates: 4/12 – 4/20 (simulate as if we're at day 5 = 4/16)
    var activityStart = new Date('2026-04-12T06:00:00');
    var simDay = 5; // day 5 of 9
    var totalDays = 9;

    for (var i = 0; i < N; i++) {
      var uid = 'user_' + String(i).padStart(5, '0');
      var displayName = surnames[Math.floor(Math.random() * surnames.length)] + names2[Math.floor(Math.random() * names2.length)];

      // Checkin count: normal(μ=8, σ=4), min=1
      var checkins = Math.max(1, Math.round(8 + randn() * 4));
      // Walk km: normal(μ=55, σ=35), min=0.5
      var walkKm = Math.max(0.5, 55 + randn() * 35);
      // Carbon: correlated with km
      var carbonKg = Math.max(0.1, walkKm * 0.15 + randn() * 2);

      // Role distribution: 92% participant, 5% volunteer, 3% admin
      var roleRand = Math.random();
      var role = roleRand < 0.92 ? 'participant' : roleRand < 0.97 ? 'volunteer' : 'admin';

      // Last active: most today, some yesterday
      var hoursAgo = Math.max(0, Math.abs(randn() * 6));
      var lastActive = new Date(now.getTime() - hoursAgo * 3600000);

      users.push({
        user_id: uid,
        display_name: displayName,
        gps_count: checkins,
        walk_km: walkKm,
        carbon_kg: carbonKg.toFixed(1),
        role: role,
        last_active: lastActive.toISOString()
      });

      // GPS points: scatter along route based on how far they've walked
      var progress = clamp(walkKm / ROUTE_TOTAL_KM, 0, 1);
      var nPts = Math.min(checkins, 8);
      for (var j = 0; j < nPts; j++) {
        var ptProgress = progress * (j + 1) / nPts;
        var pt = routePoint(ptProgress);
        var ptTime = new Date(activityStart.getTime() + (j / nPts) * simDay * 86400000 + Math.random() * 3600000);
        gpsPoints.push({
          user_id: uid,
          lat: pt.lat,
          lng: pt.lng,
          timestamp: ptTime.toISOString()
        });
      }
    }

    // Aggregate stats
    var totalCheckins = users.reduce(function(s, u) { return s + u.gps_count; }, 0);
    var totalWalkKm = users.reduce(function(s, u) { return s + u.walk_km; }, 0);
    var totalCarbon = users.reduce(function(s, u) { return s + parseFloat(u.carbon_kg); }, 0);
    var activeToday = users.filter(function(u) {
      return u.last_active && u.last_active.startsWith(now.toISOString().split('T')[0]);
    }).length;

    // Data response (matches /api/formosa/data)
    var dataRes = {
      stats: { total_users: N, total_gps_points: totalCheckins },
      gps_points: gpsPoints
    };

    // Carbon response
    var carbonRes = {
      carbon_saved_kg: totalCarbon.toFixed(0),
      avg_carbon_kg: (totalCarbon / N).toFixed(1),
      water_bottles_total: Math.round(N * 2.3),
      hotel_nights_total: Math.round(N * 0.4),
      transport_totals: {
        walk: { km: totalWalkKm, count: Math.round(N * 0.72) },
        bus: { km: totalWalkKm * 0.15, count: Math.round(N * 0.12) },
        car: { km: totalWalkKm * 0.08, count: Math.round(N * 0.06) },
        scooter: { km: totalWalkKm * 0.06, count: Math.round(N * 0.05) },
        train: { km: totalWalkKm * 0.04, count: Math.round(N * 0.03) },
        hsr: { km: totalWalkKm * 0.02, count: Math.round(N * 0.015) },
        mrt: { km: totalWalkKm * 0.01, count: Math.round(N * 0.005) }
      }
    };

    // Timeline: 9 days with bell-curve activity
    var byDay = [];
    for (var d = 0; d < totalDays; d++) {
      var dayDate = new Date(activityStart.getTime() + d * 86400000);
      // Bell curve peaked at day 4-5
      var dayActivity = Math.round(N * 0.7 * Math.exp(-0.5 * Math.pow((d - 4) / 2.2, 2)));
      if (d > simDay) dayActivity = 0; // future days
      byDay.push({
        d: dayDate.toISOString().split('T')[0],
        cnt: dayActivity
      });
    }
    var timelineRes = {
      by_day: byDay,
      active_today: activeToday,
      total_gps_points: totalCheckins
    };

    // Survey: realistic distributions
    var surveyRes = {
      total_surveys: Math.round(N * 0.85),
      q1_deeds: {
        '撿拾垃圾': Math.round(N * 0.62),
        '幫助其他香客': Math.round(N * 0.48),
        '節約用水': Math.round(N * 0.41),
        '自備環保餐具': Math.round(N * 0.55),
        '步行代替搭車': Math.round(N * 0.72),
        '分享食物給他人': Math.round(N * 0.33),
        '協助交通指揮': Math.round(N * 0.12),
        '減少使用塑膠袋': Math.round(N * 0.38)
      },
      q6_csr: {
        '非常願意': Math.round(N * 0.45),
        '願意': Math.round(N * 0.32),
        '考慮中': Math.round(N * 0.15),
        '不太願意': Math.round(N * 0.06),
        '不願意': Math.round(N * 0.02)
      }
    };

    // Only render first 200 users in table (perf)
    var tableUsers = users.slice(0, 200);

    return { dataRes: dataRes, carbonRes: carbonRes, timelineRes: timelineRes, usersRes: { users: tableUsers }, surveyRes: surveyRes, allUsersForRank: users };
  }

  function fetchAllDemo() {
    var demo = generateDemoData();
    renderKPI(demo.dataRes, demo.carbonRes, demo.timelineRes);
    // Limit GPS points for map perf (sample 5000)
    var sampledGps = demo.dataRes.gps_points;
    if (sampledGps.length > 5000) {
      var step = Math.ceil(sampledGps.length / 5000);
      sampledGps = sampledGps.filter(function(_, i) { return i % step === 0; });
    }
    renderMap(sampledGps);
    renderCarbon(demo.carbonRes);
    renderRanks(demo.allUsersForRank);
    renderSurvey(demo.surveyRes);
    renderTimeline(demo.timelineRes);
    renderUserTable(demo.usersRes.users);
    document.getElementById('lastUpdated').textContent = '🎭 Demo 模式 (' + new Date().toLocaleTimeString('zh-TW') + ')';
  }

  var isDemo = new URLSearchParams(window.location.search).get('demo') === '1';

  // ── Init + Auto-refresh ──
  if (isDemo) { fetchAllDemo(); } else { fetchAll(); }
  var refreshInterval = setInterval(function() {
    if (document.getElementById('autoRefresh').checked) {
      if (isDemo) fetchAllDemo(); else fetchAll();
    }
  }, 30000);

  document.getElementById('autoRefresh').addEventListener('change', function() {
    var pulse = document.getElementById('refreshPulse');
    pulse.className = 'dash-pulse' + (this.checked ? ' active' : '');
  });
})();
</script>

