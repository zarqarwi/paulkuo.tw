<script is:inline>
(function() {
  var btn = document.getElementById('enterpriseToggle');
  if (!btn) return;
  var expanded = false;
  btn.addEventListener('click', function() {
    expanded = !expanded;
    var items = document.querySelectorAll('.enterprise-hidden');
    items.forEach(function(el) {
      el.style.display = expanded ? '' : 'none';
    });
    btn.textContent = expanded ? '收合' : '展開全部 (' + btn.dataset.total + ')';
  });
})();
</script>
