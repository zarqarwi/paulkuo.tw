---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';
import { t } from '@/i18n/utils';
import { LOCALE_PREFIX } from '@/i18n/config';
import type { Locale } from '@/i18n/config';

interface Props {
  lang?: Locale;
}

const lang: Locale = Astro.props.lang ?? 'zh-Hant';
const prefix = LOCALE_PREFIX[lang];
---

<BaseLayout
  title="回報與修復紀錄 — 2026 白沙屯媽祖 ESG 進香"
  description="已知問題與修復進度公告"
  ogUrl="https://mazu.today/feedback/log/"
  ogImage="https://mazu.today/images/formosa-esg-2026-og.png"
  eventMode={true}
>

<div class="log-page">
  <nav class="log-breadcrumb">
    <a href={`${prefix}/projects/formosa-esg-2026/feedback/`}>← 回報問題</a>
  </nav>

  <header class="log-header">
    <h1>📋 回報與修復紀錄</h1>
    <p class="log-updated" id="logUpdated">載入中...</p>
  </header>

  <!-- Dynamic sections -->
  <section class="log-section" id="sectionNew" style="display:none">
    <h2 class="log-section-title received">📥 已收到</h2>
    <div id="listNew"></div>
  </section>

  <section class="log-section" id="sectionInProgress" style="display:none">
    <h2 class="log-section-title in-progress">🔧 處理中</h2>
    <div id="listInProgress"></div>
  </section>

  <section class="log-section" id="sectionFixed" style="display:none">
    <h2 class="log-section-title resolved">✅ 已修復</h2>
    <div id="listFixed"></div>
  </section>

  <section class="log-section" id="sectionNoted" style="display:none">
    <h2 class="log-section-title noted">💬 已知 & 說明</h2>
    <div id="listNoted"></div>
  </section>

  <!-- Loading / Error states -->
  <div id="logLoading" class="log-loading">載入中...</div>
  <div id="logError" class="log-error" style="display:none">
    <p>⚠️ 無法載入資料，請稍後重新整理頁面。</p>
  </div>

  <footer class="log-footer">
    <p>遇到問題？<a href={`${prefix}/projects/formosa-esg-2026/feedback/`}>點此回報</a></p>
  </footer>
</div>

<script is:inline>
(function() {
  var API = 'https://api.paulkuo.tw/api/formosa/feedback/status';

  function tagClass(category) {
    if (!category) return 'info';
    var c = category.toLowerCase();
    if (c.includes('bug') || c.includes('錯誤')) return 'bug';
    if (c.includes('ux') || c.includes('改善') || c.includes('建議')) return 'ux';
    return 'info';
  }

  function tagLabel(category) {
    if (!category) return '說明';
    var c = category.toLowerCase();
    if (c.includes('bug') || c.includes('錯誤')) return 'Bug';
    if (c.includes('ux') || c.includes('改善') || c.includes('建議')) return 'UX 改善';
    return '說明';
  }

  function formatDate(dateStr) {
    if (!dateStr) return '';
    var d = new Date(dateStr);
    return (d.getMonth() + 1).toString().padStart(2, '0') + '-' + d.getDate().toString().padStart(2, '0');
  }

  function renderItem(fb) {
    var dateText = '';
    if (fb.status === 'fixed' && fb.resolved_at) {
      dateText = formatDate(fb.resolved_at) + ' 修復';
    } else {
      dateText = formatDate(fb.created_at);
    }

    var note = fb.admin_note
      ? '<p>' + fb.admin_note.replace(/</g, '&lt;').replace(/>/g, '&gt;') + '</p>'
      : '<p>' + (fb.description || '').replace(/</g, '&lt;').replace(/>/g, '&gt;') + '</p>';

    return '<article class="log-item">' +
      '<div class="log-item-header">' +
        '<span class="log-tag ' + tagClass(fb.category) + '">' + tagLabel(fb.category) + '</span>' +
        '<span class="log-date">' + dateText + '</span>' +
      '</div>' +
      '<h3>' + ((fb.description || '').split('\n')[0] || '').replace(/</g, '&lt;').replace(/>/g, '&gt;') + '</h3>' +
      (fb.admin_note ? note : '') +
      (fb.screenshot_url ? '<img src="' + fb.screenshot_url + '" class="log-screenshot" loading="lazy" alt="截圖">' : '') +
    '</article>';
  }

  fetch(API)
    .then(function(r) { return r.json(); })
    .then(function(data) {
      document.getElementById('logLoading').style.display = 'none';

      if (!data.ok || !data.feedbacks) {
        document.getElementById('logError').style.display = 'block';
        return;
      }

      var received = [];
      var inProgress = [];
      var fixed = [];
      var noted = [];

      data.feedbacks.forEach(function(fb) {
        if (fb.status === 'new' || fb.status === 'open') received.push(fb);
        else if (fb.status === 'triaging' || fb.status === 'fixing') inProgress.push(fb);
        else if (fb.status === 'fixed') fixed.push(fb);
        else if (fb.status === 'wontfix' || fb.admin_note) noted.push(fb);
      });

      if (received.length) {
        document.getElementById('sectionNew').style.display = '';
        document.getElementById('listNew').innerHTML = received.map(renderItem).join('');
      }
      if (inProgress.length) {
        document.getElementById('sectionInProgress').style.display = '';
        document.getElementById('listInProgress').innerHTML = inProgress.map(renderItem).join('');
      }
      if (fixed.length) {
        document.getElementById('sectionFixed').style.display = '';
        document.getElementById('listFixed').innerHTML = fixed.map(renderItem).join('');
      }
      if (noted.length) {
        document.getElementById('sectionNoted').style.display = '';
        document.getElementById('listNoted').innerHTML = noted.map(renderItem).join('');
      }

      if (!received.length && !inProgress.length && !fixed.length && !noted.length) {
        document.getElementById('logLoading').style.display = 'block';
        document.getElementById('logLoading').textContent = '目前沒有公開的回報紀錄。';
      }

      // Update timestamp
      var latest = data.feedbacks[0];
      if (latest) {
        var d = new Date(latest.resolved_at || latest.created_at);
        document.getElementById('logUpdated').textContent = '最後更新：' + d.toLocaleDateString('zh-TW');
      }
    })
    .catch(function() {
      document.getElementById('logLoading').style.display = 'none';
      document.getElementById('logError').style.display = 'block';
    });
})();
</script>

<style>
  .log-page {
    max-width: 600px;
    margin: 0 auto;
    padding: 1rem;
    font-family: var(--font-cjk, 'Noto Sans TC', sans-serif);
  }
  .log-breadcrumb {
    margin-bottom: 1.5rem;
  }
  .log-breadcrumb a {
    color: #666;
    text-decoration: none;
    font-size: 0.875rem;
  }
  .log-breadcrumb a:hover { color: #1a5c2a; }
  .log-header {
    margin-bottom: 2rem;
  }
  .log-header h1 {
    font-size: 1.4rem;
    margin: 0 0 0.4rem;
    color: #1a5c2a;
  }
  .log-updated {
    color: #999;
    font-size: 0.85rem;
    margin: 0;
  }

  /* Sections */
  .log-section {
    margin-bottom: 2rem;
  }
  .log-section-title {
    font-size: 1.05rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #eee;
    margin: 0 0 1rem;
  }
  .log-section-title.received { border-color: #3b82f6; color: #3b82f6; }
  .log-section-title.resolved { border-color: #059669; color: #059669; }
  .log-section-title.in-progress { border-color: #d97706; color: #d97706; }
  .log-section-title.noted { border-color: #6b7280; color: #6b7280; }

  .log-loading, .log-error {
    text-align: center;
    color: #999;
    font-size: 0.9rem;
    padding: 2rem 0;
  }
  .log-error { color: #dc2626; }

  /* Items */
  :global(.log-item) {
    background: #fafafa;
    border-radius: 8px;
    padding: 0.9rem 1rem;
    margin-bottom: 0.75rem;
  }
  :global(.log-item-header) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.4rem;
  }
  :global(.log-tag) {
    font-size: 0.75rem;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 4px;
    text-transform: uppercase;
  }
  :global(.log-tag.bug) { background: #fee2e2; color: #dc2626; }
  :global(.log-tag.ux) { background: #fef3c7; color: #d97706; }
  :global(.log-tag.info) { background: #e5e7eb; color: #6b7280; }
  :global(.log-date) {
    font-size: 0.8rem;
    color: #999;
  }
  :global(.log-item h3) {
    font-size: 0.95rem;
    margin: 0 0 0.3rem;
    color: #333;
  }
  :global(.log-item p) {
    font-size: 0.88rem;
    color: #666;
    margin: 0;
    line-height: 1.5;
  }
  :global(.log-screenshot) {
    max-width: 100%;
    border-radius: 6px;
    margin-top: 0.5rem;
  }

  /* Footer */
  .log-footer {
    text-align: center;
    padding-top: 1rem;
    border-top: 1px solid #eee;
    margin-top: 2rem;
  }
  .log-footer a {
    color: #1a5c2a;
    font-weight: 600;
  }
</style>

</BaseLayout>
