---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import AuthGate from './_components/AuthGate.astro';
import { t } from '@/i18n/utils';
import { LOCALE_PREFIX } from '@/i18n/config';
import type { Locale } from '@/i18n/config';

interface Props {
  lang?: Locale;
}

const lang: Locale = Astro.props.lang ?? 'zh-Hant';
const prefix = LOCALE_PREFIX[lang];
---

<BaseLayout
  title={`${t(lang, 'dataPage.title')} — ${t(lang, 'brand.shortName')}`}
  description={t(lang, 'dataPage.subtitle')}
  ogUrl={`https://paulkuo.tw${prefix}/projects/formosa-esg-2026/data/`}
  ogImage="https://paulkuo.tw/images/formosa-esg-2026-og.png"
  eventMode={true}
>

<style is:global>
  .formosa-auth {
    align-items: flex-start !important;
    padding-top: 15vh !important;
  }
  .formosa-auth .auth-card .auth-note {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-top: 1rem;
  }
  .formosa-auth .auth-card .auth-note a {
    color: var(--accent-faith);
  }
</style>
<AuthGate title={t(lang, 'dataPage.authTitle')} subtitle={t(lang, 'dataPage.authSubtitle')} lang={lang}>

<div class="formosa-data">

  <!-- Breadcrumb -->
  <nav class="formosa-breadcrumb">
    <a href={`${prefix}/projects/formosa-esg-2026/`}>{t(lang, 'dataPage.backToProject')}</a>
  </nav>

  <!-- Header -->
  <header class="formosa-data-header">
    <div class="data-header-badge">{t(lang, 'dataPage.headerBadge')}</div>
    <h1>{t(lang, 'dataPage.title')}</h1>
    <p>{t(lang, 'dataPage.subtitle')}</p>
  </header>

  <!-- Why: Three Goals -->
  <section class="formosa-section">
    <h2 class="formosa-section-title">{t(lang, 'dataPage.whyDataTitle')}</h2>
    <div class="data-goals-grid">
      <div class="data-goal-card">
        <div class="goal-number">01</div>
        <h3>{t(lang, 'dataPage.goal1Title')}</h3>
        <p>{t(lang, 'dataPage.goal1Desc')}</p>
      </div>
      <div class="data-goal-card">
        <div class="goal-number">02</div>
        <h3>{t(lang, 'dataPage.goal2Title')}</h3>
        <p>{t(lang, 'dataPage.goal2Desc')}</p>
      </div>
      <div class="data-goal-card">
        <div class="goal-number">03</div>
        <h3>{t(lang, 'dataPage.goal3Title')}</h3>
        <p>{t(lang, 'dataPage.goal3Desc')}</p>
      </div>
    </div>
  </section>

  <!-- Flow: Four Steps -->
  <section class="formosa-section">
    <h2 class="formosa-section-title">{t(lang, 'dataPage.flowTitle')}</h2>
    <div class="data-flow-grid">
      <div class="data-flow-step">
        <div class="flow-step-num">1</div>
        <div class="flow-step-icon">📱</div>
        <h3>{t(lang, 'dataPage.flowScan')}</h3>
        <p>{t(lang, 'dataPage.flowScanDesc')}</p>
      </div>
      <div class="flow-connector">&rarr;</div>
      <div class="data-flow-step">
        <div class="flow-step-num">2</div>
        <div class="flow-step-icon">🌐</div>
        <h3>{t(lang, 'dataPage.flowOpen')}</h3>
        <p>{t(lang, 'dataPage.flowOpenDesc')}</p>
      </div>
      <div class="flow-connector">&rarr;</div>
      <div class="data-flow-step">
        <div class="flow-step-num">3</div>
        <div class="flow-step-icon">✍️</div>
        <h3>{t(lang, 'dataPage.flowFill')}</h3>
        <p>{t(lang, 'dataPage.flowFillDesc')}</p>
      </div>
      <div class="flow-connector">&rarr;</div>
      <div class="data-flow-step">
        <div class="flow-step-num">4</div>
        <div class="flow-step-icon">✅</div>
        <h3>{t(lang, 'dataPage.flowDone')}</h3>
        <p>{t(lang, 'dataPage.flowDoneDesc')}</p>
      </div>
    </div>
  </section>

  <!-- System Architecture -->
  <section class="formosa-section">
    <h2 class="formosa-section-title">{t(lang, 'dataPage.archTitle')}</h2>
    <div class="data-arch-card">
      <div class="arch-row">
        <div class="arch-block arch-input">
          <h4>{t(lang, 'dataPage.archInput')}</h4>
          <ul>
            <li>{t(lang, 'dataPage.archInput1')}</li>
            <li>{t(lang, 'dataPage.archInput2')}</li>
            <li>{t(lang, 'dataPage.archInput3')}</li>
            <li>{t(lang, 'dataPage.archInput4')}</li>
          </ul>
        </div>
        <div class="arch-arrow">&rarr;</div>
        <div class="arch-block arch-core">
          <h4>{t(lang, 'dataPage.archCore')}</h4>
          <ul>
            <li>{t(lang, 'dataPage.archCore1')}</li>
            <li>{t(lang, 'dataPage.archCore2')}</li>
            <li>{t(lang, 'dataPage.archCore3')}</li>
            <li>{t(lang, 'dataPage.archCore4')}</li>
          </ul>
        </div>
        <div class="arch-arrow">&rarr;</div>
        <div class="arch-block arch-output">
          <h4>{t(lang, 'dataPage.archOutput')}</h4>
          <ul>
            <li>{t(lang, 'dataPage.archOutput1')}</li>
            <li>{t(lang, 'dataPage.archOutput2')}</li>
            <li>{t(lang, 'dataPage.archOutput3')}</li>
            <li>{t(lang, 'dataPage.archOutput4')}</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="formosa-section">
    <h2 class="formosa-section-title">{t(lang, 'dataPage.timelineTitle')}</h2>
    <div class="data-timeline">
      <div class="timeline-phase prep">
        <div class="phase-header">
          <span class="phase-badge">{t(lang, 'dataPage.prepBadge')}</span>
          <span class="phase-period">{t(lang, 'dataPage.prepPeriod')}</span>
        </div>
        <ul>
          <li>{t(lang, 'dataPage.prep1')}</li>
          <li>{t(lang, 'dataPage.prep2')}</li>
          <li>{t(lang, 'dataPage.prep3')}</li>
          <li>{t(lang, 'dataPage.prep4')}</li>
        </ul>
      </div>
      <div class="timeline-phase active-phase">
        <div class="phase-header">
          <span class="phase-badge live">{t(lang, 'dataPage.liveBadge')}</span>
          <span class="phase-period">{t(lang, 'dataPage.livePeriod')}</span>
        </div>
        <ul>
          <li>{t(lang, 'dataPage.live1')}</li>
          <li>{t(lang, 'dataPage.live2')}</li>
          <li>{t(lang, 'dataPage.live3')}</li>
          <li>{t(lang, 'dataPage.live4')}</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Risk Management -->
  <section class="formosa-section">
    <h2 class="formosa-section-title">{t(lang, 'dataPage.riskTitle')}</h2>
    <div class="data-risks-grid">
      <div class="risk-card">
        <div class="risk-header">
          <span class="risk-icon">📡</span>
          <span class="risk-level high">{t(lang, 'dataPage.riskHigh')}</span>
        </div>
        <h3>{t(lang, 'dataPage.risk1Title')}</h3>
        <p>{t(lang, 'dataPage.risk1Desc')}</p>
        <div class="risk-solution">{t(lang, 'dataPage.risk1Solution')}</div>
      </div>
      <div class="risk-card">
        <div class="risk-header">
          <span class="risk-icon">🔋</span>
          <span class="risk-level medium">{t(lang, 'dataPage.riskMedium')}</span>
        </div>
        <h3>{t(lang, 'dataPage.risk2Title')}</h3>
        <p>{t(lang, 'dataPage.risk2Desc')}</p>
        <div class="risk-solution">{t(lang, 'dataPage.risk2Solution')}</div>
      </div>
      <div class="risk-card">
        <div class="risk-header">
          <span class="risk-icon">🗣️</span>
          <span class="risk-level medium">{t(lang, 'dataPage.riskMedium')}</span>
        </div>
        <h3>{t(lang, 'dataPage.risk3Title')}</h3>
        <p>{t(lang, 'dataPage.risk3Desc')}</p>
        <div class="risk-solution">{t(lang, 'dataPage.risk3Solution')}</div>
      </div>
      <div class="risk-card">
        <div class="risk-header">
          <span class="risk-icon">🔒</span>
          <span class="risk-level low">{t(lang, 'dataPage.riskLow')}</span>
        </div>
        <h3>{t(lang, 'dataPage.risk4Title')}</h3>
        <p>{t(lang, 'dataPage.risk4Desc')}</p>
        <div class="risk-solution">{t(lang, 'dataPage.risk4Solution')}</div>
      </div>
      <div class="risk-card">
        <div class="risk-header">
          <span class="risk-icon">🌧️</span>
          <span class="risk-level medium">{t(lang, 'dataPage.riskMedium')}</span>
        </div>
        <h3>{t(lang, 'dataPage.risk5Title')}</h3>
        <p>{t(lang, 'dataPage.risk5Desc')}</p>
        <div class="risk-solution">{t(lang, 'dataPage.risk5Solution')}</div>
      </div>
    </div>
  </section>

  <!-- Deliverables -->
  <section class="formosa-section">
    <h2 class="formosa-section-title">{t(lang, 'dataPage.deliverTitle')}</h2>
    <div class="data-deliverables-grid">
      <div class="deliverable-card">
        <div class="deliverable-icon">📊</div>
        <h3>{t(lang, 'dataPage.deliver1Title')}</h3>
        <p>{t(lang, 'dataPage.deliver1Desc')}</p>
      </div>
      <div class="deliverable-card">
        <div class="deliverable-icon">📋</div>
        <h3>{t(lang, 'dataPage.deliver2Title')}</h3>
        <p>{t(lang, 'dataPage.deliver2Desc')}</p>
      </div>
      <div class="deliverable-card">
        <div class="deliverable-icon">🗺️</div>
        <h3>{t(lang, 'dataPage.deliver3Title')}</h3>
        <p>{t(lang, 'dataPage.deliver3Desc')}</p>
      </div>
      <div class="deliverable-card">
        <div class="deliverable-icon">📝</div>
        <h3>{t(lang, 'dataPage.deliver4Title')}</h3>
        <p>{t(lang, 'dataPage.deliver4Desc')}</p>
      </div>
    </div>
  </section>

  <!-- Back link -->
  <div class="formosa-back-link">
    <a href={`${prefix}/projects/formosa-esg-2026/`}>{t(lang, 'dataPage.backToProject')}</a>
  </div>

</div>

</AuthGate>

</BaseLayout>

<style>
  .formosa-data {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 1rem 4rem;
  }

  /* Breadcrumb */
  .formosa-breadcrumb {
    padding: 1.5rem 0;
  }
  .formosa-breadcrumb a {
    font-size: 0.85rem;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .formosa-breadcrumb a:hover { color: var(--accent-faith); }

  /* Header */
  .formosa-data-header {
    text-align: center;
    padding: 2rem 0 3rem;
    border-bottom: 1px solid var(--border-light);
    margin-bottom: 3rem;
  }
  .data-header-badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent-ai);
    background: rgba(37,99,235,0.08);
    padding: 4px 14px;
    border-radius: 16px;
    margin-bottom: 1rem;
  }
  .formosa-data-header h1 {
    font-family: var(--font-cjk);
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 0.75rem;
  }
  .formosa-data-header p {
    font-size: 1rem;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* Section titles (reuse from hub) */
  .formosa-section {
    margin-bottom: 3.5rem;
  }
  .formosa-section-title {
    font-family: var(--font-cjk);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
    text-align: center;
  }
  .formosa-section-title::after {
    content: '';
    display: block;
    width: 48px; height: 3px;
    background: var(--accent-faith);
    margin: 10px auto 0;
    border-radius: 2px;
  }

  /* Goals */
  .data-goals-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .data-goal-card {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius);
    padding: 2rem;
  }
  .goal-number {
    font-family: 'DM Sans', sans-serif;
    font-size: 2rem;
    font-weight: 800;
    color: var(--border);
    margin-bottom: 0.75rem;
  }
  .data-goal-card h3 {
    font-family: var(--font-cjk);
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }
  .data-goal-card p {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  /* Flow */
  .data-flow-grid {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .data-flow-step {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius);
    padding: 1.5rem;
    text-align: center;
    flex: 1;
    min-width: 140px;
    max-width: 200px;
    position: relative;
  }
  .flow-step-num {
    position: absolute;
    top: 10px; left: 14px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--text-muted);
  }
  .flow-step-icon {
    font-size: 1.8rem;
    margin-bottom: 0.75rem;
  }
  .data-flow-step h3 {
    font-family: var(--font-cjk);
    font-size: 0.95rem;
    font-weight: 700;
    margin-bottom: 0.4rem;
  }
  .data-flow-step p {
    font-size: 0.78rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }
  .flow-connector {
    display: flex;
    align-items: center;
    font-size: 1.2rem;
    color: var(--text-muted);
    padding-top: 2rem;
  }

  /* Architecture */
  .data-arch-card {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    padding: 2.5rem;
    overflow-x: auto;
  }
  .arch-row {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    justify-content: center;
  }
  .arch-block {
    background: var(--bg-section);
    border-radius: var(--radius);
    padding: 1.5rem;
    flex: 1;
    min-width: 180px;
    border-top: 3px solid var(--border);
  }
  .arch-input { border-top-color: var(--accent-faith); }
  .arch-core { border-top-color: var(--accent-ai); }
  .arch-output { border-top-color: var(--accent-circular); }
  .arch-block h4 {
    font-family: var(--font-cjk);
    font-size: 0.88rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }
  .arch-block ul {
    list-style: none;
    padding: 0;
  }
  .arch-block li {
    font-size: 0.8rem;
    color: var(--text-secondary);
    padding: 4px 0;
    border-bottom: 1px solid var(--border-light);
  }
  .arch-block li:last-child { border-bottom: none; }
  .arch-arrow {
    font-size: 1.5rem;
    color: var(--text-muted);
    padding-top: 2rem;
    flex-shrink: 0;
  }

  /* Timeline */
  .data-timeline {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }
  .timeline-phase {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius);
    padding: 1.5rem;
  }
  .phase-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .phase-badge {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    padding: 4px 12px;
    border-radius: 12px;
    background: var(--bg-section);
    color: var(--text-secondary);
  }
  .phase-badge.live {
    background: rgba(180,83,9,0.1);
    color: var(--accent-faith);
  }
  .phase-period {
    font-size: 0.78rem;
    color: var(--text-muted);
    font-family: 'DM Sans', sans-serif;
  }
  .timeline-phase ul {
    list-style: none;
    padding: 0;
  }
  .timeline-phase li {
    font-size: 0.85rem;
    color: var(--text-secondary);
    padding: 6px 0;
    padding-left: 1.2rem;
    position: relative;
  }
  .timeline-phase li::before {
    content: '';
    position: absolute;
    left: 0; top: 12px;
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--border);
  }
  .active-phase li::before { background: var(--accent-faith); }

  /* Risks */
  .data-risks-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
  }
  .risk-card {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius);
    padding: 1.5rem;
  }
  .risk-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
  }
  .risk-icon { font-size: 1.3rem; }
  .risk-level {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    padding: 2px 10px;
    border-radius: 10px;
  }
  .risk-level.high { background: rgba(220,38,38,0.1); color: #DC2626; }
  .risk-level.medium { background: rgba(245,158,11,0.1); color: #B45309; }
  .risk-level.low { background: rgba(5,150,105,0.1); color: #059669; }
  .risk-card h3 {
    font-family: var(--font-cjk);
    font-size: 0.95rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
  }
  .risk-card > p {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }
  .risk-solution {
    font-size: 0.82rem;
    color: var(--accent-circular);
    font-weight: 500;
    padding: 8px 12px;
    background: rgba(5,150,105,0.06);
    border-radius: 6px;
  }

  /* Deliverables */
  .data-deliverables-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }
  .deliverable-card {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius);
    padding: 1.5rem;
    text-align: center;
  }
  .deliverable-icon {
    font-size: 2rem;
    margin-bottom: 0.75rem;
  }
  .deliverable-card h3 {
    font-family: var(--font-cjk);
    font-size: 0.9rem;
    font-weight: 700;
    margin-bottom: 0.4rem;
  }
  .deliverable-card p {
    font-size: 0.78rem;
    color: var(--text-secondary);
    line-height: 1.55;
  }

  /* Back link */
  .formosa-back-link {
    text-align: center;
    margin-top: 1rem;
  }
  .formosa-back-link a {
    font-size: 0.88rem;
    color: var(--text-muted);
    text-decoration: none;
  }
  .formosa-back-link a:hover { color: var(--accent-faith); }

  /* Responsive */
  @media (max-width: 768px) {
    .data-goals-grid { grid-template-columns: 1fr; }
    .data-flow-grid { flex-direction: column; align-items: center; }
    .flow-connector { transform: rotate(90deg); padding: 0; }
    .data-flow-step { max-width: 100%; }
    .arch-row { flex-direction: column; }
    .arch-arrow { transform: rotate(90deg); text-align: center; padding: 0; }
    .data-timeline { grid-template-columns: 1fr; }
    .data-deliverables-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
