---
/**
 * SourcePage.astro — Wiki source 獨立頁元件
 * Phase 4 Step C-prime.
 *
 * Renders a single wiki source entry with conditional sections.
 * Does NOT render: raw transcript / raw_source_path / raw_note_id / enrichment metadata.
 * TODO Step E: i18n section labels (摘要/重點/章節/金句)
 */
import { PILLAR_MAP } from '../config';
import ReferencedByArticlesSection from './ReferencedByArticlesSection.astro';

interface ReferencingArticle {
  article_slug: string;
  lang: string;
  title: string;
  date: string;
  pillar: string;
}

interface Props {
  source: any;
  referencingArticles: ReferencingArticle[];
}

const { source, referencingArticles } = Astro.props;
const { title, summary, key_points, chapters, quotes, pillar, raw_source_type, created, updated } = source.data;

const p = PILLAR_MAP[pillar as keyof typeof PILLAR_MAP];
const pillarLabel = p?.label ?? pillar;

function sourceTypeLabel(t: string): string {
  if (t === 'youtube') return 'YouTube';
  if (t === 'getnote' || t === 'get_note') return '得到App';
  if (t === 'article') return '文章';
  if (t === 'clip') return '片段';
  return t ?? 'Wiki 素材';
}

const createdStr = created ? new Date(created).toLocaleDateString('zh-TW', { year: 'numeric', month: '2-digit', day: '2-digit' }) : '';
const updatedStr = updated ? new Date(updated).toLocaleDateString('zh-TW', { year: 'numeric', month: '2-digit', day: '2-digit' }) : '';
---

<article class="source-page">
  <nav class="source-breadcrumb" aria-label="breadcrumb">
    <a href="/wiki/">Wiki</a>
    <span aria-hidden="true"> / </span>
    <span>素材</span>
  </nav>

  <header class="source-header">
    <h1 class="source-title">{title}</h1>
    <div class="source-meta">
      {pillar && (
        <span class="source-pillar-badge">{pillarLabel}</span>
      )}
      <span class="source-type-badge">{sourceTypeLabel(raw_source_type)}</span>
      {createdStr && <span class="source-date">{createdStr}</span>}
      {updatedStr && updatedStr !== createdStr && (
        <span class="source-date">更新 {updatedStr}</span>
      )}
    </div>
  </header>

  <div class="source-body">
    {summary && (
      <section class="source-section">
        <h2>摘要</h2>
        <p class="source-summary">{summary}</p>
      </section>
    )}

    {key_points && key_points.length > 0 && (
      <section class="source-section">
        <h2>重點</h2>
        <ul class="source-key-points">
          {key_points.map((pt: string) => (
            <li>{pt}</li>
          ))}
        </ul>
      </section>
    )}

    {chapters && chapters.length > 0 && (
      <section class="source-section">
        <h2>章節</h2>
        <ol class="source-chapters">
          {chapters.map((ch: { start?: string; title: string; summary?: string }) => (
            <li class="source-chapter-item">
              <span class="chapter-title">
                {ch.start ? `[${ch.start}] ` : ''}{ch.title}
              </span>
              {ch.summary && (
                <p class="chapter-summary">{ch.summary}</p>
              )}
            </li>
          ))}
        </ol>
      </section>
    )}

    {quotes && quotes.length > 0 && (
      <section class="source-section">
        <h2>金句</h2>
        <div class="source-quotes">
          {quotes.map((q: { text: string; timestamp?: string }) => (
            <figure class="source-quote-figure">
              <blockquote class="source-quote">{q.text}</blockquote>
              {q.timestamp && (
                <figcaption class="quote-timestamp">{q.timestamp}</figcaption>
              )}
            </figure>
          ))}
        </div>
      </section>
    )}

    <ReferencedByArticlesSection articles={referencingArticles} />
  </div>
</article>

<style>
  .source-page {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .source-breadcrumb {
    font-size: 0.85rem;
    color: var(--color-text-muted, #6b7280);
    margin-bottom: 1.5rem;
  }

  .source-breadcrumb a {
    color: var(--color-accent, #6366f1);
    text-decoration: none;
  }

  .source-breadcrumb a:hover {
    text-decoration: underline;
  }

  .source-header {
    margin-bottom: 2rem;
  }

  .source-title {
    font-size: 1.75rem;
    font-weight: 700;
    line-height: 1.3;
    margin: 0 0 0.75rem;
    color: var(--color-text, #1a1a1a);
  }

  .source-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }

  .source-pillar-badge,
  .source-type-badge {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    border-radius: 1rem;
    font-size: 0.75rem;
    font-weight: 600;
    background: var(--color-surface, #e5e7eb);
    color: var(--color-text-muted, #6b7280);
  }

  .source-pillar-badge {
    background: var(--color-accent, #6366f1);
    color: #fff;
    opacity: 0.85;
  }

  .source-date {
    font-size: 0.8rem;
    color: var(--color-text-muted, #6b7280);
  }

  .source-body {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .source-section h2 {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text, #1a1a1a);
    margin: 0 0 0.75rem;
    border-bottom: 1px solid var(--color-border, #e5e7eb);
    padding-bottom: 0.25rem;
  }

  .source-summary {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--color-text, #1a1a1a);
    margin: 0;
  }

  .source-key-points {
    padding-left: 1.25rem;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .source-key-points li {
    font-size: 0.92rem;
    line-height: 1.6;
    color: var(--color-text, #1a1a1a);
  }

  .source-chapters {
    padding-left: 1.25rem;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .source-chapter-item {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .chapter-title {
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--color-text, #1a1a1a);
  }

  .chapter-summary {
    font-size: 0.85rem;
    color: var(--color-text-muted, #6b7280);
    margin: 0;
    line-height: 1.5;
  }

  .source-quotes {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .source-quote-figure {
    margin: 0;
  }

  .source-quote {
    border-left: 3px solid var(--color-accent, #6366f1);
    margin: 0;
    padding: 0.5rem 1rem;
    font-size: 0.92rem;
    line-height: 1.6;
    color: var(--color-text, #1a1a1a);
    font-style: italic;
    background: var(--color-surface-subtle, #f8f8f8);
    border-radius: 0 0.25rem 0.25rem 0;
  }

  .quote-timestamp {
    font-size: 0.75rem;
    color: var(--color-text-muted, #6b7280);
    margin-top: 0.25rem;
    padding-left: 1rem;
  }
</style>
