---
/**
 * TrafficAnalytics.astro — 流量分析區塊
 * 純 SVG 折線圖 + CSS 橫條 bar，無外部 library
 * 資料來源：client-side fetch /analytics endpoint
 */
---

<div class="traffic-analytics" id="trafficAnalytics">
  <!-- Loading skeleton -->
  <div class="ta-loading" id="taLoading">
    <div class="ta-header">
      <div>
        <h3 class="ta-title">網站流量分析</h3>
        <p class="ta-subtitle">Cloudflare Analytics · 載入中...</p>
      </div>
    </div>
    <div class="ta-kpis">
      <div class="ak"><span class="ak-v ta-skel-v">&nbsp;</span><span class="ak-l">訪客</span></div>
      <div class="ak"><span class="ak-v ta-skel-v">&nbsp;</span><span class="ak-l">瀏覽</span></div>
    </div>
  </div>

  <!-- Content (hidden until data loads) -->
  <div class="ta-content" id="taContent" style="display:none">
    <div class="ta-header">
      <div>
        <h3 class="ta-title">網站流量分析</h3>
        <p class="ta-subtitle" id="taSubtitle">Cloudflare Analytics</p>
      </div>
      <div class="ta-toggle" id="taToggle">
        <button class="ta-btn" data-range="1">1d</button>
        <button class="ta-btn active" data-range="7">7d</button>
        <button class="ta-btn" data-range="30">30d</button>
      </div>
    </div>

    <!-- KPIs -->
    <div class="ta-kpis" id="taKpis"></div>

    <!-- Chart + Countries grid -->
    <div class="ta-grid">
      <div class="ta-chart-wrap">
        <svg id="taChart" viewBox="0 0 600 200" preserveAspectRatio="none" class="ta-chart"></svg>
        <div class="ta-legend" id="taLegend"></div>
      </div>
      <div class="ta-countries" id="taCountries"></div>
    </div>

    <!-- Phase 2: Referers / Top Pages / Devices -->
    <div class="ta-referers" id="taReferers"></div>
    <div class="ta-pages" id="taPages"></div>
    <div class="ta-devices" id="taDevices"></div>
    <div class="ta-duration" id="taDuration"></div>
    <div class="ta-bot-traffic" id="taBotTraffic"></div>

    <!-- ═══ B1：SEO 健康度 ═══ -->
    <div class="ta-seo-section" id="seoHealth">
      <h4 class="ta-section-title">搜尋表現（28 天）</h4>
      <p class="ta-seo-delay-note">搜尋數據有 2-3 天延遲，來源：Google Search Console</p>

      <div class="ta-seo-kpis" id="seoKpis">
        <div class="ak"><span class="ak-v" id="seoClicks">—</span><span class="ak-l">點擊</span></div>
        <div class="ak"><span class="ak-v" id="seoImpressions">—</span><span class="ak-l">曝光</span></div>
        <div class="ak"><span class="ak-v" id="seoCtr">—</span><span class="ak-l">CTR</span></div>
        <div class="ak"><span class="ak-v" id="seoPosition">—</span><span class="ak-l">平均排名</span></div>
      </div>

      <div class="ta-seo-sparkline" id="seoSparkline">
        <h4 class="ta-bot-sub">每日點擊趨勢</h4>
        <svg id="seoSparkSvg" width="100%" height="60" preserveAspectRatio="none"></svg>
      </div>

      <div class="ta-seo-tables">
        <div class="ta-seo-table-wrap">
          <h4 class="ta-bot-sub">熱門關鍵字</h4>
          <div class="ta-seo-table-scroll">
            <table id="seoQueryTable">
              <thead><tr><th>關鍵字</th><th>點擊</th><th>曝光</th><th>排名</th></tr></thead>
              <tbody></tbody>
            </table>
          </div>
        </div>
        <div class="ta-seo-table-wrap">
          <h4 class="ta-bot-sub">熱門頁面</h4>
          <div class="ta-seo-table-scroll">
            <table id="seoPageTable">
              <thead><tr><th>頁面</th><th>點擊</th><th>曝光</th><th>排名</th></tr></thead>
              <tbody></tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="ta-seo-index" id="seoIndex">
        <h4 class="ta-bot-sub">索引覆蓋率</h4>
        <div class="ta-seo-index-bar">
          <div class="ta-seo-index-filled" id="seoIndexFilled"></div>
        </div>
        <p class="ta-seo-index-detail" id="seoIndexDetail">載入中…</p>
      </div>
    </div>
  </div>

  <!-- Error state -->
  <div class="ta-error" id="taError" style="display:none">
    <div class="ta-header">
      <div>
        <h3 class="ta-title">網站流量分析</h3>
        <p class="ta-subtitle">暫無數據</p>
      </div>
    </div>
  </div>
</div>

<script is:inline>
(function() {
  var el = document.getElementById('trafficAnalytics');
  if (!el) return;

  var loaded = false;
  function init() {
    if (loaded) return;
    loaded = true;

    fetch('https://api.paulkuo.tw/analytics', { cache: 'no-store' })
      .then(function(r) { return r.ok ? r.json() : Promise.reject(r.status); })
      .then(function(data) { render(data); })
      .catch(function() {
        document.getElementById('taLoading').style.display = 'none';
        document.getElementById('taError').style.display = '';
      });
  }

  // IntersectionObserver lazy-load
  if ('IntersectionObserver' in window) {
    var obs = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting) { init(); obs.disconnect(); }
      });
    }, { rootMargin: '200px' });
    obs.observe(el);
  } else { init(); }

  // Country code → flag emoji
  function flag(cc) {
    if (!cc || cc.length !== 2) return '';
    return String.fromCodePoint(
      cc.charCodeAt(0) - 65 + 0x1F1E6,
      cc.charCodeAt(1) - 65 + 0x1F1E6
    );
  }

  // Format number with comma separators
  function fmt(n) { return n.toLocaleString(); }

  // SVG line chart (visits + pageViews)
  function drawChart(daily, svgEl) {
    if (!daily || daily.length < 1) return;
    // 1d 單點：複製一份畫平線
    var data = daily.length === 1 ? [daily[0], daily[0]] : daily;
    var W = 600, H = 200, padT = 10, padB = 30, padL = 5, padR = 5;
    var chartH = H - padT - padB;
    var chartW = W - padL - padR;

    var maxP = 0, maxV = 0;
    data.forEach(function(d) {
      if (d.pageViews > maxP) maxP = d.pageViews;
      if (d.visits > maxV) maxV = d.visits;
    });
    var maxVal = Math.max(maxP, maxV) || 1;

    function points(key) {
      return data.map(function(d, i) {
        var x = padL + (i / (data.length - 1)) * chartW;
        var y = padT + chartH - (d[key] / maxVal) * chartH;
        return x.toFixed(1) + ',' + y.toFixed(1);
      }).join(' ');
    }

    // X-axis labels (show ~6 labels max)
    var step = Math.max(1, Math.floor(data.length / 6));
    var labels = '';
    for (var i = 0; i < data.length; i += step) {
      var x = padL + (i / (data.length - 1)) * chartW;
      var dt = data[i].date.slice(5).replace('-', '/');
      labels += '<text x="' + x.toFixed(1) + '" y="' + (H - 5) + '" text-anchor="middle" fill="#8A8A8A" font-size="10" font-family="var(--font-body, sans-serif)">' + dt + '</text>';
    }
    if (data.length > 1 && (data.length - 1) % step !== 0) {
      var lx = padL + chartW;
      var ldt = data[data.length - 1].date.slice(5).replace('-', '/');
      labels += '<text x="' + lx.toFixed(1) + '" y="' + (H - 5) + '" text-anchor="middle" fill="#8A8A8A" font-size="10" font-family="var(--font-body, sans-serif)">' + ldt + '</text>';
    }

    // Grid lines (3 horizontal)
    var grid = '';
    for (var g = 1; g <= 3; g++) {
      var gy = padT + (g / 4) * chartH;
      grid += '<line x1="' + padL + '" y1="' + gy.toFixed(1) + '" x2="' + (W - padR) + '" y2="' + gy.toFixed(1) + '" stroke="#E8E6E1" stroke-width="0.5"/>';
    }

    svgEl.innerHTML =
      grid +
      // Area fills
      '<polyline points="' + points('pageViews') + ' ' + (W - padR) + ',' + (padT + chartH) + ' ' + padL + ',' + (padT + chartH) + '" fill="rgba(99,102,241,0.06)" stroke="none"/>' +
      '<polyline points="' + points('visits') + ' ' + (W - padR) + ',' + (padT + chartH) + ' ' + padL + ',' + (padT + chartH) + '" fill="rgba(16,185,129,0.08)" stroke="none"/>' +
      // Lines
      '<polyline points="' + points('pageViews') + '" fill="none" stroke="#6366f1" stroke-width="1.5" stroke-opacity="0.6"/>' +
      '<polyline points="' + points('visits') + '" fill="none" stroke="#10b981" stroke-width="2"/>' +
      labels;
  }

  function render(data) {
    var ov = data.overview;
    var countries = data.countries;

    // KPIs + Chart: 根據選擇的範圍動態渲染
    var daily = ov.daily;
    var svgEl = document.getElementById('taChart');

    function sumRange(arr) {
      return arr.reduce(function(acc, d) {
        return { visits: acc.visits + d.visits, pageViews: acc.pageViews + d.pageViews };
      }, { visits: 0, pageViews: 0 });
    }

    // Bounce rate + human visits from duration data
    var durData = data.duration;
    var bounceRate = (durData && durData.bounceRate != null) ? durData.bounceRate : null;
    var humanVisits = (durData && durData.humanVisits != null) ? durData.humanVisits : null;
    var durationTotalCount = (durData && durData.totalCount) ? durData.totalCount : 0;

    function bounceColor(rate) {
      if (rate < 40) return '#10b981';
      if (rate <= 60) return '#eab308';
      return '#ef4444';
    }

    function updateView(range) {
      var sliced = range === 1 ? daily.slice(-1) : range === 7 ? daily.slice(-7) : daily;
      var totals = sumRange(sliced);
      var kpiHtml =
        '<div class="ak"><span class="ak-v" style="color:#10b981">' + fmt(totals.visits) + '</span><span class="ak-l">訪客</span></div>' +
        '<div class="ak"><span class="ak-v" style="color:#6366f1">' + fmt(totals.pageViews) + '</span><span class="ak-l">瀏覽</span></div>';
      if (bounceRate !== null) {
        kpiHtml += '<div class="ak"><span class="ak-v" style="color:' + bounceColor(bounceRate) + '">' + bounceRate + '%</span><span class="ak-l">跳出率</span></div>';
      }
      if (humanVisits !== null && durationTotalCount > 0) {
        var humanPct = Math.round(humanVisits / durationTotalCount * 1000) / 10;
        kpiHtml += '<div class="ak"><span class="ak-v" style="color:#8b5cf6">' + fmt(humanVisits) + '</span><span class="ak-l">真人訪客 (' + humanPct + '%)</span></div>';
      }
      document.getElementById('taKpis').innerHTML = kpiHtml;
      drawChart(sliced, svgEl);
    }

    // Subtitle
    var updated = data.updatedAt ? new Date(data.updatedAt).toLocaleString('zh-TW', { timeZone: 'Asia/Taipei', month: 'numeric', day: 'numeric', hour: '2-digit', minute: '2-digit' }) : '';
    document.getElementById('taSubtitle').textContent = 'Cloudflare Web Analytics' + (updated ? ' · 更新於 ' + updated : '');

    // Legend
    document.getElementById('taLegend').innerHTML =
      '<span class="ta-legend-item"><span class="ta-dot" style="background:#10b981"></span>訪客</span>' +
      '<span class="ta-legend-item"><span class="ta-dot" style="background:#6366f1"></span>瀏覽</span>';

    // Initial render (7d)
    updateView(7);

    // Toggle buttons
    var toggle = document.getElementById('taToggle');
    toggle.addEventListener('click', function(e) {
      var btn = e.target.closest('.ta-btn');
      if (!btn) return;
      toggle.querySelectorAll('.ta-btn').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      updateView(parseInt(btn.dataset.range));
    });

    // Countries
    var top = countries.top15 || [];
    var maxPct = top.length > 0 ? top[0].percent : 1;
    document.getElementById('taCountries').innerHTML =
      '<h4 class="ta-countries-title">訪客來源國家</h4>' +
      top.slice(0, 10).map(function(c) {
        var barW = (c.percent / maxPct * 100).toFixed(1);
        return '<div class="ta-country-row">' +
          '<span class="ta-country-flag">' + flag(c.country) + '</span>' +
          '<span class="ta-country-code">' + c.country + '</span>' +
          '<div class="ta-country-bar-bg"><div class="ta-country-bar" style="width:' + barW + '%"></div></div>' +
          '<span class="ta-country-pct">' + c.percent + '%</span>' +
        '</div>';
      }).join('');

    // --- Phase 2: Referers ---
    var referers = data.referers;
    if (referers && referers.sources) {
      var cats = { direct: 0, search: 0, social: 0, other: 0 };
      referers.sources.forEach(function(s) { cats[s.category] = (cats[s.category] || 0) + s.count; });
      var catTotal = cats.direct + cats.search + cats.social + cats.other || 1;
      var catPcts = {
        direct: (cats.direct / catTotal * 100).toFixed(1),
        search: (cats.search / catTotal * 100).toFixed(1),
        social: (cats.social / catTotal * 100).toFixed(1),
        other:  (cats.other / catTotal * 100).toFixed(1)
      };
      var catColors = { direct: '#1b2d4f', search: '#10b981', social: '#6366f1', other: '#8A8A8A' };
      var catLabels = { direct: '直接', search: '搜尋', social: '社群', other: '其他' };

      var barSegs = '';
      ['direct','search','social','other'].forEach(function(k) {
        var pct = parseFloat(catPcts[k]);
        if (pct > 0) {
          barSegs += '<div class="ta-ref-seg" style="width:' + pct + '%;background:' + catColors[k] + '">' +
            (pct >= 5 ? '<span class="ta-ref-seg-label">' + catLabels[k] + ' ' + pct + '%</span>' : '') +
          '</div>';
        }
      });

      var refLegend = ['direct','search','social','other'].map(function(k) {
        return '<span class="ta-ref-legend-item"><span class="ta-dot" style="background:' + catColors[k] + '"></span>' + catLabels[k] + ' ' + catPcts[k] + '%</span>';
      }).join('');

      // Top 5 sources (excluding direct)
      var topSources = referers.sources.filter(function(s) { return s.category !== 'direct'; }).slice(0, 5);
      var maxSrcPct = topSources.length > 0 ? topSources[0].percent : 1;
      var srcRows = topSources.map(function(s) {
        var barW = (s.percent / maxSrcPct * 100).toFixed(1);
        return '<div class="ta-src-row">' +
          '<span class="ta-ref-cat-dot" style="background:' + catColors[s.category] + '"></span>' +
          '<span class="ta-page-name">' + s.host + '</span>' +
          '<div class="ta-country-bar-bg"><div class="ta-country-bar" style="width:' + barW + '%"></div></div>' +
          '<span class="ta-country-pct">' + s.percent + '%</span>' +
        '</div>';
      }).join('');

      document.getElementById('taReferers').innerHTML =
        '<h4 class="ta-section-title">訪客來源</h4>' +
        '<div class="ta-ref-bar">' + barSegs + '</div>' +
        '<div class="ta-ref-legend">' + refLegend + '</div>' +
        (srcRows ? '<div class="ta-ref-details">' + srcRows + '</div>' : '');
    }

    // --- Phase 2: Top Pages (with duration badges) ---
    var topPages = data.topPages;
    // Build duration lookup map: path → avgSeconds
    var durMap = {};
    if (durData && durData.pages) {
      durData.pages.forEach(function(d) { durMap[d.path] = d.avgSeconds; });
    }

    if (topPages && topPages.pages) {
      var nameMap = {
        '/': '首頁',
        '/blog/': '文章列表',
        '/tools/translator/': '翻譯工具',
        '/about/': '關於',
        '/projects/': '作品集',
        '/tags-graph/': '標籤圖譜',
        '/dashboard/': '儀表板',
        '/en/': 'English'
      };
      function pageName(path) {
        if (nameMap[path]) return nameMap[path];
        if (path.startsWith('/articles/')) {
          var slug = path.replace('/articles/', '').replace(/\/$/, '');
          return '\u{1F4C4} ' + slug.replace(/-/g, ' ');
        }
        return path;
      }
      function fmtDur(sec) {
        if (sec >= 60) return Math.floor(sec / 60) + 'm' + (sec % 60 > 0 ? sec % 60 + 's' : '');
        return sec + 's';
      }
      function durClass(sec) {
        if (sec > 60) return 'ta-dur-green';
        if (sec >= 30) return 'ta-dur-yellow';
        return 'ta-dur-gray';
      }

      var hasDur = Object.keys(durMap).length > 0;
      var pages10 = topPages.pages.slice(0, 10);
      var maxPagePct = pages10.length > 0 ? pages10[0].percent : 1;
      var pageRows = pages10.map(function(p, i) {
        var barW = (p.percent / maxPagePct * 100).toFixed(1);
        var name = pageName(p.path);
        var isArticle = p.path.startsWith('/articles/');
        var durBadge = '';
        if (hasDur && durMap[p.path] !== undefined) {
          var sec = durMap[p.path];
          durBadge = '<span class="ta-dur-badge ' + durClass(sec) + '">' + fmtDur(sec) + '</span>';
        }
        return '<div class="ta-page-row">' +
          '<span class="ta-page-rank">' + (i + 1) + '</span>' +
          '<span class="ta-page-name' + (isArticle ? ' ta-page-article' : '') + '">' + name + '</span>' +
          '<div class="ta-country-bar-bg"><div class="ta-country-bar" style="width:' + barW + '%"></div></div>' +
          '<span class="ta-country-pct">' + p.percent + '%</span>' +
          durBadge +
        '</div>';
      }).join('');

      document.getElementById('taPages').innerHTML =
        '<h4 class="ta-section-title">熱門頁面</h4>' + pageRows;
    }

    // --- Phase 2: Devices ---
    var devices = data.devices;
    if (devices) {
      var devTotal = devices.total || 1;
      var devData = [
        { icon: '\u{1F5A5}\uFE0F', label: 'Desktop', count: devices.desktop },
        { icon: '\u{1F4F1}', label: 'Mobile', count: devices.mobile },
        { icon: '\u2B1C', label: 'Tablet', count: devices.tablet }
      ];
      var maxDev = Math.max(devices.desktop, devices.mobile, devices.tablet) || 1;
      var devRows = devData.map(function(d) {
        var pct = (d.count / devTotal * 100).toFixed(1);
        var barW = (d.count / maxDev * 100).toFixed(1);
        return '<div class="ta-dev-row">' +
          '<span class="ta-dev-icon">' + d.icon + '</span>' +
          '<span class="ta-dev-label">' + d.label + '</span>' +
          '<div class="ta-country-bar-bg"><div class="ta-country-bar" style="width:' + barW + '%"></div></div>' +
          '<span class="ta-country-pct">' + pct + '%</span>' +
        '</div>';
      }).join('');

      document.getElementById('taDevices').innerHTML =
        '<h4 class="ta-section-title">裝置分佈</h4>' + devRows;
    }

    // --- Phase 3: Duration (停留時間) ---
    var durPages = [];
    if (durData && durData.pages && durData.pages.length > 0) {
      durPages = durData.pages;
    }
    if (durPages.length > 0) {
      var maxDurSec = durPages[0].avgSeconds || 1;
      var durRows = durPages.slice(0, 10).map(function(d, i) {
        var barW = (d.avgSeconds / maxDurSec * 100).toFixed(1);
        var name = (typeof pageName === 'function') ? pageName(d.path) : d.path;
        var cls = durClass(d.avgSeconds);
        var barColor = d.avgSeconds > 60 ? '#10b981' : (d.avgSeconds >= 30 ? '#eab308' : '#9ca3af');
        return '<div class="ta-dur-row">' +
          '<span class="ta-page-rank">' + (i + 1) + '</span>' +
          '<span class="ta-dur-name">' + name + '</span>' +
          '<div class="ta-dur-bar-bg"><div class="ta-dur-bar" style="width:' + barW + '%;background:' + barColor + '"></div></div>' +
          '<span class="ta-dur-badge ' + cls + '">' + fmtDur(d.avgSeconds) + '</span>' +
          '<span class="ta-dur-views">' + d.views + ' 次</span>' +
        '</div>';
      }).join('');

      var durLegend = '<div class="ta-dur-legend">' +
        '<span class="ta-dur-legend-item"><span class="ta-dot" style="background:#10b981"></span>&gt; 60s 深度閱讀</span>' +
        '<span class="ta-dur-legend-item"><span class="ta-dot" style="background:#eab308"></span>30-60s 瀏覽</span>' +
        '<span class="ta-dur-legend-item"><span class="ta-dot" style="background:#9ca3af"></span>&lt; 30s 快速掃過</span>' +
      '</div>';

      document.getElementById('taDuration').innerHTML =
        '<h4 class="ta-section-title">平均停留時間</h4>' +
        durLegend + durRows;
    }

    // --- AI/Bot Traffic ---
    var botData = data.botTraffic;
    if (botData && botData.total30d && botData.total30d.total > 0) {
      var bt = botData;
      var AI_NAMES = ['GPTBot','ChatGPT','ClaudeBot','Claude','Anthropic','Google-Extended','Bytespider','PerplexityBot','Cohere','Meta','CCBot'];

      function updateBotView(range) {
        var totals = range === 1 ? bt.total1d : range === 7 ? bt.total7d : bt.total30d;
        var sliced = range === 1 ? bt.daily.slice(-1) : range === 7 ? bt.daily.slice(-7) : bt.daily;
        var aiPct = totals.total > 0 ? (totals.ai / totals.total * 100).toFixed(1) : 0;

        var botKpiHtml =
          '<div class="ta-bot-kpis">' +
            '<div class="ak"><span class="ak-v" style="color:#f59e0b">' + fmt(totals.total) + '</span><span class="ak-l">Bot 總訪問</span></div>' +
            '<div class="ak"><span class="ak-v" style="color:#ef4444">' + fmt(totals.ai) + '</span><span class="ak-l">AI Crawler (' + aiPct + '%)</span></div>' +
            '<div class="ak"><span class="ak-v" style="color:#8b5cf6">' + fmt(totals.generic) + '</span><span class="ak-l">一般爬蟲</span></div>' +
          '</div>';

        var maxBotDay = 1;
        sliced.forEach(function(d) { if (d.total > maxBotDay) maxBotDay = d.total; });

        var barsHtml = sliced.map(function(d) {
          var h = Math.max(2, (d.total / maxBotDay * 60));
          var aiH = d.total > 0 ? (d.ai / d.total * h) : 0;
          var genH = h - aiH;
          var label = d.date.slice(5).replace('-', '/');
          var byNameStr = d.byName && Object.keys(d.byName).length > 0
            ? ' (' + Object.entries(d.byName).map(function(e) { return e[0] + '×' + e[1]; }).join(', ') + ')'
            : '';
          var titleAttr = d.date + ': AI ' + d.ai + ' / 一般 ' + d.generic + byNameStr;
          return '<div class="ta-bot-bar-col" title="' + titleAttr + '">' +
            '<div class="ta-bot-bar-stack" style="height:' + h.toFixed(0) + 'px">' +
              '<div class="ta-bot-bar-ai" style="height:' + aiH.toFixed(0) + 'px"></div>' +
              '<div class="ta-bot-bar-gen" style="height:' + genH.toFixed(0) + 'px"></div>' +
            '</div>' +
            (sliced.length <= 7 ? '<span class="ta-bot-bar-label">' + label + '</span>' : '') +
          '</div>';
        }).join('');

        var chartHtml = '<div class="ta-bot-bars">' + barsHtml + '</div>' +
          '<div class="ta-bot-legend">' +
            '<span class="ta-legend-item"><span class="ta-dot" style="background:#ef4444"></span>AI Crawler</span>' +
            '<span class="ta-legend-item"><span class="ta-dot" style="background:#8b5cf6"></span>一般爬蟲</span>' +
          '</div>';

        var crawlerRows = '';
        if (bt.topCrawlers && bt.topCrawlers.length > 0) {
          var maxCrawlerPct = bt.topCrawlers[0].percent || 1;
          crawlerRows = '<h4 class="ta-bot-sub">Top Crawlers (30d)</h4>' +
            bt.topCrawlers.slice(0, 10).map(function(c) {
              var barW = (c.percent / maxCrawlerPct * 100).toFixed(1);
              var isAI = AI_NAMES.indexOf(c.name) >= 0;
              var dotColor = isAI ? '#ef4444' : '#8b5cf6';
              return '<div class="ta-bot-crawler-row">' +
                '<span class="ta-ref-cat-dot" style="background:' + dotColor + '"></span>' +
                '<span class="ta-page-name">' + c.name + '</span>' +
                '<div class="ta-country-bar-bg"><div class="ta-country-bar" style="width:' + barW + '%"></div></div>' +
                '<span class="ta-country-pct">' + c.percent + '%</span>' +
              '</div>';
            }).join('');
        }

        document.getElementById('taBotTraffic').innerHTML =
          '<h4 class="ta-section-title">\u{1F916} AI / Bot \u6D41\u91CF</h4>' +
          botKpiHtml + chartHtml + crawlerRows;
      }

      toggle.addEventListener('click', function(e) {
        var btn = e.target.closest('.ta-btn');
        if (!btn) return;
        updateBotView(parseInt(btn.dataset.range));
      });

      updateBotView(7);
    }

    // ═══ B1：SEO 健康度 fetch ═══
    (async function loadSeoHealth() {
      try {
        var resp = await fetch('https://api.paulkuo.tw/gsc');
        if (!resp.ok) throw new Error('GSC API error');
        var seoData = await resp.json();

        if (seoData.analytics) {
          var a = seoData.analytics;
          document.getElementById('seoClicks').textContent = a.clicks.toLocaleString();
          document.getElementById('seoClicks').style.color = '#10b981';
          document.getElementById('seoImpressions').textContent = a.impressions.toLocaleString();
          document.getElementById('seoImpressions').style.color = '#6366f1';
          document.getElementById('seoCtr').textContent = (a.ctr * 100).toFixed(1) + '%';
          document.getElementById('seoCtr').style.color = '#0891b2';

          var posEl = document.getElementById('seoPosition');
          posEl.textContent = a.avgPosition.toFixed(1);
          if (a.avgPosition < 10) posEl.style.color = '#059669';
          else if (a.avgPosition <= 20) posEl.style.color = '#B45309';
          else posEl.style.color = '#ef4444';

          if (a.dailyClicks && a.dailyClicks.length > 1) {
            var svg = document.getElementById('seoSparkSvg');
            var clicks = a.dailyClicks.map(function(d) { return d.clicks; });
            var maxC = Math.max.apply(null, clicks) || 1;
            var w = svg.clientWidth || 600;
            var h = 60;
            var pts = clicks.map(function(v, i) {
              return ((i / (clicks.length - 1)) * w).toFixed(1) + ',' + (h - (v / maxC) * (h - 4)).toFixed(1);
            }).join(' ');
            svg.innerHTML =
              '<polyline points="0,' + h + ' ' + pts + ' ' + w + ',' + h + '" fill="rgba(59,130,246,0.08)" stroke="none"/>' +
              '<polyline points="' + pts + '" fill="none" stroke="#3b82f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>';
          }
        }

        if (seoData.topQueries && seoData.topQueries.length) {
          var qtbody = document.querySelector('#seoQueryTable tbody');
          qtbody.innerHTML = seoData.topQueries.slice(0, 10).map(function(q) {
            var name = q.query.length > 20 ? q.query.slice(0, 18) + '\u2026' : q.query;
            return '<tr><td title="' + q.query + '">' + name + '</td><td>' + q.clicks + '</td><td>' + q.impressions + '</td><td>' + q.position.toFixed(1) + '</td></tr>';
          }).join('');
        }

        if (seoData.topPages && seoData.topPages.length) {
          var ptbody = document.querySelector('#seoPageTable tbody');
          ptbody.innerHTML = seoData.topPages.slice(0, 10).map(function(p) {
            var path = p.page.replace('https://paulkuo.tw', '');
            var display = path.length > 25 ? path.slice(0, 23) + '\u2026' : path;
            return '<tr><td title="' + path + '">' + display + '</td><td>' + p.clicks + '</td><td>' + p.impressions + '</td><td>' + p.position.toFixed(1) + '</td></tr>';
          }).join('');
        }

        if (seoData.indexStatus && seoData.indexStatus.sitemaps && seoData.indexStatus.sitemaps.length) {
          var sitemaps = seoData.indexStatus.sitemaps;
          var submitted = sitemaps.reduce(function(s, sm) { return s + (sm.submitted || 0); }, 0);
          var indexed = sitemaps.reduce(function(s, sm) { return s + (sm.indexed || 0); }, 0);
          var pct = submitted > 0 ? (indexed / submitted) * 100 : 0;
          var filledEl = document.getElementById('seoIndexFilled');
          filledEl.style.width = pct.toFixed(1) + '%';
          if (pct >= 70) filledEl.style.backgroundColor = '#059669';
          else if (pct >= 50) filledEl.style.backgroundColor = '#B45309';
          else filledEl.style.backgroundColor = '#ef4444';
          document.getElementById('seoIndexDetail').textContent =
            '\u5DF2\u7D22\u5F15 ' + indexed + ' \u00B7 \u7E3D\u8A08 ' + submitted + '\uFF08' + pct.toFixed(1) + '%\uFF09';
        }
      } catch (err) {
        console.warn('[SEO Health] Load failed:', err);
        var seoTitle = document.querySelector('#seoHealth .ta-section-title');
        if (seoTitle) seoTitle.textContent += '\uFF08\u8F09\u5165\u5931\u6557\uFF09';
      }
    })();

    // Show content, hide loading
    document.getElementById('taLoading').style.display = 'none';
    document.getElementById('taContent').style.display = '';
  }
})();
</script>

