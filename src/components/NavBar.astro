---
/**
 * NavBar.astro — 主導航列元件
 * 包含 logo、導航連結、語言切換、漢堡選單
 * 及相關客戶端腳本（toggle、click-outside、active link、scroll effect）
 */
interface Props {
  langPrefix: string;
  langSwitchLinks: Record<string, string>;
  currentLang: string;
}

const { langPrefix, langSwitchLinks, currentLang } = Astro.props;
---

<nav id="main-nav">
  <div class="nav-inner">
    <a href="/" class="nav-logo">Paul</a>
    <div class="nav-links">
      <a href={langPrefix + '/'} id="nav-home">首頁</a>
      <a href={langPrefix + '/blog'} id="nav-blog">思想</a>
      <a href={langPrefix + '/projects'} id="nav-projects">專案</a>
      <div class="nav-dropdown">
        <a href={langPrefix ? langPrefix + '/' : '/#feed'} id="nav-feed" class="nav-dropdown-trigger">動態情報</a>
        <div class="nav-dropdown-menu">
          <a href={langPrefix ? langPrefix + '/' : '/#feed'} id="nav-dd-feed">動態牆</a>
          <a href={langPrefix + '/tags-graph'} id="nav-dd-graph">知識圖譜</a>
        </div>
      </div>
      <a href={langPrefix + '/about'} id="nav-about">關於</a>
      <a href="/search" id="nav-search" title="搜尋" aria-label="搜尋" style="font-size:1.1rem;line-height:1">🔍</a>
      <a href="/#contact" class="nav-cta">聯絡我</a>
      <!-- Auth: login/avatar -->
      <div class="nav-auth-mobile" id="navAuthMobile"></div>
      <div class="mobile-lang-divider"></div>
      <div class="mobile-lang-group">
        <a href={langSwitchLinks['zh-Hant']} class:list={['lang-btn', { active: currentLang === 'zh-Hant' }]} aria-label="繁體中文">繁</a>
        <a href={langSwitchLinks['zh-CN']} class:list={['lang-btn', { active: currentLang === 'zh-CN' }]} aria-label="简体中文">简</a>
        <a href={langSwitchLinks['en']} class:list={['lang-btn', { active: currentLang === 'en' }]} aria-label="English">EN</a>
        <a href={langSwitchLinks['ja']} class:list={['lang-btn', { active: currentLang === 'ja' }]} aria-label="日本語">日</a>
      </div>
      <div class="mobile-font-group" aria-label="字級調整">
        <span class="mobile-font-label">字級</span>
        <button class="mobile-font-btn" data-size="small" aria-label="小字">A-</button>
        <button class="mobile-font-btn" data-size="normal" aria-label="標準字級">A</button>
        <button class="mobile-font-btn" data-size="large" aria-label="大字">A+</button>
      </div>
    </div>

    <!-- Auth section (desktop) -->
    <div class="nav-auth" id="navAuth">
      <div class="nav-auth-login-wrap" id="authLoginBtn" style="display:none">
        <button class="nav-auth-login" id="authLoginTrigger" aria-label="登入">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          <span>登入</span>
        </button>
        <div class="nav-auth-providers" id="authProviders">
          <a href="https://paulkuo-ticker.paul-4bf.workers.dev/auth/google/login" class="nav-auth-provider">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18A10.96 10.96 0 001 12c0 1.77.42 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
            Google
          </a>
          <a href="https://paulkuo-ticker.paul-4bf.workers.dev/auth/line/login" class="nav-auth-provider nav-auth-provider-line">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M12 2C6.48 2 2 5.82 2 10.5c0 4.21 3.74 7.74 8.78 8.4.34.07.81.23.93.52.1.27.07.68.03.95l-.15.91c-.05.27-.21 1.06.93.58s6.18-3.64 8.43-6.23C22.83 13.47 22 11.42 22 10.5 22 5.82 17.52 2 12 2z" fill="#06C755"/></svg>
            LINE
          </a>
          <a href="https://paulkuo-ticker.paul-4bf.workers.dev/auth/facebook/login" class="nav-auth-provider nav-auth-provider-fb">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M24 12c0-6.627-5.373-12-12-12S0 5.373 0 12c0 5.99 4.388 10.954 10.125 11.854V15.47H7.078V12h3.047V9.356c0-3.007 1.792-4.668 4.533-4.668 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874V12h3.328l-.532 3.47h-2.796v8.385C19.612 22.954 24 17.99 24 12z" fill="#1877F2"/></svg>
            Facebook
          </a>
        </div>
      </div>
      <div class="nav-auth-user" id="authUser" style="display:none">
        <img class="nav-auth-avatar" id="authAvatar" src="" alt="" width="28" height="28" />
        <span class="nav-auth-name" id="authName"></span>
        <div class="nav-auth-dropdown" id="authDropdown">
          <div class="nav-auth-dropdown-info" id="authEmail"></div>
          <button class="nav-auth-dropdown-logout" id="authLogoutBtn">登出</button>
        </div>
      </div>
    </div>

    <div class="lang-switcher">
      <a href={langSwitchLinks['zh-Hant']} class:list={['lang-btn', { active: currentLang === 'zh-Hant' }]} aria-label="繁體中文">繁</a>
      <a href={langSwitchLinks['zh-CN']} class:list={['lang-btn', { active: currentLang === 'zh-CN' }]} aria-label="简体中文">简</a>
      <a href={langSwitchLinks['en']} class:list={['lang-btn', { active: currentLang === 'en' }]} aria-label="English">EN</a>
      <a href={langSwitchLinks['ja']} class:list={['lang-btn', { active: currentLang === 'ja' }]} aria-label="日本語">日</a>
    </div>
    <button class="nav-hamburger" id="hamburger-btn" aria-label="選單">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<script>
  // Hamburger toggle
  document.getElementById('hamburger-btn')?.addEventListener('click', () => {
    const navLinks = document.querySelector('.nav-links') as HTMLElement;
    const switcher = document.querySelector('.lang-switcher') as HTMLElement;
    if (navLinks) navLinks.classList.toggle('mobile-open');
    if (switcher) switcher.classList.toggle('mobile-open');
  });

  // Click outside to close
  document.addEventListener('click', (e) => {
    const navLinks = document.querySelector('.nav-links');
    const switcher = document.querySelector('.lang-switcher');
    const btn = document.getElementById('hamburger-btn');
    if (btn && !btn.contains(e.target as Node)) {
      if (navLinks && !navLinks.contains(e.target as Node)) navLinks.classList.remove('mobile-open');
      if (switcher && !switcher.contains(e.target as Node)) switcher.classList.remove('mobile-open');
    }
  });

  // Active link highlighting
  const path = window.location.pathname;
  document.querySelectorAll('.nav-links a').forEach(a => {
    const href = a.getAttribute('href');
    if (href === path || (href !== '/' && path.startsWith(href!))) {
      a.classList.add('active');
    }
  });

  // Mobile font size controls (mirrors FontToggle.astro logic)
  document.querySelectorAll('.mobile-font-btn').forEach(btn => {
    const sizes: Record<string, string> = { small: '15px', normal: '17px', large: '19px' };
    const saved = localStorage.getItem('fontSize') || 'normal';
    if ((btn as HTMLElement).dataset.size === saved) btn.classList.add('active');
    btn.addEventListener('click', () => {
      const size = (btn as HTMLElement).dataset.size || 'normal';
      document.documentElement.style.fontSize = sizes[size] || sizes.normal;
      localStorage.setItem('fontSize', size);
      document.querySelectorAll('.mobile-font-btn').forEach(b => b.classList.toggle('active', b === btn));
      // Sync desktop toggle if visible
      document.querySelectorAll('.font-size-btn').forEach(b => {
        (b as HTMLElement).classList.toggle('active', (b as HTMLElement).dataset.size === size);
      });
    });
  });

  // Nav scroll effect
  (() => {
    const nav = document.getElementById('main-nav');
    if (!nav) return;
    let ticking = false;
    const updateNav = () => {
      if (window.scrollY > 10) { nav.classList.add('nav-scrolled'); }
      else { nav.classList.remove('nav-scrolled'); }
      ticking = false;
    };
    window.addEventListener('scroll', () => {
      if (!ticking) { requestAnimationFrame(updateNav); ticking = true; }
    }, { passive: true });
  })();

  // === Auth UI ===
  (() => {
    const WORKER = 'https://paulkuo-ticker.paul-4bf.workers.dev';
    const loginBtn = document.getElementById('authLoginBtn');
    const userEl = document.getElementById('authUser');
    const avatarEl = document.getElementById('authAvatar') as HTMLImageElement;
    const nameEl = document.getElementById('authName');
    const emailEl = document.getElementById('authEmail');
    const logoutBtn = document.getElementById('authLogoutBtn');
    const mobileAuth = document.getElementById('navAuthMobile');

    // Check auth status
    async function checkAuth() {
      try {
        const res = await fetch(`${WORKER}/auth/me`, { credentials: 'include' });
        if (!res.ok) throw new Error('Auth check failed');
        const data = await res.json();
        if (data.authenticated && data.user) {
          showUser(data.user);
        } else {
          showLogin();
        }
      } catch {
        showLogin();
      }
    }

    function showLogin() {
      if (loginBtn) loginBtn.style.display = 'flex';
      if (userEl) userEl.style.display = 'none';
      // Mobile: show provider links
      if (mobileAuth) {
        mobileAuth.innerHTML = `<div class="nav-auth-mobile-providers">
          <a href="${WORKER}/auth/google/login" class="nav-auth-login-mobile">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18A10.96 10.96 0 001 12c0 1.77.42 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
            <span>Google 登入</span></a>
          <a href="${WORKER}/auth/line/login" class="nav-auth-login-mobile nav-auth-login-mobile-line">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M12 2C6.48 2 2 5.82 2 10.5c0 4.21 3.74 7.74 8.78 8.4.34.07.81.23.93.52.1.27.07.68.03.95l-.15.91c-.05.27-.21 1.06.93.58s6.18-3.64 8.43-6.23C22.83 13.47 22 11.42 22 10.5 22 5.82 17.52 2 12 2z" fill="#06C755"/></svg>
            <span>LINE 登入</span></a>
          <a href="${WORKER}/auth/facebook/login" class="nav-auth-login-mobile nav-auth-login-mobile-fb">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M24 12c0-6.627-5.373-12-12-12S0 5.373 0 12c0 5.99 4.388 10.954 10.125 11.854V15.47H7.078V12h3.047V9.356c0-3.007 1.792-4.668 4.533-4.668 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874V12h3.328l-.532 3.47h-2.796v8.385C19.612 22.954 24 17.99 24 12z" fill="#1877F2"/></svg>
            <span>Facebook 登入</span></a>
        </div>`;
      }
    }

    function showUser(user: { name: string; avatar: string; email: string }) {
      if (loginBtn) loginBtn.style.display = 'none';
      if (userEl) userEl.style.display = 'flex';
      if (avatarEl) { avatarEl.src = user.avatar || ''; avatarEl.alt = user.name || ''; }
      if (nameEl) nameEl.textContent = user.name || '';
      if (emailEl) emailEl.textContent = user.email || '';
      // Mobile: show avatar
      if (mobileAuth) {
        mobileAuth.innerHTML = `<div class="nav-auth-user-mobile">
          <img src="${user.avatar || ''}" alt="${user.name || ''}" width="24" height="24" class="nav-auth-avatar" />
          <span>${user.name || ''}</span>
          <button class="nav-auth-logout-mobile" id="authLogoutMobileBtn">登出</button></div>`;
        document.getElementById('authLogoutMobileBtn')?.addEventListener('click', doLogout);
      }
    }

    // Login click
    // Login dropdown toggle
    document.getElementById('authLoginTrigger')?.addEventListener('click', (e) => {
      const providers = document.getElementById('authProviders');
      if (providers) providers.classList.toggle('open');
      e.stopPropagation();
    });
    document.addEventListener('click', () => {
      document.getElementById('authProviders')?.classList.remove('open');
    });

    // Logout
    async function doLogout() {
      try {
        await fetch(`${WORKER}/auth/logout`, { method: 'POST', credentials: 'include' });
      } catch { /* ignore */ }
      window.location.reload();
    }
    logoutBtn?.addEventListener('click', doLogout);

    // Toggle dropdown
    userEl?.addEventListener('click', (e) => {
      const dropdown = document.getElementById('authDropdown');
      if (dropdown) dropdown.classList.toggle('open');
      e.stopPropagation();
    });
    document.addEventListener('click', () => {
      document.getElementById('authDropdown')?.classList.remove('open');
    });

    // Kick off auth check
    checkAuth();

    // Handle ?auth_success=1 redirect (clean URL)
    if (window.location.search.includes('auth_success=1')) {
      const url = new URL(window.location.href);
      url.searchParams.delete('auth_success');
      window.history.replaceState({}, '', url.pathname + url.search);
    }
  })();
</script>
