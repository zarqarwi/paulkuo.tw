---
/**
 * CostTicker.astro — 首頁 API 費用 ticker bar
 * Apple Stocks widget 風格：迷你折線圖 + 數字
 * 資料來源：純 client-side fetch api.paulkuo.tw/ticker
 */
import { version } from '../../package.json';
---

<a href="/#feed" class="cost-ticker" id="costTicker" style="text-decoration:none;color:inherit;display:block">
  <div class="ticker-inner ticker-loading">
    <span class="ticker-loading-text">載入中...</span>
  </div>
</a>

<script is:inline define:vars={{ version }}>
function drawSparkline(vals) {
  var canvas = document.getElementById('tickerSpark');
  if (!canvas || !vals || vals.length < 2) return;
  var ctx = canvas.getContext('2d');
  var w = canvas.width, h = canvas.height;
  var max = Math.max.apply(null, vals), min = Math.min.apply(null, vals);
  var range = max - min || 1, pad = 3;
  ctx.clearRect(0, 0, w, h);
  var grad = ctx.createLinearGradient(0, 0, 0, h);
  var isUp = vals[vals.length-1] >= vals[0];
  var clr = isUp ? '#059669' : '#DC2626';
  grad.addColorStop(0, isUp ? 'rgba(5,150,105,0.2)' : 'rgba(220,38,38,0.15)');
  grad.addColorStop(1, 'rgba(255,255,255,0)');
  ctx.beginPath();
  vals.forEach(function(v, i) {
    var x = pad + (i / (vals.length - 1)) * (w - pad * 2);
    var y = pad + (1 - (v - min) / range) * (h - pad * 2);
    i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
  });
  ctx.lineTo(w - pad, h); ctx.lineTo(pad, h); ctx.closePath();
  ctx.fillStyle = grad; ctx.fill();
  ctx.beginPath();
  vals.forEach(function(v, i) {
    var x = pad + (i / (vals.length - 1)) * (w - pad * 2);
    var y = pad + (1 - (v - min) / range) * (h - pad * 2);
    i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
  });
  ctx.strokeStyle = clr; ctx.lineWidth = 1.5; ctx.stroke();
}

function buildTickerHTML(d) {
  var c = d.costs || {};
  var monthUSD = c.monthUSD != null ? c.monthUSD : 0;
  var avgDay = c.avgPerDay != null ? c.avgPerDay : 0;
  var calls = c.totalCalls != null ? c.totalCalls : 0;
  var tokens = c.totalTokens != null ? c.totalTokens : 0;
  var totalUSD = c.totalUSD != null ? c.totalUSD : 0;
  var chgPct = c.changePercent != null ? c.changePercent : 0;
  var chgUp = chgPct >= 0;
  var chgCls = chgUp ? 'up' : 'down';
  var chgArrow = chgUp ? '\u25b2' : '\u25bc';
  var steps = d.fitbit ? d.fitbit.steps : 0;
  var aiToday = d.timing ? (Math.round((d.timing.todayHours || d.timing.ai_hours_today || 0) * 10) / 10) : 0;
  var aiMonth = d.timing ? Math.round(d.timing.monthHours || d.timing.ai_hours_month || 0) : 0;

  var html = '<div class="ticker-item ticker-version" title="paulkuo.tw 網站版本">'
    + '<span class="ticker-label">VER</span>'
    + '<span class="ticker-value">' + version + '</span>'
    + '</div>'
    + '<div class="ticker-sep"></div>'
    + '<div class="ticker-item ticker-primary" title="本月 AI API 費用">'
    + '<span class="ticker-label">本月 API</span>'
    + '<span class="ticker-value" id="liveMonthUSD">$' + monthUSD.toFixed(2) + '</span>'
    + '<span class="ticker-sub" id="liveMonthTWD">NT$' + Math.round(monthUSD * 32.5) + '</span>'
    + '<canvas class="ticker-spark" id="tickerSpark" width="80" height="28"></canvas>'
    + '<span class="ticker-change ' + chgCls + '" id="liveChangePercent">' + chgArrow + ' ' + Math.abs(chgPct).toFixed(0) + '%</span>'
    + '</div>'
    + '<div class="ticker-sep"></div>'
    + '<div class="ticker-item" title="每日平均 API 費用"><span class="ticker-label">日均</span><span class="ticker-value" id="liveAvgDay">$' + avgDay.toFixed(3) + '</span></div>'
    + '<div class="ticker-sep"></div>'
    + '<div class="ticker-item" title="API 呼叫總次數"><span class="ticker-label">API 呼叫</span><span class="ticker-value" id="liveCalls">' + calls.toLocaleString() + '</span></div>'
    + '<div class="ticker-sep"></div>'
    + '<div class="ticker-item" title="Token 總量"><span class="ticker-label">Token</span><span class="ticker-value" id="liveTokens">' + Math.round(tokens / 1000) + 'K</span></div>'
    + '<div class="ticker-sep"></div>'
    + '<div class="ticker-item" title="累計 API 費用"><span class="ticker-label">累計</span><span class="ticker-value" id="liveTotalUSD">$' + totalUSD.toFixed(2) + '</span></div>'
    + '<div class="ticker-sep"></div>'
    + '<div class="ticker-item" title="今日 Fitbit 步數"><span class="ticker-label">\ud83d\udeb6 步數</span><span class="ticker-value" id="liveSteps">' + steps.toLocaleString() + '</span></div>'
    + '<div class="ticker-sep"></div>'
    + '<div class="ticker-item" title="AI 協作時間"><span class="ticker-label">\u23f1 AI 協作</span><span class="ticker-value">' + aiToday + 'h</span><span class="ticker-sub">月' + aiMonth + 'h</span></div>';

  if (d.stock && d.stock.price) {
    var su = d.stock.changePercent >= 0;
    html += '<div class="ticker-sep"></div>'
      + '<div class="ticker-item" title="CyberSolutions (436A.T) 即時股價">'
      + '<span class="ticker-label">\ud83d\udcc8 ' + (d.stock.name || '') + '</span>'
      + '<span class="ticker-value" id="liveStockPrice">\u00a5' + d.stock.price.toLocaleString() + '</span>'
      + '<span class="ticker-change ' + (su ? 'up' : 'down') + '" id="liveStockChange">' + (su ? '\u25b2' : '\u25bc') + ' ' + Math.abs(d.stock.changePercent).toFixed(1) + '%</span>'
      + '</div>';
  }

  if (d.visitors && d.visitors.visits != null) {
    html += '<div class="ticker-sep"></div>'
      + '<div class="ticker-item" title="昨日訪客數（Web Analytics 同源）">'
      + '<span class="ticker-label">\ud83d\udc65 訪客</span><span class="ticker-value" id="liveVisitors">' + d.visitors.visits.toLocaleString() + '/日</span></div>';
  }

  return html;
}

// Fetch API and render ticker
(function() {
  fetch('https://api.paulkuo.tw/ticker')
    .then(function(r) { return r.json(); })
    .then(function(d) {
      var ticker = document.getElementById('costTicker');
      var inner = ticker && ticker.querySelector('.ticker-inner');
      if (!inner) return;
      inner.classList.remove('ticker-loading');
      inner.innerHTML = buildTickerHTML(d);
      if (d.costs && d.costs.dailyValues && d.costs.dailyValues.length >= 2) {
        drawSparkline(d.costs.dailyValues);
      }
    })
    .catch(function() {
      var inner = document.querySelector('#costTicker .ticker-inner');
      if (inner) {
        inner.classList.remove('ticker-loading');
        inner.innerHTML = '<span class="ticker-loading-text">數據暫時無法載入</span>';
      }
    });
})();
</script>

<style>
  .cost-ticker {
    background: var(--brand-navy);
    color: #fff;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .ticker-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 0;
    padding: 0 32px;
    height: 48px;
    white-space: nowrap;
    font-family: var(--font-body);
  }
  .ticker-loading { justify-content: center; }
  .ticker-loading-text { font-size: 0.75rem; }
  .ticker-item { display: flex; align-items: center; gap: 8px; padding: 0 14px; flex-shrink: 0; }
  .ticker-primary { gap: 10px; }
  .ticker-label { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.06em; font-weight: 500; }
  .ticker-value { font-size: 0.88rem; font-weight: 700; letter-spacing: -0.02em; }
  .ticker-sub { font-size: 0.7rem; }
  .ticker-spark { vertical-align: middle; margin: 0 4px; }
  .ticker-change { font-size: 0.65rem; font-weight: 600; padding: 2px 6px; border-radius: 3px; }
  .ticker-change.up { background: rgba(16,185,129,0.15); }
  .ticker-change.down { background: rgba(220,38,38,0.15); }
  .ticker-sep { width: 1px; height: 20px; background: rgba(255,255,255,0.15); flex-shrink: 0; margin: 0 4px; }
  @media (max-width: 768px) {
    .ticker-inner { padding: 0 16px; height: 38px; overflow-x: auto; -webkit-overflow-scrolling: touch; scrollbar-width: none; }
    .ticker-inner::-webkit-scrollbar { display: none; }
    .ticker-item { padding: 0 10px; gap: 6px; flex-shrink: 0; }
    .ticker-version { display: none; }
    .ticker-version + .ticker-sep { display: none; }
  }
</style>
