---
/**
 * DerivedFromSection.astro — Article「衍生自 N 篇素材」section
 * Phase 4 Step B (initial) + Step C-prime (source URL added) + Step E2 (i18n).
 *
 * Shows wiki sources that this article was derived from.
 * Hidden when sources array is empty.
 * visibility=public  → linked to /wiki/sources/{slug}/
 * visibility=internal → title shown as plain text (no 404 risk)
 */

interface SourceEntry {
  slug: string;
  title: string;
  summary: string;
  visibility?: string;
}

interface Props {
  sources: SourceEntry[];
  lang: 'zh-Hant' | 'en' | 'ja' | 'zh-cn';
}

const { sources, lang } = Astro.props;

const translations = {
  'zh-Hant': { heading: (n: number) => `衍生自 ${n} 篇素材` },
  'en':      { heading: (n: number) => `Derived from ${n} ${n === 1 ? 'source' : 'sources'}` },
  'ja':      { heading: (n: number) => `${n} 件の素材から派生` },
  'zh-cn':   { heading: (n: number) => `衍生自 ${n} 篇素材` },
};

if (!(lang in translations)) {
  console.warn(`DerivedFromSection: unknown lang '${lang}', falling back to zh-Hant`);
}
const t = translations[lang as keyof typeof translations] ?? translations['zh-Hant'];

function buildSourceUrl(slug: string, visibility?: string): string | null {
  if (visibility === 'internal') return null;
  return `/wiki/sources/${slug}/`;
}
---

{sources.length > 0 && (
  <section class="derived-from-section" aria-label={t.heading(sources.length)}>
    <h3 class="derived-from-title">{t.heading(sources.length)}</h3>
    <ul class="derived-from-list">
      {sources.map(src => {
        const url = buildSourceUrl(src.slug, src.visibility);
        return (
          <li class="derived-from-item">
            {url ? (
              <a href={url} class="derived-from-source-link">{src.title}</a>
            ) : (
              <span class="derived-from-source-title">{src.title}</span>
            )}
            {src.summary && (
              <p class="derived-from-summary">{src.summary}</p>
            )}
          </li>
        );
      })}
    </ul>
  </section>
)}

<style>
  .derived-from-section {
    margin: 2rem 0;
    padding: 1.25rem 1.5rem;
    border-left: 3px solid var(--brand-navy);
    background: var(--bg-section);
    border-radius: 0 0.5rem 0.5rem 0;
  }

  .derived-from-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 0.75rem;
  }

  .derived-from-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .derived-from-item {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .derived-from-source-link {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--brand-navy);
    text-decoration: none;
  }

  .derived-from-source-link:hover {
    text-decoration: underline;
  }

  .derived-from-source-title {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text-primary);
  }

  .derived-from-summary {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin: 0;
    line-height: 1.5;
  }
</style>
