---
/**
 * MobileTabBar.astro — 手機版底部固定 Tab Bar
 * 桌面版隱藏，手機版取代漢堡選單作為主要導覽
 * eventMode: 活動品牌模式（打卡/足跡/說明/更多）
 */
interface Props {
  langPrefix: string;
  langSwitchLinks: Record<string, string>;
  currentLang: string;
  eventMode?: boolean;
}
const { langPrefix, langSwitchLinks, currentLang, eventMode = false } = Astro.props;

const tabI18n: Record<string, Record<string, string>> = {
  'zh-Hant': { home: '首頁', blog: '思想', projects: '專案', more: '更多', feedWall: '動態牆', graph: '知識圖譜', about: '關於', search: '搜尋', contact: '聯絡我', fontSize: '字級' },
  'en': { home: 'Home', blog: 'Thinking', projects: 'Projects', more: 'More', feedWall: 'Feed Wall', graph: 'Knowledge Graph', about: 'About', search: 'Search', contact: 'Contact', fontSize: 'Font Size' },
  'ja': { home: 'ホーム', blog: '思想', projects: '実績', more: 'その他', feedWall: 'フィード', graph: 'タグ図', about: '概要', search: '検索', contact: '連絡', fontSize: '文字サイズ' },
  'zh-CN': { home: '首页', blog: '思想', projects: '项目', more: '更多', feedWall: '动态墙', graph: '知识图谱', about: '关于', search: '搜索', contact: '联系我', fontSize: '字号' },
};
const t = tabI18n[currentLang] || tabI18n['zh-Hant'];

const eventTabI18n: Record<string, Record<string, string>> = {
  'zh-Hant': { checkin: '打卡', track: '足跡', guide: '說明', more: '更多' },
  'en': { checkin: 'Check-in', track: 'My Track', guide: 'Guide', more: 'More' },
  'ja': { checkin: 'チェックイン', track: '足跡', guide: 'ガイド', more: 'その他' },
  'zh-CN': { checkin: '打卡', track: '足迹', guide: '说明', more: '更多' },
};
const et = eventTabI18n[currentLang] || eventTabI18n['zh-Hant'];

const formosaBase = `${langPrefix}/projects/formosa-esg-2026`;
---

{eventMode ? (
<nav class="mobile-tab-bar" aria-label="活動導覽">
  <a href={`${formosaBase}/tracker/`} class="tab-item" data-tab="checkin">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
    <span>{et.checkin}</span>
  </a>
  <a href={`${formosaBase}/my/`} class="tab-item" data-tab="track">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="10" r="3"/><path d="M12 21.7C17.3 17 20 13 20 10a8 8 0 10-16 0c0 3 2.7 7 8 11.7z"/></svg>
    <span>{et.track}</span>
  </a>
  <a href={`${formosaBase}/guide/`} class="tab-item" data-tab="guide">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z"/><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z"/></svg>
    <span>{et.guide}</span>
  </a>
  <button class="tab-item tab-more" data-tab="more" aria-label={et.more}>
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="1"/><circle cx="12" cy="5" r="1"/><circle cx="12" cy="19" r="1"/></svg>
    <span>{et.more}</span>
  </button>
</nav>

<div class="tab-more-sheet" id="tabMoreSheet">
  <div class="sheet-handle"></div>
  <div class="sheet-grid">
    <a href={`${formosaBase}/privacy/`}>隱私權聲明</a>
    <a href={`${formosaBase}/feedback/`}>問題回報</a>
  </div>
  <div class="sheet-lang">
    <a href={langSwitchLinks['zh-Hant']} class:list={['sheet-lang-btn', { active: currentLang === 'zh-Hant' }]}>繁</a>
    <a href={langSwitchLinks['zh-CN']} class:list={['sheet-lang-btn', { active: currentLang === 'zh-CN' }]}>简</a>
    <a href={langSwitchLinks['en']} class:list={['sheet-lang-btn', { active: currentLang === 'en' }]}>EN</a>
    <a href={langSwitchLinks['ja']} class:list={['sheet-lang-btn', { active: currentLang === 'ja' }]}>日</a>
  </div>
</div>
) : (
<nav class="mobile-tab-bar" aria-label="主要導覽">
  <a href={langPrefix + '/'} class="tab-item" data-tab="home">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
    <span>{t.home}</span>
  </a>
  <a href={langPrefix + '/blog'} class="tab-item" data-tab="blog">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z"/><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z"/></svg>
    <span>{t.blog}</span>
  </a>
  <a href={langPrefix + '/projects'} class="tab-item" data-tab="projects">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16"/></svg>
    <span>{t.projects}</span>
  </a>
  <button class="tab-item tab-more" data-tab="more" aria-label={t.more}>
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="1"/><circle cx="12" cy="5" r="1"/><circle cx="12" cy="19" r="1"/></svg>
    <span>{t.more}</span>
  </button>
</nav>

<!-- 更多面板（bottom sheet） -->
<div class="tab-more-sheet" id="tabMoreSheet">
  <div class="sheet-handle"></div>
  <div class="sheet-grid">
    <a href={langPrefix ? langPrefix + '/' : '/#feed'}>{t.feedWall}</a>
    <a href={langPrefix + '/tags-graph'}>{t.graph}</a>
    <a href={langPrefix + '/about'}>{t.about}</a>
    <a href="/search">{t.search}</a>
    <a href={`${langPrefix || ''}/#contact`}>{t.contact}</a>
  </div>
  <div class="sheet-lang">
    <a href={langSwitchLinks['zh-Hant']} class:list={['sheet-lang-btn', { active: currentLang === 'zh-Hant' }]}>繁</a>
    <a href={langSwitchLinks['zh-CN']} class:list={['sheet-lang-btn', { active: currentLang === 'zh-CN' }]}>简</a>
    <a href={langSwitchLinks['en']} class:list={['sheet-lang-btn', { active: currentLang === 'en' }]}>EN</a>
    <a href={langSwitchLinks['ja']} class:list={['sheet-lang-btn', { active: currentLang === 'ja' }]}>日</a>
  </div>
  <div class="sheet-font">
    <span class="sheet-font-label">{t.fontSize}</span>
    <button class="sheet-font-btn" data-size="small">A-</button>
    <button class="sheet-font-btn" data-size="normal">A</button>
    <button class="sheet-font-btn" data-size="large">A+</button>
  </div>
</div>
)}

<!-- Overlay backdrop -->
<div class="tab-more-overlay" id="tabMoreOverlay"></div>

<script>
  // Active tab highlighting
  const path = window.location.pathname;
  document.querySelectorAll('.tab-item[data-tab]').forEach(tab => {
    const href = tab.getAttribute('href');
    if (href && (href === path || (href !== '/' && path.startsWith(href)))) {
      tab.classList.add('active');
    }
  });

  // More button toggle
  const moreBtn = document.querySelector('.tab-more');
  const sheet = document.getElementById('tabMoreSheet');
  const overlay = document.getElementById('tabMoreOverlay');

  function toggleSheet() {
    sheet?.classList.toggle('open');
    overlay?.classList.toggle('open');
  }

  function closeSheet() {
    sheet?.classList.remove('open');
    overlay?.classList.remove('open');
  }

  moreBtn?.addEventListener('click', toggleSheet);
  overlay?.addEventListener('click', closeSheet);

  // Font size controls in sheet (mirrors NavBar logic)
  document.querySelectorAll('.sheet-font-btn').forEach(btn => {
    const sizes: Record<string, string> = { small: '15px', normal: '17px', large: '19px' };
    const saved = localStorage.getItem('fontSize') || 'normal';
    if ((btn as HTMLElement).dataset.size === saved) btn.classList.add('active');
    btn.addEventListener('click', () => {
      const size = (btn as HTMLElement).dataset.size || 'normal';
      document.documentElement.style.fontSize = sizes[size] || sizes.normal;
      localStorage.setItem('fontSize', size);
      document.querySelectorAll('.sheet-font-btn').forEach(b => b.classList.toggle('active', b === btn));
      // Sync other toggles
      document.querySelectorAll('.mobile-font-btn, .font-size-btn').forEach(b => {
        (b as HTMLElement).classList.toggle('active', (b as HTMLElement).dataset.size === size);
      });
    });
  });
</script>

<style>
  /* Desktop: hidden */
  .mobile-tab-bar,
  .tab-more-sheet,
  .tab-more-overlay { display: none; }

  @media (max-width: 768px) {
    .mobile-tab-bar {
      display: flex;
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      height: 56px;
      background: var(--bg-card, #fff);
      border-top: 1px solid var(--border, #e5e5e5);
      z-index: 1000;
      padding-bottom: env(safe-area-inset-bottom);
    }

    .tab-item {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 2px;
      font-size: 0.65rem;
      color: var(--text-secondary, #6b7280);
      text-decoration: none;
      background: none;
      border: none;
      cursor: pointer;
      -webkit-tap-highlight-color: transparent;
    }

    .tab-item.active {
      color: var(--brand-navy, #1b2d4f);
    }

    .tab-item svg {
      width: 22px;
      height: 22px;
    }

    /* Hamburger hidden when tab bar is active */
    :global(.nav-hamburger) {
      display: none !important;
    }

    /* Body padding to avoid content behind tab bar */
    :global(body) {
      padding-bottom: calc(56px + env(safe-area-inset-bottom));
    }

    /* More sheet */
    .tab-more-sheet {
      display: block;
      position: fixed;
      bottom: calc(56px + env(safe-area-inset-bottom));
      left: 0;
      right: 0;
      background: var(--bg-card, #fff);
      border-top: 1px solid var(--border, #e5e5e5);
      border-radius: 16px 16px 0 0;
      box-shadow: 0 -4px 20px rgba(0,0,0,0.1);
      transform: translateY(100%);
      transition: transform 0.3s ease;
      z-index: 999;
      padding: 12px 24px 16px;
      visibility: hidden;
    }

    .tab-more-sheet.open {
      transform: translateY(0);
      visibility: visible;
    }

    .sheet-handle {
      width: 36px;
      height: 4px;
      background: var(--border, #d1d5db);
      border-radius: 2px;
      margin: 0 auto 16px;
    }

    .sheet-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      margin-bottom: 16px;
    }

    .sheet-grid a {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 12px 8px;
      font-size: 0.85rem;
      color: var(--text-primary, #1f2937);
      text-decoration: none;
      background: var(--bg-secondary, #f3f4f6);
      border-radius: 8px;
      text-align: center;
    }

    .sheet-lang {
      display: flex;
      gap: 8px;
      justify-content: center;
      padding: 12px 0;
      border-top: 1px solid var(--border, #e5e5e5);
    }

    .sheet-lang-btn {
      padding: 8px 16px;
      font-size: 0.8rem;
      color: var(--text-secondary, #6b7280);
      text-decoration: none;
      border: 1px solid var(--border, #e5e5e5);
      border-radius: 6px;
    }

    .sheet-lang-btn.active {
      background: var(--brand-navy, #1b2d4f);
      color: #fff;
      border-color: var(--brand-navy, #1b2d4f);
    }

    .sheet-font {
      display: flex;
      align-items: center;
      gap: 8px;
      justify-content: center;
      padding: 12px 0 0;
      border-top: 1px solid var(--border, #e5e5e5);
    }

    .sheet-font-label {
      font-size: 0.75rem;
      color: var(--text-secondary, #6b7280);
      margin-right: 4px;
    }

    .sheet-font-btn {
      width: 36px;
      height: 36px;
      border: 1px solid var(--border, #e5e5e5);
      border-radius: 50%;
      background: transparent;
      color: var(--text-primary, #1f2937);
      font-size: 0.8rem;
      cursor: pointer;
    }

    .sheet-font-btn.active {
      background: var(--brand-navy, #1b2d4f);
      color: #fff;
      border-color: var(--brand-navy, #1b2d4f);
    }

    /* Overlay */
    .tab-more-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.3);
      z-index: 998;
    }

    .tab-more-overlay.open {
      display: block;
    }
  }
</style>
