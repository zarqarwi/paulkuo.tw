# paulkuo.tw — 環境變數範本
# 複製此檔為 .env 並填入真實值：cp .env.example .env
# .env 已被 .gitignore 排除，不會進 git

# ── Worker Secrets（也需要用 wrangler secret put 設到 Cloudflare）──

# 管理員 Token（YouTube ingest API + Formosa ESG owner 驗證共用）
FORMOSA_ADMIN_TOKEN=

# Formosa ESG 角色 Token
FORMOSA_MANAGER_TOKEN=
FORMOSA_VOLUNTEER_TOKEN=

# Worker 內部 admin（舊版，與 FORMOSA_ADMIN_TOKEN 不同）
ADMIN_SECRET=

# YouTube Data API v3 Key
YOUTUBE_API_KEY=

# ── 已規劃但尚未啟用 ──

# Google Search Console Service Account（JSON，base64 encoded）
# GSC_SERVICE_ACCOUNT_KEY=

# Anthropic API（wiki AI 功能，選用）
# ANTHROPIC_API_KEY=

# Formosa LINE 推播 alert 目標 user ID
# FORMOSA_ALERT_USER_ID=
